# Mailgun Configuration
# Replace these with your actual Mailgun credentials
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here

# Email Configuration
TO_EMAIL=rob@robspain.com

# Environment
NODE_ENV=production

# Convex admin persistence for robspain.com/admin
CONVEX_URL=https://your-deployment.convex.cloud
# Optional for protected Convex deployments/admin HTTP calls
CONVEX_DEPLOY_KEY=your_convex_deploy_key_here

# Separate Convex persistence for the private Family PWA
FAMILY_CONVEX_URL=https://your-family-deployment.convex.cloud
FAMILY_CONVEX_ACCESS_TOKEN=your_server_only_family_storage_token_here
# Optional for protected Convex deployments/admin HTTP calls
FAMILY_CONVEX_DEPLOY_KEY=your_family_convex_deploy_key_here

# Optional primary listing feed for /admin/home-search.
# If set, scheduled refresh reads this JSON feed first and uses Redfin as fallback.
HOME_SEARCH_IDX_FEED_URL=https://your-approved-idx-or-mls-feed.example.com/listings.json
HOME_SEARCH_IDX_FEED_TOKEN=your_optional_idx_feed_bearer_token

# Cloudflare R2 Configuration
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_R2_ACCESS_KEY_ID=your_r2_access_key_id
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CF_R2_BUCKET_NAME=your_r2_bucket_name
# Optional: Public base URL for listing/previewing assets
CF_R2_PUBLIC_BASE_URL=https://your-public-r2-domain-or-bucket-url
