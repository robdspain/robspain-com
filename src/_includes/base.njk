<!DOCTYPE html>
<html lang="en">
<head>
    {% set resolvedTitle = seo.metaTitle or title or "Rob Spain - School BCBA" %}
    {% set resolvedDescription = seo.metaDesc or description or "Rob Spain, School BCBA helping educators transform challenging behaviors." %}
    {% set resolvedImage = seo.socialImage or (image | postImage) %}
    {% set resolvedUrl = canonical or page.url %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ resolvedTitle }}</title>
    <meta name="description" content="{{ resolvedDescription }}">
    {% if keywords %}
    <meta name="keywords" content="{% if keywords | isArray %}{{ keywords | join(', ') }}{% else %}{{ keywords }}{% endif %}">
    {% endif %}
    <meta name="robots" content="{{ robots or 'index, follow' }}">
    <meta name="author" content="Rob Spain, BCBA, IBA">
    <link rel="canonical" href="{{ resolvedUrl | absoluteUrl }}">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">
    {% if family_pwa %}
    <meta name="theme-color" content="#123628">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Family Command">
    <link rel="manifest" href="/family-command.webmanifest">
    <link rel="apple-touch-icon" href="/public/images/family-command-icon-180.png">
    {% endif %}

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Rob Spain, BCBA - Blog" href="/feed.xml">

    <!-- Stylesheets -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="stylesheet" href="/premium-enhanced.css">
    <link rel="stylesheet" href="/premium-sections.css">
    <link rel="stylesheet" href="/premium-personal-story.css">
    <link rel="stylesheet" href="/premium-responsive.css">
    <link rel="stylesheet" href="/premium-styles.css">
    <link rel="stylesheet" href="/video-funnel.css">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/email-capture.css">
    
    {% if extra_css %}
    <link rel="stylesheet" href="{{ extra_css }}">
    {% endif %}
    {% if extra_head %}
    {{ extra_head | safe }}
    {% endif %}

    <script src="https://analytics.ahrefs.com/analytics.js" data-key="S+Vj3X2Qa6J/7godUSWIPg" async></script>

    <!-- SEO & Social Meta Tags -->
    <meta property="og:title" content="{{ resolvedTitle }}">
    <meta property="og:description" content="{{ resolvedDescription }}">
    <meta property="og:image" content="{{ resolvedImage | absoluteUrl }}">
    <meta property="og:url" content="{{ resolvedUrl | absoluteUrl }}">
    <meta property="og:type" content="{% if layout == "post.njk" %}article{% else %}website{% endif %}">
    
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ resolvedTitle }}">
    <meta name="twitter:description" content="{{ resolvedDescription }}">
    <meta name="twitter:image" content="{{ resolvedImage | absoluteUrl }}">
    <meta name="twitter:creator" content="@robspainBCBA">

    <script type="application/ld+json">
    {% if presentation %}
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": "{{ resolvedUrl | absoluteUrl }}#webpage",
          "url": "{{ resolvedUrl | absoluteUrl }}",
          "name": "{{ resolvedTitle }}",
          "description": "{{ resolvedDescription }}",
          "image": "{{ resolvedImage | absoluteUrl }}",
          "isPartOf": {
            "@type": "WebSite",
            "name": "Rob Spain, BCBA",
            "url": "https://robspain.com/"
          },
          "about": [
            "School BCBA",
            "PBIS",
            "behavior analysis in schools",
            "school behavior systems"
          ],
          "author": {
            "@id": "https://robspain.com/#rob-spain"
          }
        },
        {
          "@type": "Person",
          "@id": "https://robspain.com/#rob-spain",
          "name": "Rob Spain",
          "url": "https://robspain.com/",
          "jobTitle": "School BCBA",
          "sameAs": [
            "https://www.linkedin.com/in/robspain/",
            "https://twitter.com/robspainBCBA",
            "https://www.youtube.com/@BehaviorSchool",
            "https://www.instagram.com/robdspain/",
            "https://www.facebook.com/people/Rob-Spain-BCBA-IBA/61572496964176/",
            "https://behaviorschool.com"
          ]
        },
        {
          "@type": "PresentationDigitalDocument",
          "@id": "{{ resolvedUrl | absoluteUrl }}#presentation",
          "name": "{{ presentation.heading or resolvedTitle }}",
          "description": "{{ presentation.abstract or resolvedDescription }}",
          "image": "{{ presentation.image | absoluteUrl }}",
          "datePublished": "{{ presentation.isoDate or page.date.toISOString() }}",
          "publisher": {
            "@type": "Organization",
            "name": "Rob Spain, BCBA"
          },
          "author": [
            {% for presenter in presentation.presenters %}
            {
              "@type": "Person",
              "name": "{{ presenter.name }}"
            }{% if not loop.last %},{% endif %}
            {% endfor %}
          ],
          "about": [
            {% for topic in presentation.topics %}
            "{{ topic }}"{% if not loop.last %},{% endif %}
            {% endfor %}
          ]
        },
        {
          "@type": "BreadcrumbList",
          "@id": "{{ resolvedUrl | absoluteUrl }}#breadcrumbs",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://robspain.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Presentations",
              "item": "https://robspain.com/#interviews"
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": "{{ presentation.heading or resolvedTitle }}",
              "item": "{{ resolvedUrl | absoluteUrl }}"
            }
          ]
        }
        {% if presentation.faqs %},
        {
          "@type": "FAQPage",
          "@id": "{{ resolvedUrl | absoluteUrl }}#faq",
          "mainEntity": [
            {% for faq in presentation.faqs %}
            {
              "@type": "Question",
              "name": "{{ faq.question }}",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "{{ faq.answer }}"
              }
            }{% if not loop.last %},{% endif %}
            {% endfor %}
          ]
        }
        {% endif %}
      ]
    }
    {% elif layout == "post.njk" %}
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "@id": "{{ resolvedUrl | absoluteUrl }}#blogposting",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ resolvedUrl | absoluteUrl }}#webpage",
        "url": "{{ resolvedUrl | absoluteUrl }}"
      },
      "headline": {{ resolvedTitle | json | safe }},
      "image": ["{{ resolvedImage | absoluteUrl }}"],
      "datePublished": "{{ date.toISOString() }}",
      "dateModified": "{{ date.toISOString() }}",
      "author": {
        "@id": "https://robspain.com/#rob-spain"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Rob Spain, BCBA",
        "logo": {
          "@type": "ImageObject",
          "url": "https://robspain.com/public/images/icon/robspain-icon.png"
        }
      },
      "description": {{ resolvedDescription | json | safe }},
      "isPartOf": {
        "@type": "Blog",
        "@id": "https://robspain.com/blog/#blog",
        "name": "School BCBA Blog",
        "url": "https://robspain.com/blog/"
      },
      "about": [
        "School BCBA",
        "school-based behavior analysis",
        "school behavior systems",
        "PBIS",
        "FBA and BIP support",
        "educator coaching"
      ]{% if tags %},
      "articleSection": [
        {% for tag in tags %}
        {{ tag | json | safe }}{% if not loop.last %},{% endif %}
        {% endfor %}
      ]{% endif %}{% if tags or keywords %},
      "keywords": {% if keywords %}{% if keywords | isArray %}{{ (keywords | join(', ')) | json | safe }}{% else %}{{ keywords | json | safe }}{% endif %}{% else %}{{ (tags | join(', ')) | json | safe }}{% endif %}{% endif %}
    }
    {% else %}
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://robspain.com/#website",
          "url": "https://robspain.com/",
          "name": "Rob Spain, BCBA",
          "description": {{ resolvedDescription | json | safe }},
          "publisher": {
            "@id": "https://robspain.com/#rob-spain"
          },
          "inLanguage": "en-US"
        },
        {
          "@type": "Person",
          "@id": "https://robspain.com/#rob-spain",
          "name": "Rob Spain",
          "url": "https://robspain.com/",
          "image": "https://robspain.com/public/images/profile-Rob.png",
          "jobTitle": "School BCBA",
          "description": "Rob Spain is a school-based BCBA focused on practical behavior systems, educator coaching, PBIS integration, and implementation support for public schools.",
          "sameAs": [
            "https://www.linkedin.com/in/robspain/",
            "https://twitter.com/robspainBCBA",
            "https://www.youtube.com/@BehaviorSchool",
            "https://www.instagram.com/robdspain/",
            "https://www.facebook.com/people/Rob-Spain-BCBA-IBA/61572496964176/",
            "https://behaviorschool.com"
          ],
          "knowsAbout": [
            "School BCBA",
            "school-based behavior analysis",
            "PBIS",
            "FBA and BIP systems",
            "behavior intervention plans",
            "educator coaching",
            "implementation fidelity",
            "Acceptance and Commitment Training in schools",
            "AI tools for BCBAs"
          ],
          "alumniOf": {
            "@type": "CollegeOrUniversity",
            "name": "Fresno Pacific University"
          },
          "affiliation": {
            "@type": "Organization",
            "name": "Behavior School",
            "url": "https://behaviorschool.com"
          }
        },
        {
          "@type": "ProfessionalService",
          "@id": "https://robspain.com/#school-bcba-services",
          "name": "Rob Spain School BCBA Training and Consulting",
          "url": "https://robspain.com/",
          "image": "{{ resolvedImage | absoluteUrl }}",
          "description": "School BCBA training, presentations, consulting, and practical behavior systems support for educators, behavior intervention teams, and district leaders.",
          "areaServed": [
            {
              "@type": "Country",
              "name": "United States"
            },
            {
              "@type": "State",
              "name": "California"
            }
          ],
          "provider": {
            "@id": "https://robspain.com/#rob-spain"
          },
          "serviceType": [
            "School BCBA consulting",
            "Behavior systems training",
            "PBIS implementation support",
            "FBA and BIP systems support",
            "Professional development presentations"
          ],
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "School BCBA Services",
            "itemListElement": [
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Transformation Program",
                  "url": "https://robspain.com/transformation-program/"
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "School BCBA presentations",
                  "url": "https://robspain.com/cv/#presentations"
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "School behavior systems articles",
                  "url": "https://robspain.com/blog/"
                }
              }
            ]
          }
        },
        {
          "@type": "WebPage",
          "@id": "{{ resolvedUrl | absoluteUrl }}#webpage",
          "url": "{{ resolvedUrl | absoluteUrl }}",
          "name": {{ resolvedTitle | json | safe }},
          "description": {{ resolvedDescription | json | safe }},
          "image": "{{ resolvedImage | absoluteUrl }}",
          "isPartOf": {
            "@id": "https://robspain.com/#website"
          },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "{{ resolvedImage | absoluteUrl }}"
          },
          "author": {
            "@id": "https://robspain.com/#rob-spain"
          },
          "about": [
            "School BCBA",
            "school-based behavior analysis",
            "PBIS",
            "behavior intervention systems",
            "Transformation Program",
            "Behavior School"
          ]
          {% if page.url == "/" %},
          "mainEntity": {
            "@type": "ItemList",
            "name": "Rob Spain School BCBA resources",
            "itemListElement": [
              {
                "@type": "ListItem",
                "position": 1,
                "name": "School BCBA Blog",
                "url": "https://robspain.com/blog/"
              },
              {
                "@type": "ListItem",
                "position": 2,
                "name": "Transformation Program",
                "url": "https://robspain.com/transformation-program/"
              },
              {
                "@type": "ListItem",
                "position": 3,
                "name": "Rob Spain CV and Presentations",
                "url": "https://robspain.com/cv/"
              },
              {
                "@type": "ListItem",
                "position": 4,
                "name": "What Does a School BCBA Do?",
                "url": "https://robspain.com/blog/what-does-a-school-bcba-do/"
              }
            ]
          }
          {% endif %}
        }
      ]
    }
    {% endif %}
    </script>
    {% if family_pwa %}
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/family-command-sw.js', { scope: '/admin/' }).catch(() => {});
        });
      }
    </script>
    <style>
      .family-pwa-shell .compliance-page {
        padding-top: max(1rem, env(safe-area-inset-top)) !important;
        padding-bottom: calc(6rem + env(safe-area-inset-bottom)) !important;
      }
      .family-pwa-shell .family-nav {
        background: rgba(255, 253, 248, 0.92) !important;
        border: 1px solid rgba(18, 54, 40, 0.12) !important;
        border-radius: 22px !important;
        box-shadow: 0 16px 45px rgba(18, 54, 40, 0.1) !important;
        backdrop-filter: blur(18px);
      }
      .family-pwa-shell .family-nav-link {
        white-space: nowrap;
      }
      @media (max-width: 760px) {
        .family-pwa-shell .family-nav {
          position: sticky !important;
          top: max(8px, env(safe-area-inset-top)) !important;
          z-index: 50 !important;
          display: flex !important;
          flex-direction: column !important;
          align-items: stretch !important;
          gap: 10px !important;
          padding: 10px !important;
          margin-bottom: 16px !important;
        }
        .family-pwa-shell .family-nav-brand {
          display: flex !important;
          justify-content: flex-start !important;
          width: 100% !important;
          padding: 4px 4px 0 !important;
          font-size: 15px !important;
          line-height: 1.15 !important;
        }
        .family-pwa-shell .family-nav-brand i {
          font-size: 16px !important;
        }
        .family-pwa-shell .family-nav-links {
          display: flex !important;
          flex-wrap: nowrap !important;
          justify-content: flex-start !important;
          gap: 8px !important;
          overflow-x: auto !important;
          overscroll-behavior-x: contain;
          scroll-snap-type: x proximity;
          -webkit-overflow-scrolling: touch;
          padding: 2px 1px 3px !important;
        }
        .family-pwa-shell .family-nav-links::-webkit-scrollbar {
          display: none;
        }
        .family-pwa-shell .family-nav-link {
          flex: 0 0 auto !important;
          min-height: 40px !important;
          border-radius: 999px !important;
          padding: 10px 13px !important;
          font-size: 12px !important;
          font-weight: 850 !important;
          line-height: 1 !important;
          background: rgba(31, 77, 63, 0.06);
          scroll-snap-align: start;
        }
        .family-pwa-shell .family-nav-link.active {
          background: #1f4d3f !important;
          color: #fffdf8 !important;
          box-shadow: 0 10px 24px rgba(31, 77, 63, 0.24);
        }
        .family-pwa-shell .hero-card h1 {
          font-size: clamp(2.45rem, 12vw, 4rem);
          line-height: 0.98;
        }
        .family-pwa-shell .admin-auth-bar {
          left: 50% !important;
          right: auto !important;
          bottom: calc(10px + env(safe-area-inset-bottom)) !important;
          transform: translateX(-50%);
          max-width: calc(100vw - 24px);
          padding: 8px 10px !important;
          font-size: 11px !important;
          gap: 8px !important;
        }
      }
      @media (max-width: 390px) {
        .family-pwa-shell .family-nav-link {
          padding-inline: 11px !important;
        }
        .family-pwa-shell .family-nav-brand span {
          font-size: 14px !important;
        }
      }
    </style>
    {% endif %}

    <!-- Meta tags and other head content can go here -->
</head>
<body{% if family_pwa %} class="family-pwa-shell"{% endif %}>
