<!DOCTYPE html>
<html lang="en">
<head>
    {% set resolvedTitle = seo.metaTitle or title or "Rob Spain - School BCBA" %}
    {% set resolvedDescription = seo.metaDesc or description or "Rob Spain, School BCBA helping educators transform challenging behaviors." %}
    {% set resolvedImage = seo.socialImage or (image | postImage) %}
    {% set resolvedUrl = canonical or page.url %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ resolvedTitle }}</title>
    <meta name="description" content="{{ resolvedDescription }}">
    <meta name="robots" content="index, follow">
    <meta name="author" content="Rob Spain, BCBA, IBA">
    <link rel="canonical" href="{{ resolvedUrl | absoluteUrl }}">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Rob Spain, BCBA - Blog" href="/feed.xml">

    <!-- Stylesheets -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="stylesheet" href="/premium-enhanced.css">
    <link rel="stylesheet" href="/premium-sections.css">
    <link rel="stylesheet" href="/premium-personal-story.css">
    <link rel="stylesheet" href="/premium-responsive.css">
    <link rel="stylesheet" href="/premium-styles.css">
    <link rel="stylesheet" href="/video-funnel.css">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/email-capture.css">
    
    {% if extra_css %}
    <link rel="stylesheet" href="{{ extra_css }}">
    {% endif %}
    {% if extra_head %}
    {{ extra_head | safe }}
    {% endif %}

    <!-- Canonical URL -->
    <link rel="canonical" href="https://robspain.com{{ page.url | url }}">

    {% if page.url and page.url.indexOf("/admin/") == 0 %}
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style>
      html.admin-auth-pending body > *:not(.admin-auth-screen):not(#netlify-identity-widget):not(.netlify-identity-widget):not([id*="netlify"]):not([class*="netlify-identity"]):not([class*="identity"]) {
        visibility: hidden;
      }
      #netlify-identity-widget,
      #netlify-identity-widget *,
      .netlify-identity-widget,
      .netlify-identity-widget *,
      [class*="netlify-identity"],
      [class*="netlify-identity"] *,
      [class*="identity"],
      [class*="identity"] * {
        visibility: visible !important;
      }
      .admin-auth-screen {
        position: fixed;
        inset: 0;
        z-index: 9990;
        display: grid;
        place-items: center;
        padding: 2rem;
        background: rgba(248, 250, 252, 0.98);
        color: #0f172a;
        font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      .admin-auth-card {
        width: min(100%, 440px);
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12);
        text-align: center;
      }
      .admin-auth-mark {
        width: 56px;
        height: 56px;
        display: grid;
        place-items: center;
        margin: 0 auto 1rem;
        border: 1px solid #e2e8f0;
        border-radius: 50%;
        background: white;
        font-size: 1.6rem;
        font-weight: 900;
        color: #4285f4;
      }
      .admin-auth-card h1 {
        margin: 0 0 0.75rem;
        font-size: 1.7rem;
        color: #0f172a;
      }
      .admin-auth-card p {
        margin: 0 0 1.5rem;
        color: #475569;
        line-height: 1.6;
      }
      .admin-auth-card button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.7rem;
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 0.85rem 1.1rem;
        background: white;
        color: #0f172a;
        font-weight: 800;
        cursor: pointer;
      }
      .admin-auth-card button:hover {
        background: #f8fafc;
      }
      .admin-auth-google-icon {
        display: inline-grid;
        place-items: center;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        color: #4285f4;
        font-weight: 900;
      }
    </style>
    <script>
      document.documentElement.classList.add("admin-auth-pending");
    </script>
    {% endif %}

