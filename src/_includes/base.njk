<!DOCTYPE html>
<html lang="en">
<head>
    {% set resolvedTitle = seo.metaTitle or title or "Rob Spain - School BCBA" %}
    {% set resolvedDescription = seo.metaDesc or description or "Rob Spain, School BCBA helping educators transform challenging behaviors." %}
    {% set resolvedImage = seo.socialImage or (image | postImage) %}
    {% set resolvedUrl = canonical or page.url %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ resolvedTitle }}</title>
    <meta name="description" content="{{ resolvedDescription }}">
    {% if keywords %}
    <meta name="keywords" content="{{ keywords | join(', ') }}">
    {% endif %}
    <meta name="robots" content="index, follow">
    <meta name="author" content="Rob Spain, BCBA, IBA">
    <link rel="canonical" href="{{ resolvedUrl | absoluteUrl }}">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">
    {% if family_pwa %}
    <meta name="theme-color" content="#123628">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Family Command">
    <link rel="manifest" href="/family-command.webmanifest">
    <link rel="apple-touch-icon" href="/public/images/family-command-icon-180.png">
    {% endif %}

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Rob Spain, BCBA - Blog" href="/feed.xml">

    <!-- Stylesheets -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="stylesheet" href="/premium-enhanced.css">
    <link rel="stylesheet" href="/premium-sections.css">
    <link rel="stylesheet" href="/premium-personal-story.css">
    <link rel="stylesheet" href="/premium-responsive.css">
    <link rel="stylesheet" href="/premium-styles.css">
    <link rel="stylesheet" href="/video-funnel.css">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/email-capture.css">
    
    {% if extra_css %}
    <link rel="stylesheet" href="{{ extra_css }}">
    {% endif %}
    {% if extra_head %}
    {{ extra_head | safe }}
    {% endif %}

    <!-- SEO & Social Meta Tags -->
    <meta property="og:title" content="{{ seo.metaTitle or title or "Rob Spain - School BCBA" }}">
    <meta property="og:description" content="{{ seo.metaDesc or description or "Rob Spain, School BCBA." }}">
    <meta property="og:image" content="https://robspain.com{{ seo.socialImage or image or "/images/profile-Rob.png" }}">
    <meta property="og:url" content="https://robspain.com{{ page.url }}">
    <meta property="og:type" content="article">
    
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ seo.metaTitle or title or "Rob Spain - School BCBA" }}">
    <meta name="twitter:description" content="{{ seo.metaDesc or description or "Rob Spain, School BCBA." }}">
    <meta name="twitter:image" content="https://robspain.com{{ seo.socialImage or image or "/images/profile-Rob.png" }}">
    <meta name="twitter:creator" content="@robspainBCBA">

    <script type="application/ld+json">
    {% if presentation %}
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": "{{ resolvedUrl | absoluteUrl }}#webpage",
          "url": "{{ resolvedUrl | absoluteUrl }}",
          "name": "{{ resolvedTitle }}",
          "description": "{{ resolvedDescription }}",
          "image": "{{ resolvedImage | absoluteUrl }}",
          "isPartOf": {
            "@type": "WebSite",
            "name": "Rob Spain, BCBA",
            "url": "https://robspain.com/"
          },
          "about": [
            "School BCBA",
            "PBIS",
            "behavior analysis in schools",
            "school behavior systems"
          ],
          "author": {
            "@id": "https://robspain.com/#rob-spain"
          }
        },
        {
          "@type": "Person",
          "@id": "https://robspain.com/#rob-spain",
          "name": "Rob Spain",
          "url": "https://robspain.com/",
          "jobTitle": "School BCBA",
          "sameAs": [
            "https://www.linkedin.com/in/robspain/",
            "https://twitter.com/robspainBCBA",
            "https://behaviorschool.com"
          ]
        },
        {
          "@type": "PresentationDigitalDocument",
          "@id": "{{ resolvedUrl | absoluteUrl }}#presentation",
          "name": "{{ presentation.heading or resolvedTitle }}",
          "description": "{{ presentation.abstract or resolvedDescription }}",
          "image": "{{ presentation.image | absoluteUrl }}",
          "datePublished": "{{ presentation.isoDate or page.date.toISOString() }}",
          "publisher": {
            "@type": "Organization",
            "name": "Rob Spain, BCBA"
          },
          "author": [
            {% for presenter in presentation.presenters %}
            {
              "@type": "Person",
              "name": "{{ presenter.name }}"
            }{% if not loop.last %},{% endif %}
            {% endfor %}
          ],
          "about": [
            {% for topic in presentation.topics %}
            "{{ topic }}"{% if not loop.last %},{% endif %}
            {% endfor %}
          ]
        },
        {
          "@type": "BreadcrumbList",
          "@id": "{{ resolvedUrl | absoluteUrl }}#breadcrumbs",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://robspain.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Presentations",
              "item": "https://robspain.com/#interviews"
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": "{{ presentation.heading or resolvedTitle }}",
              "item": "{{ resolvedUrl | absoluteUrl }}"
            }
          ]
        }
        {% if presentation.faqs %},
        {
          "@type": "FAQPage",
          "@id": "{{ resolvedUrl | absoluteUrl }}#faq",
          "mainEntity": [
            {% for faq in presentation.faqs %}
            {
              "@type": "Question",
              "name": "{{ faq.question }}",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "{{ faq.answer }}"
              }
            }{% if not loop.last %},{% endif %}
            {% endfor %}
          ]
        }
        {% endif %}
      ]
    }
    {% elif layout == "post.njk" %}
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "mainEntityOfPage": "{{ resolvedUrl | absoluteUrl }}",
      "headline": "{{ resolvedTitle }}",
      "image": ["{{ resolvedImage | absoluteUrl }}"],
      "datePublished": "{{ date.toISOString() }}",
      "dateModified": "{{ date.toISOString() }}",
      "author": {
        "@type": "Person",
        "name": "Rob Spain",
        "url": "https://robspain.com/cv/",
        "jobTitle": "School BCBA",
        "sameAs": [
          "https://www.linkedin.com/in/robspain/",
          "https://twitter.com/robspainBCBA",
          "https://behaviorschool.com"
        ]
      },
      "publisher": {
        "@type": "Organization",
        "name": "Rob Spain, BCBA",
        "logo": {
          "@type": "ImageObject",
          "url": "https://robspain.com/public/images/icon/robspain-icon.png"
        }
      },
      "description": "{{ resolvedDescription }}"{% if tags or keywords %},
      "keywords": "{{ (tags or keywords) | join(', ') }}"{% endif %}
    }
    {% else %}
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "https://robspain.com/",
      "name": "Rob Spain, BCBA",
      "author": {
        "@type": "Person",
        "name": "Rob Spain",
        "url": "https://robspain.com"
      },
      "description": "{{ seo.metaDesc or description or 'Rob Spain, School BCBA.' }}"
    }
    {% endif %}
    </script>
    {% if family_pwa %}
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/family-command-sw.js', { scope: '/admin/' }).catch(() => {});
        });
      }
    </script>
    {% endif %}

    <!-- Meta tags and other head content can go here -->
</head>
<body>
    {% if page.url and page.url.startsWith('/admin/') %}
    <div class="admin-auth-bar" style="position:fixed;right:16px;bottom:16px;z-index:100000;display:flex;gap:10px;align-items:center;background:rgba(15,23,42,.92);color:#e2e8f0;border:1px solid rgba(16,185,129,.35);box-shadow:0 14px 40px rgba(0,0,0,.24);border-radius:999px;padding:9px 12px;font:600 12px/1 -apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;backdrop-filter:blur(12px);">
        <span style="display:inline-flex;align-items:center;gap:6px;"><span style="width:8px;height:8px;border-radius:50%;background:#10b981;box-shadow:0 0 0 4px rgba(16,185,129,.14);"></span>Admin authenticated</span>
        <a href="/admin/logout/" style="color:#f6c453;text-decoration:none;border-left:1px solid rgba(148,163,184,.35);padding-left:10px;">Logout</a>
    </div>
    {% endif %}
    <!-- Premium Navigation -->
    {% if not hide_public_nav %}
    <nav class="nav-premium">
        <div class="container">
            <div class="nav-content-premium">
                <a href="/" class="logo-premium">
                    Rob Spain, BCBA, IBA
                </a>
                <div class="nav-links-premium">
                    <a href="/#about" class="nav-link-premium">ABOUT</a>
                    <a href="/transformation-program/" class="nav-link-premium">PROGRAM</a>
                    <a href="/blog/" class="nav-link-premium">BLOG</a>
                    <a href="/cv/" class="nav-link-premium">CV</a>
                </div>
            </div>
        </div>
    </nav>
    {% endif %}

    <main>
        {{ content | safe }}
    </main>

    {% if not hide_public_nav %}
    <footer class="footer">
        <div class="container">
            <!-- Email Signup Section -->
            <!-- Temporarily commented out due to Nunjucks syntax issue
            <div class="footer-email-signup-wrapper">
                {% include "components/EmailSignup.njk" %}
            </div>
            -->
            
            <div class="footer-content">
                <div class="footer-section">
                    <h4>Professional Resources</h4>
                    <div class="footer-links-column">
                        <a href="https://behaviorschool.com" target="_blank" class="footer-link">
                            <i class="fas fa-graduation-cap"></i>
                            Behavior School
                        </a>
                        <a href="https://behaviorschool.com/study" target="_blank" class="footer-link">
                            <i class="fas fa-brain"></i>
                            Behavior Study Tools
                        </a>
                        <a href="https://behaviorschool.com/iep-goals" target="_blank" class="footer-link">
                            <i class="fas fa-file-signature"></i>
                            IEP Goal Generator
                        </a>
                        <a href="https://behaviorschool.com/supervisors" target="_blank" class="footer-link">
                            <i class="fas fa-user-tie"></i>
                            Supervision Tools
                        </a>
                        <a href="/transformation-program/" class="footer-link">
                            <i class="fas fa-rocket"></i>
                            Transformation Program
                        </a>
                        <a href="https://reunifyscience.com" target="_blank" class="footer-link">
                            <i class="fas fa-hands-helping"></i>
                            ReunifyScience
                        </a>
                        <a href="/cv/" class="footer-link">
                            <i class="fas fa-file-alt"></i>
                            Professional CV
                        </a>
                    </div>
                </div>

                <div class="footer-section">
                    <h4>Connect with Rob</h4>
                    <div class="footer-social-links">
                        <a href="https://www.linkedin.com/in/robspain/" target="_blank" class="social-link linkedin">
                            <i class="fab fa-linkedin"></i>
                            <span>LinkedIn</span>
                        </a>
                        <a href="https://www.facebook.com/people/Rob-Spain-BCBA-IBA/61572496964176/" target="_blank" class="social-link facebook">
                            <i class="fab fa-facebook"></i>
                            <span>Facebook</span>
                        </a>
                        <a href="https://www.instagram.com/robdspain/?hl=en" target="_blank" class="social-link instagram">
                            <i class="fab fa-instagram"></i>
                            <span>Instagram</span>
                        </a>
                        <a href="https://twitter.com/robspainBCBA" target="_blank" class="social-link twitter">
                            <i class="fab fa-twitter"></i>
                            <span>Twitter</span>
                        </a>
                    </div>
                </div>

                <div class="footer-section">
                    <h4>Legal & Certification</h4>
                    <div class="footer-links-column">
                        <a href="/#contact" class="footer-link">
                            <i class="fas fa-envelope"></i>
                            Contact Form
                        </a>
                        <a href="/privacy/" class="footer-link">
                            <i class="fas fa-shield-alt"></i>
                            Privacy Policy
                        </a>
                        <a href="/terms/" class="footer-link">
                            <i class="fas fa-file-contract"></i>
                            Terms of Service
                        </a>
                    </div>
                    <div class="bacb-info">
                        <div class="bacb-details">
                            <p><strong>BACB ACE Provider:</strong> Behavior School LLC</p>
                            <p><strong>ACE Provider #:</strong> OP-25-11420</p>
                        </div>
                        <div class="bacb-logos">
                            <img src="/public/images/BACB_ACE-Logo.jpg" alt="BACB ACE Authorized Continuing Education Provider" class="ace-logo" loading="lazy" decoding="async" style="display: block; max-width: 60px; height: auto;">
                        </div>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <div class="footer-bottom-content">
                    <p>&copy; <span id="current-year"></span> Rob Spain, BCBA, IBA. All rights reserved.</p>
                    <p class="footer-note">For comprehensive <a href="/#about" style="color: #10B981;">School BCBA</a> resources: <a href="https://behaviorschool.com/study" target="_blank" style="color: #10B981;">Behavior Study Tools</a> | <a href="https://behaviorschool.com" target="_blank" style="color: #10B981;">Behavior School</a></p>
                </div>
            </div>
        </div>
    </footer>
    {% endif %}
    <script src="/js/animations.js"></script>
    <script src="/premium-interactions.js"></script>
    <script src="/newsletter-signup.js"></script>
    <script src="/video-funnel.js"></script>
    <script src="/contact-form.js"></script>
    <script src="/email-capture.js"></script>

    <script>
      (function(){
        var el = document.getElementById('current-year');
        if (el) el.textContent = new Date().getFullYear();
        
        // Dynamically update years of experience
        var startYear = 2001;
        var currentYear = new Date().getFullYear();
        var years = currentYear - startYear;
        var yearsDisplay = years + "+";
        
        // Update all elements with the js-years-exp class
        document.querySelectorAll('.js-years-exp').forEach(function(element) {
          element.textContent = yearsDisplay;
        });
      })();
    </script>
</body>
</html>
