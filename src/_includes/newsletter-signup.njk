<aside class="newsletter-signup" aria-label="Newsletter signup" data-newsletter-source="{{ newsletterSource or page.url }}">
    <div class="newsletter-signup-copy">
        <p class="newsletter-kicker">School BCBA Systems Letter</p>
        <h2>{{ newsletterTitle or "Turn the blog into a practical weekly reset." }}</h2>
        <p>{{ newsletterDescription or "Get Rob's school-based behavior systems articles, implementation prompts, and Behavior School resources in the same newsletter used across robspain.com and Behavior School." }}</p>
    </div>
    <form class="newsletter-form" data-newsletter-form>
        <label class="sr-only" for="newsletter-email-{{ newsletterId or 'default' }}">Email address</label>
        <div class="newsletter-form-row">
            <input id="newsletter-email-{{ newsletterId or 'default' }}" type="email" name="email" placeholder="your.email@example.com" autocomplete="email" required>
            <button type="submit">
                <i class="fas fa-paper-plane"></i>
                <span>Subscribe</span>
            </button>
        </div>
        <p class="newsletter-privacy">No spam. Unsubscribe anytime. You'll receive the same newsletter as Behavior School subscribers.</p>
        <div class="newsletter-status" data-newsletter-status aria-live="polite"></div>
    </form>
</aside>

