---
layout: base.njk
---

<header class="section-premium" style="padding-top: 140px; background: var(--gradient-hero); color: white; text-align: center;">
    <div class="container" style="max-width: 800px;">
        <div class="section-badge-premium">Blog Post</div>
        <h1 class="display-2" style="font-size: 2.5rem; margin-bottom: 1rem;">{{ title }}</h1>
        <div style="color: rgba(255,255,255,0.7); font-size: 1rem;">
            <i class="far fa-calendar-alt"></i> {{ date.toDateString() }}
            <span style="margin-left: 1rem;"><i class="far fa-clock"></i> {{ content | readingTime }}</span>
        </div>
        <div style="margin-top: 0.5rem; color: rgba(255,255,255,0.8); font-size: 0.95rem;">
            Edited by Rob Spain, BCBA, IBA
        </div>
    </div>
</header>

<section class="section-premium" style="padding: 4rem 0;">
    <div class="container" style="max-width: 800px;">
        {% if youtubeUrl %}
        <div style="margin-bottom: 3rem;">
            {% set videoId = youtubeUrl | replace("https://www.youtube.com/watch?v=", "") | replace("https://youtu.be/", "") | replace("https://www.youtube.com/embed/", "") %}
            {# Basic string manipulation to extract ID, assuming simple URL formats #}
            {% youtube videoId %}
        </div>
        {% endif %}

        {% if image and not youtubeUrl %}
        <div class="post-featured-image" style="margin-bottom: 3rem; border-radius: 1rem; overflow: hidden; box-shadow: var(--shadow-xl);">
            {% image image, title, "(max-width: 800px) 100vw, 800px" %}
        </div>
        <style>.post-featured-image img { width: 100%; height: auto; display: block; }</style>
        {% endif %}

        <div class="about-copy" style="font-size: 1.125rem; line-height: 1.8; color: var(--gray-700);">
            {{ content | safe }}
        </div>

        <!-- Newsletter Signup -->
        <div style="margin-top: 4rem; padding: 2.5rem; background: linear-gradient(135deg, #1f4d3f 0%, #2a6350 100%); border-radius: 1rem; text-align: center;">
            <h3 style="color: #FAF3E0; font-size: 1.5rem; font-weight: 700; margin: 0 0 0.5rem 0;">
                Get school BCBA tips delivered weekly
            </h3>
            <p style="color: rgba(250, 243, 224, 0.8); margin: 0 0 1.5rem 0; font-size: 1rem;">
                Evidence-based strategies, free resources, and practical tips for school-based behavior analysts.
            </p>
            <form id="newsletter-form" style="display: flex; flex-direction: column; gap: 0.75rem; max-width: 400px; margin: 0 auto;">
                <input 
                    type="email" 
                    id="newsletter-email"
                    placeholder="Your email address" 
                    required
                    style="padding: 0.875rem 1rem; border-radius: 0.5rem; border: none; font-size: 1rem; background: white; color: #1a1a1a;"
                />
                <button 
                    type="submit"
                    style="padding: 0.875rem 1.5rem; background: #E3B23C; color: #1f4d3f; font-weight: 600; border: none; border-radius: 0.5rem; cursor: pointer; font-size: 1rem; transition: background 0.2s;"
                    onmouseover="this.style.background='#d4a235'"
                    onmouseout="this.style.background='#E3B23C'"
                >
                    Subscribe
                </button>
            </form>
            <p id="newsletter-success" style="display: none; color: #E3B23C; margin-top: 1rem; font-weight: 600;">
                Thanks for subscribing! Check your inbox.
            </p>
            <p id="newsletter-error" style="display: none; color: #ff6b6b; margin-top: 1rem;">
                Something went wrong. Please try again.
            </p>
            <p style="color: rgba(250, 243, 224, 0.5); font-size: 0.75rem; margin-top: 1rem;">
                Unsubscribe anytime. We never share your email.
            </p>
        </div>
        <script>
            document.getElementById('newsletter-form').addEventListener('submit', async function(e) {
                e.preventDefault();
                const email = document.getElementById('newsletter-email').value;
                const btn = this.querySelector('button');
                btn.textContent = 'Subscribing...';
                btn.disabled = true;
                
                try {
                    const response = await fetch('/api/newsletter', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email, source: 'robspain-blog' })
                    });
                    
                    if (response.ok) {
                        document.getElementById('newsletter-form').style.display = 'none';
                        document.getElementById('newsletter-success').style.display = 'block';
                    } else {
                        throw new Error('Failed');
                    }
                } catch (err) {
                    document.getElementById('newsletter-error').style.display = 'block';
                    btn.textContent = 'Subscribe';
                    btn.disabled = false;
                }
            });
        </script>

        <!-- Share & Navigation -->
        <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--gray-200);">
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem;">
                <div style="font-weight: 600; color: var(--gray-600);">Share this insights:</div>
                <div style="display: flex; gap: 1rem;">
                    <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url=https://robspain.com{{ page.url }}" target="_blank" rel="noopener" class="btn-secondary-premium" style="padding: 0.5rem 1rem; font-size: 0.9rem;">
                        <i class="fab fa-twitter"></i> Twitter
                    </a>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://robspain.com{{ page.url }}" target="_blank" rel="noopener" class="btn-secondary-premium" style="padding: 0.5rem 1rem; font-size: 0.9rem;">
                        <i class="fab fa-linkedin"></i> LinkedIn
                    </a>
                    <a href="https://www.facebook.com/sharer/sharer.php?u=https://robspain.com{{ page.url }}" target="_blank" rel="noopener" class="btn-secondary-premium" style="padding: 0.5rem 1rem; font-size: 0.9rem;">
                        <i class="fab fa-facebook"></i> Facebook
                    </a>
                </div>
            </div>

            <a href="/blog/" class="btn-secondary-premium" style="display: inline-flex; width: auto;">
                <i class="fas fa-arrow-left"></i> Back to Blog
            </a>
        </div>
    </div>
</section>