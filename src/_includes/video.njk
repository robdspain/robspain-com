---
layout: base.njk
---

<div class="video-page">
    <!-- Progress Bar -->
    <div class="video-progress-bar">
        <div class="container">
            <div class="progress-inner">
                <span class="progress-label">Video {{ step }} of 10</span>
                <div class="progress-track">
                    <div class="progress-fill" style="width: {{ (step / 10) * 100 }}%"></div>
                </div>
                <span class="progress-percent">{{ ((step / 10) * 100) | round }}%</span>
            </div>
        </div>
    </div>

    <!-- Video Header -->
    <header class="video-header">
        <div class="container">
            <div class="video-header-content">
                <span class="video-step-badge">Step {{ step }} of 10</span>
                <h1 class="video-title">{{ videoTitle }}</h1>
                {% if description %}
                <p class="video-description">{{ description }}</p>
                {% endif %}
            </div>
        </div>
    </header>

    <!-- Video Player -->
    <section class="video-player-section">
        <div class="container">
            <div class="video-wrapper">
                {% if bunnyVideoId %}
                <iframe
                    src="https://iframe.mediadelivery.net/embed/{{ bunnyLibraryId or '394122' }}/{{ bunnyVideoId }}?autoplay=false&preload=true"
                    loading="lazy"
                    style="border:none;position:absolute;top:0;left:0;height:100%;width:100%;"
                    allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
                    allowfullscreen="true">
                </iframe>
                {% else %}
                <div class="video-placeholder">
                    <div class="placeholder-content">
                        <i class="fas fa-video"></i>
                        <p>Video coming soon</p>
                        <span class="placeholder-id">Bunny Video ID: Not yet configured</span>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </section>

    <!-- Video Content -->
    <section class="video-content-section">
        <div class="container">
            <div class="video-content-grid">
                <!-- Main Content -->
                <div class="video-main-content">
                    {% if content %}
                    <div class="video-notes">
                        <h3><i class="fas fa-sticky-note"></i> Key Takeaways</h3>
                        {{ content | safe }}
                    </div>
                    {% endif %}

                    <!-- Navigation -->
                    <div class="video-navigation">
                        {% if step > 1 %}
                        <a href="/transformation/{{ step - 1 }}/" class="nav-btn nav-prev">
                            <i class="fas fa-arrow-left"></i>
                            <span>Previous Video</span>
                        </a>
                        {% else %}
                        <div class="nav-btn nav-prev disabled"></div>
                        {% endif %}

                        {% if step < 10 %}
                        <a href="/transformation/{{ step + 1 }}/" class="nav-btn nav-next">
                            <span>Next Video</span>
                            <i class="fas fa-arrow-right"></i>
                        </a>
                        {% else %}
                        <a href="https://behaviorschool.com/transformation-program" class="nav-btn nav-cta" target="_blank">
                            <span>Join the Program</span>
                            <i class="fas fa-external-link-alt"></i>
                        </a>
                        {% endif %}
                    </div>
                </div>

                <!-- Sidebar -->
                <aside class="video-sidebar">
                    <div class="sidebar-card series-card">
                        <h4><i class="fas fa-list-ol"></i> Video Series</h4>
                        <ul class="series-list">
                            <li class="{{ 'active' if step == 1 else '' }}"><a href="/transformation/1/">1. The Breaking Point</a></li>
                            <li class="{{ 'active' if step == 2 else '' }}"><a href="/transformation/2/">2. When I Almost Quit</a></li>
                            <li class="{{ 'active' if step == 3 else '' }}"><a href="/transformation/3/">3. The Myth That Kept Me Stuck</a></li>
                            <li class="{{ 'active' if step == 4 else '' }}"><a href="/transformation/4/">4. The Moment Everything Changed</a></li>
                            <li class="{{ 'active' if step == 5 else '' }}"><a href="/transformation/5/">5. The 5-Pillar Framework</a></li>
                            <li class="{{ 'active' if step == 6 else '' }}"><a href="/transformation/6/">6. What Systems Leadership Looks Like</a></li>
                            <li class="{{ 'active' if step == 7 else '' }}"><a href="/transformation/7/">7. Why Most BCBAs Stay Stuck</a></li>
                            <li class="{{ 'active' if step == 8 else '' }}"><a href="/transformation/8/">8. Real Results</a></li>
                            <li class="{{ 'active' if step == 9 else '' }}"><a href="/transformation/9/">9. The 8-Week Transformation Program</a></li>
                            <li class="{{ 'active' if step == 10 else '' }}"><a href="/transformation/10/">10. Your Invitation</a></li>
                        </ul>
                    </div>

                    {% if step >= 9 %}
                    <div class="sidebar-card cta-card">
                        <h4><i class="fas fa-rocket"></i> Ready to Transform?</h4>
                        <p>Join the 8-Week Transformation Program and go from crisis manager to systems leader.</p>
                        <a href="https://behaviorschool.com/transformation-program" class="cta-btn" target="_blank">
                            Learn More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                    {% endif %}
                </aside>
            </div>
        </div>
    </section>

    <!-- Final CTA (only on last video) -->
    {% if step == 10 %}
    <section class="final-cta-section">
        <div class="container">
            <div class="final-cta-content">
                <h2>Ready to Make the Shift?</h2>
                <p>You've seen the path from crisis manager to systems leader. Now it's time to walk it.</p>
                <div class="final-cta-buttons">
                    <a href="https://behaviorschool.com/transformation-program" class="btn-primary-cta" target="_blank">
                        <i class="fas fa-graduation-cap"></i> Join the Transformation Program
                    </a>
                </div>
            </div>
        </div>
    </section>
    {% endif %}
</div>

<style>
/* Video Page Styles */
.video-page {
    background: #f8fafc;
    min-height: 100vh;
}

.video-progress-bar {
    background: #1e293b;
    padding: 12px 0;
    position: sticky;
    top: 70px;
    z-index: 100;
}

.progress-inner {
    display: flex;
    align-items: center;
    gap: 16px;
}

.progress-label {
    color: #94a3b8;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
}

.progress-track {
    flex: 1;
    height: 8px;
    background: #334155;
    border-radius: 100px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #10B981, #34D399);
    border-radius: 100px;
    transition: width 0.3s ease;
}

.progress-percent {
    color: #10B981;
    font-size: 0.875rem;
    font-weight: 700;
    white-space: nowrap;
}

.video-header {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    padding: 3rem 0;
    color: white;
}

.video-header-content {
    max-width: 800px;
}

.video-step-badge {
    display: inline-block;
    background: rgba(16, 185, 129, 0.2);
    color: #10B981;
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
}

.video-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.2;
}

.video-description {
    font-size: 1.125rem;
    color: #94a3b8;
    line-height: 1.6;
}

.video-player-section {
    padding: 2rem 0;
    background: #0f172a;
}

.video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    background: #000;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}

.video-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
}

.placeholder-content {
    text-align: center;
    color: #64748b;
}

.placeholder-content i {
    font-size: 4rem;
    margin-bottom: 1rem;
    color: #475569;
}

.placeholder-content p {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
}

.placeholder-id {
    font-size: 0.75rem;
    color: #475569;
}

.video-content-section {
    padding: 3rem 0;
}

.video-content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
    align-items: start;
}

.video-main-content {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}

.video-notes h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.video-notes h3 i {
    color: #10B981;
}

.video-notes p {
    color: #475569;
    line-height: 1.7;
    margin-bottom: 1rem;
}

.video-navigation {
    display: flex;
    justify-content: space-between;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
}

.nav-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
}

.nav-prev {
    background: #f1f5f9;
    color: #475569;
}

.nav-prev:hover {
    background: #e2e8f0;
}

.nav-prev.disabled {
    visibility: hidden;
}

.nav-next, .nav-cta {
    background: #10B981;
    color: white;
}

.nav-next:hover, .nav-cta:hover {
    background: #059669;
    transform: translateY(-2px);
}

.video-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.sidebar-card {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}

.sidebar-card h4 {
    font-size: 1rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.sidebar-card h4 i {
    color: #10B981;
}

.series-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.series-list li {
    margin-bottom: 0.5rem;
}

.series-list li a {
    display: block;
    padding: 8px 12px;
    border-radius: 6px;
    color: #64748b;
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.2s ease;
}

.series-list li a:hover {
    background: #f1f5f9;
    color: #1e293b;
}

.series-list li.active a {
    background: rgba(16, 185, 129, 0.1);
    color: #10B981;
    font-weight: 600;
}

.cta-card {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
}

.cta-card h4 {
    color: white;
}

.cta-card p {
    color: #94a3b8;
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 1rem;
}

.cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #10B981;
    color: white;
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
    transition: all 0.2s ease;
}

.cta-btn:hover {
    background: #059669;
    transform: translateY(-2px);
}

.final-cta-section {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    padding: 4rem 0;
    text-align: center;
    color: white;
}

.final-cta-content h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
}

.final-cta-content p {
    font-size: 1.25rem;
    color: #94a3b8;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

.final-cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

.btn-primary-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: #10B981;
    color: white;
    padding: 16px 32px;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.125rem;
    transition: all 0.2s ease;
    box-shadow: 0 4px 14px rgba(16, 185, 129, 0.4);
}

.btn-primary-cta:hover {
    background: #059669;
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(16, 185, 129, 0.5);
}

@media (max-width: 900px) {
    .video-content-grid {
        grid-template-columns: 1fr;
    }

    .video-sidebar {
        order: -1;
    }

    .series-card {
        display: none;
    }

    .video-title {
        font-size: 1.75rem;
    }
}

@media (max-width: 600px) {
    .video-header {
        padding: 2rem 0;
    }

    .video-title {
        font-size: 1.5rem;
    }

    .video-navigation {
        flex-direction: column;
        gap: 1rem;
    }

    .nav-btn {
        justify-content: center;
    }

    .nav-prev.disabled {
        display: none;
    }
}
</style>
