  </section>

  <div style="text-align:center; margin: 1.4rem 0 2rem;">
    <a href="/admin/" style="color:#1f4d3f; font-size:0.9rem;">Back to Admin</a>
  </div>
</div>

<div class="modal-backdrop" id="item-modal">
  <div class="modal">
    <div class="modal-header">
      <div id="modal-title" style="font-weight:700; color:#1e293b;">Preview</div>
      <button class="btn btn-secondary" onclick="closeModal()">Close</button>
    </div>
    <div class="modal-body">
      <div class="form-grid">
        <div>
          <label for="m-title">Title</label>
          <input id="m-title" type="text">
        </div>
        <div class="two-col">
          <div>
            <label for="m-channel">Channel</label>
            <select id="m-channel">
              <option value="email">Email</option>
              <option value="linkedin">LinkedIn</option>
              <option value="blog">Blog</option>
              <option value="x">X.com</option>
            </select>
          </div>
          <div>
            <label for="m-status">Status</label>
            <select id="m-status">
              <option value="draft">Draft</option>
              <option value="pending-approval">Pending approval</option>
              <option value="approved">Approved</option>
              <option value="scheduled">Scheduled</option>
              <option value="sent-published">Sent/published</option>
            </select>
          </div>
        </div>
        <div class="two-col">
          <div>
            <label for="m-date">Date</label>
            <input id="m-date" type="date">
          </div>
          <div>
            <label for="m-project">Project</label>
            <input id="m-project" type="text">
          </div>
        </div>
        <div>
          <label for="m-body">Body</label>
          <textarea id="m-body"></textarea>
        </div>
        <div>
          <label for="m-metadata">Metadata (JSON)</label>
          <textarea id="m-metadata"></textarea>
        </div>
        <div>
          <label for="m-reject-notes">Reject notes (optional)</label>
          <textarea id="m-reject-notes"></textarea>
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-edit" onclick="saveItemEdits()">Save Changes</button>
        <button class="btn btn-approve" onclick="approveCurrent()">Approve</button>
        <button class="btn btn-reject" onclick="rejectCurrent()">Reject</button>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast">Saved</div>

<script>
const staticCalendar = {{ contentCalendar | dump | safe }};
let state = { weeks: JSON.parse(JSON.stringify(staticCalendar)) };
let activeId = null;

function normalizeItems(weeks) {
  return weeks.flatMap((week) => (week.items || []).map((item, idx) => {
    if (!item.id) item.id = `${week.week}-${item.channel || item.platform || 'item'}-${idx}`;
    if (!item.channel) item.channel = item.platform || 'email';
    if (!item.status) item.status = 'draft';
    if (!item.body) item.body = item.notes || '';
    if (!item.metadata) item.metadata = { owner: 'Rob', tags: [], audience: '' };
    return { ...item, week: week.week };
  }));
}

function chipClass(prefix, value) {
  return `${prefix}-${value}`;
}

function statusLabel(status) {
  if (status === 'pending-approval') return 'Pending approval';
  if (status === 'sent-published') return 'Sent/published';
  return status;
}

function escapeHtml(text) {
  return (text || '').replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m]));
}

function render() {
  const channelFilter = document.getElementById('channel-filter').value;
  const statusFilter = document.getElementById('status-filter').value;
  const allItems = normalizeItems(state.weeks).sort((a,b) => a.date.localeCompare(b.date));

  const filtered = allItems.filter((item) => {
    const channelOk = channelFilter === 'all' || item.channel === channelFilter;
    const statusOk = statusFilter === 'all' || item.status === statusFilter;
    return channelOk && statusOk;
  });

  const queue = filtered.filter((item) => item.status === 'pending-approval' && ['email', 'linkedin', 'blog', 'x'].includes(item.channel));
  drawList(document.getElementById('queue-list'), queue);
  drawList(document.getElementById('all-list'), filtered);

  document.getElementById('queue-count').textContent = `${queue.length} pending items`;
  document.getElementById('all-count').textContent = `${filtered.length} items`;
}

function drawList(container, items) {
  if (!items.length) {
    container.innerHTML = '<div class="empty">No items match current filters.</div>';
    return;
  }

  container.innerHTML = items.map((item) => `
    <article class="item">
      <div class="item-main">
        <div class="item-top">
          <span class="chip ${chipClass('ch', item.channel)}">${escapeHtml(item.channel)}</span>
          <span class="chip ${chipClass('st', item.status)}">${escapeHtml(statusLabel(item.status))}</span>
        </div>
        <h3 class="item-title">${escapeHtml(item.title)}</h3>
        <div class="item-meta">${escapeHtml(item.project || '')} • ${escapeHtml(item.date || '')}</div>
      </div>
      <div class="item-actions">
        <button class="btn btn-secondary" onclick="openPreview('${item.id}')">Preview</button>
        <button class="btn btn-edit" onclick="openEdit('${item.id}')">Edit</button>
        <button class="btn btn-approve" onclick="quickApprove('${item.id}')">Approve</button>
        <button class="btn btn-reject" onclick="quickReject('${item.id}')">Reject</button>
      </div>
    </article>
  `).join('');
}

function findItem(id) {
  for (const week of state.weeks) {
    const idx = (week.items || []).findIndex((item) => item.id === id);
    if (idx >= 0) return { week, item: week.items[idx], idx };
  }
  return null;
}

function openPreview(id) { openEdit(id); }

function openEdit(id) {
  const found = findItem(id);
  if (!found) return;
  activeId = id;
  const item = found.item;

  document.getElementById('modal-title').textContent = `Edit: ${item.title}`;
  document.getElementById('m-title').value = item.title || '';
  document.getElementById('m-channel').value = item.channel || 'email';
  document.getElementById('m-status').value = item.status || 'draft';
  document.getElementById('m-date').value = item.date || '';
  document.getElementById('m-project').value = item.project || '';
  document.getElementById('m-body').value = item.body || '';
  document.getElementById('m-reject-notes').value = item.rejectionNotes || '';
  document.getElementById('m-metadata').value = JSON.stringify(item.metadata || {}, null, 2);

  document.getElementById('item-modal').style.display = 'flex';
}

function closeModal() {
  document.getElementById('item-modal').style.display = 'none';
  activeId = null;
}

function saveItemEdits() {
  if (!activeId) return;
  const found = findItem(activeId);
  if (!found) return;

  let metadata = {};
  try {
    metadata = JSON.parse(document.getElementById('m-metadata').value || '{}');
  } catch (err) {
    alert('Metadata must be valid JSON.');
    return;
  }

  found.item.title = document.getElementById('m-title').value.trim();
  found.item.channel = document.getElementById('m-channel').value;
  found.item.status = document.getElementById('m-status').value;
  found.item.date = document.getElementById('m-date').value;
  found.item.project = document.getElementById('m-project').value.trim();
  found.item.body = document.getElementById('m-body').value;
  found.item.metadata = metadata;
  found.item.rejectionNotes = document.getElementById('m-reject-notes').value.trim();

  persistAndRender('Changes saved');
}

function quickApprove(id) {
  const found = findItem(id);
  if (!found) return;
  found.item.status = 'approved';
  found.item.rejectionNotes = '';
  persistAndRender('Item approved');
}

function quickReject(id) {
  const found = findItem(id);
  if (!found) return;
  const note = window.prompt('Optional reject note:', found.item.rejectionNotes || '');
  found.item.status = 'draft';
  found.item.rejectionNotes = note || '';
  persistAndRender('Item rejected to draft');
}

function approveCurrent() {
  if (!activeId) return;
  const found = findItem(activeId);
  if (!found) return;
  found.item.status = 'approved';
  found.item.rejectionNotes = '';
  persistAndRender('Item approved');
  closeModal();
}

function rejectCurrent() {
  if (!activeId) return;
  const found = findItem(activeId);
  if (!found) return;
  found.item.status = 'draft';
  found.item.rejectionNotes = document.getElementById('m-reject-notes').value.trim();
  persistAndRender('Item rejected to draft');
  closeModal();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 1800);
}

async function saveState() {
  localStorage.setItem('content-calendar-state-v1', JSON.stringify(state));
  try {
    await fetch('/.netlify/functions/content-calendar-data', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(state)
    });
  } catch (err) {
    console.warn('Remote persistence unavailable, kept local copy.', err);
  }
}

function persistAndRender(msg) {
  saveState();
  render();
  showToast(msg || 'Saved');
}

async function hydrate() {
  const local = localStorage.getItem('content-calendar-state-v1');
  if (local) {
    try { state = JSON.parse(local); } catch (e) { console.warn(e); }
  }

  try {
    const res = await fetch('/.netlify/functions/content-calendar-data');
    if (res.ok) {
      const data = await res.json();
      if (data && Array.isArray(data.weeks)) {
        state = data;
      }
    }
  } catch (err) {
    console.warn('Using local/static calendar state', err);
  }

  render();
}

document.getElementById('channel-filter').addEventListener('change', render);
document.getElementById('status-filter').addEventListener('change', render);
document.getElementById('item-modal').addEventListener('click', function(e){
  if (e.target.id === 'item-modal') closeModal();
});

hydrate();
</script>
