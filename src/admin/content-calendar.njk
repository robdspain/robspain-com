---
layout: base.njk
title: Content Calendar - Rob Spain
permalink: /admin/content-calendar/
---

<style>
.cal { max-width: 1100px; margin: 2rem auto; padding: 0 1rem; }
.cal-header { background: linear-gradient(135deg, #1f4d3f, #123628); color: #fff; padding: 2rem; border-radius: 0.75rem; margin-bottom: 1.5rem; }
.cal-header h1 { margin: 0; font-size: 1.75rem; font-weight: 800; }
.cal-header p { opacity: 0.85; margin: 0.5rem 0 0; font-size: 0.9rem; }
.week-block { background: #fff; border: 1px solid #e2e8f0; border-radius: 0.75rem; margin-bottom: 1.25rem; overflow: hidden; }
.week-header { background: #f8fafc; padding: 0.75rem 1.25rem; border-bottom: 1px solid #e2e8f0; font-weight: 700; font-size: 1rem; color: #1e293b; display: flex; justify-content: space-between; align-items: center; }
.week-count { font-size: 0.8rem; font-weight: 500; color: #64748b; }
.cal-item { display: grid; grid-template-columns: 90px 70px 1fr auto; gap: 0.75rem; align-items: center; padding: 0.75rem 1.25rem; border-bottom: 1px solid #f1f5f9; font-size: 0.85rem; }
.cal-item:last-child { border-bottom: none; }
.cal-date { color: #64748b; font-size: 0.8rem; }
.platform { padding: 0.2rem 0.5rem; border-radius: 0.25rem; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; text-align: center; }
.p-email { background: #fef3c7; color: #92400e; }
.p-linkedin { background: #dbeafe; color: #1e40af; }
.p-blog { background: #e0e7ff; color: #3730a3; }
.p-youtube { background: #fee2e2; color: #991b1b; }
.p-webinar { background: #d1fae5; color: #065f46; }
.p-app-store { background: #f3e8ff; color: #6b21a8; }
.cal-title { color: #1e293b; font-weight: 600; }
.cal-project { font-size: 0.75rem; color: #94a3b8; margin-top: 0.15rem; }
.cal-notes { font-size: 0.8rem; color: #64748b; margin-top: 0.15rem; }
.status { padding: 0.2rem 0.6rem; border-radius: 9999px; font-size: 0.7rem; font-weight: 600; white-space: nowrap; }
.s-draft { background: #fef3c7; color: #92400e; }
.s-scheduled { background: #dbeafe; color: #1e40af; }
.s-published { background: #d1fae5; color: #065f46; }
.s-in-progress { background: #fed7aa; color: #9a3412; }
.s-planned { background: #f1f5f9; color: #475569; }
.legend { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.8rem; }
.legend span { display: flex; align-items: center; gap: 0.3rem; }
.summary { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem; }
.sum-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 0.75rem; text-align: center; }
.sum-val { font-size: 1.5rem; font-weight: 800; color: #1e293b; }
.sum-lbl { font-size: 0.7rem; color: #64748b; margin-top: 0.15rem; }
@media (max-width: 640px) {
  .cal-item { grid-template-columns: 1fr; gap: 0.25rem; }
}
</style>

<div class="cal">
    <div class="cal-header">
        <h1>Content Calendar</h1>
        <p>All projects. All platforms. 5-week view.</p>
    </div>

    <!-- Summary -->
    <div class="summary">
        {% set totalItems = 0 %}{% set emailCount = 0 %}{% set linkedinCount = 0 %}{% set blogCount = 0 %}{% set youtubeCount = 0 %}{% set webinarCount = 0 %}{% set appCount = 0 %}
        {% for week in contentCalendar %}{% for item in week.items %}
            {% set totalItems = totalItems + 1 %}
            {% if item.platform == "email" %}{% set emailCount = emailCount + 1 %}{% endif %}
            {% if item.platform == "linkedin" %}{% set linkedinCount = linkedinCount + 1 %}{% endif %}
            {% if item.platform == "blog" %}{% set blogCount = blogCount + 1 %}{% endif %}
            {% if item.platform == "youtube" %}{% set youtubeCount = youtubeCount + 1 %}{% endif %}
            {% if item.platform == "webinar" %}{% set webinarCount = webinarCount + 1 %}{% endif %}
            {% if item.platform == "app-store" %}{% set appCount = appCount + 1 %}{% endif %}
        {% endfor %}{% endfor %}
        <div class="sum-card"><div class="sum-val">{{ totalItems }}</div><div class="sum-lbl">Total Items</div></div>
        <div class="sum-card"><div class="sum-val">{{ emailCount }}</div><div class="sum-lbl">Emails</div></div>
        <div class="sum-card"><div class="sum-val">{{ linkedinCount }}</div><div class="sum-lbl">LinkedIn</div></div>
        <div class="sum-card"><div class="sum-val">{{ youtubeCount }}</div><div class="sum-lbl">YouTube</div></div>
        <div class="sum-card"><div class="sum-val">{{ blogCount }}</div><div class="sum-lbl">Blog Posts</div></div>
        <div class="sum-card"><div class="sum-val">{{ webinarCount }}</div><div class="sum-lbl">Webinars</div></div>
        <div class="sum-card"><div class="sum-val">{{ appCount }}</div><div class="sum-lbl">App Releases</div></div>
    </div>

    <!-- Legend -->
    <div class="legend">
        <span><span class="platform p-email">Email</span></span>
        <span><span class="platform p-linkedin">LinkedIn</span></span>
        <span><span class="platform p-blog">Blog</span></span>
        <span><span class="platform p-youtube">YouTube</span></span>
        <span><span class="platform p-webinar">Webinar</span></span>
        <span><span class="platform p-app-store">App</span></span>
        <span style="margin-left: 1rem;"><span class="status s-draft">Draft</span></span>
        <span><span class="status s-scheduled">Scheduled</span></span>
        <span><span class="status s-in-progress">In Progress</span></span>
        <span><span class="status s-planned">Planned</span></span>
        <span><span class="status s-published">Published</span></span>
    </div>

    <!-- Weeks -->
    {% for week in contentCalendar %}
    <div class="week-block">
        <div class="week-header">
            Week of {{ week.week }}
            <span class="week-count">{{ week.items.length }} items</span>
        </div>
        {% for item in week.items %}
        <div class="cal-item">
            <div class="cal-date">{{ item.date }}</div>
            <div><span class="platform p-{{ item.platform }}">{{ item.platform }}</span></div>
            <div>
                <div class="cal-title">{{ item.title }}</div>
                <div class="cal-project">{{ item.project }}</div>
                {% if item.notes %}<div class="cal-notes">{{ item.notes }}</div>{% endif %}
            </div>
            <div><span class="status s-{{ item.status }}">{{ item.status }}</span></div>
        </div>
        {% endfor %}
    </div>
    {% endfor %}

    <div style="text-align: center; padding: 2rem; color: #94a3b8; font-size: 0.85rem;">
        <a href="/admin/" style="color: #1f4d3f;">Back to Admin</a>
    </div>
</div>
