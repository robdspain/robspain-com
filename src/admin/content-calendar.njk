<style>
.cal { max-width: 1200px; margin: 2rem auto; padding: 0 1rem; }
.cal-header { background: linear-gradient(135deg, #1f4d3f, #123628); color: #fff; padding: 1.5rem; border-radius: 0.75rem; margin-bottom: 1rem; }
.cal-header h1 { margin: 0; font-size: 1.6rem; }
.cal-header p { margin: 0.4rem 0 0; opacity: 0.9; }

.filters { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.6rem; margin-bottom: 1rem; }
.filters select { width: 100%; padding: 0.55rem 0.7rem; border: 1px solid #cbd5e1; border-radius: 0.5rem; background: #fff; color: #1e293b; }

.queue, .all-items { background: #fff; border: 1px solid #e2e8f0; border-radius: 0.75rem; margin-bottom: 1rem; overflow: hidden; }
.section-header { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; padding: 0.9rem 1rem; border-bottom: 1px solid #e2e8f0; background: #f8fafc; }
.section-header h2 { margin: 0; font-size: 1rem; color: #1e293b; }
.section-header .count { color: #475569; font-size: 0.82rem; }

.item-list { display: grid; gap: 0.55rem; padding: 0.8rem; }
.item { border: 1px solid #e2e8f0; border-radius: 0.6rem; padding: 0.75rem; display: grid; grid-template-columns: 1fr auto; gap: 0.6rem; }
.item-main { min-width: 0; }
.item-top { display: flex; align-items: center; flex-wrap: wrap; gap: 0.45rem; margin-bottom: 0.35rem; }
.item-title { color: #0f172a; font-size: 0.95rem; font-weight: 700; margin: 0; }
.item-meta { color: #64748b; font-size: 0.78rem; margin-top: 0.2rem; }

.chip { font-size: 0.68rem; font-weight: 700; border-radius: 9999px; padding: 0.2rem 0.55rem; text-transform: uppercase; letter-spacing: 0.02em; }
.ch-email { background: #fef3c7; color: #92400e; }
.ch-linkedin { background: #dbeafe; color: #1e40af; }
.ch-blog { background: #dcfce7; color: #166534; }
.ch-x { background: #e2e8f0; color: #0f172a; }

.st-draft { background: #fff7ed; color: #9a3412; }
.st-pending-approval { background: #fef9c3; color: #854d0e; }
.st-approved { background: #dcfce7; color: #166534; }
.st-scheduled { background: #dbeafe; color: #1e40af; }
.st-sent-published { background: #e2e8f0; color: #334155; }

.item-actions { display: flex; gap: 0.45rem; align-items: start; flex-wrap: wrap; justify-content: flex-end; }
.btn { border: 1px solid transparent; border-radius: 0.45rem; padding: 0.42rem 0.62rem; font-size: 0.78rem; font-weight: 600; cursor: pointer; }
.btn-secondary { background: #f8fafc; border-color: #cbd5e1; color: #334155; }
.btn-edit { background: #0f766e; color: #fff; }
.btn-approve { background: #15803d; color: #fff; }
.btn-reject { background: #b91c1c; color: #fff; }

.empty { color: #64748b; font-size: 0.85rem; padding: 0.6rem; }

.modal-backdrop { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.48); display: none; align-items: center; justify-content: center; padding: 1rem; z-index: 1000; }
.modal { width: min(760px, 100%); max-height: 90vh; overflow: auto; background: #fff; border-radius: 0.75rem; border: 1px solid #cbd5e1; }
.modal-header { padding: 0.85rem 1rem; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; }
.modal-body { padding: 0.85rem 1rem 1rem; }
.form-grid { display: grid; gap: 0.65rem; }
.form-grid input, .form-grid textarea, .form-grid select { width: 100%; border: 1px solid #cbd5e1; border-radius: 0.45rem; padding: 0.5rem 0.6rem; font-size: 0.86rem; }
.form-grid textarea { min-height: 140px; resize: vertical; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
.modal-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.8rem; }

.toast { position: fixed; right: 1rem; bottom: 1rem; background: #123628; color: #fff; padding: 0.6rem 0.9rem; border-radius: 0.5rem; opacity: 0; transition: opacity 0.2s; z-index: 1200; }
.toast.show { opacity: 1; }

@media (max-width: 760px) {
  .item { grid-template-columns: 1fr; }
  .item-actions { justify-content: flex-start; }
  .two-col { grid-template-columns: 1fr; }
}
</style>

<div class="cal">
