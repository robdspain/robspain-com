  function phaseReportData() {
    const data = snapshot();
    const completed = checkedLabels();
    const open = uncheckedLabels();
    return {
      data,
      completed,
      open,
      total: inputs.length,
      done: completed.length,
      phase: document.querySelector('[data-report-phase]')?.value || 'Phase update',
