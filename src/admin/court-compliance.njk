          { label: 'Dylan/Rob conjoint session', done: dylanConjointDone, required: 6 },
          { label: 'Link Care family session', done: familyDone, required: 16 }
        ], () => dylanTwoHourDone >= 6),
        readyText: 'Dylan conjoint and 16 family-session gates are entered, so Dylan two-hour visits are ready for review.',
        date: formatDate(projection.dylan.find(gate => gate.id === 'dylanTwoHour')?.date)
      },
