          <p>Projected date: ${escapeHtml(card.date)}</p>
        </article>
      `;
    }).join('');
  }

  function completedWeeklyBy(startDate, targetDate, existingDone, required) {
    if (!startDate || !targetDate || startDate > targetDate) {
      return Math.min(Math.max(existingDone, 0), required);
    }
    const projected = Math.floor((targetDate - startDate) / msDay / 7) + 1;
    return Math.min(Math.max(existingDone, projected, 0), required);
  }

  function completedWeeklyAfterGateBy(gateDate, targetDate, existingDone, required) {
    if (!gateDate || !targetDate || gateDate >= targetDate) {
      return Math.min(Math.max(existingDone, 0), required);
    }
    const projected = Math.floor((targetDate - gateDate) / msDay / 7);
    return Math.min(Math.max(existingDone, projected, 0), required);
  }

  function projectedConjointDoneBy(thirdSessionDate, targetDate, existingDone) {
    if (!thirdSessionDate || !targetDate || thirdSessionDate > targetDate) {
      return Math.min(Math.max(existingDone, 0), 6);
    }
    const projected = 3 + Math.floor((targetDate - thirdSessionDate) / msDay / 7);
    return Math.min(Math.max(existingDone, projected, 0), 6);
  }

  function projectionCard(title, state, label, detail, dateText) {
    return `
      <article class="readiness-card is-${state}">
        <span class="readiness-status">${escapeHtml(label)}</span>
        <h4>${escapeHtml(title)}</h4>
        <p><strong>${escapeHtml(detail)}</strong></p>
        <p>${escapeHtml(dateText)}</p>
      </article>
    `;
  }

  function renderCourtProjection() {
    const target = document.querySelector('[data-court-projection]');
    if (!target) return;
    const courtDate = parseDate('2026-07-23');
    const projection = buildProjection();
    const angerDoneByCourt = completedWeeklyBy(dateValue('angerStart'), courtDate, countValue('angerDone'), 10);
    const familyDoneByCourt = completedWeeklyBy(dateValue('familyStart'), courtDate, countValue('familyDone'), 24);
    const dylanConjointByCourt = projectedConjointDoneBy(dateValue('dylanConjointThird'), courtDate, countValue('dylanConjointDone'));
    const whGateDate = projection.wh.find(gate => gate.id === 'whGate1')?.date;
    const whTwoHourByCourt = completedWeeklyAfterGateBy(whGateDate, courtDate, countValue('whTwoHourDone'), 6);

    const cards = [
      projectionCard(
        'Anger management',
        angerDoneByCourt >= 10 ? 'complete' : 'ready',
        angerDoneByCourt >= 10 ? 'Completed' : 'On track before court',
        `Projected ${angerDoneByCourt} of 10 classes complete before July 23. Class 10 projects for July 24, the day after court.`,
        'Proof likely available through class 4 now; class 10 completion proof is not projected before this court date.'
      ),
      projectionCard(
        'Link Care family counseling',
        familyDoneByCourt >= 4 ? 'ready' : 'blocked',
        familyDoneByCourt >= 4 ? 'Gate met' : 'In progress',
        `Projected ${familyDoneByCourt} family sessions complete before July 23.`,
        familyDoneByCourt >= 4
          ? 'This should satisfy the 4-session W/H start gate if sessions occur weekly starting June 19.'
          : 'The W/H two-hour visit start gate still needs 4 completed family sessions.'
      ),
      projectionCard(
        'W/H two-hour visit start gate',
        angerDoneByCourt >= 4 && familyDoneByCourt >= 4 ? 'ready' : 'blocked',
        angerDoneByCourt >= 4 && familyDoneByCourt >= 4 ? 'Ready for review' : 'Not ready',
        angerDoneByCourt >= 4 && familyDoneByCourt >= 4
          ? `Projected start-gate date is ${formatDate(whGateDate)}: 4 anger classes and 4 family sessions should be complete.`
          : 'The start gate is not projected to be met before court.',
        'This means the two-hour visit phase may be eligible to begin before July 23, subject to confirmation and scheduling.'
      ),
      projectionCard(
        'W/H two-hour visits completed',
        whTwoHourByCourt >= 6 ? 'complete' : whTwoHourByCourt > 0 ? 'ready' : 'pending',
        whTwoHourByCourt >= 6 ? 'Completed' : whTwoHourByCourt > 0 ? 'Started' : 'Pending',
        `Projected ${whTwoHourByCourt} of 6 two-hour W/H visits complete before July 23.`,
        whTwoHourByCourt >= 6
          ? 'This would unlock Saturday 3 PM to 7 PM visit review.'
          : 'The full six-visit phase is not projected to be complete before court.'
      ),
      projectionCard(
        'Dylan/Rob Janz conjoint counseling',
        dylanConjointByCourt >= 6 ? 'ready' : 'blocked',
        dylanConjointByCourt >= 6 ? 'Conjoint gate met' : 'In progress',
        `Projected ${dylanConjointByCourt} of 6 Dylan/Rob conjoint sessions complete before July 23.`,
        dylanConjointByCourt >= 6
          ? 'The conjoint-session count should be met before court if weekly sessions continue from June 19.'
          : 'The Dylan conjoint gate is not projected to be met before court.'
      ),
      projectionCard(
        'Dylan parenting-time gates',
        'pending',
        'Still pending',
        `Even if Dylan/Rob conjoint sessions reach 6, only ${familyDoneByCourt} of 16 Link Care family sessions are projected before July 23.`,
        'Dylan two-hour visits are not projected to unlock before this court date because the 16-family-session gate is still pending.'
      )
    ];

    target.innerHTML = cards.join('');
  }

  function noteProviderName(key) {
    return {
      collier: 'Dr. Collier',
      linkCare: 'Link Care family counseling',
      janz: 'Janz Dylan/Rob conjoint',
      anger: 'Total Life Change / anger management',
      counsel: 'Counsel filing packet'
    }[key] || key;
  }

  function noteCallRows() {
    const callPattern = /\b(call|called|calling|phone|voicemail|left message|message|contacted|followed up|callback|call back)\b/i;
    return textareas.flatMap(textarea => {
      const key = textarea.dataset.note || '';
      return textarea.value
        .split(/\n+/)
        .map(line => line.trim())
        .filter(line => callPattern.test(line))
        .map(line => ({
          date: '',
          provider: noteProviderName(key),
          phone: '',
          status: 'Note reference',
          source: 'Dashboard notes',
          notes: line
        }));
    });
  }

  function combinedCallRows() {
    const notionRows = notionCallEvidence.calls.map(row => ({
      ...row,
      source: row.source || 'Notion: Therapist Assessment Contact List'
    }));
    const imported = callEvidence.calls.map(row => ({
      ...row,
      source: row.source || 'Mac Mini import'
    }));
    const noteRows = noteCallRows();
    const manual = callLog.map((row, index) => ({
      ...row,
      source: 'Manual correction',
      manualIndex: index
    }));
    return notionRows.concat(imported, noteRows, manual);
  }

  function updateCallEvidenceSummary(rows) {
    const target = document.querySelector('[data-call-evidence-summary]');
    const status = document.querySelector('[data-call-evidence-status]');
    if (!target) return;
    const notionCount = notionCallEvidence.calls.length;
    const importedCount = callEvidence.calls.length;
    const autodialerRows = callEvidence.calls.filter(row => /auto.?dial|dialer/i.test(`${row.source} ${row.status} ${row.notes}`)).length;
    const autodialerCount = Number(callEvidence.summary.autodialerCalls || callEvidence.summary.autodialerAttempts || callEvidence.summary.callsMade || autodialerRows || 0);
    const noteCount = noteCallRows().length;
    const values = [rows.length, notionCount, importedCount || autodialerCount, noteCount];
    target.querySelectorAll('strong').forEach((node, index) => {
      node.textContent = values[index] ?? 0;
    });
    if (status) {
      if (notionCallEvidence.importedAt && callEvidence.importedAt) {
        status.textContent = `Loaded ${notionCount} Notion call rows and ${importedCount} Mac Mini/autodialer rows.`;
      } else if (notionCallEvidence.importedAt) {
        status.textContent = `Loaded ${notionCount} call rows from Notion Therapist Assessment Contact List. Mac Mini/autodialer exports can still be imported below.`;
      } else if (callEvidence.importedAt) {
        const file = callEvidence.fileName ? ` from ${callEvidence.fileName}` : '';
        status.textContent = `Mac Mini phone-log evidence imported${file} at ${new Date(callEvidence.importedAt).toLocaleString([], { dateStyle: 'medium', timeStyle: 'short' })}.`;
      } else {
        status.textContent = 'No Notion or Mac Mini call-log evidence loaded yet. Export the Mac Mini autodialer or phone log as CSV/JSON, then import it below.';
      }
    }
  }

  function renderCalls() {
    const body = document.querySelector('[data-call-log]');
    if (!body) return;
    const rows = combinedCallRows();
    updateCallEvidenceSummary(rows);
    if (!rows.length) {
      body.innerHTML = '<tr><td colspan="7">No call evidence imported yet. Import the Mac Mini phone log or add call details to the notes above.</td></tr>';
      return;
    }
    body.innerHTML = rows.map(call => {
      const manualIndex = Number.isInteger(call.manualIndex) ? call.manualIndex : -1;
      return `
      <tr>
        <td>${escapeHtml(call.date || '')}</td>
        <td>${escapeHtml(call.provider || '')}</td>
        <td>${escapeHtml(call.phone || '')}</td>
        <td>${escapeHtml(call.status || '')}</td>
        <td>${escapeHtml(call.source || '')}</td>
        <td>${escapeHtml([call.duration ? `Duration: ${call.duration}` : '', call.notes || ''].filter(Boolean).join(' - '))}</td>
        <td>${manualIndex >= 0 ? `<button type="button" class="delete-call" data-delete-call="${manualIndex}">Delete</button>` : ''}</td>
      </tr>
    `;
    }).join('');
  }

  function escapeHtml(value) {
    return String(value).replace(/[&<>"']/g, char => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;'
    }[char]));
  }

  function snapshot() {
    const checks = {};
    inputs.forEach((input, index) => { checks[itemKey(input, index)] = input.checked; });
    const notes = {};
    textareas.forEach((textarea, index) => { notes[noteKey(textarea, index)] = textarea.value; });
    const plan = {};
    planInputs.forEach(input => { plan[input.dataset.planInput] = input.value; });
    return {
      exportedAt: new Date().toISOString(),
      page: 'Court compliance tracker',
      nextTask: document.querySelector('[data-next-task-detail]')?.textContent?.trim() || document.querySelector('[data-next-task]')?.textContent?.trim(),
      nextDetail: document.querySelector('[data-next-detail]')?.textContent?.trim(),
      waylonHarrisonProjection: document.querySelector('[data-wh-home-date]')?.textContent?.trim(),
      dylanProjection: document.querySelector('[data-dylan-home-date]')?.textContent?.trim(),
      plan,
      checks,
      notes,
      calls: callLog,
      callEvidence,
      notionCallEvidence,
      combinedCallEvidence: combinedCallRows()
    };
  }

  function checkedLabels() {
    return inputs
      .filter(input => input.checked)
      .map((input, index) => itemKey(input, index));
  }

  function uncheckedLabels() {
    return inputs
      .filter(input => !input.checked)
      .map((input, index) => itemKey(input, index));
  }

  function planValue(name) {
    return document.querySelector(`[data-plan-input="${name}"]`)?.value || 'Not set';
  }

  function reportLine(label, value) {
    return `- ${label}: ${value || 'Not set'}`;
  }

  function limitedList(items, emptyText, limit) {
    if (!items.length) return [`- ${emptyText}`];
    return items.slice(0, limit).map(item => `- ${item}`);
  }

  function noteLines(notes) {
    const noteLabels = {
      collier: 'Dr. Collier individual therapy',
      linkCare: 'Link Care family counseling',
      janz: 'Janz Dylan/Rob conjoint counseling',
      anger: 'Anger management',
      counsel: 'Counsel filing packet'
    };
    const lines = Object.entries(noteLabels)
      .filter(([key]) => notes[key] && notes[key].trim())
      .map(([key, label]) => `- ${label}: ${notes[key].trim()}`);
    return lines.length ? lines : ['- No dashboard notes entered yet.'];
  }

  function callLogLines(limit) {
    const rows = combinedCallRows();
    if (!rows.length) {
      return ['- No call evidence imported yet; import the Mac Mini phone log/autodialer export or add call details to dashboard notes.'];
    }
    return rows.slice(0, limit).map(call => {
      const parts = [
        call.date || 'No date',
        call.provider || 'No provider listed',
        call.source || 'No source',
        call.status || 'No status',
        call.notes || ''
      ].filter(Boolean);
      return `- ${parts.join(' - ')}`;
    });
  }

  function proofLines(completed) {
    const proofItems = completed.filter(item => /proof|letter|confirmation|attendance|certificate|file/i.test(item));
    return limitedList(proofItems, 'No proof-specific checklist item is marked complete yet.', 10);
  }

  function planNumber(name) {
    const number = Number(planValue(name));
    return Number.isFinite(number) ? number : 0;
  }

  function hasCompletedText(completed, pattern) {
    return completed.some(item => pattern.test(item));
  }

  function courtReadyDocumentationLines(completed) {
    const angerDone = planNumber('angerDone');
    const familyDone = planNumber('familyDone');
    const dylanDone = planNumber('dylanConjointDone');
    const lines = [
      'Current tracker summary and phase report generated for Amy before the July 23, 2026 court date.',
      'Documented outreach summary: 55 sent Gmail messages reviewed, 27 provider email targets, and 6+ calls/in-person contacts or attempts captured so far.',
      `Anger-management record: Total Life Change is the active provider; dashboard shows ${angerDone} of 10 classes completed.`,
      `Family-counseling record: Link Care is the active family-counseling provider; dashboard shows ${familyDone} family sessions completed.`,
      `Dylan/Rob conjoint counseling record: Janz is the active conjoint-counseling provider; dashboard shows ${dylanDone} of 6 conjoint sessions completed.`,
      'Provider/status notes and recent call evidence are included from the dashboard notes and call-evidence tracker.'
    ];
    if (hasCompletedText(completed, /Collier.*letter|individual therapy.*letter/i)) {
      lines.push('Dr. Collier proof-letter work is marked complete in the dashboard.');
    }
    if (hasCompletedText(completed, /Link Care.*appointment|Link Care.*confirmation/i)) {
      lines.push('Link Care appointment confirmation/replies are marked complete in the dashboard.');
    }
    if (hasCompletedText(completed, /Janz.*confirmation|conjoint.*confirmation/i)) {
      lines.push('Janz conjoint-counseling confirmation/replies are marked complete in the dashboard.');
    }
    return lines;
  }

  function fulfilledEvaluationRequirementLines(completed) {
    const angerDone = planNumber('angerDone');
    const familyDone = planNumber('familyDone');
    const dylanDone = planNumber('dylanConjointDone');
    const lines = [
      `Anger-management requirement: ${angerDone >= 1 ? 'started' : 'not yet marked started'}; ${angerDone} of 10 once-weekly classes are entered.`,
      `Anger-management proof gates: first-class proof ${angerDone >= 1 ? 'should be available/ready to document' : 'not yet met'}; fourth-class proof ${angerDone >= 4 ? 'should be available/ready to document' : 'not yet met'}; tenth-class proof ${angerDone >= 10 ? 'met' : 'not yet met'}.`,
      `Family-therapy requirement: Link Care is identified as the active provider; ${familyDone} of 24 total family sessions are entered, with ${Math.min(familyDone, 16)} of the first 16 weekly sessions entered.`,
      `Waylon/Harrison first step-up gate: requires 4 anger-management classes and 4 family sessions. Anger side is ${angerDone >= 4 ? 'met' : 'not met'}; family-session side is ${familyDone >= 4 ? 'met' : 'not met'}.`,
      `Dylan/Rob conjoint-counseling requirement: Janz is the active provider; ${dylanDone} of 6 conjoint sessions are entered. The third-session milestone is ${dylanDone >= 3 ? 'met' : 'not yet met'}.`,
      'Dr. Collier individual-therapy requirement: current therapy and proof-letter tracking are underway; the later twelve-session twice-monthly requirement is tied to completion of sixteen family-therapy sessions and is not yet triggered by the dashboard counts.'
    ];
    if (hasCompletedText(completed, /File first-class proof/i)) {
      lines.push('Dashboard marks first-class anger-management proof as filed/copied.');
    }
    if (hasCompletedText(completed, /File fourth-class proof/i)) {
      lines.push('Dashboard marks fourth-class anger-management proof as filed/copied.');
    }
    if (hasCompletedText(completed, /family therapy attendance proof/i)) {
      lines.push('Dashboard marks at least one family-therapy attendance proof item complete.');
    }
    return lines;
  }

  function pendingEvaluationRequirementLines() {
    const angerDone = planNumber('angerDone');
    const familyDone = planNumber('familyDone');
    const dylanDone = planNumber('dylanConjointDone');
    const lines = [];
    if (angerDone < 10) lines.push(`Complete the remaining anger-management classes (${angerDone} of 10 entered).`);
    if (familyDone < 4) lines.push(`Complete the first four Link Care family sessions needed for the Waylon/Harrison two-hour visit gate (${familyDone} of 4 entered).`);
    if (familyDone < 16) lines.push(`Continue toward sixteen Link Care family sessions before later co-parenting/individual-therapy gates are triggered (${familyDone} of 16 entered).`);
    if (dylanDone < 6) lines.push(`Continue Dylan/Rob conjoint counseling at Janz until six sessions are entered (${dylanDone} of 6 entered).`);
    if (!lines.length) lines.push('No pending phase-one requirement is shown by the current dashboard counts.');
    return lines;
  }

