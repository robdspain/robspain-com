      'UID:janz-dylan-rob-conjoint-session-3-20260619@robspain.com',
      'DTSTAMP:20260612T170000Z',
      'DTSTART;VALUE=DATE:20260619',
      'DTEND;VALUE=DATE:20260620',
      'SUMMARY:Dylan/Rob Janz conjoint counseling session 3',
      'DESCRIPTION:Janz Family Therapy / Vanessa Flores. Phone: (559) 825-1205.',
      'LOCATION:Janz Family Therapy, 1357 W Shaw Ave #100, Fresno, CA 93711',
      'END:VEVENT',
      'BEGIN:VEVENT',
      'UID:total-life-change-fridays-1015@robspain.com',
      'DTSTAMP:20260612T170000Z',
      'DTSTART;TZID=America/Los_Angeles:20260605T101500',
      'DTEND;TZID=America/Los_Angeles:20260605T111500',
      'RRULE:FREQ=WEEKLY;BYDAY=FR',
