          ${listHtml(limitedList(open, 'No open checklist items remain in the dashboard.', 10))}
        </div>
      </section>
      <section>
        <h2>Provider and Status Notes</h2>
        ${listHtml(noteLines(data.notes || {}))}
      </section>
      <section>
        <h2>Recent Call Evidence</h2>
        ${listHtml(callLogLines(8))}
      </section>
      <section class="footer">
        <p>Please let me know if you want this organized differently, or if there is any additional proof you want me to send before July 23.</p>
        <p>Thank you,<br>Rob</p>
      </section>
      <div class="actions">
        <button onclick="window.print()">Save as PDF</button>
      </div>
    </main>
  </div>
  <script>
    document.title = "court-compliance-${escapeHtml(phaseSlug)}-${todayISO()}";
    window.addEventListener('load', () => setTimeout(() => window.print(), 300));
  <\/script>
</body>
</html>`;
  }

  function setPhaseReportStatus(message) {
    const status = document.querySelector('[data-phase-report-status]');
    if (status) status.textContent = message;
  }

  function ensurePhaseReport() {
    const output = document.querySelector('[data-phase-report-output]');
    if (!output) return '';
    if (!output.value.trim()) {
      output.value = buildPhaseReport();
    }
    return output.value;
  }

  function generatePhaseReport() {
    const output = document.querySelector('[data-phase-report-output]');
    if (!output) return;
    output.value = buildPhaseReport();
    setPhaseReportStatus('Report generated. Review before sending to Amy.');
  }

  function downloadPhaseReport() {
    ensurePhaseReport();
    const reportWindow = window.open('', '_blank');
    if (!reportWindow) {
      setPhaseReportStatus('Popup blocked. Allow popups to open the PDF report.');
      return;
    }
    reportWindow.document.open();
    reportWindow.document.write(buildPhaseReportHtml());
    reportWindow.document.close();
    setPhaseReportStatus('PDF report opened. Use Save as PDF in the print dialog.');
  }

  function downloadSnapshot() {
    const blob = new Blob([JSON.stringify(snapshot(), null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `court-compliance-snapshot-${todayISO()}.json`;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

