      courtReadyDocumentation: courtReadyDocumentationLines(completed),
      fulfilledRequirements: fulfilledEvaluationRequirementLines(completed),
      pendingRequirements: pendingEvaluationRequirementLines(),
      therapistEvidence: therapistAvailabilityEvidence()
