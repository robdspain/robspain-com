<script>
(function () {
  const key = 'court-compliance-v2';
  const custodyActionDateKey = '2026-06-12';
  const custodyActions = [
    {
      id: 'anger-class-4-proof-print',
      title: 'Print fourth anger-management proof letter',
      detail: 'Get the class 4 attendance letter printed or saved as a PDF so it is ready to send today.',
      area: 'Anger management',
      due: 'Today'
    },
    {
      id: 'anger-class-4-proof-amy',
      title: 'Send class 4 proof to Amy',
      detail: 'Email Amy the fourth anger-management proof letter and note that class 4 is complete.',
      area: 'Amy proof packet',
      due: 'Today'
    },
    {
      id: 'link-care-summary-response',
      title: 'Respond to Link Care with the written summary',
      detail: 'Send Brooke / Link Care the family counseling summary you already wrote so scheduling and treatment setup keep moving.',
      area: 'Link Care',
      due: 'Today'
    }
  ];
  const syncStatus = document.querySelector('[data-sync-status]');
  let state = readLocalState();
  state.plan = state.plan || {};
  state.dailyActions = normalizeDailyActions(state.dailyActions);
  const inputs = Array.from(document.querySelectorAll('.checklist input'));
  const textareas = Array.from(document.querySelectorAll('textarea[data-note]'));
  const planInputs = Array.from(document.querySelectorAll('[data-plan-input]'));
  const callFields = Array.from(document.querySelectorAll('[data-call-field]'));
  let callLog = Array.isArray(state.calls) ? state.calls : [];
  let callEvidence = normalizeCallEvidence(state.callEvidence);
  let notionCallEvidence = normalizeCallEvidence(null);
  const stages = ['setup', 'anger', 'family', 'stepup', 'post16', 'proof'];
  const msDay = 24 * 60 * 60 * 1000;
  let syncTimer = null;
  const knownDateDefaults = {
    planStart: '2026-06-12',
    angerStart: '2026-05-22',
    familyStart: '2026-06-19',
    dylanConjointThird: '2026-06-19',
    angerDone: '4',
    familyDone: '0',
    dylanConjointDone: '3'
  };
  const nextCourtDateLabel = 'July 23, 2026';

  function readLocalState() {
    try {
      return JSON.parse(localStorage.getItem(key) || '{}');
    } catch (error) {
      return {};
    }
  }

  function setSyncStatus(message, type) {
    if (!syncStatus) return;
    syncStatus.textContent = message;
    syncStatus.classList.toggle('is-synced', type === 'synced');
    syncStatus.classList.toggle('is-error', type === 'error');
  }

  function itemKey(input, index) {
    return input.closest('li').textContent.trim().replace(/\s+/g, ' ').slice(0, 120) || String(index);
  }

  function noteKey(textarea, index) {
    return textarea.dataset.note || String(index);
  }

  function normalizeCallEvidence(value) {
    const source = value && typeof value === 'object' ? value : {};
    const calls = Array.isArray(source.calls) ? source.calls : Array.isArray(source) ? source : [];
    return {
      importedAt: source.importedAt || null,
      fileName: source.fileName || '',
      summary: source.summary && typeof source.summary === 'object' ? source.summary : {},
      calls: calls.map(normalizeCallRow).filter(row => row.provider || row.phone || row.notes)
    };
  }

  function normalizeCallRow(row) {
    const source = row && typeof row === 'object' ? row : {};
    const provider = source.provider || source.name || source.contact || source.to || source.recipient || source.callee || '';
    const phone = source.phone || source.number || source.phoneNumber || source.tel || source.destination || '';
    const status = source.status || source.result || source.outcome || source.disposition || source.type || '';
    const notes = source.notes || source.note || source.memo || source.description || source.evidence || '';
    const date = source.date || source.time || source.timestamp || source.startedAt || source.createdAt || '';
    const duration = source.duration || source.durationSeconds || source.seconds || '';
    const sourceName = source.source || source.system || source.origin || 'Mac Mini import';
    return {
      date: String(date || '').slice(0, 32),
      provider: String(provider || '').trim(),
      phone: String(phone || '').trim(),
      status: String(status || '').trim(),
      source: String(sourceName || '').trim(),
      duration: String(duration || '').trim(),
      notes: String(notes || '').trim()
    };
  }

  function normalizeDailyActions(value) {
    const source = value && typeof value === 'object' ? value : {};
    source[custodyActionDateKey] = source[custodyActionDateKey] && typeof source[custodyActionDateKey] === 'object' ? source[custodyActionDateKey] : {};
    return source;
  }

  function save() {
    const nextState = snapshotState();
    localStorage.setItem(key, JSON.stringify(nextState));
    queueRemoteSave(nextState);
    updateProgress();
    renderCalls();
  }

  function snapshotState() {
    const checks = {};
    inputs.forEach((input, index) => { checks[itemKey(input, index)] = input.checked; });
    const notes = {};
    textareas.forEach((textarea, index) => { notes[noteKey(textarea, index)] = textarea.value; });
    const plan = {};
    planInputs.forEach(input => { plan[input.dataset.planInput] = input.value; });
    return { checks, notes, plan, calls: callLog, callEvidence, dailyActions: normalizeDailyActions(state.dailyActions) };
  }

  function queueRemoteSave(value) {
    clearTimeout(syncTimer);
    setSyncStatus('Saving locally; syncing to secure site storage...', 'pending');
    syncTimer = setTimeout(async () => {
      try {
        const response = await fetch('/admin/api/family-convex', {
          method: 'PUT',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key, value, requireConvex: true })
        });
        const data = await response.json();
        if (!response.ok) {
          throw new Error(data.error || `Remote save failed (${response.status})`);
        }
        const stamp = data.updatedAt ? new Date(data.updatedAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }) : 'now';
        const source = storageSourceLabel(data);
        setSyncStatus(`Saved to ${source} at ${stamp}.`, 'synced');
      } catch (error) {
        setSyncStatus(`Saved locally. Remote sync unavailable: ${error.message}`, 'error');
      }
    }, 650);
  }

  async function loadRemoteState() {
    try {
      const response = await fetch(`/admin/api/family-convex?key=${encodeURIComponent(key)}&requireConvex=1`, { credentials: 'same-origin' });
      const data = await response.json();
      if (!response.ok) {
        throw new Error(data.error || `Remote load failed (${response.status})`);
      }
      if (!data.item || !data.item.value) {
        const source = storageSourceLabel(data);
        setSyncStatus(`No ${source} record yet. Local changes will create one.`, 'pending');
        return;
      }
      applyState(data.item.value);
      localStorage.setItem(key, JSON.stringify(snapshotState()));
      const stamp = data.item.updatedAt ? new Date(data.item.updatedAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }) : 'now';
      const source = storageSourceLabel(data);
      setSyncStatus(`Loaded from ${source}. Last saved ${stamp}.`, 'synced');
    } catch (error) {
      setSyncStatus(`Using local browser copy. Remote load unavailable: ${error.message}`, 'error');
    }
  }

  function storageSourceLabel(data) {
    if (data?.source === 'convex' || data?.source === 'convex-migrated') return 'Convex';
    if (data?.source === 'blobs') {
      return data.convexConfigured ? 'Netlify storage after Family Convex fallback' : 'Netlify storage (Family Convex URL missing)';
    }
    return 'remote storage';
  }

  async function loadNotionCallEvidence() {
    try {
      const response = await fetch('/public/data/court-compliance-notion-call-evidence.json', { cache: 'no-store' });
      if (!response.ok) throw new Error(`Notion evidence fetch failed (${response.status})`);
      const data = await response.json();
      notionCallEvidence = normalizeCallEvidence({
        importedAt: data.generatedAt || new Date().toISOString(),
        fileName: data.source || 'Notion Therapist Assessment Contact List',
        summary: data.summary || {},
        calls: data.calls || []
      });
      renderCalls();
    } catch (error) {
      const status = document.querySelector('[data-call-evidence-status]');
      if (status) status.textContent = `Notion call evidence snapshot unavailable: ${error.message}. Mac Mini/autodialer exports can still be imported below.`;
    }
  }

  function applyState(nextState) {
    state = nextState || {};
    state.plan = state.plan || {};
    state.dailyActions = normalizeDailyActions(state.dailyActions);
    callLog = Array.isArray(state.calls) ? state.calls : [];
    callEvidence = normalizeCallEvidence(state.callEvidence);

    inputs.forEach((input, index) => {
      input.checked = Boolean(state.checks && state.checks[itemKey(input, index)]);
    });
    textareas.forEach((textarea, index) => {
      textarea.value = (state.notes && state.notes[noteKey(textarea, index)]) || '';
    });
    planInputs.forEach(input => {
      const saved = state.plan[input.dataset.planInput];
      if (saved !== undefined) {
        input.value = saved;
      } else if (knownDateDefaults[input.dataset.planInput] !== undefined) {
        input.value = knownDateDefaults[input.dataset.planInput];
      } else if (input.type === 'number') {
        input.value = 0;
      } else if (input.dataset.planInput === 'planStart') {
        input.value = todayISO();
      } else {
        input.value = '';
      }
    });
    renderCalls();
    renderCustodyActions();
    updateProgress();
  }

  function renderCustodyActions() {
    const container = document.querySelector('[data-custody-actions]');
    const countTarget = document.querySelector('[data-custody-action-count]');
    if (!container) return;
    state.dailyActions = normalizeDailyActions(state.dailyActions);
    const todayState = state.dailyActions[custodyActionDateKey] || {};
    const completed = custodyActions.filter(action => todayState[action.id]).length;
    if (countTarget) countTarget.textContent = `${completed}/${custodyActions.length}`;
    container.innerHTML = custodyActions.map(action => {
      const done = Boolean(todayState[action.id]);
      return `
        <label class="custody-action-card ${done ? 'done' : ''}">
          <input class="custody-action-check" type="checkbox" data-custody-action-id="${escapeHtml(action.id)}" ${done ? 'checked' : ''}>
          <span>
            <span class="custody-action-title">${escapeHtml(action.title)}</span>
            <span class="custody-action-detail">${escapeHtml(action.detail)}</span>
            <span class="custody-action-meta">
              <span class="custody-action-pill">${escapeHtml(action.area)}</span>
              <span class="custody-action-pill">${escapeHtml(action.due)}</span>
            </span>
          </span>
        </label>
      `;
    }).join('');
  }

  function setCustodyActionDone(actionId, done) {
    if (!custodyActions.some(action => action.id === actionId)) return;
    state.dailyActions = normalizeDailyActions(state.dailyActions);
    state.dailyActions[custodyActionDateKey][actionId] = done;
    save();
    renderCustodyActions();
  }

  function resetCustodyActions() {
    state.dailyActions = normalizeDailyActions(state.dailyActions);
    state.dailyActions[custodyActionDateKey] = {};
    save();
    renderCustodyActions();
  }

  function percent(done, total) {
    return total ? Math.round((done / total) * 100) : 0;
  }

  function updateProgress() {
    const done = inputs.filter(input => input.checked).length;
    const total = inputs.length;
    const open = total - done;
    const overall = percent(done, total);
    document.querySelector('[data-count-total]').textContent = total;
    document.querySelector('[data-count-done]').textContent = done;
    document.querySelector('[data-count-open]').textContent = open;
    document.querySelector('[data-progress-label]').textContent = `${overall}% complete`;
    document.querySelector('[data-progress-fill]').style.width = `${overall}%`;

    stages.forEach(stage => {
      const stageInputs = inputs.filter(input => input.dataset.stage === stage);
      const stageDone = stageInputs.filter(input => input.checked).length;
      const stagePercent = percent(stageDone, stageInputs.length);
      const fill = document.querySelector(`[data-stage-fill="${stage}"]`);
      const label = document.querySelector(`[data-stage-label="${stage}"]`);
      const item = document.querySelector(`[data-stage="${stage}"].timeline-item`);
      if (fill) fill.style.width = `${stagePercent}%`;
      if (label) label.textContent = `${stagePercent}% complete, ${stageDone} of ${stageInputs.length} items`;
      if (item) item.classList.toggle('is-complete', stageInputs.length > 0 && stageDone === stageInputs.length);
    });
    renderProjection();
    renderPhaseReadiness();
    renderCourtProjection();
  }

  function todayISO() {
    const today = new Date();
    return toISO(today);
  }

  function toISO(date) {
    const fixed = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
    return fixed.toISOString().slice(0, 10);
  }

  function parseDate(value) {
    if (!value) return null;
    const date = new Date(`${value}T12:00:00`);
    return Number.isNaN(date.getTime()) ? null : date;
  }

  function addDays(date, days) {
    if (!date) return null;
    return new Date(date.getTime() + days * msDay);
  }

  function addWeeks(date, weeks) {
    return addDays(date, weeks * 7);
  }

  function maxDate() {
    const dates = Array.from(arguments).filter(Boolean);
    if (!dates.length) return null;
    return new Date(Math.max.apply(null, dates.map(date => date.getTime())));
  }

  function countValue(name) {
    const input = document.querySelector(`[data-plan-input="${name}"]`);
    const value = input ? Number(input.value) : 0;
    return Number.isFinite(value) ? value : 0;
  }

  function dateValue(name) {
    const input = document.querySelector(`[data-plan-input="${name}"]`);
    return parseDate(input && input.value);
  }

  function formatDate(date) {
    if (!date) return 'Set start dates';
    return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function daysUntil(date) {
    if (!date) return '';
    const today = parseDate(todayISO());
    const days = Math.ceil((date - today) / msDay);
    if (days < 0) return 'ready now';
    if (days === 0) return 'today';
    if (days === 1) return 'tomorrow';
    return `${days} days`;
  }

  function remainingWeekly(startDate, completed, required) {
    if (!startDate) return null;
    const done = Math.min(Math.max(completed, 0), required);
    if (done >= required) return addWeeks(startDate, required - 1);
    return addWeeks(startDate, required - 1);
  }

  function finishWeeklyAfter(gateDate, completed, required) {
    if (!gateDate) return null;
    const done = Math.min(Math.max(completed, 0), required);
    if (done >= required) return gateDate;
    return addWeeks(gateDate, required - done);
  }

  function finishEveryOtherWeekAfter(gateDate, completed, required) {
    if (!gateDate) return null;
    const done = Math.min(Math.max(completed, 0), required);
    if (done >= required) return gateDate;
    return addWeeks(gateDate, (required - done) * 2);
  }

  function buildProjection() {
    const planStart = dateValue('planStart') || parseDate(todayISO());
    const angerStart = dateValue('angerStart') || planStart;
    const familyStart = dateValue('familyStart') || planStart;
    const angerDone = countValue('angerDone');
    const familyDone = countValue('familyDone');

    const anger1 = angerStart;
    const anger4 = remainingWeekly(angerStart, angerDone, 4);
    const anger10 = remainingWeekly(angerStart, angerDone, 10);
    const family4 = remainingWeekly(familyStart, familyDone, 4);
    const family16 = remainingWeekly(familyStart, familyDone, 16);
    const dylanConjointThird = dateValue('dylanConjointThird');
    const dylanConjointDone = countValue('dylanConjointDone');
    const dylanConjointSix = dylanConjointThird ? addWeeks(dylanConjointThird, Math.max(0, 6 - Math.max(dylanConjointDone, 3))) : null;

    const whTwoHourStart = maxDate(anger4, family4);
    const whTwoHourDone = finishWeeklyAfter(whTwoHourStart, countValue('whTwoHourDone'), 6);
    const whSaturdayDone = finishWeeklyAfter(whTwoHourDone, countValue('whSaturdayDone'), 6);
    const whOvernightStart = maxDate(anger10, whSaturdayDone);
    const whOvernightDone = finishWeeklyAfter(whOvernightStart, countValue('whOvernightDone'), 6);
    const whWeekendDone = finishEveryOtherWeekAfter(whOvernightDone, countValue('whWeekendDone'), 6);

    const dylanTwoHourStart = maxDate(dylanConjointSix, family16);
    const dylanTwoHourDone = finishWeeklyAfter(dylanTwoHourStart, countValue('dylanTwoHourDone'), 6);
    const dylanSaturdayDone = finishWeeklyAfter(dylanTwoHourDone, countValue('dylanSaturdayDone'), 6);
    const dylanOvernightDone = finishWeeklyAfter(dylanSaturdayDone, countValue('dylanOvernightDone'), 4);
    const dylanWeekendDone = finishEveryOtherWeekAfter(dylanOvernightDone, countValue('dylanWeekendDone'), 4);

    return {
      wh: [
        { id: 'anger1', title: 'Anger-management class 1 proof', date: anger1, done: angerDone >= 1, detail: 'File proof with the Court and copy Mother.' },
        { id: 'whGate1', title: 'Eligible to begin W/H two-hour visits', date: whTwoHourStart, done: angerDone >= 4 && familyDone >= 4, detail: 'This is the start gate: 4 anger classes and 4 Link Care family sessions must be complete before the six two-hour visits can begin.' },
        { id: 'whTwoHour', title: 'All six W/H two-hour visits completed', date: whTwoHourDone, done: countValue('whTwoHourDone') >= 6, detail: 'This is the end of that phase: enter each completed two-hour visit above until the count reaches 6.' },
        { id: 'whSaturday', title: 'Six Saturday 3pm-7pm visits', date: whSaturdayDone, done: countValue('whSaturdayDone') >= 6, detail: 'Next gate before Saturday overnights.' },
        { id: 'anger10', title: 'Anger-management class 10 proof', date: anger10, done: angerDone >= 10, detail: 'File final proof/certificate with the Court and copy Mother.' },
        { id: 'whOvernight', title: 'Six Saturday overnights', date: whOvernightDone, done: countValue('whOvernightDone') >= 6, detail: 'Saturday 3pm to Sunday 2pm for six consecutive weeks.' },
        { id: 'whWeekend', title: 'Six first/third Friday-Sunday weekends', date: whWeekendDone, done: countValue('whWeekendDone') >= 6, detail: 'After this, expands to Friday-Monday plus Wednesday overnight.' },
        { id: 'whHome', title: 'Broader home schedule begins', date: whWeekendDone, done: countValue('whWeekendDone') >= 6, detail: 'First/third weekends through Monday morning plus every Wednesday overnight.' }
      ],
      dylan: [
        { id: 'dylanConjointThird', title: 'Dylan/Rob Janz conjoint session 3', date: dylanConjointThird, done: dylanConjointDone >= 3, detail: 'Known scheduled session at Janz; keep separate from Link Care family counseling.' },
        { id: 'dylanConjointSix', title: 'Six Dylan/Rob conjoint counseling sessions', date: dylanConjointSix, done: dylanConjointDone >= 6, detail: 'Projected from the known third-session date; confirm exact trigger language with counsel.' },
        { id: 'family16', title: 'Sixteen Link Care family counseling sessions completed', date: family16, done: familyDone >= 16, detail: 'Also triggers co-parenting therapy and both parents’ individual therapy requirements.' },
        { id: 'dylanTwoHour', title: 'Six Dylan two-hour unmonitored visits', date: dylanTwoHourDone, done: countValue('dylanTwoHourDone') >= 6, detail: 'Visits occur before family therapy sessions.' },
        { id: 'dylanSaturday', title: 'Six Dylan Saturday 3pm-7pm visits', date: dylanSaturdayDone, done: countValue('dylanSaturdayDone') >= 6, detail: 'Next gate before Saturday overnights.' },
        { id: 'dylanOvernight', title: 'Four Dylan Saturday overnights', date: dylanOvernightDone, done: countValue('dylanOvernightDone') >= 4, detail: 'Saturday 3pm to Sunday 2pm for four Saturday overnights.' },
        { id: 'dylanWeekend', title: 'Four Dylan first/third Friday-Sunday weekends', date: dylanWeekendDone, done: countValue('dylanWeekendDone') >= 4, detail: 'After this, expands to Friday-Monday plus Wednesday overnight.' },
        { id: 'dylanHome', title: 'Broader Dylan home schedule begins', date: dylanWeekendDone, done: countValue('dylanWeekendDone') >= 4, detail: 'First/third weekends through Monday morning plus every Wednesday overnight.' }
      ]
    };
  }

  function renderPath(name, gates) {
    const target = document.querySelector(`[data-path="${name}"]`);
    if (!target) return;
    const firstOpen = gates.find(gate => !gate.done);
    target.innerHTML = gates.map((gate, index) => {
      const active = firstOpen && firstOpen.id === gate.id;
      const className = gate.done ? 'is-complete' : active ? 'is-active' : 'is-waiting';
      return `
        <article class="timeline-item ${className}">
          <div class="timeline-marker"><span>${gate.done ? '✓' : index + 1}</span></div>
          <div class="timeline-content">
            <h3>${gate.title}</h3>
            <p>${gate.detail}</p>
            <div class="gate-meta">
              <span>${formatDate(gate.date)}</span>
              <span>${gate.done ? 'Done' : daysUntil(gate.date)}</span>
            </div>
          </div>
        </article>
      `;
    }).join('');
  }

  function renderProjection() {
    const projection = buildProjection();
    renderPath('wh', projection.wh);
    renderPath('dylan', projection.dylan);
    const allGates = projection.wh.concat(projection.dylan);
    const next = allGates
      .filter(gate => !gate.done && gate.date)
      .sort((a, b) => a.date - b.date)[0] || allGates.find(gate => !gate.done);
    const whHome = projection.wh[projection.wh.length - 1];
    const dylanHome = projection.dylan[projection.dylan.length - 1];

    const nextTitle = next ? next.title : 'All tracked gates are marked complete.';
    document.querySelector('[data-next-task]').textContent = nextTitle;
    document.querySelector('[data-next-task-detail]').textContent = nextTitle;
    document.querySelector('[data-next-detail]').textContent = next ? `${formatDate(next.date)} (${daysUntil(next.date)}). ${next.detail}` : 'Confirm final proof packet and counsel instructions.';
    document.querySelector('[data-wh-home-date]').textContent = formatDate(whHome.date);
    document.querySelector('[data-wh-home-detail]').textContent = `${daysUntil(whHome.date)} if the sequence runs without delay.`;
    document.querySelector('[data-dylan-home-date]').textContent = formatDate(dylanHome.date);
    document.querySelector('[data-dylan-home-detail]').textContent = `${daysUntil(dylanHome.date)} if the sequence runs without delay.`;
  }

  function missingRequirement(label, done, required) {
    const remaining = Math.max(required - done, 0);
    if (!remaining) return '';
    return `${remaining} more ${label}${remaining === 1 ? '' : 's'}`;
  }

  function gateStatus(requirements, completeAfter) {
    const missing = requirements
      .map(item => missingRequirement(item.label, item.done, item.required))
      .filter(Boolean);
    if (completeAfter && completeAfter()) {
      return { state: 'complete', label: 'Completed', detail: 'This phase is marked complete in the dashboard.' };
    }
    if (!missing.length) {
      return { state: 'ready', label: 'Ready for Amy review', detail: 'Gate requirements entered in the dashboard are met.' };
    }
    return { state: 'blocked', label: 'In progress', detail: `Still needs ${missing.join(' and ')}.` };
  }

  function renderPhaseReadiness() {
    const target = document.querySelector('[data-phase-readiness]');
    if (!target) return;
    const angerDone = countValue('angerDone');
    const familyDone = countValue('familyDone');
    const dylanConjointDone = countValue('dylanConjointDone');
    const whTwoHourDone = countValue('whTwoHourDone');
    const whSaturdayDone = countValue('whSaturdayDone');
    const whOvernightDone = countValue('whOvernightDone');
    const whWeekendDone = countValue('whWeekendDone');
    const dylanTwoHourDone = countValue('dylanTwoHourDone');
    const dylanSaturdayDone = countValue('dylanSaturdayDone');
    const dylanOvernightDone = countValue('dylanOvernightDone');
    const dylanWeekendDone = countValue('dylanWeekendDone');
    const projection = buildProjection();

    const cards = [
      {
        title: 'Phase 1 setup',
        status: gateStatus([
          { label: 'anger-management class', done: angerDone, required: 1 },
          { label: 'Link Care family session', done: familyDone, required: 1 },
          { label: 'Dylan/Rob conjoint session', done: dylanConjointDone, required: 3 }
        ]),
        readyText: 'Core therapy tracks are started: anger management, Link Care family counseling, and Dylan/Rob conjoint counseling.',
        date: 'First proof packet / phase update'
      },
      {
        title: 'Waylon + Harrison: eligible to begin two-hour visits',
        status: gateStatus([
          { label: 'anger-management class', done: angerDone, required: 4 },
          { label: 'family session', done: familyDone, required: 4 }
        ], () => whTwoHourDone >= 6),
        readyText: 'Start gate met: the six two-hour unmonitored visits can begin once Amy confirms the proof and process.',
        date: formatDate(projection.wh.find(gate => gate.id === 'whGate1')?.date)
      },
      {
        title: 'Waylon + Harrison: two-hour visit phase completed',
        status: gateStatus([
          { label: 'two-hour Waylon/Harrison visit', done: whTwoHourDone, required: 6 }
        ], () => whSaturdayDone >= 6),
        readyText: 'All six two-hour visits are entered, so the next Saturday 3 PM to 7 PM phase is ready for review.',
        date: formatDate(projection.wh.find(gate => gate.id === 'whTwoHour')?.date)
      },
      {
        title: 'Waylon + Harrison: overnights',
        status: gateStatus([
          { label: 'anger-management class', done: angerDone, required: 10 },
          { label: 'Saturday Waylon/Harrison visit', done: whSaturdayDone, required: 6 }
        ], () => whOvernightDone >= 6),
        readyText: 'Ten anger classes and six Saturday visits are entered, so Saturday overnights are ready for review.',
        date: formatDate(projection.wh.find(gate => gate.id === 'whOvernight')?.date)
      },
      {
