  async function copyText(text) {
    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(text);
      return;
    }
    const area = document.createElement('textarea');
    area.value = text;
    document.body.appendChild(area);
    area.select();
    document.execCommand('copy');
    area.remove();
  }

  function parseCsv(text) {
    const rows = [];
    let row = [];
    let cell = '';
    let quoted = false;
    for (let index = 0; index < text.length; index += 1) {
      const char = text[index];
      const next = text[index + 1];
      if (char === '"' && quoted && next === '"') {
        cell += '"';
        index += 1;
      } else if (char === '"') {
        quoted = !quoted;
      } else if (char === ',' && !quoted) {
        row.push(cell.trim());
        cell = '';
      } else if ((char === '\n' || char === '\r') && !quoted) {
        if (char === '\r' && next === '\n') index += 1;
        row.push(cell.trim());
        if (row.some(value => value)) rows.push(row);
        row = [];
        cell = '';
      } else {
        cell += char;
      }
    }
    row.push(cell.trim());
    if (row.some(value => value)) rows.push(row);
    return rows;
  }

  function rowsFromCsv(text) {
    const rows = parseCsv(text);
    if (rows.length < 2) return [];
    const headers = rows[0].map(header => header.trim());
    return rows.slice(1).map(row => headers.reduce((record, header, index) => {
      record[header] = row[index] || '';
      return record;
    }, {}));
  }

  function rowsFromJson(parsed) {
    if (Array.isArray(parsed)) return { calls: parsed, summary: {} };
    if (!parsed || typeof parsed !== 'object') return { calls: [], summary: {} };
    const calls = parsed.calls || parsed.records || parsed.rows || parsed.log || parsed.callLog || [];
    const summary = parsed.summary || {
      totalCalls: parsed.totalCalls,
      autodialerCalls: parsed.autodialerCalls || parsed.autodialerAttempts || parsed.callsMade,
      source: parsed.source
    };
    return { calls: Array.isArray(calls) ? calls : [], summary };
  }

  function importCallEvidenceFile(file, text) {
    const trimmed = text.trim();
    if (!trimmed) throw new Error('The selected file is empty.');
    let parsed;
    if (/\.json$/i.test(file.name) || trimmed.startsWith('{') || trimmed.startsWith('[')) {
      parsed = rowsFromJson(JSON.parse(trimmed));
    } else {
      parsed = { calls: rowsFromCsv(trimmed), summary: {} };
    }
    callEvidence = normalizeCallEvidence({
      importedAt: new Date().toISOString(),
      fileName: file.name,
      summary: parsed.summary || {},
      calls: parsed.calls || []
    });
    renderCalls();
    save();
    return callEvidence.calls.length;
  }

  inputs.forEach((input, index) => {
    input.checked = Boolean(state.checks && state.checks[itemKey(input, index)]);
    input.addEventListener('change', save);
  });
  textareas.forEach((textarea, index) => {
    textarea.value = (state.notes && state.notes[noteKey(textarea, index)]) || '';
    textarea.addEventListener('input', save);
  });
  planInputs.forEach(input => {
    const saved = state.plan[input.dataset.planInput];
    if (saved !== undefined) {
      input.value = saved;
    } else if (knownDateDefaults[input.dataset.planInput] !== undefined) {
      input.value = knownDateDefaults[input.dataset.planInput];
    } else if (input.type === 'number') {
      input.value = 0;
    } else if (input.dataset.planInput === 'planStart') {
      input.value = todayISO();
    }
    input.addEventListener('input', save);
    input.addEventListener('change', save);
  });
  document.querySelector('[data-mark-today]').addEventListener('click', () => {
    const today = todayISO();
    ['planStart', 'angerStart', 'familyStart', 'dylanConjointThird'].forEach(name => {
      const input = document.querySelector(`[data-plan-input="${name}"]`);
      if (input && !input.value) input.value = today;
    });
    save();
  });
  document.querySelector('[data-apply-known-dates]')?.addEventListener('click', () => {
    Object.entries(knownDateDefaults).forEach(([name, value]) => {
      const input = document.querySelector(`[data-plan-input="${name}"]`);
      if (input) input.value = value;
    });
    save();
  });
  document.querySelector('[data-reset-plan]').addEventListener('click', () => {
    planInputs.forEach(input => {
      const known = knownDateDefaults[input.dataset.planInput];
      input.value = known !== undefined ? known : input.type === 'number' ? 0 : '';
    });
    save();
  });
  document.querySelector('[data-add-call]')?.addEventListener('click', () => {
    const call = {};
    callFields.forEach(field => { call[field.dataset.callField] = field.value; });
    if (!call.date) call.date = todayISO();
    if (!call.provider && !call.notes) return;
    callLog.unshift(call);
    callFields.forEach(field => {
      if (field.type !== 'date') field.value = '';
      if (field.dataset.callField === 'date') field.value = todayISO();
    });
    renderCalls();
    save();
  });
  document.querySelector('[data-call-log]')?.addEventListener('click', event => {
    const button = event.target.closest('[data-delete-call]');
    if (!button) return;
    callLog.splice(Number(button.dataset.deleteCall), 1);
    renderCalls();
    save();
  });
  callFields.forEach(field => {
    if (field.dataset.callField === 'date' && !field.value) field.value = todayISO();
  });
  document.querySelector('[data-call-import-file]')?.addEventListener('change', event => {
    const file = event.target.files && event.target.files[0];
    const status = document.querySelector('[data-call-import-status]');
    if (!file) return;
    if (status) status.textContent = 'Reading import...';
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const count = importCallEvidenceFile(file, String(reader.result || ''));
        if (status) status.textContent = `Imported ${count} phone-log rows from ${file.name}.`;
      } catch (error) {
        if (status) status.textContent = `Import failed: ${error.message}`;
      }
    };
    reader.onerror = () => {
      if (status) status.textContent = 'Import failed: the file could not be read.';
    };
    reader.readAsText(file);
  });
  document.querySelector('[data-clear-call-import]')?.addEventListener('click', () => {
    callEvidence = normalizeCallEvidence(null);
    const input = document.querySelector('[data-call-import-file]');
    const status = document.querySelector('[data-call-import-status]');
    if (input) input.value = '';
    if (status) status.textContent = 'Imported phone-log data cleared.';
    renderCalls();
    save();
  });
  document.querySelectorAll('[data-copy-template]').forEach(button => {
    button.addEventListener('click', async () => {
      const template = document.querySelector(`[data-template="${button.dataset.copyTemplate}"]`);
      await copyText(template?.textContent || '');
      const original = button.textContent;
      button.textContent = 'Copied';
      setTimeout(() => { button.textContent = original; }, 1200);
    });
  });
  document.querySelector('[data-export-json]')?.addEventListener('click', downloadSnapshot);
  document.querySelector('[data-download-calendar]')?.addEventListener('click', downloadCalendar);
  document.querySelector('[data-print-page]')?.addEventListener('click', () => window.print());
  document.querySelector('[data-generate-phase-report]')?.addEventListener('click', generatePhaseReport);
  document.querySelector('[data-copy-phase-report]')?.addEventListener('click', async () => {
    await copyText(ensurePhaseReport());
    setPhaseReportStatus('Report copied. Review it in your message before sending.');
  });
  document.querySelector('[data-download-phase-report]')?.addEventListener('click', downloadPhaseReport);
  document.addEventListener('change', event => {
    const target = event.target;
    if (!target || !target.matches('[data-custody-action-id]')) return;
    setCustodyActionDone(target.dataset.custodyActionId, target.checked);
  });
  document.querySelector('[data-reset-custody-actions]')?.addEventListener('click', resetCustodyActions);
  document.querySelector('[data-send-codex]')?.addEventListener('click', async () => {
    const token = document.querySelector('[data-codex-token]').value.trim();
    const message = document.querySelector('[data-codex-message]').value.trim();
    const status = document.querySelector('[data-codex-status]');
    if (!token || !message) {
      status.textContent = 'Enter the admin token and a task first.';
      return;
    }
    status.textContent = 'Sending...';
    try {
      const response = await fetch('/api/agent-instruct', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          agentId: 'Neo',
          token,
          instruction: `${message}\n\nCourt compliance snapshot:\n${JSON.stringify(snapshot(), null, 2)}`
        })
      });
      const data = await response.json();
      status.textContent = response.ok ? `Sent. Instruction ID: ${data.instructionId || 'queued'}` : `Failed: ${data.error || response.status}`;
    } catch (error) {
      status.textContent = `Failed: ${error.message}`;
    }
  });
  renderCalls();
  renderCustodyActions();
  updateProgress();
  loadRemoteState();
  loadNotionCallEvidence();
})();
</script>
