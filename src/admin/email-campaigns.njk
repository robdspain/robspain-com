---
layout: base.njk
title: Email Campaigns - Rob Spain
permalink: /admin/email-campaigns/
---

<div class="admin-dashboard-premium">
    <div class="container">
        <div class="section-header-premium animate-fade-up">
            <div class="section-badge-premium">Marketing</div>
            <h2 class="section-title-premium">
                Email <span class="text-gradient">Campaigns</span>
            </h2>
            <p class="section-description-premium">
                Review, approve, and schedule district outreach emails one by one.
            </p>
        </div>

        <div id="campaigns-container" class="animate-fade-up stagger-1">
            {% for campaign in campaigns %}
            <div class="dashboard-card-premium" style="margin-bottom: 1.5rem; padding: 1.5rem;" data-status="{{ campaign.status | default('draft') }}">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
                    <div style="flex: 1; min-width: 280px;">
                        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                            {% set status = campaign.status | default('draft') %}
                            {% if status == 'draft' %}
                            <span style="background: #fef3c7; color: #92400e; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600;">DRAFT</span>
                            {% elif status == 'approved' %}
                            <span style="background: #d1fae5; color: #065f46; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600;">APPROVED</span>
                            {% elif status == 'scheduled' %}
                            <span style="background: #dbeafe; color: #1e40af; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600;">SCHEDULED</span>
                            {% elif status == 'sent' %}
                            <span style="background: #e0e7ff; color: #3730a3; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600;">SENT</span>
                            {% endif %}
                            {% if campaign.scheduledDate %}
                            <span style="color: #64748b; font-size: 0.8rem;">{{ campaign.scheduledDate }}</span>
                            {% endif %}
                        </div>
                        <h3 style="font-size: 1.25rem; font-weight: 700; color: #1e293b; margin: 0 0 0.5rem 0;">{{ campaign.subject }}</h3>
                        <p style="color: #64748b; font-size: 0.9rem; margin: 0 0 1rem 0;">{{ campaign.previewText }}</p>
                    </div>
                    <div style="display: flex; gap: 0.5rem; flex-shrink: 0;">
                        <button onclick="toggleBody('{{ campaign.id }}')" style="padding: 0.5rem 1rem; background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; border-radius: 0.5rem; cursor: pointer; font-size: 0.85rem;">Preview</button>
                    </div>
                </div>
                <div id="body-{{ campaign.id }}" style="display: none; margin-top: 1rem; padding: 1rem; background: #f8fafc; border-radius: 0.5rem; border: 1px solid #e2e8f0;">
                    <pre style="white-space: pre-wrap; font-family: inherit; font-size: 0.9rem; color: #334155; margin: 0;">{{ campaign.body }}</pre>
                </div>
            </div>
            {% endfor %}
        </div>

        <div style="margin-top: 2rem; padding: 1.5rem; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 0.75rem;">
            <h3 style="color: #166534; font-size: 1.1rem; font-weight: 600; margin: 0 0 0.5rem 0;">How to use</h3>
            <ul style="color: #15803d; font-size: 0.9rem; margin: 0; padding-left: 1.25rem;">
                <li>Click <strong>Preview</strong> to expand the full email body</li>
                <li>Edit the JSON files in <code>_data/emailCampaigns/</code> to rewrite copy</li>
                <li>Change <code>"status"</code> to <code>"approved"</code>, <code>"scheduled"</code>, or <code>"sent"</code></li>
                <li>Add <code>"scheduledDate": "2026-03-24 7:00 AM PT"</code> to set a send time</li>
                <li>Rebuild + deploy after edits: <code>npx @11ty/eleventy && netlify deploy --prod --dir=_site</code></li>
            </ul>
        </div>
    </div>
</div>

<script>
function toggleBody(id) {
    var el = document.getElementById('body-' + id);
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>
