function renderEnvelopes() {
  const totalIncome = getMonthlyIncomeTotal();
  let remaining = totalIncome;
  const groups = [
    { p: 1, label: 'Priority 1 — Survival', cls: 'p1' },
    { p: 2, label: 'Priority 2 — Insurance & Debt Minimums', cls: 'p2' },
    { p: 3, label: 'Priority 3 — Necessities', cls: 'p3' },
    { p: 4, label: 'Priority 4 — On Credit (adds to debt)', cls: 'p4' },
  ];

  let envelopeHtml = '<h3>April 2026 Envelopes</h3>';
  const groupTotals = [];

  groups.forEach(g => {
    const bills = STATE.bills.filter(b => b.priority === g.p);
    const groupTotal = bills.reduce((s, b) => s + robBillAmount(b), 0);
    const funded = g.p <= 3;
    envelopeHtml += `<div class="env-priority ${g.cls}">${g.label}</div>`;
    bills.forEach(b => {
      const amountDue = robBillAmount(b);
      const supportCredit = getBillSupportCredit(b.id);
      const isFunded = funded && remaining >= amountDue;
      if (funded) remaining -= amountDue;
      envelopeHtml += `<div class="envelope ${g.cls} ${!isFunded && g.p < 4 ? '' : g.p === 4 ? 'unfunded' : ''}">
        <div class="env-row">
          <span class="env-name">${esc(b.name)}</span>
          <span class="env-amt" style="color:${isFunded ? '#22c55e' : '#ef4444'}">${supportCredit ? `${fmt(amountDue)} (${fmt(supportCredit)} covered)` : isFunded ? fmt(amountDue) : fmt(amountDue) + ' unfunded'}</span>
        </div>
        <div class="env-bar"><div class="env-fill" style="width:${isFunded ? 100 : 0}%;background:${isFunded ? '#22c55e' : '#ef4444'};"></div></div>
      </div>`;
    });
    const afterRemaining = funded ? Math.max(0, remaining) : remaining;
    envelopeHtml += `<div style="display:flex;justify-content:space-between;font-size:12px;color:#64748b;margin:8px 0 4px 8px;">
      <span>${g.cls.toUpperCase()} Total: ${fmt(groupTotal)}</span>
      ${g.p < 4 ? `<span style="color:${afterRemaining > 0 ? '#22c55e' : '#ef4444'}">Remaining: ${fmt(afterRemaining)}</span>` : `<span style="color:#ef4444">This adds to debt</span>`}
    </div>`;
    groupTotals.push({ label: g.label, total: groupTotal, cls: g.cls });
  });

  document.getElementById('envelopesCard').innerHTML = envelopeHtml;

  // Summary
  const onCredit = STATE.bills.filter(b => b.priority === 4).reduce((s, b) => s + robBillAmount(b), 0);
  const buffer = Math.max(0, totalIncome - STATE.bills.filter(b => b.priority <= 3).reduce((s, b) => s + robBillAmount(b), 0));
  const p1 = STATE.bills.filter(b => b.priority === 1).reduce((s, b) => s + robBillAmount(b), 0);
  const p2 = STATE.bills.filter(b => b.priority === 2).reduce((s, b) => s + robBillAmount(b), 0);
  const p3 = STATE.bills.filter(b => b.priority === 3).reduce((s, b) => s + robBillAmount(b), 0);

  document.getElementById('envelopeSummaryCard').innerHTML = `
    <h3>Envelope Summary</h3>
    <div style="margin-bottom:24px;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
        <span style="font-size:14px;">Monthly Income</span>
        <span style="font-size:20px;font-weight:700;color:#22c55e;">${fmt(totalIncome)}</span>
      </div>
      <div class="fin-bar-bg" style="height:24px;border-radius:6px;">
        <div style="height:100%;display:flex;border-radius:6px;overflow:hidden;">
          <div style="width:${p1/totalIncome*100}%;background:#ef4444;" title="P1: ${fmt(p1)}"></div>
          <div style="width:${p2/totalIncome*100}%;background:#eab308;" title="P2: ${fmt(p2)}"></div>
          <div style="width:${p3/totalIncome*100}%;background:#3b82f6;" title="P3: ${fmt(p3)}"></div>
          <div style="width:${buffer/totalIncome*100}%;background:#22c55e;" title="Buffer: ${fmt(buffer)}"></div>
        </div>
      </div>
      <div style="display:flex;gap:12px;margin-top:8px;flex-wrap:wrap;font-size:11px;">
        <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#ef4444;margin-right:4px;"></span>P1 ${fmt(p1)}</span>
        <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#eab308;margin-right:4px;"></span>P2 ${fmt(p2)}</span>
        <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#3b82f6;margin-right:4px;"></span>P3 ${fmt(p3)}</span>
        <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#22c55e;margin-right:4px;"></span>Buffer ${fmt(buffer)}</span>
      </div>
    </div>
    ${onCredit > 0 ? `
    <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:8px;padding:16px;margin-bottom:16px;">
      <div style="font-size:13px;font-weight:600;color:#ef4444;margin-bottom:8px;">THE HIDDEN COST</div>
      <div style="font-size:13px;color:#1e293b;line-height:1.6;">
        ${fmt(buffer)} looks like a buffer, but <strong>${fmt(onCredit)}/mo goes on Apple Card</strong> — that's new debt every month. The real deficit is:<br>
        <span style="font-size:20px;font-weight:700;color:#ef4444;display:block;margin-top:8px;">-${fmt(onCredit - buffer)}/mo net new debt</span>
        <span style="font-size:12px;color:#64748b;">Plus interest compounding on the balance</span>
      </div>
    </div>` : ''}
    <div style="border-top:1px solid #e2e8f0;padding-top:16px;">
      <h3>How Envelope Budgeting Helps</h3>
      <ul style="font-size:13px;color:#64748b;line-height:1.8;padding-left:16px;">
        <li>P1-P3 are <strong>fully funded</strong> from checking — these get paid first</li>
        <li>P4 items go on credit — they're <strong>visible as unfunded</strong></li>
        <li>Supporting Hands is now treated as checking-funded, not Apple Card debt</li>
        <li>The buffer covers irregular expenses and prevents new LOC draws</li>
      </ul>
    </div>
  `;
}

function renderCalendar() {
