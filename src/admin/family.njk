function normalizeStatements(existing, sourceKey) {
  const byMonth = new Map((existing || []).map(item => [item.month, item]));
  const expected = [];
  const start = new Date(2025, 0, 1); // January 2025
  const today = new Date();
  const end = new Date(today.getFullYear(), today.getMonth() - 1, 1);
  for (let cursor = new Date(start); cursor <= end; cursor.setMonth(cursor.getMonth() + 1)) {
    const month = cursor.toISOString().slice(0, 7);
    const saved = byMonth.get(month) || {};
    const historical = sourceKey === 'appleCard' && month <= '2026-03';
    expected.push({
      month,
      status: saved.status || (historical ? 'imported' : 'missing'),
      fileName: saved.fileName || '',
      driveUrl: saved.driveUrl || '',
      updatedAt: saved.updatedAt || '',
      notes: saved.notes || (historical ? 'Included in original historical Apple Card dataset.' : '')
    });
  }
  return expected.sort((a, b) => b.month.localeCompare(a.month));
}

function applyEecuDriveSnapshot(showMessage, targetState) {
  const state = targetState || STATE;
  state.statementFolders = state.statementFolders || {};
  state.statements = state.statements || {};
  state.statementFolders.eecu = state.statementFolders.eecu || EECU_DRIVE_FOLDER_URL;
  state.statements.eecu = normalizeStatements(state.statements.eecu || [], 'eecu');

  EECU_DRIVE_FILES.forEach(file => {
    let item = state.statements.eecu.find(statement => statement.month === file.month);
    if (!item) {
      item = { month: file.month, status: 'missing', fileName: '', driveUrl: '', updatedAt: '', notes: '' };
      state.statements.eecu.push(item);
    }
    const hasPdf = item.status === 'uploaded' || item.status === 'imported';
    if (!hasPdf) item.status = file.status;
    item.fileName = item.fileName || file.title;
    item.driveUrl = item.driveUrl || file.url;
    item.notes = hasPdf ? item.notes : file.notes;
    item.updatedAt = item.updatedAt || new Date().toISOString();
  });

  state.statements.eecu = normalizeStatements(state.statements.eecu, 'eecu');
  if (!targetState) {
    saveState(state);
    renderAll();
  }
  if (showMessage) showToast(`Imported ${EECU_DRIVE_FILES.length} EECU Drive records`);
}

