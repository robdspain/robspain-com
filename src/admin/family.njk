      <span style="font-size:11px;font-weight:700;color:${readyColor};text-transform:uppercase;">${readiness.ready ? 'ready' : 'needs review'}</span>
    </div>
    <div style="font-size:12px;color:#64748b;margin-top:5px;line-height:1.45;">${readiness.rowCount} rows · ${fmtCents(readiness.income)} income · ${fmtCents(readiness.expenses)} expenses · ${fmtCents(readiness.net)} net · ${readiness.frappePendingCount} Frappe pending</div>
    <div style="font-size:11px;margin-top:5px;">${blockers}</div>
  </div>`;
}

function accountingCloseReadiness(rows) {
  const allRows = Array.isArray(rows) ? rows : [];
  const period = latestAccountingPeriod(allRows);
  const periodRows = allRows.filter(row => String(row.date || '').startsWith(period));
  const summary = summarizeCpaRows(periodRows);
  const frappePendingCount = periodRows.filter(row => isFrappeExportable(row) && !row.frappeJournalEntry && !row.frappeSyncedAt).length;
  const sourceMissingCount = periodRows.filter(row => !row.sourceFile).length;
  const blockers = [];
  if (!periodRows.length) blockers.push('no rows in period');
  if (summary.needsReviewCount) blockers.push(summary.needsReviewCount + ' review exception' + (summary.needsReviewCount === 1 ? '' : 's'));
  if (summary.balanceMismatchCount) blockers.push(summary.balanceMismatchCount + ' balance mismatch' + (summary.balanceMismatchCount === 1 ? '' : 'es'));
  if (summary.ocrNeededCount) blockers.push(summary.ocrNeededCount + ' OCR/document item' + (summary.ocrNeededCount === 1 ? '' : 's'));
  if (sourceMissingCount) blockers.push(sourceMissingCount + ' missing source file' + (sourceMissingCount === 1 ? '' : 's'));
  if (frappePendingCount) blockers.push(frappePendingCount + ' Frappe export pending');
  const income = periodRows.filter(row => Number(row.amount) > 0).reduce((sum, row) => sum + Number(row.amount), 0);
  const expenses = periodRows.filter(row => Number(row.amount) < 0).reduce((sum, row) => sum + Math.abs(Number(row.amount)), 0);
  return {
    period,
    periodLabel: period,
    rowCount: periodRows.length,
    income,
    expenses,
    net: income - expenses,
    frappePendingCount,
    sourceMissingCount,
    blockers,
    ready: periodRows.length > 0 && blockers.length === 0,
  };
}

function latestAccountingPeriod(rows) {
  const periods = (Array.isArray(rows) ? rows : [])
    .map(row => String(row.date || '').match(/^(\d{4}-\d{2})/)?.[1])
    .filter(Boolean)
    .sort();
  return periods[periods.length - 1] || todayStamp().slice(0, 7);
}

function renderAccountingReviewQueue() {
  const el = document.getElementById('accountingReviewQueue');
  if (!el) return;
  const queue = [...STATE.accounting.reviewQueue].sort((a, b) => (b.date || '').localeCompare(a.date || ''));
  if (!queue.length) {
    el.innerHTML = `<div style="padding:18px 0;color:#64748b;font-size:13px;">No transactions yet. Import a statement or seed from the existing finance data.</div>`;
    return;
  }
  el.innerHTML = `
    <div class="review-row header">
      <span>Date</span><span>Description</span><span>Amount</span><span class="mobile-hide">Category</span><span class="mobile-hide">Entity</span><span class="mobile-hide">Frappe Account</span><span class="mobile-hide">Review</span>
    </div>
    ${queue.map(t => accountingReviewRow(t)).join('')}
  `;
}

function accountingReviewRow(t) {
  const categories = [...new Set(ACCOUNTING_CATEGORY_RULES.map(r => r.category).concat(['Uncategorized', 'Personal / exclude', 'Transfer or debt payment', 'Document needs OCR']))];
  const entities = Object.entries(ACCOUNTING_ENTITIES);
  const amountClass = t.amount >= 0 ? 'income' : 'expense';
  return `<div class="review-row" data-txn-id="${esc(t.id)}">
    <input type="date" value="${esc(t.date || '')}" onchange="updateAccountingTxn('${t.id}', 'date', this.value)">
    <span class="desc" title="${esc(t.description)}">${esc(t.description)}</span>
    <span class="amount ${amountClass}">${fmtCents(t.amount)}</span>
    <select class="mobile-hide" onchange="updateAccountingTxn('${t.id}', 'category', this.value)">
      ${categories.map(c => `<option value="${esc(c)}" ${c === t.category ? 'selected' : ''}>${esc(c)}</option>`).join('')}
    </select>
    <select class="mobile-hide" onchange="updateAccountingTxn('${t.id}', 'entity', this.value)">
      ${entities.map(([key, val]) => `<option value="${key}" ${key === t.entity ? 'selected' : ''}>${esc(val.label)}</option>`).join('')}
    </select>
    <input class="mobile-hide" list="frappeAccountOptions" value="${esc(t.frappeAccount || '')}" onchange="updateAccountingTxn('${t.id}', 'frappeAccount', this.value)" placeholder="Frappe account">
    <span class="mobile-hide" style="display:flex;gap:6px;">
      <button class="${t.approved ? 'btn-pay' : 'btn-edit'} btn-sm" onclick="toggleAccountingApproval('${t.id}')">${t.approved ? 'Approved' : 'Review'}</button>
      <button class="btn-edit btn-sm" onclick="createVendorRuleFromTransaction('${t.id}')" title="Create a reusable vendor rule">Rule</button>
    </span>
  </div>
  <div style="font-size:11px;color:#64748b;margin:-4px 0 8px 94px;">
    ${esc(t.taxCategory || 'Unmapped')} · ${Math.round((t.confidence || 0) * 100)}% confidence · payee ${esc(t.payee || partyForTransaction(t))}${t.automationRuleName ? ' · rule ' + esc(t.automationRuleName) : ''} · ${esc(t.sourceAccount || 'Unknown source')}${t.importProfile ? ' · ' + esc(t.importProfile) : ''}${t.balanceCheck ? ' · balance ' + esc(t.balanceCheck) : ''}${t.reconciliationStatus ? ' · reconcile ' + esc(t.reconciliationStatus) + (t.reconciliationName ? ': ' + esc(t.reconciliationName) : '') : ''}${t.frappeJournalEntry ? ' · Frappe ' + esc(t.frappeJournalEntry) : ''}
  </div>`;
}

function setAccountingEntity(entity) {
  ensureAccountingState();
  STATE.accounting.activeEntity = entity;
  document.getElementById('statementEntity').value = entity;
  saveState(STATE);
  renderAccountingHub();
}

function setDefaultFrappeAccount(account) {
  ensureAccountingState();
  STATE.accounting.defaultFrappeAccount = account;
  saveState(STATE);
  showToast('Default Frappe Books account set to ' + account);
}

function updateFrappeSetting(field, value) {
  ensureAccountingState();
  if (!Object.prototype.hasOwnProperty.call(defaultFrappeSettings(), field)) return;
  const previous = STATE.accounting.frappeSettings[field];
  STATE.accounting.frappeSettings[field] = String(value || '').trim();
  if (field === 'defaultRevenueAccount') {
    updateDefaultMappedAccounts('Sales', previous || 'Sales', STATE.accounting.frappeSettings[field] || 'Sales');
    remapFrappeAccountsForCategory('Sales');
  }
  if (field === 'defaultExpenseAccount') {
    updateDefaultMappedAccounts('Uncategorized', previous || 'Expenses', STATE.accounting.frappeSettings[field] || 'Expenses');
    remapFrappeAccountsForCategory('Uncategorized');
  }
  saveState(STATE);
  renderFrappeAccountMap();
  renderFrappeAccountOptions();
}

function updateDefaultMappedAccounts(category, previousValue, nextValue) {
  const map = STATE.accounting.frappeSettings.categoryAccountMap || {};
  if (!map[category] || map[category] === previousValue || map[category] === defaultCategoryAccountMap()[category]) {
    map[category] = nextValue;
  }
  STATE.accounting.frappeSettings.categoryAccountMap = map;
}

function renderFrappeAccountMap() {
  const el = document.getElementById('frappeAccountMap');
  if (!el) return;
  const map = accountingCategoryAccountMap();
  const categories = [...new Set(ACCOUNTING_CATEGORY_RULES.map(rule => rule.category).concat(['Uncategorized', 'Personal / exclude']))];
  el.innerHTML = categories.map(category => `
    <div class="account-map-row">
      <span>${esc(category)}</span>
      <input list="frappeAccountOptions" value="${esc(map[category] || '')}" onchange="updateFrappeAccountMapping(${jsArg(category)}, this.value)" placeholder="Frappe account">
    </div>
  `).join('');
}

function renderFrappeAccountOptions() {
  const el = document.getElementById('frappeAccountOptions');
  if (!el) return;
  const settings = STATE.accounting.frappeSettings || defaultFrappeSettings();
  const accounts = [
    settings.defaultBankAccount,
    settings.defaultRevenueAccount,
    settings.defaultExpenseAccount,
    STATE.accounting.defaultFrappeAccount,
    ...Object.values(accountingCategoryAccountMap()),
    ...STATE.accounting.reviewQueue.map(row => row.frappeAccount),
  ].map(value => String(value || '').trim()).filter(Boolean);
  el.innerHTML = [...new Set(accounts)].sort().map(account => `<option value="${esc(account)}"></option>`).join('');
