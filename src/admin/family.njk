function isChecklistStale(item) {
  if (!item.lastDone) return true;
  const age = daysSince(item.lastDone);
  const limit = item.cadence === 'weekly' ? 7 : item.cadence === 'monthly' ? 35 : 14;
  return age > limit;
}

function isAccountSyncStale(item) {
  if (!item.lastRefreshed) return true;
  const age = daysSince(item.lastRefreshed);
  const limit = item.cadence === 'weekly' ? 7 : item.cadence === 'monthly' ? 35 : 14;
  return age > limit;
}

function daysSince(dateString) {
  if (!dateString) return 9999;
  const last = new Date(dateString + 'T00:00:00');
  const today = new Date();
  return Math.floor((new Date(today.getFullYear(), today.getMonth(), today.getDate()) - last) / 86400000);
}

function currentMonthKey() {
  return new Date().toISOString().slice(0, 7);
}

function normalizeBillRolloverRules(bills) {
  (bills || []).forEach(bill => {
    const rule = Object.assign({}, DEFAULT_BILL_RULE, BILL_ROLLOVER_RULES[bill.id] || {});
    if (!bill.recurrence) bill.recurrence = rule.recurrence;
    if (!bill.rolloverStatus) bill.rolloverStatus = rule.rolloverStatus;
    if (bill.variable === undefined) bill.variable = rule.variable;
  });
}

function renderCreditReadiness() {
  const target = document.getElementById('creditReadiness');
  const debtTarget = document.getElementById('creditDebtPlan');
  if (!target || !debtTarget) return;
  const cash = getCashAvailable();
  const plan = STATE.creditPlan || {};
  const cardDebt = STATE.accounts
    .filter(account => account.type === 'credit')
    .reduce((sum, account) => sum + Math.abs(Number(account.balance || 0)), 0);
  const totalDebt = STATE.accounts
    .filter(account => account.balance < 0)
    .reduce((sum, account) => sum + Math.abs(Number(account.balance || 0)), 0);
  const overdue = STATE.bills.filter(bill => bill.status === 'overdue').length;
  const unpaidCredit = STATE.bills.filter(bill => bill.priority <= 2 && bill.status !== 'paid' && bill.status !== 'current').length;
  const reserveScore = Math.min(100, Math.round(cash / Number(plan.targetReserve || 1000) * 100));
  const paymentScore = overdue ? 25 : unpaidCredit ? 70 : 100;
  const utilizationScore = cardDebt <= 5000 ? 80 : cardDebt <= 10000 ? 55 : 30;
  const readiness = Math.round((reserveScore * 0.25) + (paymentScore * 0.45) + (utilizationScore * 0.30));
  const currentScore = Number(plan.currentScore || 0);
  const goalScore = Number(plan.goalScore || 700);
  const scoreGap = Math.max(0, goalScore - currentScore);
  const scoreChange = Number(plan.scoreChange || 0);
  const scoreColor = currentScore >= 740 ? '#1f4d3f' : currentScore >= 700 ? '#3f6f54' : currentScore >= 660 ? '#d97706' : '#b91c1c';
  const scoreDate = plan.scoreDate ? fmtDate(plan.scoreDate) : 'Not refreshed';
  const factors = Array.isArray(plan.factors) ? plan.factors : [];
  const actions = Array.isArray(plan.actions) ? plan.actions : [];
  target.innerHTML = `
    <div style="display:grid;gap:14px;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;">
        <div class="fin-metric">
          <span>FICO score</span>
          <strong style="color:${scoreColor};">${currentScore || 'Set'}</strong>
          <small>${esc(plan.scoreBand || 'Unknown')} via ${esc(plan.scoreSource || 'Credit guide')}</small>
        </div>
        <div class="fin-metric">
          <span>Latest move</span>
          <strong style="color:${scoreChange >= 0 ? '#1f4d3f' : '#b91c1c'};">${scoreChange >= 0 ? '+' : ''}${scoreChange}</strong>
          <small>Refreshed ${esc(scoreDate)}</small>
        </div>
        <div class="fin-metric">
          <span>Home target</span>
          <strong>${goalScore}+</strong>
          <small>${scoreGap ? `${scoreGap} points to first target` : 'At or above first target'}</small>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:baseline;"><span class="fin-sub">Readiness score</span><strong style="font-size:32px;color:${readiness >= 75 ? '#1f4d3f' : readiness >= 50 ? '#d97706' : '#b91c1c'};">${readiness}/100</strong></div>
      <div class="ops-meter"><span style="width:${readiness}%;background:${readiness >= 75 ? '#1f4d3f' : readiness >= 50 ? '#d97706' : '#b91c1c'};"></span></div>
      <div class="ops-decision ${currentScore >= goalScore ? 'success' : 'warn'}">
        Credit score plan: keep every required payment current first, then use extra cash to lower Apple/Discover utilization before taking on new credit or mortgage inquiries.
      </div>
      <div class="advisor-item ${overdue ? 'critical' : ''}">
        <div class="advisor-rank">1</div><div><div class="advisor-title">No missed payments</div><div class="advisor-note">${overdue ? `${overdue} overdue bill(s) still listed.` : 'No overdue bills are currently listed.'}</div></div><div class="advisor-amount">${paymentScore}/100</div>
      </div>
      <div class="advisor-item ${cash < Number(plan.targetReserve || 1000) ? 'warn' : ''}">
        <div class="advisor-rank">2</div><div><div class="advisor-title">Cash reserve</div><div class="advisor-note">Target reserve is ${fmt(Number(plan.targetReserve || 1000))}; current cash is ${fmt(cash)}.</div></div><div class="advisor-amount">${reserveScore}/100</div>
      </div>
      <div class="advisor-item warn">
        <div class="advisor-rank">3</div><div><div class="advisor-title">Revolving debt</div><div class="advisor-note">Credit-card balances listed total ${fmt(cardDebt)}. Utilization needs exact credit limits from Apple/Discover imports.</div></div><div class="advisor-amount">${utilizationScore}/100</div>
      </div>
      <div style="font-size:13px;color:#526158;line-height:1.6;">
        <strong>Factors to monitor:</strong>
        <ul style="margin:8px 0 0 18px;padding:0;">
          ${factors.map(factor => `<li>${esc(factor)}</li>`).join('')}
        </ul>
      </div>
      <div class="advisor-controls">
        <button onclick="editCreditScorePlan('currentScore','Current FICO score')">Score</button>
        <button onclick="editCreditScorePlan('goalScore','Goal score')">Goal</button>
        <button onclick="editCreditPlan('targetReserve','Target cash reserve')">Reserve Target</button>
        <button onclick="activatePanel('statements')">Fix Statements</button>
      </div>
    </div>
  `;

  const debts = buildDebtPlan();
  debtTarget.innerHTML = `
    <div class="ops-decision danger">
      Credit-improvement order: never miss minimums, stop new personal-card business charges, lower Apple/Discover utilization, then build cash reserves for underwriting.
    </div>
    <div style="margin-top:14px;" class="advisor-list">
      ${debts.map((debt, index) => `
        <div class="advisor-item ${index === 0 ? 'critical' : index === 1 ? 'warn' : ''}">
          <div class="advisor-rank">${index + 1}</div>
          <div>
            <div class="advisor-title">${esc(debt.name)}</div>
            <div class="advisor-note">${esc(debt.reason)}</div>
          </div>
          <div class="advisor-amount">${fmt(debt.balance)}</div>
        </div>
      `).join('')}
    </div>
    <div style="margin-top:14px;font-size:13px;color:#526158;line-height:1.6;">
      Listed total debt: <strong>${fmt(totalDebt)}</strong>. Before shopping for a house, this dashboard should show no overdue bills, current statements for all accounts, and a repeatable monthly surplus or documented household contribution.
    </div>
    <div style="margin-top:14px;font-size:13px;color:#526158;line-height:1.6;">
      <strong>Monthly score actions:</strong>
      <ul style="margin:8px 0 0 18px;padding:0;">
        ${actions.map(action => `<li>${esc(action)}</li>`).join('')}
      </ul>
    </div>
  `;
}

