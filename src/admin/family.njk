async function postSourceImport(payload, label) {
  const settings = STATE.accounting.frappeSettings || defaultFrappeSettings();
  sourceImportStatus('Normalizing ' + label + '...', '#64748b');
  const res = await fetch(ACCOUNTING_SOURCE_IMPORT_URL, {
    method: 'POST',
    headers: accountingAuthHeaders(),
    body: JSON.stringify({
      ...payload,
      defaultRevenueAccount: settings.defaultRevenueAccount || 'Sales',
      defaultExpenseAccount: settings.defaultExpenseAccount || STATE.accounting.defaultFrappeAccount || 'Expenses',
      categoryAccountMap: accountingCategoryAccountMap(),
    }),
  });
  await handleSourceImportResponse(res, label);
}

async function handleSourceImportResponse(res, label) {
  const payload = await res.json().catch(() => ({}));
  if (!res.ok) throw new Error(payload.error || 'HTTP ' + res.status);

  if (payload.accounting) {
    mergeAccountingState(payload.accounting);
  } else if (Array.isArray(payload.rows)) {
    mergeSourceRowsLocally(payload.rows);
  }

  renderAccountingHub();
  const inserted = payload.inserted ?? payload.rows?.length ?? 0;
  const skipped = payload.skipped ?? 0;
  const persistence = payload.persisted ? 'saved to admin store' : 'merged locally';
  const warnings = Array.isArray(payload.meta?.errors) && payload.meta.errors.length
    ? ' Setup needed: ' + payload.meta.errors.map(error => error.source + ' - ' + error.error).join('; ')
    : '';
  if (payload.importRun && !payload.accounting) {
    recordAccountingImportRun(payload.importRun);
  } else if (!payload.accounting) {
    recordAccountingImportRun({
      source: label,
      sourceFile: payload.meta?.sourceFile || payload.meta?.source || label,
      status: warnings ? 'partial' : 'success',
      inserted,
      skipped,
      rowCount: payload.rows?.length || 0,
      persisted: Boolean(payload.persisted),
      fingerprint: payload.meta?.sourceFingerprint || '',
      errors: payload.meta?.errors || [],
    });
  }
  renderAccountingImportRuns();
  sourceImportStatus(`${label}: ${inserted} imported, ${skipped} skipped, ${persistence}.${warnings}`, warnings ? '#d97706' : (payload.persisted ? '#0f766e' : '#d97706'));
  if (!payload.persisted) scheduleAccountingSync();
}

function mergeSourceRowsLocally(rows) {
  ensureAccountingState();
  const before = STATE.accounting.reviewQueue.length;
  const byKey = new Map(STATE.accounting.reviewQueue.map(row => [row.importKey || row.id || [row.date, row.description, row.amount].join('|'), row]));
  const sourceFile = rows.find(row => row.sourceFile)?.sourceFile || 'source-import';
  const sourceFingerprint = rows.find(row => row.sourceFingerprint)?.sourceFingerprint || sourceFingerprintForRows(sourceFile, rows);
  rows.forEach(row => {
    const normalized = normalizeAccountingRow({ ...row, sourceFingerprint }, row.sourceFile || sourceFile, byKey.size);
    if (!normalized) return;
    const key = normalized.importKey || normalized.id;
    if (!byKey.has(key)) byKey.set(key, normalized);
  });
  STATE.accounting.reviewQueue = [...byKey.values()];
  STATE.accounting.importedFiles.push({
    name: sourceFile,
    importedAt: new Date().toISOString(),
    count: STATE.accounting.reviewQueue.length - before,
    fingerprint: sourceFingerprint,
  });
  localStorage.setItem(STORE_KEY, JSON.stringify(STATE));
}

