  .fin-badge.paid { background: #d1fae5; color: #065f46; }
  .fin-badge.review { background: #ffedd5; color: #9a3412; }
  .fin-badge.archived { background: #e5e7eb; color: #374151; }
  
  .sync-bar { display: none; background: #ecf4ef; border: 1px solid #d9d1c4; border-radius: 12px; padding: 10px 16px; margin-bottom: 16px; font-size: 13px; color: #123628; align-items: center; justify-content: space-between; }
  .sync-bar.visible { display: flex; }
