function editContributionTarget() {
  const totalIncome = STATE.income.reduce((s, i) => s + Number(i.amount || 0), 0);
  const totalBills = STATE.bills.reduce((s, b) => s + Number(b.amount || 0), 0);
  const suggested = Math.max(0, totalBills - totalIncome);
  const current = Number(STATE.householdPlan?.contributionTarget || suggested);
  const val = prompt('Monthly household contribution target to close the budget gap:', current);
  if (val === null) return;
  const num = parseFloat(val);
  if (isNaN(num) || num < 0) return;
  STATE.householdPlan.contributionTarget = num;
  saveState(STATE);
  renderAll();
  showToast('Contribution target set to ' + fmt(num) + '/mo');
}

function saveImportedTransactions(fileName, source, txns) {
  const importedAt = new Date().toISOString();
  const normalized = txns.map(txn => ({
    id: `txn_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
    fileName,
    source,
    importedAt,
    date: txn.date || '',
    desc: txn.desc || '',
    amount: Number(txn.amount || 0)
  }));
  const existingKeys = new Set((STATE.transactions || []).map(txn => `${txn.fileName}|${txn.date}|${txn.desc}|${txn.amount}`));
  const fresh = normalized.filter(txn => !existingKeys.has(`${txn.fileName}|${txn.date}|${txn.desc}|${txn.amount}`));
  STATE.transactions = [...fresh, ...(STATE.transactions || [])].slice(0, 2500);
  if (fresh.length) saveState(STATE);
  return fresh.length;
}

