  .toast-msg { position: fixed; bottom: 20px; right: 20px; background: #1f4d3f; color: #fff; padding: 12px 20px; border-radius: 12px; font-size: 13px; font-weight: 700; opacity: 0; transition: opacity 0.3s; z-index: 100; }
