function mergeAccountingState(remote) {
  if (!remote || !Array.isArray(remote.reviewQueue)) return false;
  ensureAccountingState();

  const before = STATE.accounting.reviewQueue.length;
  const byKey = new Map();
  [...remote.reviewQueue, ...STATE.accounting.reviewQueue].forEach(row => {
    const key = row.importKey || row.id || [row.date, row.description, row.amount].join('|');
    const existing = byKey.get(key);
    if (!existing) {
      byKey.set(key, row);
      return;
    }
    const existingUpdated = Date.parse(existing.updatedAt || existing.importedAt || 0) || 0;
    const rowUpdated = Date.parse(row.updatedAt || row.importedAt || 0) || 0;
    byKey.set(key, rowUpdated >= existingUpdated ? row : existing);
  });

  STATE.accounting.reviewQueue = [...byKey.values()];
  STATE.accounting.importedFiles = mergeImportedFiles(remote.importedFiles || [], STATE.accounting.importedFiles || []);
  STATE.accounting.importRuns = mergeImportRuns(remote.importRuns || [], STATE.accounting.importRuns || []);
  STATE.accounting.frappeRuns = mergeFrappeRuns(remote.frappeRuns || [], STATE.accounting.frappeRuns || []);
  STATE.accounting.vendorRules = mergeVendorRules(remote.vendorRules || [], STATE.accounting.vendorRules || []);
  STATE.accounting.cpaNotes = STATE.accounting.cpaNotes || remote.cpaNotes || defaultState().accounting.cpaNotes;
  STATE.accounting.activeEntity = STATE.accounting.activeEntity || remote.activeEntity || 'behavior-school';
  STATE.accounting.defaultFrappeAccount = STATE.accounting.defaultFrappeAccount || remote.defaultFrappeAccount || 'Expenses';
  STATE.accounting.frappeSettings = {
    ...defaultFrappeSettings(),
    ...(remote.frappeSettings || {}),
    ...(STATE.accounting.frappeSettings || {}),
    categoryAccountMap: {
      ...defaultCategoryAccountMap(remote.frappeSettings || {}),
      ...(remote.frappeSettings?.categoryAccountMap || {}),
      ...(STATE.accounting.frappeSettings?.categoryAccountMap || {}),
    },
  };
  STATE.accounting.lastSyncedAt = remote.lastSyncedAt || STATE.accounting.lastSyncedAt || null;

  const changed = STATE.accounting.reviewQueue.length !== before || (remote.importedFiles || []).length > 0 || (remote.importRuns || []).length > 0 || (remote.frappeRuns || []).length > 0;
  localStorage.setItem(STORE_KEY, JSON.stringify(STATE));
  return changed;
}

function mergeImportedFiles(remoteFiles, localFiles) {
  const byKey = new Map();
  [...remoteFiles, ...localFiles].forEach(file => {
    if (!file || !file.name) return;
    const key = file.fingerprint || [file.name, file.importedAt || '', file.count || 0].join('|');
    byKey.set(key, file);
  });
  return [...byKey.values()].sort((a, b) => String(b.importedAt || '').localeCompare(String(a.importedAt || '')));
}

function mergeImportRuns(remoteRuns, localRuns) {
  const byKey = new Map();
  [...remoteRuns, ...localRuns].forEach(run => {
    if (!run) return;
    const key = run.id || [run.startedAt || run.finishedAt || '', run.source || '', run.fingerprint || ''].join('|');
    if (!key.trim()) return;
    byKey.set(key, run);
  });
  return [...byKey.values()]
    .sort((a, b) => String(b.startedAt || b.finishedAt || '').localeCompare(String(a.startedAt || a.finishedAt || '')))
    .slice(0, 100);
}

function mergeFrappeRuns(remoteRuns, localRuns) {
  const byKey = new Map();
  [...remoteRuns, ...localRuns].forEach(run => {
    if (!run) return;
    const key = run.id || [run.startedAt || run.finishedAt || '', run.mode || '', run.rowCount || 0].join('|');
    if (!key.trim()) return;
    byKey.set(key, run);
  });
  return [...byKey.values()]
    .sort((a, b) => String(b.startedAt || b.finishedAt || '').localeCompare(String(a.startedAt || a.finishedAt || '')))
    .slice(0, 100);
}

function mergeVendorRules(remoteRules, localRules) {
  const byKey = new Map();
  [...remoteRules, ...localRules].forEach(rule => {
    if (!rule) return;
    const key = rule.id || String(rule.match || rule.payee || '').toLowerCase();
    if (!key.trim()) return;
    byKey.set(key, {
      id: rule.id || 'rule_' + simpleFingerprint(key).slice(4),
      match: String(rule.match || rule.payee || '').trim(),
      payee: String(rule.payee || rule.match || '').trim(),
      entity: rule.entity || 'behavior-school',
      category: rule.category || 'Uncategorized',
      taxCategory: rule.taxCategory || 'Needs CPA review',
      frappeAccount: String(rule.frappeAccount || '').trim(),
      autoApprove: Boolean(rule.autoApprove),
      confidence: Number(rule.confidence || 0.9),
      createdAt: rule.createdAt || new Date().toISOString(),
      updatedAt: rule.updatedAt || rule.createdAt || new Date().toISOString(),
    });
  });
  return [...byKey.values()].sort((a, b) => String(a.payee || a.match).localeCompare(String(b.payee || b.match)));
}

async function loadAccountingFromRemote() {
  ensureAccountingState();
  accountingSyncStatus('loading...', '#64748b');
  try {
    const res = await fetch(ACCOUNTING_SYNC_URL, { headers: { Accept: 'application/json' } });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const remote = await res.json();
    const source = remote.meta?.source || res.headers.get('X-Accounting-Data-Source') || 'unknown';
    const changed = mergeAccountingState(remote);
    if (changed) renderAccountingHub();
    accountingSyncStatus(source === 'netlify-blobs' ? 'loaded from admin store' : 'local fallback', source === 'netlify-blobs' ? '#0f766e' : '#94a3b8');
  } catch (err) {
    accountingSyncStatus('local only (' + err.message + ')', '#dc2626');
  }
}

function scheduleAccountingSync() {
  if (!STATE || !STATE.accounting) return;
  clearTimeout(ACCOUNTING_SYNC_TIMER);
  ACCOUNTING_SYNC_TIMER = setTimeout(syncAccountingToRemote, 900);
}

async function syncAccountingToRemote() {
  if (ACCOUNTING_SYNC_IN_FLIGHT || !STATE.accounting) return;
  ACCOUNTING_SYNC_IN_FLIGHT = true;
  accountingSyncStatus('saving...', '#64748b');
  try {
    const res = await fetch(ACCOUNTING_SYNC_URL, {
      method: 'PUT',
      headers: accountingAuthHeaders(),
      body: JSON.stringify(accountingPayload()),
    });
    const payload = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(payload.error || 'HTTP ' + res.status);
    if (payload.accounting?.lastSyncedAt) {
      STATE.accounting.lastSyncedAt = payload.accounting.lastSyncedAt;
      localStorage.setItem(STORE_KEY, JSON.stringify(STATE));
    }
    accountingSyncStatus(payload.persisted ? 'saved to admin store' : 'saved locally only', payload.persisted ? '#0f766e' : '#d97706');
  } catch (err) {
    accountingSyncStatus('local only (' + err.message + ')', '#dc2626');
  } finally {
    ACCOUNTING_SYNC_IN_FLIGHT = false;
  }
}

