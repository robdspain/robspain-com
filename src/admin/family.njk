  .txn-summary { display: flex; gap: 16px; margin-top: 12px; padding-top: 12px; border-top: 1px solid #d9d1c4; font-size: 13px; }
  .txn-summary span { color: #526158; }

  /* Statement tracking */
  .statement-toolbar { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 16px; }
  .statement-toolbar input { flex: 1; min-width: 260px; padding: 10px 12px; border: 1px solid #d9d1c4; border-radius: 12px; background: #fffdf8; color: #17221d; font: inherit; font-size: 13px; }
  .statement-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 16px; }
  .statement-stat { border: 1px solid #d9d1c4; border-radius: 16px; padding: 14px; background: #fffdf8; }
  .statement-stat .label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #526158; font-weight: 750; }
  .statement-stat .value { margin-top: 4px; font-size: 24px; font-weight: 800; color: #123628; }
  .statement-row { display: grid; grid-template-columns: 110px 1fr auto; gap: 12px; align-items: center; padding: 12px 0; border-bottom: 1px solid #e8e2d5; }
  .statement-row:last-child { border-bottom: none; }
  .statement-month { font-weight: 750; color: #17221d; }
  .statement-detail { font-size: 12px; color: #526158; line-height: 1.45; }
  .statement-actions { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
