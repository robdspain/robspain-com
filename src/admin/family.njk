function setStatementStatus(sourceKey, month, status, fileName) {
  STATE.statements[sourceKey] = normalizeStatements(STATE.statements[sourceKey] || [], sourceKey);
  const item = STATE.statements[sourceKey].find(statement => statement.month === month);
  if (!item) return;
  item.status = status;
  if (fileName) item.fileName = fileName;
  item.updatedAt = new Date().toISOString();
  if (status === 'downloaded' && !item.notes) item.notes = 'Downloaded locally; upload PDF/CSV to Google Drive.';
  if (status === 'uploaded') item.notes = 'Uploaded to Google Drive.';
  if (status === 'imported') item.notes = 'CSV imported into this dashboard.';
  saveState(STATE);
  renderAll();
  showToast(statementSourceLabel(sourceKey) + ' ' + formatMonth(month) + ' marked ' + status);
