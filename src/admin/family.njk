    frappe: {
      company: settings.company || '',
      defaultBankAccount: settings.defaultBankAccount || '',
      defaultRevenueAccount: settings.defaultRevenueAccount || '',
      defaultExpenseAccount: settings.defaultExpenseAccount || '',
      categoryAccountMap: accountingCategoryAccountMap(),
    },
    notes: STATE.accounting?.cpaNotes || '',
  };
}

function summarizeCpaRows(rows) {
  const entityMap = new Map();
  const categoryMap = new Map();
  const sourceFiles = new Map();
  const reviewExceptions = [];

  rows.forEach(row => {
    const amount = Number(row.amount) || 0;
    const entityLabel = ACCOUNTING_ENTITIES[row.entity]?.label || row.entity || 'Unassigned';
    const categoryLabel = row.category || 'Uncategorized';
    addSummaryAmount(entityMap, entityLabel, amount);
    addSummaryAmount(categoryMap, categoryLabel, amount);
    if (row.sourceFile) {
      const item = sourceFiles.get(row.sourceFile) || { name: row.sourceFile, fingerprints: new Set() };
      if (row.sourceFingerprint) item.fingerprints.add(row.sourceFingerprint);
      sourceFiles.set(row.sourceFile, item);
    }
    const reasons = [];
    if (!row.approved) reasons.push('not approved');
    if ((row.confidence || 0) < 0.75) reasons.push('low confidence');
    if (row.balanceCheck === 'mismatch') reasons.push('balance mismatch');
    if (row.category === 'Document needs OCR') reasons.push('document needs OCR');
    if (reasons.length) {
      reviewExceptions.push({
        date: row.date || '',
        entity: entityLabel,
        description: row.description || '',
        amount,
        reason: reasons.join(', '),
      });
    }
  });

  return {
    rowCount: rows.length,
    approvedCount: rows.filter(row => row.approved).length,
    automationApprovedCount: rows.filter(row => row.approvedByAutomation).length,
    needsReviewCount: reviewExceptions.length,
    ocrNeededCount: rows.filter(row => row.category === 'Document needs OCR').length,
    balanceMismatchCount: rows.filter(row => row.balanceCheck === 'mismatch').length,
    frappeSyncedCount: rows.filter(row => row.frappeJournalEntry || row.frappeSyncedAt).length,
    reconciledCount: rows.filter(row => row.reconciliationStatus === 'matched').length,
    possibleReconciliationCount: rows.filter(row => row.reconciliationStatus === 'possible').length,
    unmatchedReconciliationCount: rows.filter(row => row.reconciliationStatus === 'unmatched').length,
    entityTotals: mapToSummaryRows(entityMap),
    categoryTotals: mapToSummaryRows(categoryMap),
    sourceFiles: [...sourceFiles.values()]
      .map(file => ({ name: file.name, fingerprints: [...file.fingerprints].sort() }))
      .sort((a, b) => a.name.localeCompare(b.name)),
    reviewExceptions,
  };
}

function addSummaryAmount(map, label, amount) {
  const item = map.get(label) || { label, income: 0, expenses: 0, net: 0, count: 0 };
  if (amount >= 0) item.income += amount;
  else item.expenses += Math.abs(amount);
  item.net += amount;
  item.count += 1;
  map.set(label, item);
}

function mapToSummaryRows(map) {
  return [...map.values()].sort((a, b) => Math.abs(b.net) - Math.abs(a.net));
}

function partyForTransaction(t) {
  if (t.payee) return t.payee;
  if (t.amount > 0) return ACCOUNTING_ENTITIES[t.entity]?.label || 'Customer';
  return (t.description || '').split(/\s+-\s+|\s{2,}/)[0].slice(0, 48) || 'Vendor';
}

function toCsv(rows) {
  return rows.map(row => row.map(cell => {
    const s = String(cell ?? '');
    return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
  }).join(',')).join('\n');
}

function downloadText(filename, text, type) {
  const blob = new Blob([text], { type: type || 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
  showToast('Downloaded ' + filename);
}

function todayStamp() {
  return new Date().toISOString().slice(0, 10);
}

// ═══════════════════════════════════════════════════════════════
// UTILITIES
// ═══════════════════════════════════════════════════════════════

function showPanel(name, el) {
  const panel = document.getElementById('panel-' + name);
  if (!panel) return;
  document.querySelectorAll('.fin-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.fin-tab').forEach(t => t.classList.remove('active'));
  panel.classList.add('active');
  if (el) el.classList.add('active');
}

function activatePanel(name) {
  const tab = Array.from(document.querySelectorAll('.fin-tab')).find(item => item.getAttribute('onclick')?.includes(`'${name}'`));
  showPanel(name, tab);
}

function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function showToast(text) {
  const t = document.getElementById('toast');
  t.textContent = text;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

function esc(str) {
  if (!str) return '';
  return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function jsArg(value) {
  return JSON.stringify(String(value || '')).replace(/</g, '\\u003c');
}

function ordinal(n) {
  if (!n) return '';
  const s = ['th','st','nd','rd'];
  const v = n % 100;
  return n + (s[(v - 20) % 10] || s[v] || s[0]);
}

function formatMonth(month) {
  const [year, monthNum] = month.split('-').map(Number);
  return new Date(year, monthNum - 1, 1).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function statementSourceLabel(sourceKey) {
  return STATEMENT_SOURCES.find(source => source.key === sourceKey)?.label || sourceKey;
}

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
  });
});

// CSV Import
function handleDragOver(e) { e.preventDefault(); e.currentTarget.classList.add('dragover'); }
function handleDragLeave(e) { e.currentTarget.classList.remove('dragover'); }
function handleDrop(e) {
  e.preventDefault();
  e.currentTarget.classList.remove('dragover');
  const file = e.dataTransfer.files[0];
  if (file) handleFile(file);
}

function handleFile(file) {
  if (!file) return;
  if (!file.name.toLowerCase().endsWith('.csv')) {
    handleAccountingFile(file);
    activatePanel('accounting');
    return;
  }
  const reader = new FileReader();
  reader.onload = function(e) {
    const lines = e.target.result.split('\n').filter(l => l.trim());
    if (lines.length < 2) return;
    const header = lines[0].toLowerCase();
    let txns = [];
    let source = detectStatementSource(file.name, header);

    if (header.includes('transaction date') && header.includes('merchant')) {
      source = 'appleCard';
      for (let i = 1; i < lines.length; i++) {
        const cols = parseCSVLine(lines[i]);
        if (cols.length < 7) continue;
        txns.push({ date: cols[0], desc: cols[2] || cols[1], amount: parseFloat(cols[6]) || 0 });
      }
    } else {
      for (let i = 1; i < lines.length; i++) {
        const cols = parseCSVLine(lines[i]);
        if (cols.length < 3) continue;
        const amtCol = parseFloat((cols[cols.length - 2] || cols[cols.length - 1] || '0').replace(/[,$]/g, ''));
        if (isNaN(amtCol)) continue;
        txns.push({ date: cols[0], desc: cols[1], amount: amtCol });
      }
    }

    if (txns.length === 0) { showToast('Could not parse transactions'); return; }

    const totalOut = txns.filter(t => t.amount < 0).reduce((s, t) => s + Math.abs(t.amount), 0);
    const totalIn = txns.filter(t => t.amount > 0).reduce((s, t) => s + t.amount, 0);
    if (source !== 'unknown') markStatementFromImport(source, file.name, txns);
    const newTransactions = saveImportedTransactions(file.name, source, txns);

    document.getElementById('importResults').style.display = 'block';
    document.getElementById('importTitle').textContent = file.name;
    document.getElementById('importCount').textContent = txns.length + ' transactions · ' + newTransactions + ' new saved';
    document.getElementById('importSummary').innerHTML =
      '<span>Total in: <strong style="color:#22c55e">$' + totalIn.toFixed(2) + '</strong></span>' +
      '<span>Total out: <strong style="color:#ef4444">$' + totalOut.toFixed(2) + '</strong></span>' +
      '<span>Net: <strong style="color:' + (totalIn - totalOut >= 0 ? '#22c55e' : '#ef4444') + '">$' + (totalIn - totalOut).toFixed(2) + '</strong></span>';

    const list = document.getElementById('txnList');
    list.innerHTML = txns.slice(0, 100).map(t => {
      const isDebit = t.amount < 0;
      return '<div class="txn-row">' +
        '<span class="txn-date">' + (t.date || '').substring(0, 10) + '</span>' +
        '<span class="txn-desc">' + esc(t.desc || 'Unknown') + '</span>' +
        '<span class="txn-amt ' + (isDebit ? 'debit' : 'credit') + '">$' + Math.abs(t.amount).toFixed(2) + '</span></div>';
    }).join('');
    if (txns.length > 100) list.innerHTML += '<div style="text-align:center;padding:8px;color:#64748b;font-size:12px;">Showing first 100 of ' + txns.length + '</div>';
    renderAdvisor();
  };
  reader.readAsText(file);
}

function detectStatementSource(fileName, header) {
  const haystack = `${fileName || ''} ${header || ''}`.toLowerCase();
  if (haystack.includes('apple') || haystack.includes('merchant')) return 'appleCard';
  if (haystack.includes('discover')) return 'discover';
  if (haystack.includes('eecu') || haystack.includes('educational employees') || haystack.includes('checking') || haystack.includes('share draft')) return 'eecu';
  return 'unknown';
}

function markStatementFromImport(sourceKey, fileName, txns) {
  const month = inferStatementMonth(fileName, txns);
  if (!month) return;
  STATE.statements[sourceKey] = normalizeStatements(STATE.statements[sourceKey] || [], sourceKey);
  const item = STATE.statements[sourceKey].find(statement => statement.month === month);
  if (!item) return;
  item.status = 'imported';
  item.fileName = fileName;
  item.updatedAt = new Date().toISOString();
  item.notes = 'CSV imported into this dashboard. Upload matching PDF/CSV to Google Drive if not already done.';
  saveState(STATE);
}

function inferStatementMonth(fileName, txns) {
  const fromName = String(fileName || '').match(/(20\d{2})[-_ ]?(0[1-9]|1[0-2])/);
  if (fromName) return fromName[1] + '-' + fromName[2];
  const dates = txns
    .map(t => String(t.date || '').match(/(20\d{2})[-/](0?[1-9]|1[0-2])[-/](0?[1-9]|[12]\d|3[01])/))
    .filter(Boolean)
    .map(match => match[1] + '-' + match[2].padStart(2, '0'));
  if (!dates.length) return '';
  const counts = dates.reduce((acc, month) => {
    acc[month] = (acc[month] || 0) + 1;
    return acc;
  }, {});
  return Object.entries(counts).sort((a, b) => b[1] - a[1])[0][0];
}

function isDelimitedHeader(line) {
  const delimiter = detectCsvDelimiter(line);
  return Boolean(delimiter) && /date|posted|description|merchant|amount|debit|credit|balance|transaction|invoice|customer|memo/i.test(line);
}

function detectCsvDelimiter(line) {
  const raw = String(line || '');
  const candidates = [',', '\t', ';', '|'];
  let best = '';
  let bestCount = 0;
  candidates.forEach(delimiter => {
    const count = parseCSVLine(raw, delimiter).length - 1;
    if (count > bestCount) {
      best = delimiter;
      bestCount = count;
    }
  });
  return bestCount > 0 ? best : '';
}

function parseCSVLine(line, delimiter = ',') {
  const result = [];
  let current = '';
  let inQuotes = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"') { inQuotes = !inQuotes; }
    else if (ch === delimiter && !inQuotes) { result.push(current.trim()); current = ''; }
    else { current += ch; }
  }
  result.push(current.trim());
  return result;
}

function activateInitialPanelFromUrl() {
  const params = new URLSearchParams(window.location.search);
  const panel = params.get('panel') || window.location.hash.replace(/^#/, '');
  if (panel) activatePanel(panel);
}

// Initial render
renderAll();
activateInitialPanelFromUrl();
loadFinanceFromConvex();
loadAccountingFromRemote();
</script>
