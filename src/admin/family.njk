  }
  if (supportCredits.length > 0) {
    html += `<div class="fin-alert info"><strong>July bridge plan:</strong> ${supportCredits.map(item => `${esc(item.payer)} covers ${fmt(item.amount)} for ${esc(item.label.replace(`${item.payer} covering `, ''))}`).join('; ')}.</div>`;
