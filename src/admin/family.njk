  .accounting-step .num { width: 26px; height: 26px; border-radius: 999px; background: #123628; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
  .accounting-step strong { display: block; color: #123628; font-size: 13px; margin-bottom: 2px; }
  .accounting-step span { display: block; color: #526158; font-size: 12px; line-height: 1.45; }
  .acct-controls { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .acct-controls select, .acct-controls input, .acct-controls textarea { border: 1px solid #d9d1c4; border-radius: 8px; padding: 8px 10px; font-size: 13px; color: #123628; background: #fff; }
  .acct-controls textarea { min-height: 72px; width: 100%; resize: vertical; }
  .accounting-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .btn-export { background: #1f4d3f; color: #fff; padding: 8px 12px; border-radius: 8px; border: none; cursor: pointer; font-size: 12px; font-weight: 700; }
  .btn-export:hover { background: #123628; }
  .btn-secondary { background: #ecf4ef; color: #1f4d3f; padding: 8px 12px; border-radius: 8px; border: 1px solid #d9d1c4; cursor: pointer; font-size: 12px; font-weight: 700; }
  .btn-secondary:hover { background: #d9d1c4; }
  .review-row { display: grid; grid-template-columns: 86px minmax(180px, 1fr) 112px 160px 120px 128px; gap: 8px; align-items: center; padding: 8px 0; border-bottom: 1px solid #d9d1c4; font-size: 12px; }
  .review-row.header { color: #526158; text-transform: uppercase; letter-spacing: .04em; font-weight: 700; font-size: 11px; }
  .review-row select, .review-row input { width: 100%; border: 1px solid #d9d1c4; border-radius: 7px; padding: 6px 7px; font-size: 12px; }
  .review-row .desc { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; color: #123628; }
  .review-row .amount { font-weight: 700; text-align: right; font-variant-numeric: tabular-nums; }
  .review-row .amount.income { color: #1f4d3f; }
