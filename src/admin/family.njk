function fmt(n) {
  return '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}

function fmtDate(d) {
  if (!d) return '';
  const parts = d.split('-');
  return parts[1] + '/' + parts[2];
}

function renderAll() {
  renderSummary();
  renderAlerts();
  renderAdvisor();
  renderBills();
  renderAccounts();
  renderIncome();
  renderBudget();
  renderDeficit();
  renderPayments();
  renderEnvelopes();
  renderCalendar();
  renderNetWorth();
  renderDebtPayoff();
  renderStatements();
  document.getElementById('lastUpdated').textContent = 'Updated: ' + new Date(STATE.lastUpdated).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
}

function renderSummary() {
  const cash = STATE.accounts.filter(a => a.type === 'checking' || a.type === 'savings').reduce((s, a) => s + Math.max(0, a.balance), 0);
  const locAcct = STATE.accounts.find(a => a.type === 'loc');
  const locAvail = locAcct ? 10000 + locAcct.balance : 0;
  const totalDebt = STATE.accounts.filter(a => a.balance < 0).reduce((s, a) => s + Math.abs(a.balance), 0);
  const totalIncome = STATE.income.reduce((s, i) => s + i.amount, 0);
  const totalBills = STATE.bills.reduce((s, b) => s + b.amount, 0);
  const deficit = totalIncome - totalBills;

  document.getElementById('summaryCards').innerHTML = `
    <div class="fin-card">
      <h3>Cash Available</h3>
      <div class="fin-stat ${cash > 2000 ? 'yellow' : 'red'}">${fmt(cash)}</div>
      <div class="fin-sub">${STATE.accounts.filter(a=>a.type==='checking'||a.type==='savings').map(a=>a.name+' '+fmt(a.balance)).join(' + ')}</div>
    </div>
    <div class="fin-card">
      <h3>LOC Available</h3>
      <div class="fin-stat blue">${fmt(locAvail)}</div>
      <div class="fin-sub">${fmt(Math.abs(locAcct?.balance||0))} used</div>
    </div>
    <div class="fin-card">
      <h3>Total Debt</h3>
      <div class="fin-stat red">${fmt(totalDebt)}</div>
      <div class="fin-sub">${STATE.accounts.filter(a=>a.balance<0).map(a=>a.name).join(', ')}</div>
    </div>
    <div class="fin-card">
      <h3>Monthly ${deficit >= 0 ? 'Surplus' : 'Deficit'}</h3>
      <div class="fin-stat ${deficit >= 0 ? 'green' : 'red'}">${deficit >= 0 ? '' : '-'}${fmt(Math.abs(deficit))}</div>
      <div class="fin-sub">Income ${fmt(totalIncome)} vs Bills ${fmt(totalBills)}</div>
    </div>
  `;
}

function renderAlerts() {
  const totalIncome = STATE.income.reduce((s, i) => s + i.amount, 0);
  const totalBills = STATE.bills.reduce((s, b) => s + b.amount, 0);
  const overdue = STATE.bills.filter(b => b.status === 'overdue');
  let html = '';
  if (totalBills > totalIncome) {
    html += `<div class="fin-alert danger"><strong>Structural deficit:</strong> Fixed expenses (${fmt(totalBills)}/mo) exceed income (${fmt(totalIncome)}/mo).</div>`;
  }
  if (overdue.length > 0) {
    html += `<div class="fin-alert danger"><strong>Overdue (${overdue.length}):</strong> ${overdue.map(b => b.name + ' ' + fmt(b.amount)).join(', ')}</div>`;
  }
  document.getElementById('alertsContainer').innerHTML = html;
}

function renderAdvisor() {
  const cash = getCashAvailable();
  const reserveFloor = Number(STATE.householdPlan?.reserveFloor ?? CASH_RESERVE_FLOOR);
  const spendableCash = Math.max(0, cash - reserveFloor);
  const totalIncome = STATE.income.reduce((s, i) => s + Number(i.amount || 0), 0);
  const totalBills = STATE.bills.reduce((s, b) => s + Number(b.amount || 0), 0);
  const deficit = totalBills - totalIncome;
  const sixMonthGap = Math.max(0, deficit) * Number(STATE.householdPlan?.sixMonthHorizon || 6);
  const billPlan = buildBillPayPlan(spendableCash);
  const urgentUnfunded = billPlan.filter(item => !item.funded && item.bill.priority <= 2);
  const businessCharges = findBusinessCharges();
  const debtPlan = buildDebtPlan();

  const decisionTone = urgentUnfunded.length ? 'red' : deficit > 0 ? 'yellow' : 'green';
  const decisionText = urgentUnfunded.length
    ? `Pay only the highest-priority bills until ${fmt(urgentUnfunded.reduce((s, item) => s + item.remainingShort, 0))} more cash is found.`
    : deficit > 0
      ? `The immediate bills can be staged, but the monthly plan is short by ${fmt(deficit)}.`
      : 'The monthly plan is currently covered if balances and bill amounts are current.';

  const decision = document.getElementById('advisorDecision');
  if (decision) {
    decision.innerHTML = `
      <h3>Plain-English Recommendation</h3>
      <div class="advisor-headline">${esc(decisionText)}</div>
      <div class="advisor-copy">
        Keep at least ${fmt(reserveFloor)} in checking as a floor. Do not make extra debt payments until P1 survival bills, P2 minimums, and any overdue utility/legal/custody-related obligations are covered. Business software and domain charges should move off personal cards so the personal budget stops absorbing business costs.
      </div>
      <div class="advisor-controls">
        <button onclick="activatePanel('calendar')">Open Bill Calendar</button>
        <button onclick="activatePanel('import')">Import Transactions</button>
        <button onclick="editReserveFloor()">Edit Cash Floor</button>
      </div>
      <div style="margin-top:14px;"><span class="advisor-pill ${decisionTone}">${urgentUnfunded.length ? 'Cash triage' : deficit > 0 ? 'Monthly gap' : 'Covered'}</span></div>
    `;
  }

  const cashPlan = document.getElementById('advisorCashPlan');
  if (cashPlan) {
    const fundedTotal = billPlan.filter(item => item.funded).reduce((s, item) => s + item.bill.amount, 0);
    const unfundedTotal = billPlan.filter(item => !item.funded).reduce((s, item) => s + item.bill.amount, 0);
    cashPlan.innerHTML = `
      <h3>Available Cash Plan</h3>
      <div style="display:grid;gap:12px;">
        <div><div class="fin-sub">Cash in checking/savings</div><div class="fin-stat ${cash > reserveFloor ? 'yellow' : 'red'}">${fmt(cash)}</div></div>
        <div><div class="fin-sub">Spendable after ${fmt(reserveFloor)} floor</div><div class="fin-stat ${spendableCash > 0 ? 'green' : 'red'}">${fmt(spendableCash)}</div></div>
        <div style="display:flex;justify-content:space-between;font-size:14px;"><span>Can fund now</span><strong>${fmt(fundedTotal)}</strong></div>
        <div style="display:flex;justify-content:space-between;font-size:14px;"><span>Still unfunded</span><strong style="color:#b91c1c;">${fmt(unfundedTotal)}</strong></div>
      </div>
    `;
  }

  renderAdvisorBillOrder(billPlan);
  renderAdvisorDebtOrder(debtPlan);
  renderAdvisorBusinessCharges(businessCharges);
  renderAdvisorSixMonth(totalIncome, totalBills, deficit, sixMonthGap, businessCharges);
}

function renderAdvisorBillOrder(plan) {
  const target = document.getElementById('advisorBillOrder');
  if (!target) return;
  const visible = plan.slice(0, 10);
  target.innerHTML = visible.length ? visible.map((item, index) => {
    const cls = item.bill.status === 'overdue' || (!item.funded && item.bill.priority <= 2) ? 'critical' : item.bill.priority <= 2 ? 'warn' : '';
    const status = item.funded ? 'Fund now' : 'Needs cash';
    const dueText = item.bill.dueDay ? `Due ${ordinal(item.bill.dueDay)}` : 'Monthly/variable';
    return `
      <div class="advisor-item ${cls}">
        <div class="advisor-rank">${index + 1}</div>
        <div>
          <div class="advisor-title">${esc(item.bill.name)} <span class="advisor-pill ${item.funded ? 'green' : 'red'}">${status}</span></div>
