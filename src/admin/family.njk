function saveState(state) {
  state.lastUpdated = new Date().toISOString();
  localStorage.setItem(STORE_KEY, JSON.stringify(state));
  queueFinanceSync(state);
  if (state.accounting) scheduleAccountingSync();
}

let STATE = loadState();

function queueFinanceSync(state) {
  clearTimeout(financeSyncTimer);
  setConvexStatus('Syncing...');
  const value = JSON.parse(JSON.stringify(state));
  financeSyncTimer = setTimeout(async () => {
    try {
      const response = await fetch('/admin/api/family-convex', {
        method: 'PUT',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: STORE_KEY, value })
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      const stamp = data.updatedAt ? new Date(data.updatedAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }) : 'now';
      setConvexStatus(`Saved to ${storageSourceLabel(data)} ${stamp}.`);
    } catch (error) {
      setConvexStatus(`Local only: ${error.message}`, true);
    }
  }, 650);
}

async function loadFinanceFromConvex() {
  setConvexStatus('Loading saved app data...');
  try {
    const response = await fetch(`/admin/api/family-convex?key=${encodeURIComponent(STORE_KEY)}`, { credentials: 'same-origin' });
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    const data = await response.json();
    if (!data.item || !data.item.value) {
      setConvexStatus(`No ${storageSourceLabel(data)} record yet.`);
      return;
    }
    const currentAccounting = STATE.accounting;
    STATE = data.item.value;
    if (!STATE.accounting && currentAccounting) STATE.accounting = currentAccounting;
    applyCurrentFinanceCorrections(STATE);
    localStorage.setItem(STORE_KEY, JSON.stringify(STATE));
    renderAll();
    const stamp = data.item.updatedAt ? new Date(data.item.updatedAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }) : 'now';
    setConvexStatus(`Loaded from ${storageSourceLabel(data)} ${stamp}.`);
  } catch (error) {
    setConvexStatus(`Using local copy: ${error.message}`, true);
  }
}

function storageSourceLabel(data) {
  if (data?.source === 'convex' || data?.source === 'convex-migrated') return 'Convex';
  if (data?.source === 'blobs') {
    return data.convexConfigured ? 'Netlify storage after Family Convex fallback' : 'Netlify storage (Family Convex URL missing)';
  }
  return 'remote storage';
}

