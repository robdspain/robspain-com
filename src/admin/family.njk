  .fin-bar { height: 100%; border-radius: 4px; }
  .fin-bar.green { background: #1f4d3f; }
  .fin-bar.red { background: #b91c1c; }
  .fin-bar.yellow { background: #e4b63d; }
  .fin-bar.blue { background: #8ba4b8; }
  .fin-bar.purple { background: #7c3aed; }
  
  .fin-deficit { background: rgba(185, 28, 28, 0.06); border: 1px solid rgba(185, 28, 28, 0.15); border-radius: 22px; padding: 20px; margin-top: 24px; text-align: center; }
