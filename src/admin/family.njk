function renderStatements() {
  const container = document.getElementById('statementAccounts');
  if (!container) return;
  container.innerHTML = STATEMENT_SOURCES.map(source => renderStatementSource(source)).join('');
}

function renderStatementSource(source) {
  STATE.statements[source.key] = normalizeStatements(STATE.statements[source.key] || [], source.key);
  const items = STATE.statements[source.key];
  const counts = items.reduce((acc, item) => {
    acc[item.status] = (acc[item.status] || 0) + 1;
    return acc;
  }, {});
  const latestCovered = items
    .filter(item => item.status === 'uploaded' || item.status === 'imported')
    .sort((a, b) => b.month.localeCompare(a.month))[0];
  const missing = items.filter(item => item.status === 'missing');
  const snapshotButton = source.key === 'appleCard'
    ? '<button class="btn-add" onclick="applyAppleCardDriveSnapshot(true)">Import Drive Snapshot</button>'
    : '';

  return `
    <section class="statement-account">
      <div class="statement-account-head">
        <div>
          <div class="statement-account-title">${esc(source.label)}</div>
          <div class="statement-account-note">${esc(source.note)}</div>
        </div>
        <span class="statement-badge ${missing.length ? 'missing' : 'uploaded'}">${missing.length ? `${missing.length} missing` : 'covered'}</span>
      </div>
      <div class="statement-toolbar">
        <input type="url" value="${esc(STATE.statementFolders[source.key] || '')}" placeholder="${esc(source.folderLabel)}" onchange="saveStatementFolder('${source.key}', this.value)">
        <button class="btn-add" onclick="openStatementFolder('${source.key}')">Open Drive</button>
        ${snapshotButton}
      </div>
      <div class="statement-summary">
      <div class="statement-stat"><div class="label">Missing</div><div class="value" style="color:#b91c1c;">${counts.missing || 0}</div></div>
      <div class="statement-stat"><div class="label">Downloaded</div><div class="value" style="color:#d97706;">${counts.downloaded || 0}</div></div>
      <div class="statement-stat"><div class="label">Uploaded</div><div class="value" style="color:#1f4d3f;">${counts.uploaded || 0}</div></div>
      <div class="statement-stat"><div class="label">Latest Covered</div><div class="value" style="font-size:18px;">${latestCovered ? formatMonth(latestCovered.month) : 'None'}</div></div>
      </div>
    ${missing.length ? `<div class="fin-alert danger"><strong>Need now:</strong> ${missing.slice(0, 6).map(item => formatMonth(item.month)).join(', ')}${missing.length > 6 ? ` and ${missing.length - 6} more` : ''}</div>` : `<div class="fin-alert info"><strong>${esc(source.label)} coverage complete:</strong> No missing completed months are currently listed.</div>`}
    ${items.map(item => `
      <div class="statement-row">
        <div class="statement-month">${formatMonth(item.month)}</div>
        <div>
          <span class="statement-badge ${esc(item.status)}">${esc(item.status)}</span>
          <div class="statement-detail">
            ${item.fileName ? `File: ${esc(item.fileName)}<br>` : ''}
            ${item.driveUrl ? `<a href="${esc(item.driveUrl)}" target="_blank" rel="noopener">Drive file</a><br>` : ''}
            ${item.notes ? esc(item.notes) : 'Download PDF + CSV, upload to Drive, then import CSV.'}
          </div>
        </div>
        <div class="statement-actions">
          <button class="btn-sm btn-edit" onclick="setStatementStatus('${source.key}','${item.month}','downloaded')">Downloaded</button>
          <button class="btn-sm btn-pay" onclick="setStatementStatus('${source.key}','${item.month}','uploaded')">Uploaded</button>
          <button class="btn-sm btn-del" onclick="setStatementStatus('${source.key}','${item.month}','missing')">Missing</button>
        </div>
      </div>
    `).join('')}
