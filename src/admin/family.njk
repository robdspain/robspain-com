  @media (max-width: 800px) { .advisor-hero { grid-template-columns: 1fr; } }
  @media (max-width: 600px) { .fin-grid-4 { grid-template-columns: 1fr 1fr; } .fin-grid-2, .fin-grid-3 { grid-template-columns: 1fr; } .fin-tabs { gap: 4px; } .fin-tab { padding: 8px 12px; font-size: 12px; } .advisor-item { grid-template-columns: auto 1fr; } .advisor-amount { grid-column: 2; text-align: left; } }
</style>

