function ensureAccountingState() {
  if (!STATE.accounting) STATE.accounting = defaultState().accounting;
  if (!Array.isArray(STATE.accounting.reviewQueue)) STATE.accounting.reviewQueue = [];
  if (!Array.isArray(STATE.accounting.importedFiles)) STATE.accounting.importedFiles = [];
  if (!Array.isArray(STATE.accounting.importRuns)) STATE.accounting.importRuns = [];
  if (!Array.isArray(STATE.accounting.frappeRuns)) STATE.accounting.frappeRuns = [];
  if (!Array.isArray(STATE.accounting.vendorRules)) STATE.accounting.vendorRules = [];
  if (!STATE.accounting.activeEntity) STATE.accounting.activeEntity = 'behavior-school';
  if (!STATE.accounting.defaultFrappeAccount) STATE.accounting.defaultFrappeAccount = 'Expenses';
  STATE.accounting.reviewQueue.forEach(row => {
    if (!row.payee) row.payee = normalizePayee(row.description, row.amount);
  });
  STATE.accounting.frappeSettings = {
    ...defaultFrappeSettings(),
    ...(STATE.accounting.frappeSettings || {}),
    categoryAccountMap: {
      ...defaultCategoryAccountMap(STATE.accounting.frappeSettings || {}),
      ...(STATE.accounting.frappeSettings?.categoryAccountMap || {}),
    },
  };
}

function renderAccountingHub() {
  ensureAccountingState();
  const entity = ACCOUNTING_ENTITIES[STATE.accounting.activeEntity] || ACCOUNTING_ENTITIES['behavior-school'];
  const entitySel = document.getElementById('acctEntity');
  const defaultAcctSel = document.getElementById('acctDefaultAccount');
  const summaryEl = document.getElementById('accountingEntitySummary');
  if (!entitySel || !defaultAcctSel || !summaryEl) return;

  entitySel.value = STATE.accounting.activeEntity;
  defaultAcctSel.value = STATE.accounting.defaultFrappeAccount;
  const frappeSettings = STATE.accounting.frappeSettings || defaultFrappeSettings();
  const frappeCompany = document.getElementById('frappeCompany');
  const frappeBankAccount = document.getElementById('frappeBankAccount');
  const frappeRevenueAccount = document.getElementById('frappeRevenueAccount');
  const frappeExpenseAccount = document.getElementById('frappeExpenseAccount');
  if (frappeCompany) frappeCompany.value = frappeSettings.company || '';
  if (frappeBankAccount) frappeBankAccount.value = frappeSettings.defaultBankAccount || '';
  if (frappeRevenueAccount) frappeRevenueAccount.value = frappeSettings.defaultRevenueAccount || 'Sales';
  if (frappeExpenseAccount) frappeExpenseAccount.value = frappeSettings.defaultExpenseAccount || 'Expenses';
  summaryEl.innerHTML = `<strong style="color:#1e293b;">${esc(entity.label)}</strong><br>${esc(entity.legalNote)}<br><span style="color:#0f766e;">Revenue defaults to ${esc(entity.defaultRevenueAccount)}.</span>`;

  document.getElementById('accountingRules').innerHTML = ACCOUNTING_CATEGORY_RULES.map(rule =>
    `<span class="rule-chip"><strong>${esc(rule.category)}</strong>${esc(rule.taxCategory)}</span>`
  ).join('');
  renderFrappeAccountMap();
  renderFrappeAccountOptions();
  renderVendorRules();

  const queue = STATE.accounting.reviewQueue;
  const income = queue.filter(t => t.amount > 0).reduce((s, t) => s + t.amount, 0);
  const expenses = queue.filter(t => t.amount < 0).reduce((s, t) => s + Math.abs(t.amount), 0);
  const approved = queue.filter(t => t.approved).length;
  const unreviewed = queue.filter(t => !t.approved || t.confidence < 0.75).length;
  const automationReady = queue.filter(isAutomationReadyForApproval).length;
  document.getElementById('accountingSummary').innerHTML = `
    <span>Transactions: <strong>${queue.length}</strong></span>
    <span>Income: <strong style="color:#16a34a;">${fmtCents(income)}</strong></span>
    <span>Expenses: <strong style="color:#dc2626;">${fmtCents(expenses)}</strong></span>
    <span>Approved: <strong>${approved}</strong></span>
    <span>Needs review: <strong style="color:${unreviewed ? '#dc2626' : '#16a34a'};">${unreviewed}</strong></span>
    <span>Automation ready: <strong style="color:${automationReady ? '#0f766e' : '#64748b'};">${automationReady}</strong></span>
  `;
  renderAccountingCloseStatus();
  renderAccountingReviewQueue();
  renderAccountingImportRuns();
  renderFrappeSyncRuns();
  renderCpaNotes();
  if (!ACCOUNTING_STATUS_LOADED) {
    ACCOUNTING_STATUS_LOADED = true;
    loadAccountingAutomationStatus();
  }
}

