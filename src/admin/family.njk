function loadState() {
  try {
    const raw = localStorage.getItem(STORE_KEY);
    if (raw) {
      const saved = JSON.parse(raw);
      // Merge with defaults to pick up new fields
      const def = defaultState();
      const merged = {
        bills: saved.bills || def.bills,
        accounts: saved.accounts || def.accounts,
        income: saved.income || def.income,
        payments: saved.payments || def.payments,
        transactions: saved.transactions || def.transactions,
        householdPlan: saved.householdPlan || def.householdPlan,
        statementFolders: saved.statementFolders || def.statementFolders,
        statements: saved.statements || def.statements,
        lastUpdated: saved.lastUpdated || def.lastUpdated,
      };
      applyCurrentFinanceCorrections(merged);
      return merged;
    }
  } catch(e) {}
  // Migrate from v1 localStorage if present
  try {
    const v1 = localStorage.getItem('spain-finance-bills');
    if (v1) {
      const statuses = JSON.parse(v1);
      const state = defaultState();
      state.bills.forEach(b => { if (statuses[b.id]) b.status = statuses[b.id]; });
      saveState(state);
      applyCurrentFinanceCorrections(state);
      return state;
    }
  } catch(e) {}
  const state = defaultState();
  applyCurrentFinanceCorrections(state);
  return state;
}

function applyCurrentFinanceCorrections(state) {
  state.statementFolders = state.statementFolders || {};
  state.statements = state.statements || {};
  state.transactions = Array.isArray(state.transactions) ? state.transactions : [];
  state.householdPlan = state.householdPlan || { reserveFloor: CASH_RESERVE_FLOOR, sixMonthHorizon: 6, contributionTarget: 0, notes: '' };
  if (!state.householdPlan.reserveFloor && state.householdPlan.reserveFloor !== 0) state.householdPlan.reserveFloor = CASH_RESERVE_FLOOR;
  if (!state.householdPlan.sixMonthHorizon) state.householdPlan.sixMonthHorizon = 6;
  STATEMENT_SOURCES.forEach(source => {
    if (state.statementFolders[source.key] === undefined) state.statementFolders[source.key] = '';
    state.statements[source.key] = normalizeStatements(state.statements[source.key] || [], source.key);
  });
  if (!state.statementFolders.appleCard) state.statementFolders.appleCard = APPLE_CARD_DRIVE_FOLDER_URL;
  applyAppleCardDriveSnapshot(false, state);

  const fpu = state.income?.find(i => i.id === 'fpu' || /FPU|Fresno Pacific/i.test(i.name || ''));
  if (fpu) {
    fpu.amount = 0;
    fpu.frequency = 'Paused — no current income';
  }

  const support = state.bills?.find(b => b.id === 'support' || /Supporting Hands/i.test(b.name || ''));
  if (support) {
    support.account = 'EECU Checking';
    support.priority = 1;
    support.notes = 'Childcare — no longer on Apple Card';
  }

  const requiredBudgetBills = [
    { id:'childsupport', name:'Child Support / DCSS', dueDay:1, amount:2100, status:'current', priority:1, account:'Payroll/DCSS', notes:'Court-ordered support baseline; set to $0 here if already withheld from net pay', payUrl:'https://www.childsupport.ca.gov/payment-options/' },
    { id:'groceries', name:'Groceries / Household', dueDay:null, amount:500, status:'current', priority:1, account:'EECU Checking', notes:'Planning floor from prior monthly budget', payUrl:'' },
    { id:'fuel', name:'Fuel / Transportation', dueDay:null, amount:250, status:'current', priority:1, account:'EECU Checking', notes:'Monthly operating reserve; adjust from card/bank imports', payUrl:'' },
    { id:'familytherapy', name:'Child / Family Therapy Reserve', dueDay:null, amount:260, status:'current', priority:1, account:'EECU Checking', notes:'Assumes Rob half-share of four $130 sessions; update to actual order/provider cadence', payUrl:'' },
    { id:'ofw', name:'OurFamilyWizard', dueDay:null, amount:9, status:'current', priority:3, account:'EECU Checking', notes:'Annual renewal normalized to monthly budget', payUrl:'https://www.ourfamilywizard.com/' },
    { id:'netflix', name:'Netflix', dueDay:null, amount:18, status:'current', priority:3, account:'Apple Card', notes:'Streaming subscription', payUrl:'https://www.netflix.com/' },
    { id:'apple_services', name:'Apple Services', dueDay:null, amount:30, status:'current', priority:3, account:'Apple Card', notes:'Recurring services rounded from historical statements', payUrl:'https://www.apple.com/' },
    { id:'legalreserve', name:'Legal Fee Reserve', dueDay:null, amount:750, status:'current', priority:4, account:'EECU Checking', notes:'Working reserve against active 2026 Tipton invoices; pause before adding new card debt', payUrl:'' },
  ];

  requiredBudgetBills.forEach(required => {
    const existing = state.bills?.find(b => b.id === required.id || b.name === required.name);
    if (!existing) {
      state.bills.push({...required});
      return;
    }
    existing.name = required.name;
    existing.priority = required.priority;
    existing.account = required.account;
    existing.notes = required.notes;
    if (required.payUrl && !existing.payUrl) existing.payUrl = required.payUrl;
    if (existing.amount == null || existing.amount === 0) existing.amount = required.amount;
    if (!existing.status) existing.status = required.status;
    if (existing.dueDay === undefined) existing.dueDay = required.dueDay;
  });

  const defaultUrls = {
    rent: '',
    childsupport: 'https://www.childsupport.ca.gov/payment-options/',
    support: 'https://supportinghandspediatrictherapy.com/',
    auto: 'https://www.myeecu.org/',
    apple: 'https://card.apple.com/',
    toggle: 'https://www.gettoggle.com/',
    pge: 'https://www.pge.com/',
    att: 'https://www.att.com/',
    fresno: 'https://www.fresno.gov/utilitypayments',
    xfinity: 'https://www.xfinity.com/',
    discover: 'https://www.discover.com/',
    loc: 'https://www.myeecu.org/',
    principal: 'https://www.principal.com/',
    allstate: 'https://www.allstate.com/',
    ofw: 'https://www.ourfamilywizard.com/',
    netflix: 'https://www.netflix.com/',
    apple_services: 'https://www.apple.com/'
  };

  state.bills?.forEach(b => {
    if (defaultUrls[b.id] && !b.payUrl) {
      b.payUrl = defaultUrls[b.id];
    }
  });

  const kcusd = state.income?.find(i => i.id === 'kcusd' || /Kings Canyon/i.test(i.name || ''));
  if (kcusd && /biweekly/i.test(kcusd.frequency || '')) {
    kcusd.frequency = 'Monthly net estimate';
  }
}

function normalizeStatements(existing, sourceKey) {
  const byMonth = new Map((existing || []).map(item => [item.month, item]));
  const expected = [];
  const start = new Date(2025, 0, 1); // January 2025
  const today = new Date();
  const end = new Date(today.getFullYear(), today.getMonth() - 1, 1);
  for (let cursor = new Date(start); cursor <= end; cursor.setMonth(cursor.getMonth() + 1)) {
    const month = cursor.toISOString().slice(0, 7);
    const saved = byMonth.get(month) || {};
    const historical = sourceKey === 'appleCard' && month <= '2026-03';
    expected.push({
      month,
      status: saved.status || (historical ? 'imported' : 'missing'),
      fileName: saved.fileName || '',
      driveUrl: saved.driveUrl || '',
      updatedAt: saved.updatedAt || '',
      notes: saved.notes || (historical ? 'Included in original historical Apple Card dataset.' : '')
    });
  }
  return expected.sort((a, b) => b.month.localeCompare(a.month));
}

function applyAppleCardDriveSnapshot(showMessage, targetState) {
  const state = targetState || STATE;
  state.statementFolders = state.statementFolders || {};
  state.statements = state.statements || {};
  state.statementFolders.appleCard = state.statementFolders.appleCard || APPLE_CARD_DRIVE_FOLDER_URL;
  state.statements.appleCard = normalizeStatements(state.statements.appleCard || [], 'appleCard');

  APPLE_CARD_DRIVE_FILES.forEach(file => {
    let item = state.statements.appleCard.find(statement => statement.month === file.month);
    if (!item) {
      item = { month: file.month, status: 'missing', fileName: '', driveUrl: '', updatedAt: '', notes: '' };
      state.statements.appleCard.push(item);
    }
    const keepImported = item.status === 'imported';
    item.status = keepImported ? 'imported' : 'uploaded';
    item.fileName = file.title;
    item.driveUrl = file.url;
    item.notes = keepImported ? item.notes : 'PDF statement found in the Apple Card Google Drive folder.';
    item.updatedAt = item.updatedAt || new Date().toISOString();
  });

  state.statements.appleCard = normalizeStatements(state.statements.appleCard, 'appleCard');
  if (!targetState) {
    saveState(state);
    renderAll();
  }
  if (showMessage) showToast(`Imported ${APPLE_CARD_DRIVE_FILES.length} Apple Card Drive files`);
}


function saveState(state) {
  state.lastUpdated = new Date().toISOString();
  localStorage.setItem(STORE_KEY, JSON.stringify(state));
  queueFinanceSync(state);
}

let STATE = loadState();

function queueFinanceSync(state) {
  clearTimeout(financeSyncTimer);
  setConvexStatus('Syncing...');
  const value = JSON.parse(JSON.stringify(state));
  financeSyncTimer = setTimeout(async () => {
    try {
      const response = await fetch('/admin/api/admin-convex', {
        method: 'PUT',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: STORE_KEY, value })
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      const stamp = data.updatedAt ? new Date(data.updatedAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }) : 'now';
      setConvexStatus(`Saved to Convex ${stamp}.`);
    } catch (error) {
      setConvexStatus(`Local only: ${error.message}`, true);
    }
  }, 650);
}

async function loadFinanceFromConvex() {
  setConvexStatus('Loading Convex...');
  try {
    const response = await fetch(`/admin/api/admin-convex?key=${encodeURIComponent(STORE_KEY)}`, { credentials: 'same-origin' });
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    const data = await response.json();
    if (!data.item || !data.item.value) {
      setConvexStatus('No Convex record yet.');
      return;
    }
    STATE = data.item.value;
    applyCurrentFinanceCorrections(STATE);
    localStorage.setItem(STORE_KEY, JSON.stringify(STATE));
    renderAll();
    const stamp = data.item.updatedAt ? new Date(data.item.updatedAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }) : 'now';
    setConvexStatus(`Loaded from Convex ${stamp}.`);
  } catch (error) {
    setConvexStatus(`Using local copy: ${error.message}`, true);
  }
}

