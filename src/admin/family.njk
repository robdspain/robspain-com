  .envelope .env-fill { height: 100%; border-radius: 2px; }
  .env-priority { font-size: 11px; font-weight: 750; text-transform: uppercase; letter-spacing: 0.05em; color: #526158; margin: 20px 0 10px; padding-bottom: 4px; border-bottom: 1px solid #d9d1c4; }
  .env-priority.p1 { color: #b91c1c; }
  .env-priority.p2 { color: #e4b63d; }
  .env-priority.p3 { color: #8ba4b8; }
  .env-priority.p4 { color: #1f4d3f; }
  
  /* Calendar styles */
  .cal-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid #e8e2d5; }
  .cal-row:last-child { border-bottom: none; }
  .cal-day { width: 48px; height: 48px; border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; font-weight: 750; flex-shrink: 0; }
