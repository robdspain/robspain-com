function saveBill() {
  const id = document.getElementById('editBillId').value;
  const name = document.getElementById('billName').value.trim();
  const amount = parseFloat(document.getElementById('billAmount').value);
  if (!name || isNaN(amount)) { showToast('Name and amount required'); return; }

  const data = {
    name,
    dueDay: parseInt(document.getElementById('billDueDay').value) || null,
    amount,
    status: document.getElementById('billStatus').value,
    priority: parseInt(document.getElementById('billPriority').value),
    account: document.getElementById('billAccount').value.trim(),
    payUrl: document.getElementById('billPayUrl').value.trim(),
    notes: document.getElementById('billNotes').value.trim(),
  };

  if (id) {
    const bill = STATE.bills.find(b => b.id === id);
    if (bill) Object.assign(bill, data);
    showToast('Updated ' + name);
  } else {
    data.id = 'bill_' + Date.now();
    STATE.bills.push(data);
    showToast('Added ' + name);
  }
  saveState(STATE);
  closeModal('addBillModal');
  renderAll();
}

function deleteBill() {
  const id = document.getElementById('editBillId').value;
  if (!id) return;
  const bill = STATE.bills.find(b => b.id === id);
  if (bill && confirm('Delete "' + bill.name + '"?')) {
    STATE.bills = STATE.bills.filter(b => b.id !== id);
    saveState(STATE);
    closeModal('addBillModal');
    renderAll();
    showToast('Deleted ' + bill.name);
  }
}

