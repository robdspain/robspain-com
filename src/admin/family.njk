function getCashAvailable() {
  return STATE.accounts
    .filter(account => account.type === 'checking' || account.type === 'savings')
    .reduce((sum, account) => sum + Math.max(0, Number(account.balance || 0)), 0);
}

function buildBillPayPlan(spendableCash) {
  let remaining = spendableCash;
  return STATE.bills
    .map(bill => ({
      bill,
      amountDue: robBillAmount(bill),
      supportCredit: getBillSupportCredit(bill.id),
      score: billUrgencyScore(bill),
      reason: billUrgencyReason(bill)
    }))
    .filter(item => item.bill.status !== 'paid' && item.amountDue > 0)
    .sort((a, b) => b.score - a.score || Number(a.bill.dueDay || 99) - Number(b.bill.dueDay || 99))
    .map(item => {
      const funded = remaining >= item.amountDue;
      if (funded) remaining -= item.amountDue;
      return {
        ...item,
        funded,
        remainingCash: remaining,
        remainingShort: funded ? 0 : Math.max(0, item.amountDue - remaining)
      };
    });
}

function billUrgencyScore(bill) {
  let score = (5 - Number(bill.priority || 4)) * 100;
  if (bill.status === 'overdue') score += 500;
  if (bill.status === 'autopay') score += 75;
  if (bill.status === 'current') score += 50;
  const days = daysUntilDue(bill.dueDay);
  if (days !== null) score += Math.max(0, 45 - days) * 5;
  if (/rent|vista|pge|pg&e|fresno|xfinity|therapy|supporting|child support|dcss|auto loan/i.test(bill.name || '')) score += 80;
  if (/legal|tipton|court|ofw|familywizard/i.test(`${bill.name || ''} ${bill.notes || ''}`)) score += 40;
  return score;
}

function billUrgencyReason(bill) {
  if (bill.status === 'overdue') return 'Overdue or already at risk.';
  if (bill.priority === 1) return 'Survival/custody/utility obligation.';
  if (bill.priority === 2) return 'Minimum payment or insurance; protect credit and coverage.';
  if (bill.priority === 3) return 'Useful, but should wait until P1/P2 are covered.';
  return 'Lower-priority or credit-funded item; do not pay ahead while cash is tight.';
}

function daysUntilDue(dueDay) {
  if (!dueDay) return null;
  const today = new Date();
  let due = new Date(today.getFullYear(), today.getMonth(), Number(dueDay));
  if (due < new Date(today.getFullYear(), today.getMonth(), today.getDate())) {
    due = new Date(today.getFullYear(), today.getMonth() + 1, Number(dueDay));
  }
  return Math.ceil((due - today) / 86400000);
}

function buildDebtPlan() {
  return STATE.accounts
    .filter(account => account.balance < 0)
    .map(account => {
      const balance = Math.abs(Number(account.balance || 0));
      const bill = STATE.bills.find(b => accountBillMatch(account, b));
      const kindScore = debtKindScore(account);
      return {
        name: account.name,
        balance,
        minPay: bill ? Number(bill.amount || 0) : 0,
        score: kindScore + Math.min(balance / 1000, 20),
        reason: debtReason(account)
      };
    })
    .sort((a, b) => b.score - a.score);
}

function accountBillMatch(account, bill) {
  const haystack = `${account.name || ''} ${bill.name || ''}`.toLowerCase();
  if (account.id === 'applecard' && haystack.includes('apple')) return true;
  if (account.id === 'discover' && haystack.includes('discover')) return true;
  if (account.type === 'loc' && /loc|line of credit/i.test(haystack)) return true;
  if (account.type === 'loan' && /auto|loan/i.test(haystack)) return true;
  return false;
}

function debtKindScore(account) {
  const text = `${account.id || ''} ${account.name || ''} ${account.type || ''}`.toLowerCase();
  if (/apple|discover|credit/.test(text)) return 300;
  if (/loc|line of credit/.test(text)) return 220;
  if (/loan|auto/.test(text)) return 80;
  return 150;
}

function debtReason(account) {
  const text = `${account.id || ''} ${account.name || ''} ${account.type || ''}`.toLowerCase();
  if (/apple/.test(text)) return 'Highest-risk revolving debt; do not add new charges and attack after survival bills are current.';
  if (/discover|credit/.test(text)) return 'Likely high-interest revolving debt; pay minimum first, then extra after Apple if Apple APR is higher.';
  if (/loc|line of credit/.test(text)) return 'Useful emergency buffer; pay down after high-interest cards so available credit stays open.';
  if (/loan|auto/.test(text)) return 'Keep current, but do not accelerate while cash is tight unless rate or repossession risk changes.';
  return 'Pay minimum until exact APR is known.';
}

function findBusinessCharges() {
  const imported = (STATE.transactions || [])
    .filter(txn => Number(txn.amount || 0) < 0)
    .map(txn => {
      const desc = String(txn.desc || '');
      const rule = BUSINESS_CHARGE_RULES.find(item => item.pattern.test(desc));
      if (!rule) return null;
      return {
        label: rule.label,
        action: rule.action,
        desc,
        amount: Math.abs(Number(txn.amount || 0)),
        source: txn.source || txn.fileName || '',
        date: txn.date || ''
      };
    })
    .filter(Boolean);

  const manualWatch = [
    { label:'OpenAI / ChatGPT', desc:'Known recurring AI tool to verify in card imports', amount:0, source:'Watchlist', action:'Move to Behavior School business card if still on personal card.' },
    { label:'Anthropic / Claude', desc:'Known recurring AI tool to verify in card imports', amount:0, source:'Watchlist', action:'Move to Behavior School business card if still on personal card.' },
    { label:'Domain names', desc:'Domain renewals and hosting should not stay on personal cards', amount:0, source:'Watchlist', action:'Move GoDaddy/domain/hosting renewals to the business account.' }
  ];

  const deduped = [];
  [...imported, ...manualWatch].forEach(item => {
    const key = `${item.label}|${item.desc}|${item.amount}|${item.date}`;
    if (!deduped.some(existing => `${existing.label}|${existing.desc}|${existing.amount}|${existing.date}` === key)) deduped.push(item);
  });
  return deduped.sort((a, b) => b.amount - a.amount);
}

function mergeChecklist(defaultItems, savedItems) {
  const savedById = new Map((savedItems || []).map(item => [item.id, item]));
  return defaultItems.map(item => Object.assign({}, item, savedById.get(item.id) || {}));
}

function mergeTemporarySupport(defaultItems, savedItems) {
  const savedById = new Map((savedItems || []).map(item => [item.id, item]));
  return defaultItems.map(item => Object.assign({}, item, savedById.get(item.id) || {}));
}

function getTemporarySupportCredits() {
  return (STATE.householdPlan?.temporarySupport || [])
    .filter(item => item.month === '2026-07')
    .map(item => ({
      ...item,
      amount: Math.max(0, Number(item.amount || 0))
    }));
}

function getBillSupportCredit(billId) {
  return getTemporarySupportCredits()
    .filter(item => item.billId === billId)
    .reduce((sum, item) => sum + item.amount, 0);
}

function robBillAmount(bill) {
  return Math.max(0, Number(bill.amount || 0) - getBillSupportCredit(bill.id));
}

function getMonthlyIncomeTotal() {
  return STATE.income.reduce((sum, item) => sum + Number(item.amount || 0), 0);
}

function getMonthlyBillTotal() {
  return STATE.bills.reduce((sum, bill) => sum + Number(bill.amount || 0), 0);
}

function getRobMonthlyBillTotal() {
