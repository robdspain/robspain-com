function buildOwnerDrawDecision() {
  const plan = STATE.businessPlan || {};
  const cash = getCashAvailable();
  const reserveFloor = Number(STATE.householdPlan?.reserveFloor ?? CASH_RESERVE_FLOOR);
  const householdShort = Math.max(0, reserveFloor - cash);
  const spendableCash = Math.max(0, cash - reserveFloor);
  const urgentUnfunded = buildBillPayPlan(spendableCash)
    .filter(item => !item.funded && (item.bill.priority <= 2 || item.bill.status === 'overdue' || item.bill.status === 'autopay'))
    .reduce((s, item) => s + item.amountDue, 0);
  const businessCash = getNovoBalance();
  const businessDebt = Number(plan.businessDebt || 0);
  const businessDebtApr = Number(plan.businessDebtApr || 0);
  const personalDebtApr = Number(plan.personalDebtApr || 0);
  const businessReserve = Number(plan.minimumBusinessReserve || 0);
  const drawable = Math.max(0, businessCash - businessReserve);
  const suggestedDraw = Math.min(drawable, Math.max(householdShort, urgentUnfunded));

  if (urgentUnfunded > 0 || householdShort > 0) {
    if (drawable > 0) {
      return {
        tone: 'danger',
        headline: `Draw up to ${fmt(suggestedDraw)} only if needed`,
        copy: `Household cash cannot cover all priority bills while keeping the reserve. Available business cash above reserve is ${fmt(drawable)}.`,
        rule: 'Use an owner draw for missed-bill prevention before paying down business debt. Document it as an owner draw, not business income.'
      };
    }
    return {
      tone: 'danger',
      headline: 'Do not count on Novo yet',
      copy: 'The app needs current Novo cash before it can recommend a draw. Household priority bills are not fully covered.',
      rule: 'Refresh Novo/business cash first. If no drawable business cash exists, defer lower-priority bills rather than paying extra debt.'
    };
  }

  if (businessDebt > 0 && drawable > 0) {
    const payBusinessFirst = businessDebtApr > personalDebtApr && businessDebtApr > 0;
    return {
      tone: 'warn',
      headline: payBusinessFirst ? 'Hold household steady, then pay business debt' : 'Hold household steady, then attack personal cards',
      copy: `Priority household bills are covered. Business has ${fmt(drawable)} above reserve and ${fmt(businessDebt)} debt listed.`,
      rule: payBusinessFirst
        ? `Business debt APR (${businessDebtApr}%) is higher than personal APR (${personalDebtApr}%). Keep reserves, then pay business debt before extra personal-card payments.`
        : `Personal revolving APR/utilization appears more urgent than business debt. Keep business reserve intact and use extra cash to reduce Apple/Discover after minimums are covered.`
    };
  }

  return {
    tone: '',
    headline: 'No owner draw needed from current data',
    copy: 'Priority household bills appear covered after reserve. Keep the business reserve intact and keep importing transactions.',
    rule: 'Only take draws for a known household shortfall, planned owner compensation, or to prevent missed payments.'
  };
}

