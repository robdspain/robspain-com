function saveImportedTransactions(fileName, source, txns) {
  const importedAt = new Date().toISOString();
  const normalized = txns.map(txn => ({
    id: `txn_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
    fileName,
    source,
    importedAt,
    date: txn.date || '',
    desc: txn.desc || '',
    amount: Number(txn.amount || 0)
  }));
  const existingKeys = new Set((STATE.transactions || []).map(txn => `${txn.fileName}|${txn.date}|${txn.desc}|${txn.amount}`));
  const fresh = normalized.filter(txn => !existingKeys.has(`${txn.fileName}|${txn.date}|${txn.desc}|${txn.amount}`));
  STATE.transactions = [...fresh, ...(STATE.transactions || [])].slice(0, 2500);
  if (fresh.length) saveState(STATE);
  return fresh.length;
}

