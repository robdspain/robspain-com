  .import-zone p { color: #526158; margin: 0; font-size: 13px; }
  .txn-list { max-height: 300px; overflow-y: auto; margin-top: 12px; }
  .txn-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #e8e2d5; font-size: 13px; }
