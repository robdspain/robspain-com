function renderMonthlyRunway() {
  const target = document.getElementById('monthlyRunwayCard');
  if (!target) return;
  const cash = getCashAvailable();
  const reserveFloor = Number(STATE.householdPlan?.reserveFloor ?? CASH_RESERVE_FLOOR);
  const spendableCash = Math.max(0, cash - reserveFloor);
  const unpaid = buildBillPayPlan(spendableCash);
  const mustPay = unpaid.filter(item => item.bill.priority <= 2 || item.bill.status === 'overdue' || item.bill.status === 'autopay');
  const funded = mustPay.filter(item => item.funded).reduce((s, item) => s + item.amountDue, 0);
  const unfunded = mustPay.filter(item => !item.funded).reduce((s, item) => s + item.amountDue, 0);
  const nextUnfunded = mustPay.find(item => !item.funded);
  const tone = unfunded ? 'danger' : spendableCash < 200 ? 'warn' : '';
  target.innerHTML = `
    <h3>Bill Runway</h3>
