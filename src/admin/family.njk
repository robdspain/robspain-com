  .modal-actions .btn-danger:hover { background: #991b1b; }
  
  /* Envelope styles */
  .envelope { border: 1px solid #d9d1c4; border-radius: 16px; padding: 12px 16px; margin-bottom: 8px; position: relative; overflow: hidden; background: #fffdf8; }
  .envelope::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; border-radius: 8px 0 0 8px; }
  .envelope.p1::before { width: 4px; background: #b91c1c; }
