}

function startNewMonth() {
  normalizeBillRolloverRules(STATE.bills);
  const nextMonth = currentMonthKey();
  const summary = { autopay: 0, review: 0, recurring: 0, archived: 0 };

  STATE.bills.forEach(bill => {
    if (bill.recurrence === 'one-time') {
      if (bill.status === 'paid') {
        bill.status = 'archived';
        summary.archived += 1;
      }
      return;
    }

    if (bill.rolloverStatus === 'autopay') {
      bill.status = 'autopay';
      summary.autopay += 1;
      return;
    }

    if (bill.variable) {
      bill.status = 'review';
      summary.review += 1;
      return;
    }

    bill.status = bill.rolloverStatus || 'upcoming';
    summary.recurring += 1;
  });

  STATE.monthlyOps = STATE.monthlyOps || {};
  STATE.monthlyOps.activeMonth = nextMonth;
  STATE.monthlyOps.lastRollover = new Date().toISOString().slice(0, 10);
  markChecklistDate('monthly_close', STATE.monthlyOps.lastRollover);
  saveState(STATE);
  renderAll();
  showToast(`New month started: ${summary.autopay} autopay, ${summary.review} review, ${summary.recurring} recurring reset`);
}

function markChecklistDate(id, date) {
  const item = STATE.monthlyOps?.checklist?.find(entry => entry.id === id);
  if (item) item.lastDone = date;
}

