  .statement-account-title { font-size: 15px; font-weight: 800; color: #123628; }
  .statement-account-note { font-size: 12px; color: #526158; margin-top: 3px; line-height: 1.45; }

  /* Advisor */
  .advisor-hero { display: grid; grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr); gap: 18px; margin-bottom: 18px; }
  .advisor-decision { border: 1px solid #d9d1c4; background: #fffdf8; border-radius: 22px; padding: 22px; box-shadow: 0 14px 35px rgba(18, 54, 40, 0.08); }
  .advisor-decision h3 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #526158; margin: 0 0 10px; font-weight: 800; }
  .advisor-headline { font-size: 28px; line-height: 1.15; font-weight: 850; color: #123628; margin-bottom: 8px; }
