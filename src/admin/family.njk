  .fin-alert.warn { background: #fef3c7; border: 1px solid #fcd34d; color: #92400e; }
  .fin-alert.info { background: #dbeafe; border: 1px solid #bfdbfe; color: #1e40af; }
  
  .fin-section { margin-top: 24px; }
