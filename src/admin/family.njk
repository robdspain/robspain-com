    bar.style.background = d.nw < -28000 ? '#ef4444' : d.nw < -25000 ? '#eab308' : '#3b82f6';
    bar.title = d.month + ': -$' + Math.abs(d.nw).toLocaleString();
    const label = document.createElement('div');
    label.className = 'nw-label';
    label.textContent = d.month;
    wrap.appendChild(bar);
    wrap.appendChild(label);
    chart.appendChild(wrap);
  });

  document.getElementById('nwSummary').innerHTML = `
    <div style="display:flex;justify-content:space-between;font-size:13px;">
      <span style="color:#64748b">Current Net Worth</span>
      <span style="font-weight:700;color:#ef4444;font-size:18px;">${currentNW >= 0 ? '' : '-'}${fmt(Math.abs(currentNW))}</span>
    </div>
    <div style="display:flex;justify-content:space-between;font-size:13px;margin-top:8px;">
      <span style="color:#64748b">12-month change</span>
      <span style="font-weight:600;color:${currentNW > -22165 ? '#22c55e' : '#ef4444'};">${currentNW > -22165 ? '+' : '-'}${fmt(Math.abs(currentNW - (-22165)))} (${currentNW > -22165 ? 'better' : 'worse'})</span>
    </div>
  `;
}

function renderDebtPayoff() {
  const debts = STATE.accounts.filter(a => a.balance < 0).map(a => {
    const bill = STATE.bills.find(b => b.name.toLowerCase().includes(a.name.split(' ')[0].toLowerCase()));
    const minPay = bill ? bill.amount : 0;
    const bal = Math.abs(a.balance);
    let payoff = minPay > 0 ? Math.ceil(bal / minPay) : 999;
    let payoffStr = payoff > 120 ? (Math.round(payoff / 12) + '+ years') : payoff > 12 ? ('~' + Math.round(payoff / 12) + ' years') : ('~' + payoff + ' months');
    const color = payoff > 60 ? '#ef4444' : payoff > 24 ? '#eab308' : '#22c55e';
    return { name: a.name, balance: bal, minPay, payoffStr, color };
  });

  document.getElementById('debtPayoff').innerHTML = `
    <table class="fin-table">
      <thead><tr><th>Account</th><th class="amt">Balance</th><th class="amt">Min Pay</th><th>Payoff at Min</th></tr></thead>
      <tbody>
        ${debts.map(d => `<tr>
          <td>${esc(d.name)}</td>
          <td class="amt" style="color:#ef4444">${fmt(d.balance)}</td>
          <td class="amt">${d.minPay ? fmt(d.minPay) : '—'}</td>
          <td style="color:${d.color};font-weight:600;">${d.payoffStr}</td>
        </tr>`).join('')}
      </tbody>
    </table>
    <div style="margin-top:20px;padding-top:16px;border-top:1px solid #e2e8f0;">
      <h3>Avalanche Strategy (save most interest)</h3>
      <div style="font-size:13px;color:#64748b;margin-bottom:12px;">Pay minimums on everything, throw any extra at the highest-interest debt first.</div>
      <ol style="font-size:13px;color:#1e293b;padding-left:20px;line-height:2;">
        <li><strong style="color:#ef4444;">Apple Card</strong> — highest interest rate, balance growing</li>
