    </tr>`;
  }).join('');

  // Debt breakdown
  const debts = STATE.accounts.filter(a => a.balance < 0);
  const totalDebt = debts.reduce((s, a) => s + Math.abs(a.balance), 0);
  const colors = ['#ef4444','#eab308','#3b82f6','#22c55e','#a855f7'];
  document.getElementById('debtBreakdown').innerHTML = debts.length ? `
    <h3>Debt Breakdown</h3>
    ${debts.map((a, i) => {
      const pct = Math.round(Math.abs(a.balance) / totalDebt * 100);
      return `<div style="margin-top:12px;">
        <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
          <span>${esc(a.name)}</span><span style="color:#64748b">${fmt(Math.abs(a.balance))} (${pct}%)</span>
        </div>
        <div class="fin-bar-bg"><div class="fin-bar" style="width:${pct}%;background:${colors[i%colors.length]}"></div></div>
      </div>`;
    }).join('')}
  ` : '';
}

