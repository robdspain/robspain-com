function saveStatementFolder(sourceKey, value) {
  STATE.statementFolders[sourceKey] = value.trim();
  saveState(STATE);
  showToast(statementSourceLabel(sourceKey) + ' Drive folder saved');
}

function openStatementFolder(sourceKey) {
  const url = STATE.statementFolders[sourceKey];
  if (!url) {
    showToast('Paste the Google Drive folder URL first');
    return;
  }
  window.open(url, '_blank', 'noopener');
}

function setStatementStatus(sourceKey, month, status, fileName) {
  STATE.statements[sourceKey] = normalizeStatements(STATE.statements[sourceKey] || [], sourceKey);
  const item = STATE.statements[sourceKey].find(statement => statement.month === month);
  if (!item) return;
  item.status = status;
  if (fileName) item.fileName = fileName;
  item.updatedAt = new Date().toISOString();
  if (status === 'downloaded' && !item.notes) item.notes = 'Downloaded locally; upload PDF/CSV to Google Drive.';
  if (status === 'partial') item.notes = 'CSV or summary data is available, but the monthly PDF statement still needs to be downloaded and uploaded.';
  if (status === 'uploaded') item.notes = 'Uploaded to Google Drive.';
  if (status === 'imported') item.notes = 'CSV imported into this dashboard.';
  saveState(STATE);
  renderAll();
  showToast(statementSourceLabel(sourceKey) + ' ' + formatMonth(month) + ' marked ' + status);
}

function editReserveFloor() {
  const current = Number(STATE.householdPlan?.reserveFloor ?? CASH_RESERVE_FLOOR);
  const val = prompt('Minimum checking/savings cash floor before paying optional bills:', current);
  if (val === null) return;
  const num = parseFloat(val);
  if (isNaN(num) || num < 0) return;
  STATE.householdPlan.reserveFloor = num;
  saveState(STATE);
  renderAll();
  showToast('Cash floor set to ' + fmt(num));
}

function editContributionTarget() {
  const totalIncome = getMonthlyIncomeTotal();
  const totalBills = getRobMonthlyBillTotal();
  const suggested = Math.max(0, totalBills - totalIncome);
  const current = Number(STATE.householdPlan?.contributionTarget || suggested);
  const val = prompt('Monthly household contribution target to close the budget gap:', current);
  if (val === null) return;
  const num = parseFloat(val);
  if (isNaN(num) || num < 0) return;
  STATE.householdPlan.contributionTarget = num;
  saveState(STATE);
