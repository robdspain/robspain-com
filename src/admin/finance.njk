    { month: 'Oct', nw: -26278 }, { month: 'Nov', nw: -26482 },
    { month: 'Dec', nw: -28655 }, { month: 'Jan', nw: -29007 },
    { month: 'Feb', nw: -30289 }, { month: 'Mar', nw: -31420 }
  ];
  // Add current computed net worth
  const currentNW = STATE.accounts.reduce((s, a) => s + a.balance, 0);
  data.push({ month: 'Apr', nw: currentNW });

  const maxAbs = Math.max(...data.map(d => Math.abs(d.nw)));
  const chart = document.getElementById('nwChart');
  chart.innerHTML = '';
  data.forEach(d => {
    const wrap = document.createElement('div');
    wrap.className = 'nw-bar-wrap';
    const bar = document.createElement('div');
    bar.className = 'nw-bar';
    const pct = (Math.abs(d.nw) / maxAbs) * 100;
    bar.style.height = pct + '%';
    bar.style.background = d.nw < -28000 ? '#ef4444' : d.nw < -25000 ? '#eab308' : '#3b82f6';
    bar.title = d.month + ': -$' + Math.abs(d.nw).toLocaleString();
    const label = document.createElement('div');
    label.className = 'nw-label';
    label.textContent = d.month;
    wrap.appendChild(bar);
    wrap.appendChild(label);
    chart.appendChild(wrap);
  });

  document.getElementById('nwSummary').innerHTML = `
    <div style="display:flex;justify-content:space-between;font-size:13px;">
      <span style="color:#64748b">Current Net Worth</span>
      <span style="font-weight:700;color:#ef4444;font-size:18px;">${currentNW >= 0 ? '' : '-'}${fmt(Math.abs(currentNW))}</span>
    </div>
    <div style="display:flex;justify-content:space-between;font-size:13px;margin-top:8px;">
      <span style="color:#64748b">12-month change</span>
      <span style="font-weight:600;color:${currentNW > -22165 ? '#22c55e' : '#ef4444'};">${currentNW > -22165 ? '+' : '-'}${fmt(Math.abs(currentNW - (-22165)))} (${currentNW > -22165 ? 'better' : 'worse'})</span>
    </div>
  `;
}

function renderDebtPayoff() {
