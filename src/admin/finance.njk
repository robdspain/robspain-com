---
layout: base.njk
title: Household Finance Dashboard - Rob Spain
permalink: /admin/finance/
---

<style>
  .fin-dash { max-width: 1200px; margin: 0 auto; padding: 20px; }
  .fin-dash * { box-sizing: border-box; }
  .fin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #e2e8f0; flex-wrap: wrap; gap: 8px; }
  .fin-header h2 { font-size: 24px; font-weight: 700; color: #1e293b; margin: 0; }
  .fin-header .updated { color: #64748b; font-size: 13px; }
  .fin-tabs { display: flex; gap: 4px; margin-bottom: 20px; flex-wrap: wrap; }
  .fin-tab { padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: 1px solid #e2e8f0; background: #f8fafc; color: #64748b; transition: all 0.2s; }
  .fin-tab:hover { border-color: #64748b; color: #1e293b; }
  .fin-tab.active { background: #3b82f6; border-color: #3b82f6; color: #fff; }
  .fin-panel { display: none; }
  .fin-panel.active { display: block; }
  .fin-grid { display: grid; gap: 16px; }
  .fin-grid-4 { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
  .fin-grid-2 { grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); }
  .fin-grid-3 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .fin-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; }
  .fin-card h3 { font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin: 0 0 12px 0; font-weight: 500; }
  .fin-stat { font-size: 28px; font-weight: 700; }
  .fin-stat.green { color: #22c55e; }
  .fin-stat.red { color: #ef4444; }
  .fin-stat.yellow { color: #eab308; }
  .fin-stat.blue { color: #3b82f6; }
  .fin-sub { font-size: 13px; color: #64748b; margin-top: 4px; }
  .fin-table { width: 100%; border-collapse: collapse; font-size: 14px; color: #1e293b; }
  .fin-table th { text-align: left; padding: 8px 12px; color: #64748b; font-weight: 500; font-size: 12px; text-transform: uppercase; border-bottom: 1px solid #e2e8f0; }
  .fin-table td { padding: 10px 12px; border-bottom: 1px solid #e2e8f0; }
  .fin-table tr:last-child td { border-bottom: none; }
  .fin-table .amt { text-align: right; font-variant-numeric: tabular-nums; }
  .fin-badge { display: inline-block; padding: 2px 8px; border-radius: 9999px; font-size: 11px; font-weight: 600; text-transform: uppercase; cursor: pointer; transition: all 0.15s; user-select: none; }
  .fin-badge:hover { transform: scale(1.08); filter: brightness(0.9); }
  .fin-badge:active { transform: scale(0.95); }
  .fin-badge.overdue { background: rgba(239,68,68,0.15); color: #ef4444; }
  .fin-badge.current { background: rgba(34,197,94,0.15); color: #22c55e; }
  .fin-badge.upcoming { background: rgba(59,130,246,0.15); color: #3b82f6; }
  .fin-badge.autopay { background: rgba(168,85,247,0.15); color: #a855f7; }
  .fin-badge.paid { background: rgba(34,197,94,0.25); color: #16a34a; }
  .sync-bar { display: none; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 10px 16px; margin-bottom: 16px; font-size: 13px; color: #1e40af; align-items: center; justify-content: space-between; }
  .sync-bar.visible { display: flex; }
  .sync-bar button { padding: 4px 12px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; border: none; background: #3b82f6; color: #fff; }
  .sync-bar button:hover { background: #2563eb; }
  .toast-msg { position: fixed; bottom: 20px; right: 20px; background: #16a34a; color: #fff; padding: 10px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; opacity: 0; transition: opacity 0.3s; z-index: 100; }
  .toast-msg.show { opacity: 1; }
  .fin-alert { border-radius: 8px; padding: 12px 16px; margin-bottom: 16px; font-size: 14px; color: #1e293b; }
  .fin-alert.danger { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); }
  .fin-alert.warn { background: rgba(234,179,8,0.1); border: 1px solid rgba(234,179,8,0.3); }
  .fin-alert.info { background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.3); }
  .fin-section { margin-top: 24px; }
  .fin-bar-bg { height: 8px; background: #e2e8f0; border-radius: 4px; overflow: hidden; margin-top: 8px; }
  .fin-bar { height: 100%; border-radius: 4px; }
  .fin-bar.green { background: #22c55e; }
  .fin-bar.red { background: #ef4444; }
  .fin-bar.yellow { background: #eab308; }
  .fin-bar.blue { background: #3b82f6; }
  .fin-bar.purple { background: #a855f7; }
  .fin-deficit { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 12px; padding: 20px; margin-top: 24px; text-align: center; }
  .fin-deficit .label { font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin-bottom: 8px; }
  .fin-deficit .amount { font-size: 36px; font-weight: 700; color: #ef4444; }
  .fin-deficit .note { font-size: 13px; color: #64748b; margin-top: 8px; }
  /* Editable cells */
  .editable { cursor: pointer; position: relative; border-radius: 4px; padding: 2px 4px; margin: -2px -4px; }
  .editable:hover { background: rgba(59,130,246,0.08); }
  .editable input, .editable select { font: inherit; border: 1px solid #3b82f6; border-radius: 4px; padding: 2px 6px; width: 100%; background: #fff; outline: none; box-shadow: 0 0 0 2px rgba(59,130,246,0.2); }
  .editable input[type="number"] { width: 90px; text-align: right; }
  /* Action buttons */
  .btn-sm { padding: 3px 8px; border-radius: 6px; font-size: 11px; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s; }
  .btn-add { background: #3b82f6; color: #fff; padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; }
  .btn-add:hover { background: #2563eb; }
  .btn-pay { background: rgba(34,197,94,0.15); color: #16a34a; }
  .btn-pay:hover { background: rgba(34,197,94,0.3); }
  .btn-del { background: rgba(239,68,68,0.1); color: #ef4444; }
  .btn-del:hover { background: rgba(239,68,68,0.2); }
  .btn-edit { background: rgba(59,130,246,0.1); color: #3b82f6; }
  .btn-edit:hover { background: rgba(59,130,246,0.2); }
  /* Modal */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; align-items: center; justify-content: center; }
  .modal-overlay.open { display: flex; }
  .modal { background: #fff; border-radius: 16px; padding: 24px; width: 90%; max-width: 480px; box-shadow: 0 20px 60px rgba(0,0,0,0.2); }
  .modal h3 { font-size: 18px; font-weight: 700; color: #1e293b; margin: 0 0 16px; }
  .modal label { display: block; font-size: 13px; font-weight: 500; color: #64748b; margin-bottom: 4px; margin-top: 12px; }
  .modal input, .modal select { width: 100%; padding: 8px 12px; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 14px; color: #1e293b; }
  .modal input:focus, .modal select:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 2px rgba(59,130,246,0.2); }
  .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 20px; }
  .modal-actions button { padding: 8px 20px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; }
  .modal-actions .btn-cancel { background: #f1f5f9; color: #64748b; }
  .modal-actions .btn-cancel:hover { background: #e2e8f0; }
  .modal-actions .btn-save { background: #3b82f6; color: #fff; }
  .modal-actions .btn-save:hover { background: #2563eb; }
  .modal-actions .btn-danger { background: #ef4444; color: #fff; }
  .modal-actions .btn-danger:hover { background: #dc2626; }
  /* Envelope styles */
  .envelope { border: 1px solid #e2e8f0; border-radius: 8px; padding: 12px 16px; margin-bottom: 8px; position: relative; overflow: hidden; }
  .envelope::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; border-radius: 8px 0 0 8px; }
  .envelope.p1::before { width: 4px; background: #ef4444; }
  .envelope.p2::before { width: 4px; background: #eab308; }
  .envelope.p3::before { width: 4px; background: #3b82f6; }
  .envelope.p4::before { width: 4px; background: #22c55e; }
  .envelope.unfunded { opacity: 0.5; border-style: dashed; }
  .envelope .env-row { display: flex; justify-content: space-between; align-items: center; }
  .envelope .env-name { font-size: 14px; font-weight: 500; padding-left: 8px; }
  .envelope .env-amt { font-size: 14px; font-weight: 700; font-variant-numeric: tabular-nums; }
  .envelope .env-bar { height: 4px; background: #e2e8f0; border-radius: 2px; margin-top: 6px; margin-left: 8px; overflow: hidden; }
  .envelope .env-fill { height: 100%; border-radius: 2px; }
  .env-priority { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin: 16px 0 8px; padding-bottom: 4px; border-bottom: 1px solid #e2e8f0; }
  .env-priority.p1 { color: #ef4444; }
  .env-priority.p2 { color: #eab308; }
  .env-priority.p3 { color: #3b82f6; }
  .env-priority.p4 { color: #22c55e; }
  /* Calendar styles */
  .cal-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid #e2e8f0; }
  .cal-row:last-child { border-bottom: none; }
  .cal-day { width: 48px; height: 48px; border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
  .cal-day .month { font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; }
  .cal-day .date { font-size: 18px; line-height: 1; }
  .cal-day.danger { background: rgba(239,68,68,0.15); color: #ef4444; }
  .cal-day.warn { background: rgba(234,179,8,0.15); color: #eab308; }
  .cal-day.ok { background: rgba(59,130,246,0.15); color: #3b82f6; }
  .cal-day.done { background: rgba(34,197,94,0.15); color: #22c55e; }
  .cal-info { flex: 1; }
  .cal-info .name { font-size: 14px; font-weight: 500; }
  .cal-info .detail { font-size: 12px; color: #64748b; margin-top: 2px; }
  .cal-amt { font-size: 14px; font-weight: 700; font-variant-numeric: tabular-nums; text-align: right; }
  /* Net worth chart */
  .nw-chart { display: flex; align-items: flex-end; gap: 2px; height: 120px; padding: 0 4px; }
  .nw-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
  .nw-bar { width: 100%; border-radius: 3px 3px 0 0; min-height: 2px; transition: height 0.3s; }
  .nw-label { font-size: 10px; color: #64748b; margin-top: 4px; text-align: center; }
  /* Import area */
  .import-zone { border: 2px dashed #e2e8f0; border-radius: 12px; padding: 32px; text-align: center; cursor: pointer; transition: all 0.2s; }
  .import-zone:hover { border-color: #3b82f6; background: rgba(59,130,246,0.05); }
  .import-zone.dragover { border-color: #22c55e; background: rgba(34,197,94,0.05); }
  .import-zone h4 { color: #1e293b; margin: 0 0 8px; font-size: 16px; }
  .import-zone p { color: #64748b; margin: 0; font-size: 13px; }
  .txn-list { max-height: 300px; overflow-y: auto; margin-top: 12px; }
  .txn-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #e2e8f0; font-size: 13px; }
  .txn-row .txn-date { color: #64748b; width: 80px; flex-shrink: 0; }
  .txn-row .txn-desc { flex: 1; padding: 0 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .txn-row .txn-amt { font-weight: 600; font-variant-numeric: tabular-nums; text-align: right; width: 80px; flex-shrink: 0; }
  .txn-row .txn-amt.debit { color: #ef4444; }
  .txn-row .txn-amt.credit { color: #22c55e; }
  .txn-summary { display: flex; gap: 16px; margin-top: 12px; padding-top: 12px; border-top: 1px solid #e2e8f0; font-size: 13px; }
  .txn-summary span { color: #64748b; }
  /* Payment history */
  .payment-row { display: flex; align-items: center; gap: 8px; padding: 8px 0; border-bottom: 1px solid #e2e8f0; font-size: 13px; }
  .payment-row:last-child { border-bottom: none; }
  .payment-row .pay-date { color: #64748b; width: 70px; flex-shrink: 0; }
  .payment-row .pay-name { flex: 1; font-weight: 500; }
  .payment-row .pay-amt { font-weight: 700; color: #22c55e; font-variant-numeric: tabular-nums; }
  .payment-row .pay-from { font-size: 11px; color: #94a3b8; margin-left: 8px; }
  @media (max-width: 600px) { .fin-grid-4 { grid-template-columns: 1fr 1fr; } .fin-grid-2, .fin-grid-3 { grid-template-columns: 1fr; } .fin-tabs { gap: 2px; } .fin-tab { padding: 6px 10px; font-size: 12px; } }
</style>

<div class="fin-dash">
  <div class="fin-header">
    <h2>Household Finance</h2>
    <span class="updated" id="lastUpdated">Updated: loading...</span>
  </div>

  <!-- Tab Navigation -->
  <div class="fin-tabs">
    <div class="fin-tab active" onclick="showPanel('overview', this)">Overview</div>
    <div class="fin-tab" onclick="showPanel('payments', this)">Payments</div>
    <div class="fin-tab" onclick="showPanel('envelopes', this)">Envelopes</div>
    <div class="fin-tab" onclick="showPanel('calendar', this)">Bill Calendar</div>
    <div class="fin-tab" onclick="showPanel('networth', this)">Net Worth</div>
    <div class="fin-tab" onclick="showPanel('import', this)">Import</div>
  </div>

  <!-- ═══════════════════════ OVERVIEW TAB ═══════════════════════ -->
  <div id="panel-overview" class="fin-panel active">

    <!-- Alerts -->
    <div id="alertsContainer"></div>

    <!-- Summary Cards -->
    <div class="fin-grid fin-grid-4" id="summaryCards"></div>

    <!-- Bills + Accounts -->
    <div class="fin-section">
      <div class="fin-grid fin-grid-2">
        <div class="fin-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <h3 style="margin:0;">Bills &amp; Due Dates</h3>
            <button class="btn-add" onclick="openAddBillModal()">+ Add Bill</button>
          </div>
          <table class="fin-table">
            <thead><tr><th>Bill</th><th>Due</th><th class="amt">Amount</th><th>Status</th><th></th></tr></thead>
            <tbody id="billsBody"></tbody>
          </table>
        </div>
        <div class="fin-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <h3 style="margin:0;">Account Balances</h3>
            <span style="font-size:11px;color:#94a3b8;">Click balance to edit</span>
          </div>
          <table class="fin-table">
            <thead><tr><th>Account</th><th class="amt">Balance</th><th>Notes</th></tr></thead>
            <tbody id="accountsBody"></tbody>
          </table>
          <div id="debtBreakdown" style="margin-top:20px;padding-top:16px;border-top:1px solid #e2e8f0;"></div>
        </div>
      </div>
    </div>

    <!-- Budget + Income -->
    <div class="fin-section">
      <div class="fin-grid fin-grid-2">
        <div class="fin-card" id="budgetCard"></div>
        <div class="fin-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <h3 style="margin:0;">Income Sources</h3>
            <span style="font-size:11px;color:#94a3b8;">Click amount to edit</span>
          </div>
          <table class="fin-table">
            <thead><tr><th>Source</th><th class="amt">Amount</th><th>Frequency</th></tr></thead>
            <tbody id="incomeBody"></tbody>
          </table>
          <div id="incomeTotalRow" style="margin-top:16px;padding-top:12px;border-top:1px solid #e2e8f0;display:flex;justify-content:space-between;font-weight:600;"></div>
        </div>
      </div>
    </div>

    <!-- Deficit Summary -->
    <div class="fin-deficit" id="deficitSummary"></div>
  </div>

  <!-- ═══════════════════════ PAYMENTS TAB ═══════════════════════ -->
  <div id="panel-payments" class="fin-panel">
    <div class="fin-alert info">
      <strong>Payment history:</strong> Log payments as you make them. Click "Log Payment" on any bill, or use the button below.
    </div>
    <div style="margin-bottom:16px;">
      <button class="btn-add" onclick="openPaymentModal()">+ Log Payment</button>
    </div>
    <div class="fin-grid fin-grid-2">
      <div class="fin-card">
        <h3>Recent Payments</h3>
        <div id="paymentsListFull"></div>
      </div>
      <div class="fin-card">
        <h3>Payment Summary</h3>
        <div id="paymentSummary"></div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════ ENVELOPES TAB ═══════════════════════ -->
  <div id="panel-envelopes" class="fin-panel">

    <div class="fin-alert info">
      <strong>Envelope budgeting:</strong> Every dollar of monthly income is assigned by priority. When money runs out, lower-priority envelopes go unfunded — making the deficit visible.
    </div>

    <div class="fin-grid fin-grid-2">
      <div class="fin-card" id="envelopesCard"></div>
      <div class="fin-card" id="envelopeSummaryCard"></div>
    </div>
  </div>

  <!-- ═══════════════════════ BILL CALENDAR TAB ═══════════════════════ -->
  <div id="panel-calendar" class="fin-panel">

    <div class="fin-alert info">
      <strong>Bill calendar:</strong> Auto-generated from your bills. Sorted by due date, overdue items first.
    </div>

    <div class="fin-grid fin-grid-2" id="calendarGrid"></div>
  </div>

  <!-- ═══════════════════════ NET WORTH TAB ═══════════════════════ -->
  <div id="panel-networth" class="fin-panel">

    <div class="fin-alert info">
      <strong>Net worth tracker:</strong> Assets minus debts over time. Based on EECU + Apple Card statement data (Mar 2025 — Mar 2026).
    </div>

    <div class="fin-grid fin-grid-2">
      <div class="fin-card">
        <h3>Net Worth Trend (12 months)</h3>
        <div class="nw-chart" id="nwChart"></div>
        <div style="display:flex;justify-content:space-between;margin-top:12px;font-size:12px;color:#64748b;">
          <span>Apr 2025</span>
          <span>Mar 2026</span>
        </div>
        <div id="nwSummary" style="margin-top:16px;padding-top:12px;border-top:1px solid #e2e8f0;"></div>
      </div>

      <div class="fin-card">
        <h3>Debt Payoff Projection</h3>
        <div id="debtPayoff"></div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════ IMPORT TAB ═══════════════════════ -->
  <div id="panel-import" class="fin-panel">

    <div class="fin-alert info">
      <strong>Transaction import:</strong> Drop CSV files from EECU or Apple Card to analyze spending. Files are processed locally in your browser — nothing is uploaded.
    </div>

    <div class="fin-grid fin-grid-2">
      <div class="fin-card">
        <div class="import-zone" id="importZone" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" onclick="document.getElementById('fileInput').click()">
          <input type="file" id="fileInput" accept=".csv" style="display:none" onchange="handleFile(this.files[0])">
          <h4>Drop CSV Here</h4>
          <p>EECU checking export or Apple Card CSV</p>
          <p style="margin-top:8px;font-size:11px;">Supports: EECU (.csv), Apple Card (.csv)</p>
        </div>
        <div id="importResults" style="display:none;margin-top:16px;">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <h3 id="importTitle">Imported Transactions</h3>
            <span id="importCount" style="font-size:13px;color:#64748b;"></span>
          </div>
          <div class="txn-summary" id="importSummary"></div>
          <div class="txn-list" id="txnList"></div>
        </div>
      </div>

      <div class="fin-card">
        <h3>How to Export Your Data</h3>
        <div style="margin-bottom:20px;">
          <div style="font-size:14px;font-weight:600;color:#1e293b;margin-bottom:8px;">EECU Checking</div>
          <ol style="font-size:13px;color:#64748b;padding-left:20px;line-height:1.8;">
            <li>Log into myeecu.org</li>
            <li>Go to Accounts > Checking</li>
            <li>Click "Export" or "Download transactions"</li>
            <li>Select date range and CSV format</li>
            <li>Drop the file here</li>
          </ol>
        </div>
        <div style="margin-bottom:20px;">
          <div style="font-size:14px;font-weight:600;color:#1e293b;margin-bottom:8px;">Apple Card</div>
          <ol style="font-size:13px;color:#64748b;padding-left:20px;line-height:1.8;">
            <li>Open Wallet app on iPhone</li>
            <li>Tap Apple Card > Card Balance</li>
            <li>Tap "Total Activity" for a month</li>
            <li>Scroll down, tap "Export Transactions"</li>
            <li>Email the CSV to yourself, then drop here</li>
          </ol>
        </div>
        <div style="padding:12px;background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:8px;">
          <div style="font-size:12px;color:#64748b;">
            <strong style="color:#3b82f6;">Privacy:</strong> Files are parsed entirely in your browser using JavaScript. No data leaves your device.
          </div>
        </div>
      </div>
    </div>
  </div>

  <div style="text-align:center;margin-top:24px;font-size:12px;color:#64748b;">
    Data managed by Paperclip CTO agent. All changes saved locally. <span id="convexStatus" style="color:#94a3b8;"></span>
  </div>
</div>

<div class="toast-msg" id="toast"></div>

<!-- Add Bill Modal -->
<div class="modal-overlay" id="addBillModal">
  <div class="modal">
    <h3 id="billModalTitle">Add New Bill</h3>
    <input type="hidden" id="editBillId">
    <label>Bill Name</label>
    <input type="text" id="billName" placeholder="e.g. PG&E">
    <label>Due Day (1-31, or leave blank)</label>
    <input type="number" id="billDueDay" min="1" max="31" placeholder="14">
    <label>Amount ($)</label>
    <input type="number" id="billAmount" step="0.01" placeholder="200.00">
    <label>Status</label>
    <select id="billStatus">
      <option value="upcoming">Upcoming</option>
      <option value="current">Active</option>
      <option value="overdue">Overdue</option>
      <option value="autopay">Autopay</option>
      <option value="paid">Paid</option>
    </select>
    <label>Priority</label>
    <select id="billPriority">
      <option value="1">P1 — Survival</option>
      <option value="2">P2 — Insurance/Debt</option>
      <option value="3">P3 — Necessities</option>
      <option value="4">P4 — On Credit</option>
    </select>
    <label>Account (paid from)</label>
    <input type="text" id="billAccount" placeholder="e.g. EECU Checking">
    <label>Notes</label>
    <input type="text" id="billNotes" placeholder="Optional notes">
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('addBillModal')">Cancel</button>
      <button class="btn-danger" id="deleteBillBtn" style="display:none" onclick="deleteBill()">Delete</button>
      <button class="btn-save" onclick="saveBill()">Save</button>
    </div>
  </div>
</div>

<!-- Log Payment Modal -->
<div class="modal-overlay" id="paymentModal">
  <div class="modal">
    <h3>Log Payment</h3>
    <label>Bill</label>
    <select id="payBill"></select>
    <label>Amount ($)</label>
    <input type="number" id="payAmount" step="0.01" placeholder="200.00">
    <label>Date</label>
    <input type="date" id="payDate">
    <label>From Account</label>
    <select id="payFrom">
      <option value="EECU Checking">EECU Checking</option>
      <option value="EECU Savings">EECU Savings</option>
      <option value="EECU LOC">Line of Credit</option>
      <option value="Apple Card">Apple Card</option>
      <option value="Other">Other</option>
    </select>
    <label>Notes</label>
    <input type="text" id="payNotes" placeholder="Optional notes">
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('paymentModal')">Cancel</button>
      <button class="btn-save" onclick="savePayment()">Log Payment</button>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════════════
// DATA STORE — localStorage now, Convex-ready structure
// ═══════════════════════════════════════════════════════════════
const STORE_KEY = 'spain-finance-v2';
const STATUS_CYCLE = ['overdue','upcoming','current','autopay','paid'];
const STATUS_LABELS = {overdue:'Overdue',upcoming:'Upcoming',current:'Active',autopay:'Autopay',paid:'Paid'};
const PRIORITY_LABELS = {1:'P1 Survival',2:'P2 Insurance/Debt',3:'P3 Necessities',4:'P4 On Credit'};

function defaultState() {
  return {
    bills: [
      { id:'rent', name:'Valley Vista (Rent)', dueDay:1, amount:2445, status:'upcoming', priority:1, account:'EECU Checking', notes:'' },
      { id:'support', name:'Supporting Hands', dueDay:null, amount:1800, status:'current', priority:4, account:'Apple Card', notes:'Childcare — on credit' },
      { id:'auto', name:'EECU Auto Loan', dueDay:5, amount:499, status:'autopay', priority:1, account:'EECU Checking', notes:'' },
      { id:'apple', name:'Apple Card Min', dueDay:27, amount:366, status:'paid', priority:2, account:'EECU Checking', notes:'' },
      { id:'collier', name:'Phillip M. Collier', dueDay:null, amount:375, status:'current', priority:4, account:'Apple Card', notes:'2-3x/mo' },
      { id:'toggle', name:'Toggle Insurance', dueDay:26, amount:202, status:'paid', priority:2, account:'EECU Debit', notes:'Car insurance' },
      { id:'pge', name:'PG&E', dueDay:14, amount:200, status:'upcoming', priority:1, account:'EECU Checking', notes:'Payment plan' },
      { id:'att', name:'AT&T Wireless', dueDay:null, amount:129, status:'current', priority:2, account:'EECU Checking', notes:'' },
      { id:'fresno', name:'City of Fresno', dueDay:1, amount:121, status:'overdue', priority:1, account:'EECU Checking', notes:'Water/sewer — shutoff risk' },
      { id:'xfinity', name:'Xfinity', dueDay:1, amount:95, status:'paid', priority:1, account:'EECU Checking', notes:'' },
      { id:'discover', name:'Discover Min', dueDay:18, amount:83, status:'upcoming', priority:2, account:'EECU Checking', notes:'' },
      { id:'loc', name:'EECU LOC Min', dueDay:26, amount:75, status:'upcoming', priority:2, account:'EECU Checking', notes:'' },
      { id:'principal', name:'Principal Insurance', dueDay:null, amount:35, status:'current', priority:2, account:'Auto-deduct', notes:'' },
      { id:'allstate', name:'Allstate Insurance', dueDay:null, amount:25, status:'current', priority:2, account:'Auto-deduct', notes:'' },
    ],
    accounts: [
      { id:'checking', name:'EECU Checking', type:'checking', balance:4009, notes:'After paycheck + payments' },
      { id:'savings', name:'EECU Savings', type:'savings', balance:87, notes:'Available' },
      { id:'loc', name:'Line of Credit', type:'loc', balance:-404, notes:'$9,596 available' },
      { id:'autoloan', name:'Auto Loan', type:'loan', balance:-16354, notes:'Due 04/05 autopay' },
      { id:'applecard', name:'Apple Card', type:'credit', balance:-16199, notes:'Paid $960 on 3/30' },
      { id:'discover', name:'Discover', type:'credit', balance:-1000, notes:'Min $83/mo' },
    ],
    income: [
      { id:'kcusd', name:'Kings Canyon USD', amount:4361, frequency:'Biweekly' },
      { id:'fpu', name:'FPU Payroll', amount:1093, frequency:'Monthly' },
      { id:'behavior', name:'Behavior School', amount:272, frequency:'Irregular' },
    ],
    payments: [
      { id:'p1', billName:'Toggle Insurance', amount:204, date:'2026-03-29', fromAccount:'EECU Debit', notes:'' },
      { id:'p2', billName:'Xfinity', amount:95, date:'2026-03-29', fromAccount:'EECU Checking', notes:'' },
      { id:'p3', billName:'Apple Card', amount:960, date:'2026-03-30', fromAccount:'EECU Checking', notes:'Exceeds $366 min' },
      { id:'p4', billName:'OFW Basic Plan', amount:110, date:'2026-03-03', fromAccount:'EECU Checking', notes:'Renewed' },
    ],
    lastUpdated: '2026-04-01T00:00:00Z',
  };
}

function loadState() {
  try {
    const raw = localStorage.getItem(STORE_KEY);
    if (raw) {
      const saved = JSON.parse(raw);
      // Merge with defaults to pick up new fields
      const def = defaultState();
      return {
        bills: saved.bills || def.bills,
        accounts: saved.accounts || def.accounts,
        income: saved.income || def.income,
        payments: saved.payments || def.payments,
        lastUpdated: saved.lastUpdated || def.lastUpdated,
      };
    }
  } catch(e) {}
  // Migrate from v1 localStorage if present
  try {
    const v1 = localStorage.getItem('spain-finance-bills');
    if (v1) {
      const statuses = JSON.parse(v1);
      const state = defaultState();
      state.bills.forEach(b => { if (statuses[b.id]) b.status = statuses[b.id]; });
      saveState(state);
      return state;
    }
  } catch(e) {}
  return defaultState();
}

function saveState(state) {
  state.lastUpdated = new Date().toISOString();
  localStorage.setItem(STORE_KEY, JSON.stringify(state));
}

let STATE = loadState();

// ═══════════════════════════════════════════════════════════════
// RENDER FUNCTIONS
// ═══════════════════════════════════════════════════════════════

function fmt(n) {
  return '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}

function fmtDate(d) {
  if (!d) return '';
  const parts = d.split('-');
  return parts[1] + '/' + parts[2];
}

function renderAll() {
  renderSummary();
  renderAlerts();
  renderBills();
  renderAccounts();
  renderIncome();
  renderBudget();
  renderDeficit();
  renderPayments();
  renderEnvelopes();
  renderCalendar();
  renderNetWorth();
  renderDebtPayoff();
  document.getElementById('lastUpdated').textContent = 'Updated: ' + new Date(STATE.lastUpdated).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
}

function renderSummary() {
  const cash = STATE.accounts.filter(a => a.type === 'checking' || a.type === 'savings').reduce((s, a) => s + Math.max(0, a.balance), 0);
  const locAcct = STATE.accounts.find(a => a.type === 'loc');
  const locAvail = locAcct ? 10000 + locAcct.balance : 0;
  const totalDebt = STATE.accounts.filter(a => a.balance < 0).reduce((s, a) => s + Math.abs(a.balance), 0);
  const totalIncome = STATE.income.reduce((s, i) => s + i.amount, 0);
  const totalBills = STATE.bills.reduce((s, b) => s + b.amount, 0);
  const deficit = totalIncome - totalBills;

  document.getElementById('summaryCards').innerHTML = `
    <div class="fin-card">
      <h3>Cash Available</h3>
      <div class="fin-stat ${cash > 2000 ? 'yellow' : 'red'}">${fmt(cash)}</div>
      <div class="fin-sub">${STATE.accounts.filter(a=>a.type==='checking'||a.type==='savings').map(a=>a.name+' '+fmt(a.balance)).join(' + ')}</div>
    </div>
    <div class="fin-card">
      <h3>LOC Available</h3>
      <div class="fin-stat blue">${fmt(locAvail)}</div>
      <div class="fin-sub">${fmt(Math.abs(locAcct?.balance||0))} used</div>
    </div>
    <div class="fin-card">
      <h3>Total Debt</h3>
      <div class="fin-stat red">${fmt(totalDebt)}</div>
      <div class="fin-sub">${STATE.accounts.filter(a=>a.balance<0).map(a=>a.name).join(', ')}</div>
    </div>
    <div class="fin-card">
      <h3>Monthly ${deficit >= 0 ? 'Surplus' : 'Deficit'}</h3>
      <div class="fin-stat ${deficit >= 0 ? 'green' : 'red'}">${deficit >= 0 ? '' : '-'}${fmt(Math.abs(deficit))}</div>
      <div class="fin-sub">Income ${fmt(totalIncome)} vs Bills ${fmt(totalBills)}</div>
    </div>
  `;
}

function renderAlerts() {
  const totalIncome = STATE.income.reduce((s, i) => s + i.amount, 0);
  const totalBills = STATE.bills.reduce((s, b) => s + b.amount, 0);
  const overdue = STATE.bills.filter(b => b.status === 'overdue');
  let html = '';
  if (totalBills > totalIncome) {
    html += `<div class="fin-alert danger"><strong>Structural deficit:</strong> Fixed expenses (${fmt(totalBills)}/mo) exceed income (${fmt(totalIncome)}/mo).</div>`;
  }
  if (overdue.length > 0) {
    html += `<div class="fin-alert danger"><strong>Overdue (${overdue.length}):</strong> ${overdue.map(b => b.name + ' ' + fmt(b.amount)).join(', ')}</div>`;
  }
  document.getElementById('alertsContainer').innerHTML = html;
}

function renderBills() {
  const tbody = document.getElementById('billsBody');
  tbody.innerHTML = STATE.bills.map((b, i) => {
    const dueStr = b.dueDay ? ordinal(b.dueDay) : 'Monthly';
    return `<tr>
      <td><span class="editable" onclick="editBill('${b.id}')" title="Click to edit">${esc(b.name)}</span></td>
      <td>${dueStr}</td>
      <td class="amt">${fmt(b.amount)}</td>
      <td><span class="fin-badge ${b.status}" onclick="cycleBill('${b.id}')" title="Click to change status">${STATUS_LABELS[b.status]}</span></td>
      <td style="white-space:nowrap;">
        <button class="btn-sm btn-pay" onclick="openPaymentFor('${b.id}')" title="Log payment">$</button>
        <button class="btn-sm btn-edit" onclick="editBill('${b.id}')" title="Edit">&#9998;</button>
      </td>
    </tr>`;
  }).join('');
}

function renderAccounts() {
  const tbody = document.getElementById('accountsBody');
  tbody.innerHTML = STATE.accounts.map(a => {
    const color = a.balance < 0 ? 'color:#ef4444' : a.type === 'loc' ? 'color:#3b82f6' : '';
    return `<tr>
      <td>${esc(a.name)}</td>
      <td class="amt"><span class="editable" onclick="editAccountBalance('${a.id}')" style="${color}" title="Click to edit">${a.balance < 0 ? '-' : ''}${fmt(a.balance)}</span></td>
      <td style="color:#64748b;font-size:13px;"><span class="editable" onclick="editAccountNotes('${a.id}')" title="Click to edit">${esc(a.notes || '—')}</span></td>
    </tr>`;
  }).join('');

  // Debt breakdown
  const debts = STATE.accounts.filter(a => a.balance < 0);
  const totalDebt = debts.reduce((s, a) => s + Math.abs(a.balance), 0);
  const colors = ['#ef4444','#eab308','#3b82f6','#22c55e','#a855f7'];
  document.getElementById('debtBreakdown').innerHTML = debts.length ? `
    <h3>Debt Breakdown</h3>
    ${debts.map((a, i) => {
      const pct = Math.round(Math.abs(a.balance) / totalDebt * 100);
      return `<div style="margin-top:12px;">
        <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
          <span>${esc(a.name)}</span><span style="color:#64748b">${fmt(Math.abs(a.balance))} (${pct}%)</span>
        </div>
        <div class="fin-bar-bg"><div class="fin-bar" style="width:${pct}%;background:${colors[i%colors.length]}"></div></div>
      </div>`;
    }).join('')}
  ` : '';
}

function renderIncome() {
  const tbody = document.getElementById('incomeBody');
  tbody.innerHTML = STATE.income.map(inc => `<tr>
    <td>${esc(inc.name)}</td>
    <td class="amt"><span class="editable" onclick="editIncomeAmount('${inc.id}')" title="Click to edit">${fmt(inc.amount)}</span></td>
    <td style="color:#64748b">${esc(inc.frequency)}</td>
  </tr>`).join('');

  const total = STATE.income.reduce((s, i) => s + i.amount, 0);
  document.getElementById('incomeTotalRow').innerHTML = `
    <span>Total Monthly Income</span>
    <span class="fin-stat green" style="font-size:20px;">${fmt(total)}</span>
  `;
}

function renderBudget() {
  const totalIncome = STATE.income.reduce((s, i) => s + i.amount, 0);
  const categories = {};
  STATE.bills.forEach(b => {
    const cat = b.priority <= 1 ? (b.name.match(/rent|vista/i) ? 'Housing' : 'Utilities & Essentials')
      : b.priority === 2 ? 'Insurance & Debt' : b.priority === 3 ? 'Necessities' : 'On Credit';
    categories[cat] = (categories[cat] || 0) + b.amount;
  });
  const colors = { 'Housing':'#ef4444', 'Utilities & Essentials':'#eab308', 'Insurance & Debt':'#3b82f6', 'Necessities':'#22c55e', 'On Credit':'#a855f7' };
  const totalBills = Object.values(categories).reduce((s, v) => s + v, 0);

  document.getElementById('budgetCard').innerHTML = `
    <h3>Monthly Budget Breakdown</h3>
    ${Object.entries(categories).map(([cat, amt]) => {
      const pct = Math.round(amt / totalIncome * 100);
      return `<div style="margin-bottom:12px;">
        <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
          <span>${cat}</span><span style="color:#64748b">${fmt(amt)} — ${pct}%</span>
        </div>
        <div class="fin-bar-bg"><div class="fin-bar" style="width:${Math.min(pct, 100)}%;background:${colors[cat]||'#94a3b8'}"></div></div>
      </div>`;
    }).join('')}
    <div style="margin-top:16px;padding-top:12px;border-top:1px solid #e2e8f0;display:flex;justify-content:space-between;font-weight:600;">
      <span>Total Recurring</span>
      <span style="color:${totalBills > totalIncome ? '#ef4444' : '#22c55e'}">${fmt(totalBills)}/mo</span>
    </div>
  `;
}

function renderDeficit() {
  const totalIncome = STATE.income.reduce((s, i) => s + i.amount, 0);
  const totalBills = STATE.bills.reduce((s, b) => s + b.amount, 0);
  const deficit = totalIncome - totalBills;
  const onCredit = STATE.bills.filter(b => b.priority === 4).reduce((s, b) => s + b.amount, 0);

  document.getElementById('deficitSummary').innerHTML = `
    <div class="label">Monthly Structural ${deficit >= 0 ? 'Surplus' : 'Deficit'}</div>
    <div class="amount">${deficit >= 0 ? '+' : '-'}${fmt(Math.abs(deficit))}/mo</div>
    ${onCredit > 0 ? `<div class="note">${fmt(onCredit)}/mo goes on credit card, adding to debt each month.</div>` : ''}
    <div style="margin-top: 16px; font-size: 13px; color: #64748b; text-align: left; max-width: 600px; margin-left: auto; margin-right: auto;">
      <strong style="color:#1e293b;">Biggest levers to close the gap:</strong>
      <ol style="margin-top: 8px; padding-left: 20px; line-height: 1.8;">
        <li><strong>Supporting Hands funding</strong> — if IHSS/insurance covers 50%, saves ~$900/mo</li>
        <li><strong>Increase behavior school income</strong> — currently ${fmt(STATE.income.find(i=>i.id==='behavior')?.amount||272)}/mo avg</li>
        <li><strong>Move Supporting Hands off Apple Card</strong> — stop interest compounding</li>
        <li><strong>AT&T plan review</strong> — ${fmt(STATE.bills.find(b=>b.id==='att')?.amount||129)}/mo may be reducible</li>
      </ol>
    </div>
  `;
}

function renderPayments() {
  const payments = [...STATE.payments].sort((a, b) => b.date.localeCompare(a.date));
  document.getElementById('paymentsListFull').innerHTML = payments.length === 0
    ? '<div style="color:#94a3b8;font-size:13px;padding:16px 0;">No payments logged yet. Click "Log Payment" to start tracking.</div>'
    : payments.map(p => `<div class="payment-row">
        <span class="pay-date">${fmtDate(p.date)}</span>
        <span class="pay-name">${esc(p.billName)}</span>
        <span class="pay-amt">${fmt(p.amount)}</span>
        <span class="pay-from">${esc(p.fromAccount || '')}</span>
        <button class="btn-sm btn-del" onclick="deletePayment('${p.id}')" title="Remove" style="margin-left:4px;">&times;</button>
      </div>`).join('');

  // Summary
  const thisMonth = new Date().toISOString().slice(0, 7);
  const monthPayments = payments.filter(p => p.date.startsWith(thisMonth));
  const totalMonth = monthPayments.reduce((s, p) => s + p.amount, 0);
  const totalAll = payments.reduce((s, p) => s + p.amount, 0);
  const paidBills = STATE.bills.filter(b => b.status === 'paid').length;

  document.getElementById('paymentSummary').innerHTML = `
    <div style="margin-bottom:16px;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:14px;">
        <span>This month</span><span style="font-weight:700;color:#22c55e;font-size:20px;">${fmt(totalMonth)}</span>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:14px;">
        <span>All time logged</span><span style="font-weight:700;color:#64748b;">${fmt(totalAll)}</span>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:14px;">
        <span>Bills marked paid</span><span style="font-weight:700;color:#22c55e;">${paidBills} / ${STATE.bills.length}</span>
      </div>
    </div>
    <div style="border-top:1px solid #e2e8f0;padding-top:16px;">
      <h3>By Account</h3>
      ${Object.entries(payments.reduce((acc, p) => { acc[p.fromAccount||'Unknown'] = (acc[p.fromAccount||'Unknown']||0) + p.amount; return acc; }, {}))
        .sort((a, b) => b[1] - a[1])
        .map(([acct, total]) => `<div style="display:flex;justify-content:space-between;font-size:13px;padding:4px 0;">
          <span>${esc(acct)}</span><span style="font-weight:600;">${fmt(total)}</span>
        </div>`).join('')}
    </div>
  `;
}

function renderEnvelopes() {
  const totalIncome = STATE.income.reduce((s, i) => s + i.amount, 0);
  let remaining = totalIncome;
  const groups = [
    { p: 1, label: 'Priority 1 — Survival', cls: 'p1' },
    { p: 2, label: 'Priority 2 — Insurance & Debt Minimums', cls: 'p2' },
    { p: 3, label: 'Priority 3 — Necessities', cls: 'p3' },
    { p: 4, label: 'Priority 4 — On Credit (adds to debt)', cls: 'p4' },
  ];

  let envelopeHtml = '<h3>April 2026 Envelopes</h3>';
  const groupTotals = [];

  groups.forEach(g => {
    const bills = STATE.bills.filter(b => b.priority === g.p);
    const groupTotal = bills.reduce((s, b) => s + b.amount, 0);
    const funded = g.p <= 3;
    envelopeHtml += `<div class="env-priority ${g.cls}">${g.label}</div>`;
    bills.forEach(b => {
      const isFunded = funded && remaining >= b.amount;
      if (funded) remaining -= b.amount;
      envelopeHtml += `<div class="envelope ${g.cls} ${!isFunded && g.p < 4 ? '' : g.p === 4 ? 'unfunded' : ''}">
        <div class="env-row">
          <span class="env-name">${esc(b.name)}</span>
          <span class="env-amt" style="color:${isFunded ? '#22c55e' : '#ef4444'}">${isFunded ? fmt(b.amount) : fmt(b.amount) + ' unfunded'}</span>
        </div>
        <div class="env-bar"><div class="env-fill" style="width:${isFunded ? 100 : 0}%;background:${isFunded ? '#22c55e' : '#ef4444'};"></div></div>
      </div>`;
    });
    const afterRemaining = funded ? Math.max(0, remaining) : remaining;
    envelopeHtml += `<div style="display:flex;justify-content:space-between;font-size:12px;color:#64748b;margin:8px 0 4px 8px;">
      <span>${g.cls.toUpperCase()} Total: ${fmt(groupTotal)}</span>
      ${g.p < 4 ? `<span style="color:${afterRemaining > 0 ? '#22c55e' : '#ef4444'}">Remaining: ${fmt(afterRemaining)}</span>` : `<span style="color:#ef4444">This adds to debt</span>`}
    </div>`;
    groupTotals.push({ label: g.label, total: groupTotal, cls: g.cls });
  });

  document.getElementById('envelopesCard').innerHTML = envelopeHtml;

  // Summary
  const onCredit = STATE.bills.filter(b => b.priority === 4).reduce((s, b) => s + b.amount, 0);
  const buffer = Math.max(0, totalIncome - STATE.bills.filter(b => b.priority <= 3).reduce((s, b) => s + b.amount, 0));
  const p1 = STATE.bills.filter(b => b.priority === 1).reduce((s, b) => s + b.amount, 0);
  const p2 = STATE.bills.filter(b => b.priority === 2).reduce((s, b) => s + b.amount, 0);
  const p3 = STATE.bills.filter(b => b.priority === 3).reduce((s, b) => s + b.amount, 0);

  document.getElementById('envelopeSummaryCard').innerHTML = `
    <h3>Envelope Summary</h3>
    <div style="margin-bottom:24px;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
        <span style="font-size:14px;">Monthly Income</span>
        <span style="font-size:20px;font-weight:700;color:#22c55e;">${fmt(totalIncome)}</span>
      </div>
      <div class="fin-bar-bg" style="height:24px;border-radius:6px;">
        <div style="height:100%;display:flex;border-radius:6px;overflow:hidden;">
          <div style="width:${p1/totalIncome*100}%;background:#ef4444;" title="P1: ${fmt(p1)}"></div>
          <div style="width:${p2/totalIncome*100}%;background:#eab308;" title="P2: ${fmt(p2)}"></div>
          <div style="width:${p3/totalIncome*100}%;background:#3b82f6;" title="P3: ${fmt(p3)}"></div>
          <div style="width:${buffer/totalIncome*100}%;background:#22c55e;" title="Buffer: ${fmt(buffer)}"></div>
        </div>
      </div>
      <div style="display:flex;gap:12px;margin-top:8px;flex-wrap:wrap;font-size:11px;">
        <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#ef4444;margin-right:4px;"></span>P1 ${fmt(p1)}</span>
        <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#eab308;margin-right:4px;"></span>P2 ${fmt(p2)}</span>
        <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#3b82f6;margin-right:4px;"></span>P3 ${fmt(p3)}</span>
        <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#22c55e;margin-right:4px;"></span>Buffer ${fmt(buffer)}</span>
      </div>
    </div>
    ${onCredit > 0 ? `
    <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:8px;padding:16px;margin-bottom:16px;">
      <div style="font-size:13px;font-weight:600;color:#ef4444;margin-bottom:8px;">THE HIDDEN COST</div>
      <div style="font-size:13px;color:#1e293b;line-height:1.6;">
        ${fmt(buffer)} looks like a buffer, but <strong>${fmt(onCredit)}/mo goes on Apple Card</strong> — that's new debt every month. The real deficit is:<br>
        <span style="font-size:20px;font-weight:700;color:#ef4444;display:block;margin-top:8px;">-${fmt(onCredit - buffer)}/mo net new debt</span>
        <span style="font-size:12px;color:#64748b;">Plus interest compounding on the balance</span>
      </div>
    </div>` : ''}
    <div style="border-top:1px solid #e2e8f0;padding-top:16px;">
      <h3>How Envelope Budgeting Helps</h3>
      <ul style="font-size:13px;color:#64748b;line-height:1.8;padding-left:16px;">
        <li>P1-P3 are <strong>fully funded</strong> from checking — these get paid first</li>
        <li>P4 items go on credit — they're <strong>visible as unfunded</strong></li>
        <li>If Supporting Hands gets insurance coverage, that $1,800 moves from P4 to P1</li>
        <li>The buffer covers irregular expenses and prevents new LOC draws</li>
      </ul>
    </div>
  `;
}

function renderCalendar() {
  const now = new Date();
  const month = now.getMonth();
  const year = now.getFullYear();
  const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  // Build calendar entries from bills
  const overdue = STATE.bills.filter(b => b.status === 'overdue');
  const paid = STATE.bills.filter(b => b.status === 'paid');
  const upcoming = STATE.bills.filter(b => b.status !== 'overdue' && b.status !== 'paid' && b.dueDay);

  let html = '<div class="fin-card"><h3>Overdue & Paid</h3>';
  overdue.forEach(b => {
    html += `<div class="cal-row">
      <div class="cal-day danger"><span class="month">${monthNames[month]}</span><span class="date">${b.dueDay || '?'}</span></div>
      <div class="cal-info"><div class="name">${esc(b.name)}</div><div class="detail">${esc(b.notes || '')}</div></div>
      <div class="cal-amt" style="color:#ef4444">${fmt(b.amount)}</div>
    </div>`;
  });
  paid.forEach(b => {
    html += `<div class="cal-row">
      <div class="cal-day done"><span class="month">${monthNames[month]}</span><span class="date">${b.dueDay || '?'}</span></div>
      <div class="cal-info"><div class="name">${esc(b.name)}</div><div class="detail">Paid</div></div>
      <div class="cal-amt" style="color:#22c55e">${fmt(b.amount)} paid</div>
    </div>`;
  });
  html += '</div>';

  html += '<div class="fin-card"><h3>Upcoming This Month</h3>';
  upcoming.sort((a, b) => (a.dueDay || 99) - (b.dueDay || 99)).forEach(b => {
    const isPast = b.dueDay < now.getDate();
    html += `<div class="cal-row">
      <div class="cal-day ${isPast ? 'warn' : 'ok'}"><span class="month">${monthNames[month]}</span><span class="date">${b.dueDay}</span></div>
      <div class="cal-info"><div class="name">${esc(b.name)}</div><div class="detail">${esc(b.account || '')} ${esc(b.notes || '')}</div></div>
      <div class="cal-amt">${fmt(b.amount)}</div>
    </div>`;
  });
  html += '</div>';

  document.getElementById('calendarGrid').innerHTML = html;
}

function renderNetWorth() {
  const data = [
    { month: 'Apr', nw: -22165 }, { month: 'May', nw: -22115 },
    { month: 'Jun', nw: -23033 }, { month: 'Jul', nw: -23201 },
    { month: 'Aug', nw: -23835 }, { month: 'Sep', nw: -24274 },
    { month: 'Oct', nw: -26278 }, { month: 'Nov', nw: -26482 },
    { month: 'Dec', nw: -28655 }, { month: 'Jan', nw: -29007 },
    { month: 'Feb', nw: -30289 }, { month: 'Mar', nw: -31420 }
  ];
  // Add current computed net worth
  const currentNW = STATE.accounts.reduce((s, a) => s + a.balance, 0);
  data.push({ month: 'Apr', nw: currentNW });

  const maxAbs = Math.max(...data.map(d => Math.abs(d.nw)));
  const chart = document.getElementById('nwChart');
  chart.innerHTML = '';
  data.forEach(d => {
    const wrap = document.createElement('div');
    wrap.className = 'nw-bar-wrap';
    const bar = document.createElement('div');
    bar.className = 'nw-bar';
    const pct = (Math.abs(d.nw) / maxAbs) * 100;
    bar.style.height = pct + '%';
    bar.style.background = d.nw < -28000 ? '#ef4444' : d.nw < -25000 ? '#eab308' : '#3b82f6';
    bar.title = d.month + ': -$' + Math.abs(d.nw).toLocaleString();
    const label = document.createElement('div');
    label.className = 'nw-label';
    label.textContent = d.month;
    wrap.appendChild(bar);
    wrap.appendChild(label);
    chart.appendChild(wrap);
  });

  document.getElementById('nwSummary').innerHTML = `
    <div style="display:flex;justify-content:space-between;font-size:13px;">
      <span style="color:#64748b">Current Net Worth</span>
      <span style="font-weight:700;color:#ef4444;font-size:18px;">${currentNW >= 0 ? '' : '-'}${fmt(Math.abs(currentNW))}</span>
    </div>
    <div style="display:flex;justify-content:space-between;font-size:13px;margin-top:8px;">
      <span style="color:#64748b">12-month change</span>
      <span style="font-weight:600;color:${currentNW > -22165 ? '#22c55e' : '#ef4444'};">${currentNW > -22165 ? '+' : '-'}${fmt(Math.abs(currentNW - (-22165)))} (${currentNW > -22165 ? 'better' : 'worse'})</span>
    </div>
  `;
}

function renderDebtPayoff() {
  const debts = STATE.accounts.filter(a => a.balance < 0).map(a => {
    const bill = STATE.bills.find(b => b.name.toLowerCase().includes(a.name.split(' ')[0].toLowerCase()));
    const minPay = bill ? bill.amount : 0;
    const bal = Math.abs(a.balance);
    let payoff = minPay > 0 ? Math.ceil(bal / minPay) : 999;
    let payoffStr = payoff > 120 ? (Math.round(payoff / 12) + '+ years') : payoff > 12 ? ('~' + Math.round(payoff / 12) + ' years') : ('~' + payoff + ' months');
    const color = payoff > 60 ? '#ef4444' : payoff > 24 ? '#eab308' : '#22c55e';
    return { name: a.name, balance: bal, minPay, payoffStr, color };
  });

  document.getElementById('debtPayoff').innerHTML = `
    <table class="fin-table">
      <thead><tr><th>Account</th><th class="amt">Balance</th><th class="amt">Min Pay</th><th>Payoff at Min</th></tr></thead>
      <tbody>
        ${debts.map(d => `<tr>
          <td>${esc(d.name)}</td>
          <td class="amt" style="color:#ef4444">${fmt(d.balance)}</td>
          <td class="amt">${d.minPay ? fmt(d.minPay) : '—'}</td>
          <td style="color:${d.color};font-weight:600;">${d.payoffStr}</td>
        </tr>`).join('')}
      </tbody>
    </table>
    <div style="margin-top:20px;padding-top:16px;border-top:1px solid #e2e8f0;">
      <h3>Avalanche Strategy (save most interest)</h3>
      <div style="font-size:13px;color:#64748b;margin-bottom:12px;">Pay minimums on everything, throw any extra at the highest-interest debt first.</div>
      <ol style="font-size:13px;color:#1e293b;padding-left:20px;line-height:2;">
        <li><strong style="color:#ef4444;">Apple Card</strong> — highest interest rate, balance growing</li>
        <li><strong style="color:#eab308;">Discover</strong> — likely high rate, small balance = quick win</li>
        <li><strong style="color:#3b82f6;">EECU LOC</strong> — small balance, LOC rate</li>
        <li><strong style="color:#64748b;">Auto Loan</strong> — lowest rate, keep at minimum</li>
      </ol>
    </div>
    <div style="margin-top:16px;padding:12px;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:8px;">
      <div style="font-size:13px;font-weight:600;color:#22c55e;margin-bottom:4px;">Quick win: Discover + LOC</div>
      <div style="font-size:12px;color:#64748b;">Both can be eliminated within 14 months at current minimums. Frees up $158/mo that can attack the Apple Card balance.</div>
    </div>
  `;
}

