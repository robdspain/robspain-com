function cycleBill(id) {
  const bill = STATE.bills.find(b => b.id === id);
  if (!bill) return;
  const idx = STATUS_CYCLE.indexOf(bill.status);
  bill.status = STATUS_CYCLE[(idx + 1) % STATUS_CYCLE.length];
  saveState(STATE);
  renderAll();
  showToast(bill.name + ' → ' + STATUS_LABELS[bill.status]);
}

function openAddBillModal() {
  document.getElementById('billModalTitle').textContent = 'Add New Bill';
  document.getElementById('editBillId').value = '';
  document.getElementById('billName').value = '';
  document.getElementById('billDueDay').value = '';
  document.getElementById('billAmount').value = '';
  document.getElementById('billStatus').value = 'upcoming';
  document.getElementById('billPriority').value = '3';
  document.getElementById('billAccount').value = 'EECU Checking';
  document.getElementById('billNotes').value = '';
  document.getElementById('deleteBillBtn').style.display = 'none';
  document.getElementById('addBillModal').classList.add('open');
}

function editBill(id) {
  const bill = STATE.bills.find(b => b.id === id);
  if (!bill) return;
  document.getElementById('billModalTitle').textContent = 'Edit Bill';
  document.getElementById('editBillId').value = id;
  document.getElementById('billName').value = bill.name;
  document.getElementById('billDueDay').value = bill.dueDay || '';
  document.getElementById('billAmount').value = bill.amount;
  document.getElementById('billStatus').value = bill.status;
  document.getElementById('billPriority').value = bill.priority;
  document.getElementById('billAccount').value = bill.account || '';
  document.getElementById('billNotes').value = bill.notes || '';
  document.getElementById('deleteBillBtn').style.display = 'inline-block';
  document.getElementById('addBillModal').classList.add('open');
}

function saveBill() {
  const id = document.getElementById('editBillId').value;
  const name = document.getElementById('billName').value.trim();
  const amount = parseFloat(document.getElementById('billAmount').value);
  if (!name || isNaN(amount)) { showToast('Name and amount required'); return; }

  const data = {
    name,
    dueDay: parseInt(document.getElementById('billDueDay').value) || null,
    amount,
    status: document.getElementById('billStatus').value,
    priority: parseInt(document.getElementById('billPriority').value),
    account: document.getElementById('billAccount').value.trim(),
    notes: document.getElementById('billNotes').value.trim(),
  };

  if (id) {
    const bill = STATE.bills.find(b => b.id === id);
    if (bill) Object.assign(bill, data);
    showToast('Updated ' + name);
  } else {
    data.id = 'bill_' + Date.now();
    STATE.bills.push(data);
    showToast('Added ' + name);
  }
  saveState(STATE);
  closeModal('addBillModal');
  renderAll();
}

function deleteBill() {
  const id = document.getElementById('editBillId').value;
  if (!id) return;
  const bill = STATE.bills.find(b => b.id === id);
  if (bill && confirm('Delete "' + bill.name + '"?')) {
    STATE.bills = STATE.bills.filter(b => b.id !== id);
    saveState(STATE);
    closeModal('addBillModal');
    renderAll();
    showToast('Deleted ' + bill.name);
  }
}

function openPaymentFor(billId) {
  const bill = STATE.bills.find(b => b.id === billId);
  openPaymentModal(bill ? bill.name : '', bill ? bill.amount : '');
}

function openPaymentModal(billName, amount) {
  const sel = document.getElementById('payBill');
  sel.innerHTML = '<option value="">— Select bill —</option>' +
    STATE.bills.map(b => `<option value="${esc(b.name)}" ${b.name === billName ? 'selected' : ''}>${esc(b.name)}</option>`).join('') +
    '<option value="__other__">Other...</option>';
  document.getElementById('payAmount').value = amount || '';
  document.getElementById('payDate').value = new Date().toISOString().split('T')[0];
  document.getElementById('payNotes').value = '';
  document.getElementById('paymentModal').classList.add('open');
}

function savePayment() {
  let billName = document.getElementById('payBill').value;
  if (billName === '__other__') billName = prompt('Bill name:');
  const amount = parseFloat(document.getElementById('payAmount').value);
  if (!billName || isNaN(amount)) { showToast('Bill and amount required'); return; }

  STATE.payments.push({
    id: 'pay_' + Date.now(),
    billName,
    amount,
    date: document.getElementById('payDate').value,
    fromAccount: document.getElementById('payFrom').value,
    notes: document.getElementById('payNotes').value.trim(),
  });

  // Auto-mark bill as paid
  const bill = STATE.bills.find(b => b.name === billName);
  if (bill && bill.status !== 'paid') {
    bill.status = 'paid';
  }

  saveState(STATE);
  closeModal('paymentModal');
  renderAll();
  showToast('Logged ' + fmt(amount) + ' for ' + billName);
}

function deletePayment(id) {
  STATE.payments = STATE.payments.filter(p => p.id !== id);
  saveState(STATE);
  renderAll();
  showToast('Payment removed');
}

function editAccountBalance(id) {
  const acct = STATE.accounts.find(a => a.id === id);
  if (!acct) return;
  const val = prompt('New balance for ' + acct.name + ' (use negative for debt):', acct.balance);
  if (val === null) return;
  const num = parseFloat(val);
  if (isNaN(num)) return;
  acct.balance = num;
  saveState(STATE);
  renderAll();
  showToast(acct.name + ' → ' + (num < 0 ? '-' : '') + fmt(Math.abs(num)));
}

function editAccountNotes(id) {
  const acct = STATE.accounts.find(a => a.id === id);
  if (!acct) return;
  const val = prompt('Notes for ' + acct.name + ':', acct.notes || '');
  if (val === null) return;
  acct.notes = val;
  saveState(STATE);
  renderAll();
}

function editIncomeAmount(id) {
  const inc = STATE.income.find(i => i.id === id);
  if (!inc) return;
  const val = prompt('Monthly amount for ' + inc.name + ':', inc.amount);
  if (val === null) return;
  const num = parseFloat(val);
  if (isNaN(num)) return;
  inc.amount = num;
  saveState(STATE);
  renderAll();
  showToast(inc.name + ' → ' + fmt(num));
}

