<style>
  .fin-dash { max-width: 1200px; margin: 0 auto; padding: 20px; }
  .fin-dash * { box-sizing: border-box; }
  .fin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #334155; flex-wrap: wrap; gap: 8px; }
  .fin-header h2 { font-size: 24px; font-weight: 700; color: #e2e8f0; margin: 0; }
  .fin-header .updated { color: #94a3b8; font-size: 13px; }
  .fin-header .actions { display: flex; gap: 8px; }
  .fin-tabs { display: flex; gap: 4px; margin-bottom: 20px; flex-wrap: wrap; }
  .fin-tab { padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: 1px solid #334155; background: #1e293b; color: #94a3b8; transition: all 0.2s; }
  .fin-tab:hover { border-color: #64748b; color: #e2e8f0; }
  .fin-tab.active { background: #3b82f6; border-color: #3b82f6; color: #fff; }
  .fin-panel { display: none; }
  .fin-panel.active { display: block; }
  .fin-grid { display: grid; gap: 16px; }
  .fin-grid-4 { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
  .fin-grid-2 { grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); }
  .fin-grid-3 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .fin-card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 20px; }
  .fin-card h3 { font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; margin: 0 0 12px 0; font-weight: 500; display: flex; justify-content: space-between; align-items: center; }
  .fin-stat { font-size: 28px; font-weight: 700; }
  .fin-stat.green { color: #22c55e; }
  .fin-stat.red { color: #ef4444; }
  .fin-stat.yellow { color: #eab308; }
  .fin-stat.blue { color: #3b82f6; }
  .fin-sub { font-size: 13px; color: #94a3b8; margin-top: 4px; }
  .fin-table { width: 100%; border-collapse: collapse; font-size: 14px; color: #e2e8f0; }
  .fin-table th { text-align: left; padding: 8px 12px; color: #94a3b8; font-weight: 500; font-size: 12px; text-transform: uppercase; border-bottom: 1px solid #334155; }
  .fin-table td { padding: 10px 12px; border-bottom: 1px solid #334155; }
  .fin-table tr:last-child td { border-bottom: none; }
  .fin-table tr:hover { background: rgba(59,130,246,0.05); }
  .fin-table .amt { text-align: right; font-variant-numeric: tabular-nums; }
  .fin-badge { display: inline-block; padding: 2px 8px; border-radius: 9999px; font-size: 11px; font-weight: 600; text-transform: uppercase; cursor: pointer; user-select: none; }
  .fin-badge:hover { filter: brightness(1.3); }
  .fin-badge.overdue { background: rgba(239,68,68,0.15); color: #ef4444; }
  .fin-badge.paid { background: rgba(34,197,94,0.15); color: #22c55e; }
  .fin-badge.upcoming { background: rgba(59,130,246,0.15); color: #3b82f6; }
  .fin-badge.autopay { background: rgba(168,85,247,0.15); color: #a855f7; }
  .fin-badge.oncard { background: rgba(234,179,8,0.15); color: #eab308; }
  .fin-alert { border-radius: 8px; padding: 12px 16px; margin-bottom: 16px; font-size: 14px; color: #e2e8f0; }
  .fin-alert.danger { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); }
  .fin-alert.warn { background: rgba(234,179,8,0.1); border: 1px solid rgba(234,179,8,0.3); }
  .fin-alert.info { background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.3); }
  .fin-section { margin-top: 24px; }
  .fin-bar-bg { height: 8px; background: #334155; border-radius: 4px; overflow: hidden; margin-top: 8px; }
  .fin-bar { height: 100%; border-radius: 4px; }
  .fin-bar.green { background: #22c55e; }
  .fin-bar.red { background: #ef4444; }
  .fin-bar.yellow { background: #eab308; }
  .fin-bar.blue { background: #3b82f6; }
  .fin-bar.purple { background: #a855f7; }
  .fin-deficit { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 12px; padding: 20px; margin-top: 24px; text-align: center; }
  .fin-deficit .label { font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; margin-bottom: 8px; }
  .fin-deficit .amount { font-size: 36px; font-weight: 700; color: #ef4444; }
  .fin-deficit .note { font-size: 13px; color: #94a3b8; margin-top: 8px; }
  .envelope { border: 1px solid #334155; border-radius: 8px; padding: 12px 16px; margin-bottom: 8px; position: relative; overflow: hidden; }
  .envelope::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; border-radius: 8px 0 0 8px; }
  .envelope.p1::before { width: 4px; background: #ef4444; }
  .envelope.p2::before { width: 4px; background: #eab308; }
  .envelope.p3::before { width: 4px; background: #3b82f6; }
  .envelope.p4::before { width: 4px; background: #22c55e; }
  .envelope.unfunded { opacity: 0.5; border-style: dashed; }
  .envelope .env-row { display: flex; justify-content: space-between; align-items: center; }
  .envelope .env-name { font-size: 14px; font-weight: 500; padding-left: 8px; }
  .envelope .env-amt { font-size: 14px; font-weight: 700; font-variant-numeric: tabular-nums; }
  .envelope .env-bar { height: 4px; background: #334155; border-radius: 2px; margin-top: 6px; margin-left: 8px; overflow: hidden; }
  .envelope .env-fill { height: 100%; border-radius: 2px; }
  .env-priority { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin: 16px 0 8px; padding-bottom: 4px; border-bottom: 1px solid #1e293b; }
  .env-priority.p1 { color: #ef4444; }
  .env-priority.p2 { color: #eab308; }
  .env-priority.p3 { color: #3b82f6; }
  .env-priority.p4 { color: #22c55e; }
  .cal-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid #1e293b; }
  .cal-row:last-child { border-bottom: none; }
  .cal-day { width: 48px; height: 48px; border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
  .cal-day .month { font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; }
  .cal-day .date { font-size: 18px; line-height: 1; }
  .cal-day.danger { background: rgba(239,68,68,0.15); color: #ef4444; }
  .cal-day.warn { background: rgba(234,179,8,0.15); color: #eab308; }
  .cal-day.ok { background: rgba(59,130,246,0.15); color: #3b82f6; }
  .cal-day.done { background: rgba(34,197,94,0.15); color: #22c55e; }
  .cal-info { flex: 1; }
  .cal-info .name { font-size: 14px; font-weight: 500; }
  .cal-info .detail { font-size: 12px; color: #94a3b8; margin-top: 2px; }
  .cal-amt { font-size: 14px; font-weight: 700; font-variant-numeric: tabular-nums; text-align: right; }
  .nw-chart { display: flex; align-items: flex-end; gap: 2px; height: 120px; padding: 0 4px; }
  .nw-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
  .nw-bar { width: 100%; border-radius: 3px 3px 0 0; min-height: 2px; transition: height 0.3s; }
  .nw-label { font-size: 10px; color: #64748b; margin-top: 4px; text-align: center; }
  .import-zone { border: 2px dashed #334155; border-radius: 12px; padding: 32px; text-align: center; cursor: pointer; transition: all 0.2s; }
  .import-zone:hover { border-color: #3b82f6; background: rgba(59,130,246,0.05); }
  .import-zone.dragover { border-color: #22c55e; background: rgba(34,197,94,0.05); }
  .import-zone h4 { color: #e2e8f0; margin: 0 0 8px; font-size: 16px; }
  .import-zone p { color: #64748b; margin: 0; font-size: 13px; }
  .txn-list { max-height: 300px; overflow-y: auto; margin-top: 12px; }
  .txn-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #1e293b; font-size: 13px; }
  .txn-row .txn-date { color: #64748b; width: 80px; flex-shrink: 0; }
  .txn-row .txn-desc { flex: 1; padding: 0 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .txn-row .txn-amt { font-weight: 600; font-variant-numeric: tabular-nums; text-align: right; width: 80px; flex-shrink: 0; }
  .txn-row .txn-amt.debit { color: #ef4444; }
  .txn-row .txn-amt.credit { color: #22c55e; }
  .txn-summary { display: flex; gap: 16px; margin-top: 12px; padding-top: 12px; border-top: 1px solid #334155; font-size: 13px; }
  .txn-summary span { color: #94a3b8; }
  .btn-sm { padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; border: 1px solid #334155; background: #1e293b; color: #94a3b8; transition: all 0.15s; }
  .btn-sm:hover { border-color: #3b82f6; color: #e2e8f0; }
  .btn-sm.primary { background: #3b82f6; border-color: #3b82f6; color: #fff; }
  .btn-sm.primary:hover { background: #2563eb; }
  .btn-sm.danger { color: #ef4444; border-color: transparent; background: transparent; }
  .btn-sm.danger:hover { background: rgba(239,68,68,0.1); }
  .editable { cursor: pointer; border-bottom: 1px dashed transparent; transition: border-color 0.2s; }
  .editable:hover { border-bottom-color: #3b82f6; }
  .edit-input { background: #0f172a; border: 1px solid #3b82f6; color: #e2e8f0; padding: 4px 8px; border-radius: 4px; font-size: 14px; width: 100%; font-family: inherit; }
  .edit-input:focus { outline: none; box-shadow: 0 0 0 2px rgba(59,130,246,0.3); }
  .payment-form { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 12px; }
  .payment-form select, .payment-form input { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 8px 12px; border-radius: 6px; font-size: 14px; font-family: inherit; }
  .payment-form select:focus, .payment-form input:focus { outline: none; border-color: #3b82f6; }
  @media (max-width: 600px) { .fin-grid-4 { grid-template-columns: 1fr 1fr; } .fin-grid-2, .fin-grid-3 { grid-template-columns: 1fr; } .fin-tabs { gap: 2px; } .fin-tab { padding: 6px 10px; font-size: 12px; } .payment-form { grid-template-columns: 1fr; } }
</style>

<div class="fin-dash">
  <div class="fin-header">
    <h2>Household Finance</h2>
    <div class="actions">
      <button class="btn-sm" onclick="exportData()">Export JSON</button>
      <button class="btn-sm" onclick="document.getElementById('jsonImport').click()">Import JSON</button>
      <input type="file" id="jsonImport" accept=".json" style="display:none" onchange="importData(this.files[0])">
    </div>
    <span class="updated" id="lastUpdated"></span>
  </div>

  <div class="fin-tabs">
    <div class="fin-tab active" onclick="showPanel('overview', this)">Overview</div>
    <div class="fin-tab" onclick="showPanel('envelopes', this)">Envelopes</div>
    <div class="fin-tab" onclick="showPanel('calendar', this)">Bill Calendar</div>
    <div class="fin-tab" onclick="showPanel('networth', this)">Net Worth</div>
    <div class="fin-tab" onclick="showPanel('payments', this)">Payments</div>
    <div class="fin-tab" onclick="showPanel('import', this)">CSV Import</div>
  </div>

  <div id="panel-overview" class="fin-panel active">
    <div id="alerts"></div>
    <div class="fin-grid fin-grid-4" id="summaryCards"></div>
    <div class="fin-section">
      <div class="fin-grid fin-grid-2">
        <div class="fin-card">
          <h3>Bills & Due Dates <button class="btn-sm primary" onclick="addBill()">+ Add</button></h3>
          <table class="fin-table"><thead><tr><th>Bill</th><th>Due</th><th class="amt">Amount</th><th>Status</th><th></th></tr></thead><tbody id="billsBody"></tbody></table>
        </div>
        <div class="fin-card">
          <h3>Account Balances <button class="btn-sm primary" onclick="addAccount()">+ Add</button></h3>
          <table class="fin-table"><thead><tr><th>Account</th><th class="amt">Balance</th><th>Notes</th><th></th></tr></thead><tbody id="accountsBody"></tbody></table>
        </div>
      </div>
    </div>
    <div class="fin-section">
      <div class="fin-grid fin-grid-2">
        <div class="fin-card">
          <h3>Monthly Budget Breakdown</h3>
          <div id="budgetBreakdown"></div>
        </div>
        <div class="fin-card">
          <h3>Income Sources <button class="btn-sm primary" onclick="addIncome()">+ Add</button></h3>
          <table class="fin-table"><thead><tr><th>Source</th><th class="amt">Amount</th><th>Frequency</th><th></th></tr></thead><tbody id="incomeBody"></tbody></table>
          <div id="incomeTotals" style="margin-top:16px;padding-top:12px;border-top:1px solid #334155;"></div>
        </div>
      </div>
    </div>
    <div class="fin-deficit" id="deficitCard"></div>
  </div>

  <div id="panel-envelopes" class="fin-panel">
    <div class="fin-alert info"><strong>Envelope budgeting:</strong> Bills are allocated by priority. P1 gets funded first, then P2, etc. Items past the budget line are shown as unfunded.</div>
    <div class="fin-card" id="envelopeContainer"></div>
  </div>

  <div id="panel-calendar" class="fin-panel">
    <div class="fin-grid fin-grid-2">
      <div class="fin-card">
        <h3>Upcoming Bills</h3>
        <div id="calendarList"></div>
      </div>
      <div class="fin-card">
        <h3>Cash Flow Projection</h3>
        <div id="cashFlowProjection"></div>
      </div>
    </div>
  </div>

  <div id="panel-networth" class="fin-panel">
    <div class="fin-grid fin-grid-2">
      <div class="fin-card">
        <h3>Net Worth Trend (12 months)</h3>
        <div class="nw-chart" id="nwChart"></div>
        <div id="nwSummary" style="margin-top:16px;text-align:center;"></div>
      </div>
      <div class="fin-card">
        <h3>Debt Breakdown</h3>
        <div id="debtBreakdown"></div>
        <div id="debtStrategy" style="margin-top:16px;"></div>
      </div>
    </div>
  </div>

  <div id="panel-payments" class="fin-panel">
    <div class="fin-grid fin-grid-2">
      <div class="fin-card">
        <h3>Log a Payment</h3>
        <div class="payment-form">
          <select id="payBill"><option value="">Select bill...</option></select>
          <input type="number" id="payAmount" placeholder="Amount" step="0.01">
          <input type="date" id="payDate">
          <select id="payFrom"><option value="">Paid from...</option></select>
        </div>
        <div style="margin-top:12px;"><button class="btn-sm primary" onclick="logPayment()">Log Payment</button></div>
      </div>
      <div class="fin-card">
        <h3>Payment History</h3>
        <div id="paymentHistory"></div>
      </div>
    </div>
  </div>

  <div id="panel-import" class="fin-panel">
    <div class="fin-alert info"><strong>Transaction import:</strong> Drop CSV files from EECU or Apple Card to analyze spending. Files are processed locally in your browser.</div>
    <div class="fin-grid fin-grid-2">
      <div class="fin-card">
        <div class="import-zone" id="importZone" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" onclick="document.getElementById('fileInput').click()">
          <input type="file" id="fileInput" accept=".csv" style="display:none" onchange="handleFile(this.files[0])">
          <h4>Drop CSV Here</h4>
          <p>EECU checking export or Apple Card CSV</p>
        </div>
        <div id="importResults" style="display:none;margin-top:16px;">
          <div style="display:flex;justify-content:space-between;align-items:center;"><h3 id="importTitle"></h3><span id="importCount" style="font-size:13px;color:#94a3b8;"></span></div>
          <div class="txn-summary" id="importSummary"></div>
          <div class="txn-list" id="txnList"></div>
        </div>
      </div>
      <div class="fin-card">
        <h3>How to Export Your Data</h3>
        <div style="margin-bottom:20px;">
          <div style="font-size:14px;font-weight:600;color:#e2e8f0;margin-bottom:8px;">EECU Checking</div>
          <ol style="font-size:13px;color:#94a3b8;padding-left:20px;line-height:1.8;">
            <li>Log into myeecu.org</li><li>Go to Accounts > Checking</li><li>Click "Export" or "Download transactions"</li><li>Select date range and CSV format</li><li>Drop the file here</li>
          </ol>
        </div>
        <div>
          <div style="font-size:14px;font-weight:600;color:#e2e8f0;margin-bottom:8px;">Apple Card</div>
          <ol style="font-size:13px;color:#94a3b8;padding-left:20px;line-height:1.8;">
            <li>Open Wallet app on iPhone</li><li>Tap Apple Card > Card Balance</li><li>Tap "Total Activity" for a month</li><li>Scroll down, tap "Export Transactions"</li><li>Email the CSV to yourself, then drop here</li>
          </ol>
        </div>
      </div>
    </div>
  </div>

  <div style="text-align:center;margin-top:24px;font-size:12px;color:#64748b;">
    All data stored in your browser's localStorage. Use Export/Import to back up. Managed by Paperclip Household CTO.
  </div>
</div>

<script>
const STORAGE_KEY = 'household-finance-v2';
const STATUSES = ['overdue','upcoming','oncard','autopay','paid'];
const STATUS_LABELS = { overdue:'Overdue', upcoming:'Upcoming', oncard:'On Card', autopay:'Autopay', paid:'Paid' };

const DEFAULT_DATA = {
  bills: [
    { id: 1, name: 'Valley Vista (Rent)', due: '1st', amount: 2445, status: 'upcoming', priority: 1, note: '' },
    { id: 2, name: 'Supporting Hands', due: 'Monthly', amount: 1800, status: 'oncard', priority: 4, note: 'court-ordered visitation' },
    { id: 3, name: 'EECU Auto Loan', due: '5th', amount: 499, status: 'autopay', priority: 1, note: '' },
    { id: 4, name: 'Apple Card Min', due: '~27th', amount: 374, status: 'upcoming', priority: 2, note: '' },
    { id: 5, name: 'Phillip M. Collier', due: '2-3x/mo', amount: 375, status: 'oncard', priority: 4, note: 'therapist' },
    { id: 6, name: 'Toggle Insurance', due: '26th', amount: 199, status: 'paid', priority: 2, note: 'car insurance' },
    { id: 7, name: 'PG&E', due: '14th', amount: 200, status: 'upcoming', priority: 1, note: 'payment plan' },
    { id: 8, name: 'AT&T Wireless', due: 'Monthly', amount: 129, status: 'oncard', priority: 1, note: '' },
    { id: 9, name: 'City of Fresno', due: '1st', amount: 121, status: 'overdue', priority: 1, note: 'water/sewer' },
    { id: 10, name: 'Xfinity', due: '1st', amount: 95, status: 'paid', priority: 1, note: '' },
    { id: 11, name: 'Discover Min', due: '~18th', amount: 83, status: 'upcoming', priority: 2, note: '' },
    { id: 12, name: 'EECU LOC Min', due: '26th', amount: 75, status: 'upcoming', priority: 2, note: '' },
    { id: 13, name: 'Principal Insurance', due: 'Monthly', amount: 35, status: 'autopay', priority: 2, note: '' },
    { id: 14, name: 'Allstate Insurance', due: 'Monthly', amount: 25, status: 'autopay', priority: 2, note: '' }
  ],
  accounts: [
    { id: 1, name: 'EECU Checking', balance: 220, type: 'asset', notes: 'Available' },
    { id: 2, name: 'EECU Savings', balance: 87, type: 'asset', notes: 'Available' },
    { id: 3, name: 'Line of Credit', balance: 9596, type: 'credit', notes: '$404 used' },
    { id: 4, name: 'Auto Loan', balance: -16354, type: 'debt', notes: 'Due 04/05 autopay' },
    { id: 5, name: 'Apple Card', balance: -14173, type: 'debt', notes: 'Min $374/mo' },
    { id: 6, name: 'Discover', balance: -1000, type: 'debt', notes: 'Min $83/mo (est)' }
  ],
  income: [
    { id: 1, name: 'Kings Canyon USD', amount: 4845, frequency: 'Monthly (verified from paystubs)' },
    { id: 2, name: 'FPU Payroll', amount: 1093, frequency: 'Monthly' },
    { id: 3, name: 'Behavior School', amount: 272, frequency: 'Irregular' }
  ],
  payments: [],
  netWorth: [
    { month: 'Apr 25', nw: -22165 }, { month: 'May', nw: -22115 }, { month: 'Jun', nw: -23033 },
    { month: 'Jul', nw: -23201 }, { month: 'Aug', nw: -23835 }, { month: 'Sep', nw: -24274 },
    { month: 'Oct', nw: -26278 }, { month: 'Nov', nw: -26482 }, { month: 'Dec', nw: -28655 },
    { month: 'Jan 26', nw: -29007 }, { month: 'Feb', nw: -30289 }, { month: 'Mar', nw: -31420 }
  ],
  updatedAt: null
};

let data;
function load() {
  try { data = JSON.parse(localStorage.getItem(STORAGE_KEY)); } catch(e) { data = null; }
  if (!data || !data.bills) data = JSON.parse(JSON.stringify(DEFAULT_DATA));
  if (!data.payments) data.payments = [];
}
function save() {
  data.updatedAt = new Date().toISOString();
  localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  document.getElementById('lastUpdated').textContent = 'Updated: ' + new Date(data.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}
function nextId(arr) { return arr.length ? Math.max(...arr.map(x => x.id)) + 1 : 1; }
function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function fmt(n) { return (n < 0 ? '-' : '') + '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 }); }

// Tab switching
function showPanel(name, el) {
  document.querySelectorAll('.fin-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.fin-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  if (el) el.classList.add('active');
  if (name === 'payments') renderPaymentForm();
}

// Inline editing
function editField(el, value, onSave) {
  const input = document.createElement('input');
  input.className = 'edit-input';
  input.value = value;
  input.style.width = Math.max(60, el.offsetWidth) + 'px';
  el.textContent = '';
  el.appendChild(input);
  input.focus();
  input.select();
  function finish() {
    const newVal = input.value.trim();
    onSave(newVal);
    save();
    renderAll();
  }
  input.addEventListener('blur', finish);
  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); input.blur(); } if (e.key === 'Escape') { input.value = value; input.blur(); } });
}

// Bills
function renderBills() {
  const tbody = document.getElementById('billsBody');
  tbody.innerHTML = data.bills.map(b => {
    const statusClass = b.status || 'upcoming';
    const statusLabel = STATUS_LABELS[statusClass] || statusClass;
    const noteHtml = b.note ? ' <span style="color:#64748b;font-size:12px">(' + esc(b.note) + ')</span>' : '';
    return '<tr>' +
      '<td><span class="editable" onclick="editBillName(' + b.id + ', this)">' + esc(b.name) + '</span>' + noteHtml + '</td>' +
      '<td><span class="editable" onclick="editBillDue(' + b.id + ', this)">' + esc(b.due) + '</span></td>' +
      '<td class="amt"><span class="editable" onclick="editBillAmount(' + b.id + ', this)">' + fmt(b.amount) + '</span></td>' +
      '<td><span class="fin-badge ' + statusClass + '" onclick="cycleBillStatus(' + b.id + ')">' + statusLabel + '</span></td>' +
      '<td><button class="btn-sm danger" onclick="deleteBill(' + b.id + ')" title="Delete">&times;</button></td>' +
      '</tr>';
  }).join('');
}
function editBillName(id, el) { const b = data.bills.find(x => x.id === id); if (b) editField(el, b.name, v => { b.name = v || b.name; }); }
function editBillDue(id, el) { const b = data.bills.find(x => x.id === id); if (b) editField(el, b.due, v => { b.due = v || b.due; }); }
function editBillAmount(id, el) { const b = data.bills.find(x => x.id === id); if (b) editField(el, b.amount, v => { const n = parseFloat(v.replace(/[$,]/g,'')); if (!isNaN(n)) b.amount = n; }); }
function cycleBillStatus(id) { const b = data.bills.find(x => x.id === id); if (!b) return; const i = STATUSES.indexOf(b.status); b.status = STATUSES[(i + 1) % STATUSES.length]; save(); renderAll(); }
function deleteBill(id) { data.bills = data.bills.filter(x => x.id !== id); save(); renderAll(); }
function addBill() {
  data.bills.push({ id: nextId(data.bills), name: 'New Bill', due: '1st', amount: 0, status: 'upcoming', priority: 3, note: '' });
  save(); renderAll();
}

// Accounts
function renderAccounts() {
  const tbody = document.getElementById('accountsBody');
  tbody.innerHTML = data.accounts.map(a => {
    const color = a.balance < 0 ? '#ef4444' : a.type === 'credit' ? '#3b82f6' : '#e2e8f0';
    return '<tr>' +
      '<td><span class="editable" onclick="editAccName(' + a.id + ', this)">' + esc(a.name) + '</span></td>' +
      '<td class="amt" style="color:' + color + '"><span class="editable" onclick="editAccBalance(' + a.id + ', this)">' + fmt(a.balance) + '</span></td>' +
      '<td><span class="editable" onclick="editAccNotes(' + a.id + ', this)" style="color:#94a3b8">' + esc(a.notes) + '</span></td>' +
      '<td><button class="btn-sm danger" onclick="deleteAccount(' + a.id + ')" title="Delete">&times;</button></td>' +
      '</tr>';
  }).join('');
}
function editAccName(id, el) { const a = data.accounts.find(x => x.id === id); if (a) editField(el, a.name, v => { a.name = v || a.name; }); }
function editAccBalance(id, el) { const a = data.accounts.find(x => x.id === id); if (a) editField(el, a.balance, v => { const n = parseFloat(v.replace(/[$,]/g,'')); if (!isNaN(n)) a.balance = n; }); }
function editAccNotes(id, el) { const a = data.accounts.find(x => x.id === id); if (a) editField(el, a.notes, v => { a.notes = v; }); }
function deleteAccount(id) { data.accounts = data.accounts.filter(x => x.id !== id); save(); renderAll(); }
function addAccount() {
  data.accounts.push({ id: nextId(data.accounts), name: 'New Account', balance: 0, type: 'asset', notes: '' });
  save(); renderAll();
}

// Income
function renderIncome() {
  const tbody = document.getElementById('incomeBody');
  tbody.innerHTML = data.income.map(i => {
    return '<tr>' +
      '<td><span class="editable" onclick="editIncName(' + i.id + ', this)">' + esc(i.name) + '</span></td>' +
      '<td class="amt"><span class="editable" onclick="editIncAmount(' + i.id + ', this)">' + fmt(i.amount) + '</span></td>' +
