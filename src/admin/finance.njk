function createVendorRuleFromTransaction(id) {
  ensureAccountingState();
  const txn = STATE.accounting.reviewQueue.find(row => row.id === id);
  if (!txn) return null;
  const payee = txn.payee || normalizePayee(txn.description, txn.amount);
  const match = payee || txn.description;
  const now = new Date().toISOString();
  const rule = {
    id: 'rule_' + simpleFingerprint([match, txn.entity, txn.category, txn.frappeAccount].join('|')).slice(4),
    match,
    payee,
    entity: txn.entity || STATE.accounting.activeEntity || 'behavior-school',
    category: txn.category || 'Uncategorized',
    taxCategory: txn.taxCategory || 'Needs CPA review',
    frappeAccount: txn.frappeAccount || frappeAccountForTransaction(txn),
    autoApprove: Boolean(txn.approved),
    confidence: Math.max(Number(txn.confidence || 0), 0.9),
    createdAt: now,
    updatedAt: now,
  };
  STATE.accounting.vendorRules = mergeVendorRules([rule], STATE.accounting.vendorRules || []);
  const applied = applyVendorRulesToQueue(false);
  saveState(STATE);
  renderAccountingHub();
  showToast('Saved vendor rule for ' + payee + (applied ? ` and applied to ${applied} row${applied === 1 ? '' : 's'}` : ''));
  return rule;
}

function deleteVendorRule(id) {
  ensureAccountingState();
  STATE.accounting.vendorRules = (STATE.accounting.vendorRules || []).filter(rule => rule.id !== id);
  saveState(STATE);
  renderAccountingHub();
  showToast('Vendor rule deleted');
}

function applyVendorRulesToQueue(showMessage = true) {
  ensureAccountingState();
  let count = 0;
  STATE.accounting.reviewQueue.forEach(row => {
    const before = JSON.stringify([row.entity, row.category, row.taxCategory, row.frappeAccount, row.approved, row.automationRuleId]);
    applyVendorRulesToRow(row);
    const after = JSON.stringify([row.entity, row.category, row.taxCategory, row.frappeAccount, row.approved, row.automationRuleId]);
    if (before !== after) {
      row.updatedAt = new Date().toISOString();
      count++;
    }
  });
  saveState(STATE);
  renderAccountingHub();
  if (showMessage) showToast(count ? `Applied vendor rules to ${count} row${count === 1 ? '' : 's'}` : 'No matching vendor rules found');
  return count;
}

function applyVendorRulesToRow(row) {
  if (!row) return row;
  const rule = matchingVendorRule(row);
  if (!rule) return row;
  row.payee = row.payee || normalizePayee(row.description, row.amount);
  row.entity = rule.entity || row.entity;
  row.category = rule.category || row.category;
  row.taxCategory = rule.taxCategory || row.taxCategory;
  row.frappeAccount = rule.frappeAccount || frappeAccountForTransaction(row);
  row.confidence = Math.max(Number(row.confidence || 0), Number(rule.confidence || 0.9));
  row.automationRuleId = rule.id;
  row.automationRuleName = rule.payee || rule.match;
  if (rule.autoApprove && isVendorRuleAutoApprovalSafe(row)) {
    row.approved = true;
    row.approvedByAutomation = true;
    row.approvedAt = row.approvedAt || new Date().toISOString();
  }
  return row;
}

function matchingVendorRule(row) {
  const haystack = [row.payee, row.description, row.sourceAccount].filter(Boolean).join(' ').toLowerCase();
  return (STATE.accounting.vendorRules || []).find(rule => {
    const match = String(rule.match || rule.payee || '').trim().toLowerCase();
    return match && haystack.includes(match);
  });
}

function isVendorRuleAutoApprovalSafe(row) {
  if (!row.sourceFile || !row.frappeAccount) return false;
  if (!Number.isFinite(Number(row.amount)) || Number(row.amount) === 0) return false;
  if (row.category === 'Document needs OCR' || row.category === 'Personal / exclude') return false;
  if (row.balanceCheck === 'mismatch') return false;
  return Number(row.confidence || 0) >= 0.75 || row.balanceCheck === 'matched' || row.reconciliationStatus === 'matched';
}

function updateFrappeAccountMapping(category, value) {
  ensureAccountingState();
  const account = String(value || '').trim();
  STATE.accounting.frappeSettings.categoryAccountMap[category] = account || defaultCategoryAccountMap(STATE.accounting.frappeSettings)[category] || STATE.accounting.defaultFrappeAccount || 'Expenses';
  remapFrappeAccountsForCategory(category);
  saveState(STATE);
  renderAccountingHub();
  showToast('Updated Frappe account map for ' + category);
}

function remapFrappeAccountsForCategory(category) {
  STATE.accounting.reviewQueue.forEach(row => {
    if (row.category !== category) return;
    row.frappeAccount = frappeAccountForTransaction(row);
    row.updatedAt = new Date().toISOString();
  });
}

function resetFrappeAccountMapping() {
  ensureAccountingState();
  STATE.accounting.frappeSettings.categoryAccountMap = defaultCategoryAccountMap(STATE.accounting.frappeSettings);
  STATE.accounting.reviewQueue.forEach(row => {
    row.frappeAccount = frappeAccountForTransaction(row);
    row.updatedAt = new Date().toISOString();
  });
  saveState(STATE);
  renderAccountingHub();
  showToast('Frappe account map reset');
}

function accountingCategoryAccountMap() {
  ensureAccountingState();
  const settings = STATE.accounting.frappeSettings || defaultFrappeSettings();
  return {
    ...defaultCategoryAccountMap(settings),
    ...(settings.categoryAccountMap || {}),
  };
}

function frappeAccountForTransaction(row) {
  const settings = STATE.accounting.frappeSettings || defaultFrappeSettings();
  const map = accountingCategoryAccountMap();
  const category = row.category || '';
  if (map[category]) return map[category];
  if (Number(row.amount) >= 0) return settings.defaultRevenueAccount || ACCOUNTING_ENTITIES[row.entity]?.defaultRevenueAccount || 'Sales';
  return settings.defaultExpenseAccount || STATE.accounting.defaultFrappeAccount || 'Expenses';
}

function updateAccountingTxn(id, field, value) {
  const txn = STATE.accounting.reviewQueue.find(t => t.id === id);
  if (!txn) return;
  txn[field] = field === 'frappeAccount' ? String(value || '').trim() : value;
  txn.updatedAt = new Date().toISOString();
  if (field === 'category') {
    const rule = ACCOUNTING_CATEGORY_RULES.find(r => r.category === value);
    if (rule) txn.taxCategory = rule.taxCategory;
    txn.frappeAccount = frappeAccountForTransaction(txn);
  }
  if (field === 'entity' && Number(txn.amount) >= 0) {
    txn.frappeAccount = frappeAccountForTransaction(txn);
  }
  saveState(STATE);
  renderAccountingHub();
}

function toggleAccountingApproval(id) {
  const txn = STATE.accounting.reviewQueue.find(t => t.id === id);
  if (!txn) return;
  txn.approved = !txn.approved;
  if (!txn.approved) {
    txn.approvedByAutomation = false;
    txn.approvedAt = '';
  } else {
    txn.approvedAt = new Date().toISOString();
  }
  txn.updatedAt = new Date().toISOString();
  saveState(STATE);
  renderAccountingHub();
}

function isAutomationReadyForApproval(row) {
  if (!row || row.approved) return false;
  if (row.category === 'Document needs OCR' || row.category === 'Personal / exclude') return false;
  if (row.balanceCheck === 'mismatch') return false;
  if (!row.sourceFile || !row.frappeAccount) return false;
  if (!Number.isFinite(Number(row.amount)) || Number(row.amount) === 0) return false;
  const confidence = Number(row.confidence) || 0;
  if (confidence >= 0.85) return true;
  if (confidence >= 0.75 && row.reconciliationStatus === 'matched') return true;
  if (confidence >= 0.75 && row.balanceCheck === 'matched') return true;
  return false;
}

function approveAutomationReadyRows() {
  ensureAccountingState();
  const now = new Date().toISOString();
  let count = 0;
  STATE.accounting.reviewQueue.forEach(row => {
    if (!isAutomationReadyForApproval(row)) return;
    row.approved = true;
    row.approvedByAutomation = true;
    row.approvedAt = now;
    row.updatedAt = now;
    count++;
  });
  saveState(STATE);
  renderAccountingHub();
  showToast(count ? `Approved ${count} automation-ready row${count === 1 ? '' : 's'}` : 'No automation-ready rows found');
  return count;
}

function seedAccountingFromExistingFinance() {
  ensureAccountingState();
  const seedRows = [];
  STATE.payments.forEach(p => {
    seedRows.push({
      date: p.date,
      description: p.billName + (p.notes ? ' - ' + p.notes : ''),
      amount: -Math.abs(p.amount),
      sourceAccount: p.fromAccount || 'Existing payments',
      entity: inferEntity(p.billName + ' ' + (p.notes || '')),
      sourceFile: 'Existing finance payments',
    });
  });
  STATE.income.forEach(i => {
    seedRows.push({
      date: new Date().toISOString().slice(0, 10),
      description: i.name + ' monthly income estimate',
      amount: Math.abs(i.amount),
      sourceAccount: 'Existing income',
      entity: inferEntity(i.name),
      sourceFile: 'Existing finance income',
    });
  });
  addAccountingTransactions(seedRows, 'existing-finance');
  showToast('Seeded accounting queue from current finance data');
}

function clearAccountingReviewQueue() {
  if (!confirm('Clear the accounting review queue? Existing bills, balances, and payments stay intact.')) return;
  STATE.accounting.reviewQueue = [];
  saveState(STATE);
  renderAccountingHub();
  showToast('Accounting review queue cleared');
}

function addAccountingTransactions(rows, sourceFile) {
  ensureAccountingState();
  const existingKeys = new Set(STATE.accounting.reviewQueue.map(t => t.importKey));
  const sourceFingerprint = rows.find(row => row.sourceFingerprint)?.sourceFingerprint || sourceFingerprintForRows(sourceFile, rows);
  const imported = [];
  rows.forEach((row, index) => {
    const normalized = normalizeAccountingRow({ ...row, sourceFingerprint }, sourceFile, index);
    if (!normalized || existingKeys.has(normalized.importKey)) return;
    existingKeys.add(normalized.importKey);
    imported.push(normalized);
  });
  const duplicateSource = STATE.accounting.importedFiles.some(file => file.fingerprint === sourceFingerprint);
  STATE.accounting.reviewQueue.push(...imported);
  STATE.accounting.importedFiles.push({
    name: sourceFile,
    importedAt: new Date().toISOString(),
    count: imported.length,
    fingerprint: sourceFingerprint,
    duplicateSource,
  });
  recordAccountingImportRun({
    source: sourceFile,
    sourceFile,
    sourceAccount: rows.find(row => row.sourceAccount)?.sourceAccount || document.getElementById('statementAccount')?.value || '',
    status: imported.length ? 'success' : 'partial',
    inserted: imported.length,
    skipped: rows.length - imported.length,
    rowCount: rows.length,
    fingerprint: sourceFingerprint,
    duplicateSource,
    persisted: false,
  });
  saveState(STATE);
  renderAccountingHub();
  logStatementParse(`Imported ${imported.length} new transaction${imported.length === 1 ? '' : 's'} from ${sourceFile}. Source fingerprint: ${sourceFingerprint}${duplicateSource ? ' (source seen before)' : ''}.`);
  return imported;
}

function normalizeAccountingRow(row, sourceFile, index) {
  const desc = String(row.description || row.desc || row.memo || row.name || '').trim();
  const date = normalizeDate(row.date || row.transactionDate || row.postedDate || '');
  const amount = normalizeAmount(row.amount);
  if (!desc || !date || !Number.isFinite(amount) || amount === 0) return null;
  const entity = row.entity || inferEntity(desc);
  const classified = classifyTransaction(desc, amount);
  const category = row.category || classified.category;
  const mappedFrappeAccount = frappeAccountForTransaction({ amount, entity, category });
  const incomingFrappeAccount = String(row.frappeAccount || '').trim();
  const keepIncomingFrappeAccount = incomingFrappeAccount && !['Sales', 'Expenses'].includes(incomingFrappeAccount);
  const reconciliation = row.reconciliationStatus
    ? {
        reconciliationStatus: row.reconciliationStatus,
        reconciliationType: row.reconciliationType || '',
        reconciliationName: row.reconciliationName || '',
        reconciliationId: row.reconciliationId || '',
        reconciliationConfidence: row.reconciliationConfidence || 0,
        reconciliationNotes: row.reconciliationNotes || '',
      }
    : reconcileExistingFinance({ description: desc, date, amount, sourceAccount: row.sourceAccount });
  const normalized = {
    id: 'acct_' + Date.now() + '_' + index + '_' + Math.random().toString(16).slice(2, 8),
    importKey: row.importKey || [date, desc.toLowerCase(), amount.toFixed(2), sourceFile].join('|'),
    date,
    description: desc,
    payee: row.payee || normalizePayee(desc, amount),
    amount,
    sourceAccount: row.sourceAccount || document.getElementById('statementAccount')?.value || 'Imported statement',
    sourceFile,
    sourceFingerprint: row.sourceFingerprint || '',
    ...reconciliation,
    entity,
    category,
    taxCategory: row.taxCategory || classified.taxCategory,
    frappeAccount: keepIncomingFrappeAccount ? incomingFrappeAccount : mappedFrappeAccount,
    confidence: row.confidence ?? classified.confidence,
    approved: typeof row.approved === 'boolean' ? row.approved : (row.confidence ?? classified.confidence) >= 0.85,
    approvedByAutomation: Boolean(row.approvedByAutomation),
    approvedAt: row.approvedAt || '',
    notes: row.notes || '',
    importProfile: row.importProfile || '',
    bankBalance: Number.isFinite(normalizeAmount(row.bankBalance ?? row.balance)) ? normalizeAmount(row.bankBalance ?? row.balance) : undefined,
    balanceCheck: row.balanceCheck || '',
    importedAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
  };
  return applyVendorRulesToRow(normalized);
}

function reconcileExistingFinance(row) {
  const candidates = [];
  const date = row.date || '';
  const amount = Number(row.amount) || 0;
  const desc = row.description || '';

  (STATE.payments || []).forEach(payment => {
    const expected = -Math.abs(Number(payment.amount) || 0);
    const amountScore = amountWithin(amount, expected, 2) ? 0.45 : 0;
    const dateScore = daysBetween(date, payment.date) <= 7 ? 0.25 : 0;
    const textScore = textMatchScore(desc, payment.billName);
    const score = amountScore + dateScore + (textScore * 0.3);
    if (score >= 0.55) {
      candidates.push({
        status: score >= 0.82 ? 'matched' : 'possible',
        type: 'payment',
        name: payment.billName,
        id: payment.id,
        confidence: Math.min(score, 0.98),
        notes: `Matches recorded payment ${payment.billName} on ${payment.date}.`,
      });
    }
  });

  (STATE.bills || []).forEach(bill => {
    const expected = -Math.abs(Number(bill.amount) || 0);
    const amountScore = amountWithin(amount, expected, Math.max(3, Math.abs(expected) * 0.03)) ? 0.45 : 0;
    const dueScore = bill.dueDay && date.slice(8, 10) ? (Math.abs(Number(date.slice(8, 10)) - Number(bill.dueDay)) <= 4 ? 0.15 : 0) : 0;
    const textScore = textMatchScore(desc, bill.name);
    const score = amountScore + dueScore + (textScore * 0.35);
    if (score >= 0.58) {
      candidates.push({
        status: score >= 0.82 ? 'matched' : 'possible',
        type: 'bill',
        name: bill.name,
        id: bill.id,
        confidence: Math.min(score, 0.95),
        notes: `Matches tracked bill ${bill.name}.`,
      });
    }
  });

  (STATE.income || []).forEach(income => {
    const expected = Math.abs(Number(income.amount) || 0);
    const amountScore = amountWithin(amount, expected, Math.max(5, expected * 0.05)) ? 0.5 : 0;
    const textScore = textMatchScore(desc, income.name);
    const score = amount > 0 ? amountScore + (textScore * 0.4) : 0;
    if (score >= 0.55) {
      candidates.push({
        status: score >= 0.82 ? 'matched' : 'possible',
        type: 'income',
        name: income.name,
        id: income.id,
        confidence: Math.min(score, 0.95),
        notes: `Matches tracked income ${income.name}.`,
      });
    }
  });

  candidates.sort((a, b) => b.confidence - a.confidence);
  const best = candidates[0];
  if (!best) {
    return {
      reconciliationStatus: 'unmatched',
      reconciliationType: '',
      reconciliationName: '',
      reconciliationId: '',
      reconciliationConfidence: 0,
      reconciliationNotes: 'No existing bill, payment, or income match found.',
    };
  }
  return {
    reconciliationStatus: best.status,
    reconciliationType: best.type,
    reconciliationName: best.name,
    reconciliationId: best.id,
    reconciliationConfidence: best.confidence,
    reconciliationNotes: best.notes,
  };
}

function amountWithin(actual, expected, tolerance) {
  return Number.isFinite(actual) && Number.isFinite(expected) && Math.abs(actual - expected) <= tolerance;
}

function daysBetween(a, b) {
  const aTime = Date.parse(a || '');
  const bTime = Date.parse(b || '');
  if (!Number.isFinite(aTime) || !Number.isFinite(bTime)) return Infinity;
  return Math.abs(aTime - bTime) / 86400000;
}

function textMatchScore(left, right) {
  const leftTokens = meaningfulTokens(left);
  const rightTokens = meaningfulTokens(right);
  if (!leftTokens.length || !rightTokens.length) return 0;
  const matches = rightTokens.filter(token => leftTokens.includes(token)).length;
  return matches / rightTokens.length;
}

function meaningfulTokens(text) {
  return String(text || '').toLowerCase()
    .replace(/[^a-z0-9\s]/g, ' ')
    .split(/\s+/)
    .filter(token => token.length >= 3 && !['the', 'and', 'for', 'min', 'payment', 'auto'].includes(token));
}

function sourceFingerprintForRows(sourceFile, rows, extra = {}) {
  const safeRows = Array.isArray(rows) ? rows : [];
  const dates = safeRows.map(row => normalizeDate(row.date || row.transactionDate || row.postedDate || '')).filter(Boolean).sort();
  const total = safeRows.reduce((sum, row) => sum + (Number(row.amount) || 0), 0);
  return simpleFingerprint([
    sourceFile || 'unknown-source',
    extra.size || '',
    extra.lastModified || '',
    safeRows.length,
    total.toFixed(2),
    dates[0] || '',
    dates[dates.length - 1] || '',
  ].join('|'));
}

function simpleFingerprint(value) {
  let hash = 2166136261;
  const text = String(value || '');
  for (let index = 0; index < text.length; index++) {
    hash ^= text.charCodeAt(index);
    hash = Math.imul(hash, 16777619);
  }
  return 'src_' + (hash >>> 0).toString(16).padStart(8, '0');
}

function classifyTransaction(description, amount) {
  const rule = ACCOUNTING_CATEGORY_RULES.find(r => r.match.test(description));
  if (rule) return rule;
  if (amount > 0) return { category: 'Sales', taxCategory: 'Gross receipts', confidence: 0.6 };
  return { category: 'Uncategorized', taxCategory: 'Needs CPA review', confidence: 0.35 };
}

function normalizePayee(description, amount) {
  const raw = String(description || '').trim();
  if (!raw) return Number(amount) >= 0 ? 'Customer' : 'Vendor';
  const known = [
    [/openai|chatgpt/i, 'OpenAI'],
    [/anthropic|claude/i, 'Anthropic'],
    [/google.*workspace|google/i, 'Google'],
    [/stripe/i, 'Stripe'],
    [/freshbooks/i, 'FreshBooks'],
    [/github/i, 'GitHub'],
    [/netlify/i, 'Netlify'],
    [/vercel/i, 'Vercel'],
    [/zoom/i, 'Zoom'],
    [/calendly/i, 'Calendly'],
    [/apple\.com\/bill|apple/i, 'Apple'],
    [/xfinity|comcast/i, 'Xfinity'],
    [/at&t|att\b/i, 'AT&T'],
    [/eecu|educational employees/i, 'EECU'],
  ];
  const found = known.find(([pattern]) => pattern.test(raw));
  if (found) return found[1];
  const cleaned = raw
    .replace(/\b(pos|debit|credit|card|purchase|checkcard|visa|mastercard|ach|online|mobile|payment|autopay|withdrawal|deposit|transfer)\b/gi, ' ')
    .replace(/\b(auth|trace|ref|id|terminal|term|seq|fitid)[:#]?\s*[a-z0-9-]+\b/gi, ' ')
    .replace(/\b\d{2}\/\d{2}(?:\/\d{2,4})?\b/g, ' ')
    .replace(/\b\d{4,}\b/g, ' ')
    .replace(/[*#_]/g, ' ')
    .replace(/\s{2,}/g, ' ')
    .trim();
  const candidate = cleaned || raw;
  return candidate
    .split(/\s+/)
    .slice(0, 6)
    .join(' ')
    .toLowerCase()
    .replace(/\b[a-z]/g, letter => letter.toUpperCase())
    .slice(0, 64);
}

function inferEntity(text) {
  if (/behavior school|stripe|freshbooks|invoice|rbt|bcba|student|cohort|course|tuition|customer/i.test(text)) return 'behavior-school';
  if (/robspain|speaking|consulting|calaba|website|rob spain/i.test(text)) return 'rob-spain';
  return STATE.accounting?.activeEntity || 'behavior-school';
}

function normalizeDate(value, fallbackYear) {
  const raw = String(value || '').trim();
  if (!raw) return '';
  if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
  const monthName = raw.match(/^(jan(?:uary)?|feb(?:ruary)?|mar(?:ch)?|apr(?:il)?|may|jun(?:e)?|jul(?:y)?|aug(?:ust)?|sep(?:t|tember)?|oct(?:ober)?|nov(?:ember)?|dec(?:ember)?)\.?\s+(\d{1,2})(?:,?\s+(\d{2,4}))?$/i);
  if (monthName) {
    const currentYear = new Date().getFullYear();
    const month = monthIndex(monthName[1]);
    const year = monthName[3] ? Number(monthName[3].length === 2 ? '20' + monthName[3] : monthName[3]) : (fallbackYear || currentYear);
    return [year, String(month).padStart(2, '0'), String(monthName[2]).padStart(2, '0')].join('-');
  }
  const mdy = raw.match(/^(\d{1,2})[\/-](\d{1,2})(?:[\/-](\d{2,4}))?$/);
  if (mdy) {
    const currentYear = new Date().getFullYear();
    const year = mdy[3] ? Number(mdy[3].length === 2 ? '20' + mdy[3] : mdy[3]) : (fallbackYear || currentYear);
    return [year, String(mdy[1]).padStart(2, '0'), String(mdy[2]).padStart(2, '0')].join('-');
  }
  const d = new Date(raw);
  return Number.isNaN(d.getTime()) ? '' : d.toISOString().slice(0, 10);
}

function monthIndex(value) {
  const month = String(value || '').toLowerCase().replace(/\./g, '').slice(0, 3);
  return ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'].indexOf(month) + 1;
}

function inferStatementYear(text, sourceName) {
  const haystack = [sourceName, text].filter(Boolean).join('\n');
  const explicitYears = [...haystack.matchAll(/\b(20\d{2})\b/g)].map(match => Number(match[1]));
  if (!explicitYears.length) return new Date().getFullYear();
  const counts = new Map();
  explicitYears.forEach(year => counts.set(year, (counts.get(year) || 0) + 1));
  return [...counts.entries()].sort((a, b) => b[1] - a[1] || b[0] - a[0])[0][0];
}

function normalizeAmount(value) {
  if (typeof value === 'number') return value;
  let raw = String(value || '').trim();
  const neg = raw.includes('(') && raw.includes(')');
  raw = raw.replace(/[,$()]/g, '');
  const num = parseFloat(raw);
  if (!Number.isFinite(num)) return NaN;
  return neg ? -Math.abs(num) : num;
}

function fmtCents(n) {
  const sign = n < 0 ? '-' : '';
  return sign + '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function handleAccountingDrop(e) {
  e.preventDefault();
  e.currentTarget.classList.remove('dragover');
  const file = e.dataTransfer.files[0];
  if (file) handleAccountingFile(file);
}

async function handleAccountingFile(file) {
  if (!file) return;
  const entity = document.getElementById('statementEntity').value || STATE.accounting.activeEntity;
  STATE.accounting.activeEntity = entity;
  logStatementParse('Reading ' + file.name + '...');
  const isPdf = file.name.toLowerCase().endsWith('.pdf');
  try {
    let text = '';
    if (isPdf) {
      text = await extractPdfText(file);
    } else {
      text = await file.text();
    }
    const parsed = parseStatementWithProfile(text, file.name);
    logStatementParse(`Profile: ${parsed.profile.label} (${Math.round(parsed.profile.confidence * 100)}% parser confidence).`);
    const fingerprintRows = parsed.rows.map(row => ({ ...row, entity }));
    const sourceFingerprint = sourceFingerprintForRows(file.name, fingerprintRows, { size: file.size, lastModified: file.lastModified });
    const rows = fingerprintRows.map(row => ({ ...row, sourceFingerprint }));
    if (!rows.length) {
      if (isPdf) {
        addOcrNeededRecord(file, 'PDF text was extracted, but no transaction rows matched. Run OCR or paste extracted text for this statement.');
        logStatementParse('No transaction rows detected; added an OCR/document-review item to the queue.');
      } else {
        logStatementParse('No transaction rows detected. Paste OCR or export text into the statement text box and parse it there.');
      }
      showToast(isPdf ? 'Added PDF for OCR review' : 'No transaction rows detected');
      return;
    }
    const imported = addAccountingTransactions(rows, file.name);
    showAccountingImportPreview(imported, file.name);
    showToast('Imported ' + imported.length + ' accounting rows');
  } catch (err) {
    if (isPdf) {
      addOcrNeededRecord(file, 'PDF text extraction failed: ' + err.message + '. Run OCR or paste extracted text for this statement.');
      logStatementParse('PDF text extraction failed; added an OCR/document-review item to the queue.');
      showToast('Added PDF for OCR review');
    } else {
      logStatementParse('Import failed: ' + err.message + '\nPaste statement text as a fallback.');
      showToast('Statement import failed');
    }
  }
}

async function extractPdfText(file) {
  let pdf = null;
  let text = '';
  try {
    const pdfjs = await import('https://cdn.jsdelivr.net/npm/pdfjs-dist@4.10.38/build/pdf.mjs');
    pdfjs.GlobalWorkerOptions.workerSrc = 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.10.38/build/pdf.worker.mjs';
    pdf = await pdfjs.getDocument({ data: await file.arrayBuffer() }).promise;
    const pages = [];
    for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
      const page = await pdf.getPage(pageNum);
      const content = await page.getTextContent();
      pages.push(content.items.map(item => item.str).join(' '));
    }
    text = pages.join('\n');
    if (hasTransactionSignals(text)) return text;
    logStatementParse('PDF text layer is sparse; trying OCR on rendered pages...');
    const ocrText = await extractPdfOcrText(pdf);
    if (ocrText.trim()) return [text, ocrText].filter(part => part && part.trim()).join('\n');
    return text;
  } catch (err) {
    const raw = new TextDecoder('utf-8', { fatal: false }).decode(await file.arrayBuffer());
    text = raw.replace(/[^\x09\x0A\x0D\x20-\x7E]+/g, ' ');
    if (text.trim().length >= 80) return text;
    throw err;
  }
}

function hasTransactionSignals(text) {
  const raw = String(text || '');
  const dateCount = (raw.match(/\b(\d{4}-\d{1,2}-\d{1,2}|\d{1,2}[\/-]\d{1,2}(?:[\/-]\d{2,4})?|(?:jan(?:uary)?|feb(?:ruary)?|mar(?:ch)?|apr(?:il)?|may|jun(?:e)?|jul(?:y)?|aug(?:ust)?|sep(?:t|tember)?|oct(?:ober)?|nov(?:ember)?|dec(?:ember)?)\.?\s+\d{1,2}(?:,?\s+\d{2,4})?)\b/gi) || []).length;
  const moneyCount = (raw.match(/-?\$?\(?\d[\d,]*\.\d{2}\)?/g) || []).length;
  return dateCount >= 1 && moneyCount >= 1;
}

async function loadTesseract() {
  if (window.Tesseract) return window.Tesseract;
  await new Promise((resolve, reject) => {
    const existing = document.querySelector('script[data-accounting-ocr="tesseract"]');
    if (existing) {
      existing.addEventListener('load', resolve, { once: true });
      existing.addEventListener('error', reject, { once: true });
      return;
    }
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/tesseract.js@5.1.1/dist/tesseract.min.js';
    script.async = true;
    script.dataset.accountingOcr = 'tesseract';
    script.onload = resolve;
    script.onerror = () => reject(new Error('Could not load OCR library'));
    document.head.appendChild(script);
  });
  if (!window.Tesseract) throw new Error('OCR library did not initialize');
  return window.Tesseract;
}

async function extractPdfOcrText(pdf) {
  if (!pdf || !document.createElement) return '';
  const Tesseract = await loadTesseract();
  const pages = [];
  const pageLimit = Math.min(pdf.numPages || 0, 8);
  for (let pageNum = 1; pageNum <= pageLimit; pageNum++) {
    logStatementParse('OCR page ' + pageNum + ' of ' + pageLimit + '...');
    const page = await pdf.getPage(pageNum);
    const viewport = page.getViewport({ scale: 2 });
    const canvas = document.createElement('canvas');
    const context = canvas.getContext('2d');
    canvas.width = Math.ceil(viewport.width);
    canvas.height = Math.ceil(viewport.height);
    await page.render({ canvasContext: context, viewport }).promise;
    const result = await Tesseract.recognize(canvas, 'eng');
    pages.push(result?.data?.text || '');
  }
  const text = pages.join('\n');
  if (text.trim()) logStatementParse('OCR extracted ' + text.trim().length + ' characters from PDF image pages.');
  return text;
}

function parsePastedStatementText() {
  const text = document.getElementById('statementTextPaste').value;
  if (!text.trim()) { showToast('Paste statement text first'); return; }
  const parsed = parseStatementWithProfile(text, 'pasted-statement.txt');
  logStatementParse(`Pasted statement profile: ${parsed.profile.label} (${Math.round(parsed.profile.confidence * 100)}%).`);
  const rows = parsed.rows.map(row => ({
    ...row,
    entity: document.getElementById('statementEntity').value || STATE.accounting.activeEntity,
    sourceAccount: document.getElementById('statementAccount').value,
  }));
  const sourceFingerprint = sourceFingerprintForRows('pasted-statement.txt', rows);
  rows.forEach(row => { row.sourceFingerprint = sourceFingerprint; });
  if (!rows.length) {
    logStatementParse('No rows detected from pasted statement text.');
    showToast('No transaction rows detected');
    return;
  }
  const imported = addAccountingTransactions(rows, 'pasted-statement.txt');
  showAccountingImportPreview(imported, 'pasted statement');
  showToast('Parsed ' + imported.length + ' rows from pasted text');
}

function parseStatementText(text, sourceName) {
  return parseStatementWithProfile(text, sourceName).rows;
}

function parseStatementWithProfile(text, sourceName) {
  const trimmed = String(text || '').trim();
  const profile = detectStatementProfile(trimmed, sourceName);
  const statementYear = inferStatementYear(trimmed, sourceName);
  if (!trimmed) return { rows: [], profile, warnings: ['No statement text was provided.'] };
  let rows = [];
  if (profile.format === 'csv') {
    const csvRows = parseStatementCsv(trimmed, { statementYear });
    if (csvRows.length) rows = csvRows;
  }
  if (profile.format === 'ofx') {
    const ofxRows = parseStatementOfx(trimmed, sourceName);
    if (ofxRows.length) rows = ofxRows;
  }
  if (!rows.length) rows = parseStatementLines(trimmed, sourceName, { statementYear });
  rows = rows.map(row => ({
    ...row,
    confidence: row.confidence ?? profile.confidence,
    importProfile: profile.id,
    notes: row.notes || 'Parsed as ' + profile.label,
  }));
  const warnings = rows.length ? [] : ['No transaction rows were detected for ' + profile.label + '.'];
  return { rows, profile, warnings };
}

function detectStatementProfile(text, sourceName) {
  const raw = String(text || '');
  const firstLine = raw.split(/\r?\n/).find(line => line.trim()) || '';
  const headerHaystack = (String(sourceName || '') + '\n' + firstLine).toLowerCase();
  const csvLike = isDelimitedHeader(firstLine);
  const statementDatePattern = String.raw`(?:\d{4}-\d{1,2}-\d{1,2}|\d{1,2}[\/-]\d{1,2}(?:[\/-]\d{2,4})?|(?:jan(?:uary)?|feb(?:ruary)?|mar(?:ch)?|apr(?:il)?|may|jun(?:e)?|jul(?:y)?|aug(?:ust)?|sep(?:t|tember)?|oct(?:ober)?|nov(?:ember)?|dec(?:ember)?)\.?\s+\d{1,2}(?:,?\s+\d{2,4})?)`;
  const transactionLineCount = raw.split(/\r?\n/).filter(line =>
    new RegExp(`${statementDatePattern}\\s+.+?\\s+-?\\$?\\(?\\d[\\d,]*\\.\\d{2}\\)?\\s*$`, 'i').test(line.trim())
  ).length;

  if (/<OFX|<STMTTRN|\.ofx|\.qfx/i.test(String(sourceName || '') + '\n' + raw.slice(0, 1000))) {
    return { id: 'ofx-qfx', label: 'OFX/QFX bank export', confidence: 0.88, format: 'ofx' };
  }
  if (/transaction date.*clearing date.*merchant.*amount|amount \(usd\)/i.test(headerHaystack) || /apple card/i.test(String(sourceName || ''))) {
    return { id: 'apple-card', label: 'Apple Card CSV', confidence: 0.9, format: 'csv' };
  }
  if (/balance_transaction|reporting_category|available_on|stripe balance/i.test(headerHaystack) || /stripe/i.test(String(sourceName || '')) && csvLike) {
    return { id: 'stripe-csv', label: 'Stripe CSV export', confidence: 0.9, format: csvLike ? 'csv' : 'text' };
  }
  if (/invoice_number|invoiceid|client_name|customer_name|amount_paid/i.test(headerHaystack) || /freshbooks/i.test(String(sourceName || '')) && csvLike) {
    return { id: 'freshbooks-csv', label: 'FreshBooks export', confidence: 0.86, format: csvLike ? 'csv' : 'text' };
  }
  if (/eecu|educational employees credit union|debit.*credit.*balance|withdrawal.*deposit/i.test(headerHaystack)) {
    return { id: 'eecu', label: 'EECU statement/export', confidence: 0.84, format: csvLike ? 'csv' : 'text' };
  }
  if (csvLike) return { id: 'generic-csv', label: 'Generic CSV statement', confidence: 0.68, format: 'csv' };
  if (transactionLineCount > 0) {
    return { id: 'statement-text', label: 'Statement text', confidence: Math.min(0.75, 0.48 + (transactionLineCount * 0.05)), format: 'text' };
  }
  return { id: 'unknown', label: 'Unknown statement format', confidence: 0.1, format: 'unknown' };
}

function parseStatementCsv(text, options = {}) {
  const lines = text.split(/\r?\n/).filter(l => l.trim());
  if (lines.length < 2) return [];
  const delimiter = detectCsvDelimiter(lines[0]) || ',';
  const headers = parseCSVLine(lines[0], delimiter).map(h => h.toLowerCase().trim());
  const findIdx = (...needles) => headers.findIndex(h => needles.some(n => h.includes(n)));
  const dateIdx = findIdx('date', 'posted');
  const descIdx = findIdx('description', 'merchant', 'payee', 'name', 'memo');
  const amountIdx = findIdx('amount');
  const debitIdx = findIdx('debit', 'withdrawal', 'charge');
  const creditIdx = findIdx('credit', 'deposit');
  const balanceIdx = findIdx('balance', 'running balance', 'available balance');
  const typeIdx = findIdx('type');
  if (dateIdx < 0 || descIdx < 0 || (amountIdx < 0 && debitIdx < 0 && creditIdx < 0)) return [];

  const rows = lines.slice(1).map(line => {
    const cols = parseCSVLine(line, delimiter);
    const desc = cols[descIdx] || '';
    const type = (cols[typeIdx] || '').toLowerCase();
    let amount = amountIdx >= 0 ? normalizeAmount(cols[amountIdx]) : 0;
    const debit = debitIdx >= 0 ? normalizeAmount(cols[debitIdx]) : NaN;
    const credit = creditIdx >= 0 ? normalizeAmount(cols[creditIdx]) : NaN;
    const balance = balanceIdx >= 0 ? normalizeAmount(cols[balanceIdx]) : NaN;
    if (Number.isFinite(debit) && Math.abs(debit) > 0) amount = -Math.abs(debit);
    if (Number.isFinite(credit) && Math.abs(credit) > 0) amount = Math.abs(credit);
    if (amount > 0 && /purchase|sale|debit|charge|fee/i.test(type)) amount = -Math.abs(amount);
    return {
      date: normalizeDate(cols[dateIdx], options.statementYear),
      description: desc,
      amount,
      bankBalance: Number.isFinite(balance) ? balance : undefined,
      sourceAccount: document.getElementById('statementAccount')?.value || 'Imported CSV',
    };
  });
  return applyCsvBalanceValidation(rows);
}

function parseStatementOfx(text, sourceName) {
  const raw = String(text || '');
  const accountId = ofxTag(raw, 'ACCTID') || document.getElementById('statementAccount')?.value || 'OFX account';
  const blocks = [...raw.matchAll(/<STMTTRN>([\s\S]*?)(?=<STMTTRN>|<\/BANKTRANLIST>|<\/CREDITCARDMSGSRSV1>|<\/OFX>|$)/gi)]
    .map(match => match[1]);
  return blocks.map(block => {
    const amount = normalizeAmount(ofxTag(block, 'TRNAMT'));
    const date = normalizeOfxDate(ofxTag(block, 'DTPOSTED') || ofxTag(block, 'DTUSER'));
    const name = ofxTag(block, 'NAME');
    const memo = ofxTag(block, 'MEMO');
    const fitid = ofxTag(block, 'FITID');
    const description = [name, memo].filter(Boolean).join(' - ') || ofxTag(block, 'TRNTYPE') || 'OFX transaction';
    if (!description || !date || !Number.isFinite(amount) || amount === 0) return null;
    return {
      importKey: fitid ? `ofx|${accountId}|${fitid}` : undefined,
      date,
      description,
      amount,
      sourceAccount: document.getElementById('statementAccount')?.value || `OFX ${accountId}`,
      sourceFile: sourceName,
      notes: fitid ? `OFX FITID ${fitid}` : 'Parsed from OFX/QFX export',
    };
  }).filter(Boolean);
}

function ofxTag(text, tag) {
  const match = String(text || '').match(new RegExp(`<${tag}>([^<\\r\\n]+)`, 'i'));
  return match ? match[1].trim() : '';
}

function normalizeOfxDate(value) {
  const raw = String(value || '').trim();
  const match = raw.match(/^(\d{4})(\d{2})(\d{2})/);
  if (!match) return '';
  return `${match[1]}-${match[2]}-${match[3]}`;
}

function applyCsvBalanceValidation(rows) {
  const parsed = rows.filter(row => row.description && Number.isFinite(row.amount) && row.amount !== 0);
  const balanceRows = parsed.filter(row => Number.isFinite(row.bankBalance));
  if (balanceRows.length < 2) return parsed;

  let forwardMatches = 0;
  let reverseMatches = 0;
  for (let index = 1; index < parsed.length; index++) {
    const prev = parsed[index - 1];
    const row = parsed[index];
    if (Number.isFinite(prev.bankBalance) && Number.isFinite(row.bankBalance) && Math.abs((prev.bankBalance + row.amount) - row.bankBalance) < 0.01) {
      forwardMatches++;
    }
  }
  for (let index = 0; index < parsed.length - 1; index++) {
    const row = parsed[index];
    const next = parsed[index + 1];
    if (Number.isFinite(row.bankBalance) && Number.isFinite(next.bankBalance) && Math.abs((row.bankBalance - row.amount) - next.bankBalance) < 0.01) {
      reverseMatches++;
    }
  }
  const order = reverseMatches > forwardMatches ? 'reverse' : 'forward';

  return parsed.map((row, index) => {
    let expected = NaN;
    if (order === 'forward' && index > 0 && Number.isFinite(parsed[index - 1].bankBalance)) {
      expected = parsed[index - 1].bankBalance + row.amount;
    } else if (order === 'reverse' && index < parsed.length - 1 && Number.isFinite(parsed[index + 1].bankBalance)) {
      expected = parsed[index + 1].bankBalance + row.amount;
    }
    if (!Number.isFinite(row.bankBalance) || !Number.isFinite(expected)) {
      return { ...row, balanceCheck: 'unchecked' };
    }
    const mismatch = Math.abs(expected - row.bankBalance) >= 0.01;
    if (!mismatch) return { ...row, balanceCheck: 'matched' };
    const warning = `Running balance mismatch: expected ${expected.toFixed(2)}, saw ${row.bankBalance.toFixed(2)}.`;
    return {
      ...row,
      balanceCheck: 'mismatch',
      confidence: Math.min(row.confidence ?? 0.5, 0.45),
      notes: [row.notes, warning].filter(Boolean).join(' '),
    };
  });
}

function parseStatementLines(text, sourceName, options = {}) {
  const lines = reconstructStatementLines(text);
  return applyCsvBalanceValidation(lines.map(line => parseStatementLine(line, sourceName, options)).filter(Boolean));
}

function reconstructStatementLines(text) {
  const lines = String(text || '').split(/\r?\n/).map(line => line.replace(/\s+/g, ' ').trim()).filter(Boolean);
  const dateStart = /^(?:\d{4}-\d{1,2}-\d{1,2}|\d{1,2}[\/-]\d{1,2}(?:[\/-]\d{2,4})?|(?:jan(?:uary)?|feb(?:ruary)?|mar(?:ch)?|apr(?:il)?|may|jun(?:e)?|jul(?:y)?|aug(?:ust)?|sep(?:t|tember)?|oct(?:ober)?|nov(?:ember)?|dec(?:ember)?)\.?\s+\d{1,2}(?:,?\s+\d{2,4})?)(?:\s+|$)/i;
  const rows = [];
  for (let index = 0; index < lines.length; index++) {
    if (!dateStart.test(lines[index])) continue;
    let candidate = lines[index];
    let cursor = index + 1;
    while (cursor < lines.length && !dateStart.test(lines[cursor]) && cursor - index <= 8) {
      candidate += ' ' + lines[cursor];
      cursor++;
    }
    rows.push(candidate);
    index = cursor - 1;
  }
  return rows;
}

function parseStatementLine(line, sourceName, options = {}) {
  const linePattern = /^(\d{4}-\d{1,2}-\d{1,2}|\d{1,2}[\/-]\d{1,2}(?:[\/-]\d{2,4})?|(?:jan(?:uary)?|feb(?:ruary)?|mar(?:ch)?|apr(?:il)?|may|jun(?:e)?|jul(?:y)?|aug(?:ust)?|sep(?:t|tember)?|oct(?:ober)?|nov(?:ember)?|dec(?:ember)?)\.?\s+\d{1,2}(?:,?\s+\d{2,4})?)\s+(.+)$/i;
  const match = String(line || '').trim().match(linePattern);
  if (!match) return null;
  const date = match[1];
  const rest = match[2].trim();
  const moneyPattern = /-?\$?\(?\d[\d,]*\.\d{2}\)?/g;
  const moneyMatches = [...rest.matchAll(moneyPattern)];
  if (!moneyMatches.length) return null;

  const lastMoney = moneyMatches[moneyMatches.length - 1];
  const previousMoney = moneyMatches.length > 1 ? moneyMatches[moneyMatches.length - 2] : null;
  const hasPossibleBalance = Boolean(previousMoney && lastMoney.index + lastMoney[0].length === rest.length);
  const amountToken = hasPossibleBalance ? previousMoney[0] : lastMoney[0];
  const balanceToken = hasPossibleBalance ? lastMoney[0] : '';
  const descEnd = hasPossibleBalance ? previousMoney.index : lastMoney.index;
  const desc = rest.slice(0, descEnd).replace(/\s+[-–—]\s*$/, '').trim();
  if (!desc) return null;

  let amount = normalizeAmount(amountToken);
  const bankBalance = normalizeAmount(balanceToken);
  if (amount > 0 && !/deposit|credit|payout|payroll|invoice|stripe|refund|transfer from/i.test(desc)) {
    amount = -Math.abs(amount);
  }

  return {
    date: normalizeDate(date, options.statementYear),
    description: desc,
    amount,
    bankBalance: Number.isFinite(bankBalance) ? bankBalance : undefined,
    sourceAccount: document.getElementById('statementAccount')?.value || sourceName || 'Imported statement',
  };
}

function addOcrNeededRecord(file, reason) {
  ensureAccountingState();
  const entity = document.getElementById('statementEntity')?.value || STATE.accounting.activeEntity || 'behavior-school';
  const sourceAccount = document.getElementById('statementAccount')?.value || 'Imported statement';
  const sourceFile = file?.name || 'scanned statement';
  const sourceFingerprint = simpleFingerprint([sourceFile, file?.size || 0, file?.lastModified || 0, entity, sourceAccount, 'ocr-needed'].join('|'));
  const importKey = ['ocr-needed', sourceFile, file?.size || 0, file?.lastModified || 0, entity, sourceAccount].join('|').toLowerCase();
  if (STATE.accounting.reviewQueue.some(t => t.importKey === importKey)) return null;
  const now = new Date().toISOString();
  const row = {
    id: 'ocr_' + Date.now() + '_' + Math.random().toString(16).slice(2, 8),
    importKey,
    date: now.slice(0, 10),
    description: 'Needs OCR: ' + sourceFile,
    amount: 0,
    sourceAccount,
    sourceFile,
    sourceFingerprint,
    entity,
    category: 'Document needs OCR',
    taxCategory: 'Needs document review',
    frappeAccount: 'Document review',
    confidence: 0,
    approved: false,
    notes: reason || 'PDF appears scanned or image-only; OCR text is needed before transaction import.',
    importProfile: 'ocr-needed',
    importedAt: now,
    updatedAt: now,
  };
  STATE.accounting.reviewQueue.push(row);
  STATE.accounting.importedFiles.push({
    name: sourceFile,
    importedAt: now,
    count: 0,
    status: 'needs-ocr',
    fingerprint: sourceFingerprint,
  });
  saveState(STATE);
  renderAccountingHub();
  return row;
}

function showAccountingImportPreview(imported, sourceName) {
  if (!imported || !imported.length) return;
  document.getElementById('importResults').style.display = 'block';
  document.getElementById('importTitle').textContent = sourceName;
  document.getElementById('importCount').textContent = imported.length + ' accounting rows';
  const income = imported.filter(t => t.amount > 0).reduce((s, t) => s + t.amount, 0);
  const expenses = imported.filter(t => t.amount < 0).reduce((s, t) => s + Math.abs(t.amount), 0);
  document.getElementById('importSummary').innerHTML =
    '<span>Total in: <strong style="color:#22c55e">' + fmtCents(income) + '</strong></span>' +
    '<span>Total out: <strong style="color:#ef4444">' + fmtCents(expenses) + '</strong></span>' +
    '<span>Net: <strong style="color:' + (income - expenses >= 0 ? '#22c55e' : '#ef4444') + '">' + fmtCents(income - expenses) + '</strong></span>';
  document.getElementById('txnList').innerHTML = imported.slice(0, 100).map(t => {
    const isDebit = t.amount < 0;
    return '<div class="txn-row">' +
      '<span class="txn-date">' + esc(t.date) + '</span>' +
      '<span class="txn-desc">' + esc(t.description) + '</span>' +
      '<span class="txn-amt ' + (isDebit ? 'debit' : 'credit') + '">' + fmtCents(t.amount) + '</span></div>';
  }).join('');
}

function logStatementParse(message) {
  const el = document.getElementById('statementParseLog');
  if (!el) return;
  el.style.display = 'block';
  el.textContent = '[' + new Date().toLocaleTimeString() + '] ' + message + '\n' + el.textContent;
}

function exportFrappeBooksCsv() {
  ensureAccountingState();
  const rows = STATE.accounting.reviewQueue.filter(isFrappeExportable);
  if (!rows.length) { showToast('Approve transactions before exporting'); return; }
  const csv = toCsv([
    ['Date', 'Party', 'Account', 'Debit', 'Credit', 'Description', 'Reference', 'Entity', 'Tax Category'],
    ...rows.map(t => [
      t.date,
      t.payee || partyForTransaction(t),
      t.frappeAccount || (t.amount >= 0 ? 'Sales' : STATE.accounting.defaultFrappeAccount),
      t.amount < 0 ? Math.abs(t.amount).toFixed(2) : '',
      t.amount > 0 ? t.amount.toFixed(2) : '',
      t.description,
      t.sourceFile || '',
      ACCOUNTING_ENTITIES[t.entity]?.label || t.entity,
      t.taxCategory || '',
    ]),
  ]);
  downloadText('frappe-books-import-' + todayStamp() + '.csv', csv, 'text/csv');
}

async function syncFrappeBooks(dryRun) {
  ensureAccountingState();
  const rows = STATE.accounting.reviewQueue.filter(isFrappeExportable);
  if (!rows.length) {
    frappeSyncStatus('No approved Frappe-exportable rows are ready.', '#dc2626');
    showToast('Approve rows before Frappe sync');
    return;
  }
  const startedAt = new Date().toISOString();
  frappeSyncStatus((dryRun ? 'Previewing' : 'Syncing') + ' ' + rows.length + ' row' + (rows.length === 1 ? '' : 's') + '...', '#64748b');
  try {
    const res = await fetch(ACCOUNTING_FRAPPE_SYNC_URL, {
      method: 'POST',
      headers: accountingAuthHeaders(),
      body: JSON.stringify({
        dryRun,
        rows,
        ...frappeSyncSettingsPayload(),
      }),
    });
    const payload = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(payload.error || 'HTTP ' + res.status);
    if (!payload.dryRun && Array.isArray(payload.results)) {
      markRowsSyncedToFrappe(payload.results);
    }
    const created = payload.created || 0;
    const failed = payload.failed || 0;
    const previewed = payload.entries?.length || 0;
    recordFrappeSyncRun(payload.frappeRun || {
      mode: payload.dryRun ? 'preview' : 'sync',
      status: failed ? (created ? 'partial' : 'failed') : 'success',
      configured: Boolean(payload.configured),
      rowCount: rows.length,
      entryCount: previewed || created,
      created,
      failed,
      skipped: payload.skipped || 0,
      company: frappeSyncSettingsPayload().company,
      defaultBankAccount: frappeSyncSettingsPayload().defaultBankAccount,
      note: payload.note || '',
      errors: payload.errors || [],
      startedAt,
      finishedAt: new Date().toISOString(),
    });
    const note = payload.note ? ' ' + payload.note : '';
    const label = payload.dryRun
      ? `Frappe preview ready: ${previewed} Journal Entry payload${previewed === 1 ? '' : 's'}.${note}`
      : `Frappe sync finished: ${created} created, ${failed} failed.`;
    frappeSyncStatus(label, failed ? '#dc2626' : (payload.dryRun ? '#d97706' : '#0f766e'));
    showToast(payload.dryRun ? 'Frappe sync preview ready' : 'Frappe sync complete');
    if (!payload.dryRun && created) {
      saveState(STATE);
      renderAccountingHub();
    } else {
      saveState(STATE);
      renderFrappeSyncRuns();
    }
  } catch (err) {
    recordFrappeSyncRun({
      mode: dryRun ? 'preview' : 'sync',
      status: 'failed',
      rowCount: rows.length,
      entryCount: 0,
      failed: rows.length,
      errors: [{ error: err.message }],
      startedAt,
      finishedAt: new Date().toISOString(),
    });
    saveState(STATE);
    renderFrappeSyncRuns();
    frappeSyncStatus('Frappe sync failed: ' + err.message, '#dc2626');
    showToast('Frappe sync failed');
  }
}

function frappeSyncSettingsPayload() {
  ensureAccountingState();
  const settings = STATE.accounting.frappeSettings || defaultFrappeSettings();
  return {
    company: settings.company || '',
    defaultBankAccount: settings.defaultBankAccount || '',
    defaultRevenueAccount: settings.defaultRevenueAccount || '',
    defaultExpenseAccount: settings.defaultExpenseAccount || STATE.accounting.defaultFrappeAccount || 'Expenses',
  };
}

function markRowsSyncedToFrappe(results) {
  const byKey = new Map((results || []).map(result => [result.importKey, result]));
  STATE.accounting.reviewQueue.forEach(row => {
    const result = byKey.get(row.importKey);
    if (!result) return;
    row.frappeSyncedAt = new Date().toISOString();
    row.frappeJournalEntry = result.name || '';
    row.updatedAt = new Date().toISOString();
  });
}

function exportCpaPackage() {
  ensureAccountingState();
  const queue = STATE.accounting.reviewQueue;
  if (!queue.length) { showToast('No accounting rows to export'); return; }
  const stamp = todayStamp();
  downloadText('cpa-accounting-review-' + stamp + '.csv', buildCpaReviewCsv(queue), 'text/csv');
  downloadText('cpa-accounting-summary-' + stamp + '.md', buildCpaSummaryMarkdown(queue), 'text/markdown');
  downloadText('cpa-accounting-manifest-' + stamp + '.json', JSON.stringify(buildCpaPackageManifest(queue), null, 2), 'application/json');
}

function buildCpaReviewCsv(queue) {
  const rows = Array.isArray(queue) ? queue : [];
  return toCsv([
    ['Date', 'Entity', 'Source Account', 'Description', 'Payee', 'Amount', 'Bank Balance', 'Balance Check', 'Category', 'Tax Category', 'Frappe Account', 'Approved', 'Approved By Automation', 'Approved At', 'Confidence', 'Source File', 'Source Fingerprint', 'Reconciliation Status', 'Reconciliation Type', 'Reconciliation Name', 'Reconciliation Confidence', 'Import Profile', 'Frappe Journal Entry', 'Notes'],
    ...rows.map(t => [
      t.date,
      ACCOUNTING_ENTITIES[t.entity]?.label || t.entity,
      t.sourceAccount || '',
      t.description,
      t.payee || partyForTransaction(t),
      t.amount.toFixed(2),
      Number.isFinite(Number(t.bankBalance)) ? Number(t.bankBalance).toFixed(2) : '',
      t.balanceCheck || '',
      t.category || '',
      t.taxCategory || '',
      t.frappeAccount || '',
      t.approved ? 'yes' : 'no',
      t.approvedByAutomation ? 'yes' : 'no',
      t.approvedAt || '',
      Math.round((t.confidence || 0) * 100) + '%',
      t.sourceFile || '',
      t.sourceFingerprint || '',
      t.reconciliationStatus || '',
      t.reconciliationType || '',
      t.reconciliationName || '',
      t.reconciliationConfidence ? Math.round(t.reconciliationConfidence * 100) + '%' : '',
      t.importProfile || '',
      t.frappeJournalEntry || '',
      t.notes || '',
    ]),
  ]);
}

function exportCpaSummary() {
  ensureAccountingState();
  const queue = STATE.accounting.reviewQueue;
  if (!queue.length) { showToast('No accounting rows to summarize'); return; }
  downloadText('cpa-accounting-summary-' + todayStamp() + '.md', buildCpaSummaryMarkdown(queue), 'text/markdown');
}

function buildCpaSummaryMarkdown(queue) {
  const rows = Array.isArray(queue) ? queue : [];
  const summary = summarizeCpaRows(rows);
  const lines = [
    '# CPA Accounting Summary',
    '',
    '- Generated: ' + new Date().toISOString(),
    '- Rows: ' + summary.rowCount,
    '- Approved: ' + summary.approvedCount,
    '- Approved by automation: ' + summary.automationApprovedCount,
    '- Needs review: ' + summary.needsReviewCount,
    '- OCR/document review: ' + summary.ocrNeededCount,
    '- Balance mismatches: ' + summary.balanceMismatchCount,
    '- Frappe synced: ' + summary.frappeSyncedCount,
    '- Reconciled: ' + summary.reconciledCount,
    '- Possible existing-finance matches: ' + summary.possibleReconciliationCount,
    '- Unmatched to existing finance: ' + summary.unmatchedReconciliationCount,
    '',
    '## Entity Totals',
    '',
    '| Entity | Income | Expenses | Net | Rows |',
    '| --- | ---: | ---: | ---: | ---: |',
    ...summary.entityTotals.map(row => `| ${row.label} | ${fmtCents(row.income)} | ${fmtCents(row.expenses)} | ${fmtCents(row.net)} | ${row.count} |`),
    '',
    '## Category Totals',
    '',
    '| Category | Income | Expenses | Net | Rows |',
    '| --- | ---: | ---: | ---: | ---: |',
    ...summary.categoryTotals.map(row => `| ${row.label} | ${fmtCents(row.income)} | ${fmtCents(row.expenses)} | ${fmtCents(row.net)} | ${row.count} |`),
    '',
    '## Review Exceptions',
    '',
    ...summary.reviewExceptions.map(row => '- ' + [row.date, row.entity, row.description, fmtCents(row.amount), row.reason].filter(Boolean).join(' | ')),
    '',
    '## Source Files',
    '',
    ...summary.sourceFiles.map(file => '- ' + file.name + (file.fingerprints.length ? ' (' + file.fingerprints.join(', ') + ')' : '')),
    '',
    '## Notes',
    '',
    STATE.accounting.cpaNotes || 'No CPA notes saved.',
    '',
  ];
  if (!summary.reviewExceptions.length) {
    const index = lines.indexOf('## Source Files');
    lines.splice(index - 1, 0, '- No exceptions detected.');
  }
  if (!summary.sourceFiles.length) {
    lines.splice(lines.length - 3, 0, '- No source files recorded.');
  }
  return lines.join('\n');
}

function buildCpaPackageManifest(queue, generatedAt = new Date().toISOString()) {
  const rows = Array.isArray(queue) ? queue : [];
  const summary = summarizeCpaRows(rows);
  const close = accountingCloseReadiness(rows);
  const stamp = generatedAt.slice(0, 10).replace(/-/g, '');
  const settings = STATE.accounting?.frappeSettings || defaultFrappeSettings();
  return {
    package: 'robspain-accounting-cpa-handoff',
    generatedAt,
    period: close.period,
    readyForCpa: close.ready,
    blockers: close.blockers,
    files: [
      { name: 'cpa-accounting-review-' + stamp + '.csv', type: 'review-csv', description: 'All normalized accounting rows with review status, source fingerprints, reconciliation, Frappe account, and notes.' },
      { name: 'cpa-accounting-summary-' + stamp + '.md', type: 'summary-markdown', description: 'CPA-facing totals, review exceptions, source list, and notes.' },
      { name: 'cpa-accounting-manifest-' + stamp + '.json', type: 'manifest-json', description: 'Machine-readable package manifest and close-readiness record.' },
    ],
    summary: {
      rows: summary.rowCount,
      approved: summary.approvedCount,
      approvedByAutomation: summary.automationApprovedCount,
      needsReview: summary.needsReviewCount,
      ocrNeeded: summary.ocrNeededCount,
      balanceMismatches: summary.balanceMismatchCount,
      frappeSynced: summary.frappeSyncedCount,
      reconciled: summary.reconciledCount,
      possibleReconciliation: summary.possibleReconciliationCount,
      unmatchedReconciliation: summary.unmatchedReconciliationCount,
    },
    closeReadiness: {
      period: close.period,
      rows: close.rowCount,
      income: Number(close.income.toFixed(2)),
      expenses: Number(close.expenses.toFixed(2)),
      net: Number(close.net.toFixed(2)),
      frappePending: close.frappePendingCount,
      missingSources: close.sourceMissingCount,
      ready: close.ready,
      blockers: close.blockers,
    },
    sourceFiles: summary.sourceFiles,
    entityTotals: summary.entityTotals,
    categoryTotals: summary.categoryTotals,
    frappe: {
      company: settings.company || '',
      defaultBankAccount: settings.defaultBankAccount || '',
      defaultRevenueAccount: settings.defaultRevenueAccount || '',
      defaultExpenseAccount: settings.defaultExpenseAccount || '',
      categoryAccountMap: accountingCategoryAccountMap(),
    },
    notes: STATE.accounting?.cpaNotes || '',
  };
}

function summarizeCpaRows(rows) {
  const entityMap = new Map();
  const categoryMap = new Map();
  const sourceFiles = new Map();
  const reviewExceptions = [];

  rows.forEach(row => {
    const amount = Number(row.amount) || 0;
    const entityLabel = ACCOUNTING_ENTITIES[row.entity]?.label || row.entity || 'Unassigned';
    const categoryLabel = row.category || 'Uncategorized';
    addSummaryAmount(entityMap, entityLabel, amount);
    addSummaryAmount(categoryMap, categoryLabel, amount);
    if (row.sourceFile) {
      const item = sourceFiles.get(row.sourceFile) || { name: row.sourceFile, fingerprints: new Set() };
      if (row.sourceFingerprint) item.fingerprints.add(row.sourceFingerprint);
      sourceFiles.set(row.sourceFile, item);
    }
    const reasons = [];
    if (!row.approved) reasons.push('not approved');
    if ((row.confidence || 0) < 0.75) reasons.push('low confidence');
    if (row.balanceCheck === 'mismatch') reasons.push('balance mismatch');
    if (row.category === 'Document needs OCR') reasons.push('document needs OCR');
    if (reasons.length) {
      reviewExceptions.push({
        date: row.date || '',
        entity: entityLabel,
        description: row.description || '',
        amount,
        reason: reasons.join(', '),
      });
    }
  });

  return {
    rowCount: rows.length,
    approvedCount: rows.filter(row => row.approved).length,
    automationApprovedCount: rows.filter(row => row.approvedByAutomation).length,
    needsReviewCount: reviewExceptions.length,
    ocrNeededCount: rows.filter(row => row.category === 'Document needs OCR').length,
    balanceMismatchCount: rows.filter(row => row.balanceCheck === 'mismatch').length,
    frappeSyncedCount: rows.filter(row => row.frappeJournalEntry || row.frappeSyncedAt).length,
    reconciledCount: rows.filter(row => row.reconciliationStatus === 'matched').length,
    possibleReconciliationCount: rows.filter(row => row.reconciliationStatus === 'possible').length,
    unmatchedReconciliationCount: rows.filter(row => row.reconciliationStatus === 'unmatched').length,
    entityTotals: mapToSummaryRows(entityMap),
    categoryTotals: mapToSummaryRows(categoryMap),
    sourceFiles: [...sourceFiles.values()]
      .map(file => ({ name: file.name, fingerprints: [...file.fingerprints].sort() }))
      .sort((a, b) => a.name.localeCompare(b.name)),
    reviewExceptions,
  };
}

function addSummaryAmount(map, label, amount) {
  const item = map.get(label) || { label, income: 0, expenses: 0, net: 0, count: 0 };
  if (amount >= 0) item.income += amount;
  else item.expenses += Math.abs(amount);
  item.net += amount;
  item.count += 1;
  map.set(label, item);
}

function mapToSummaryRows(map) {
  return [...map.values()].sort((a, b) => Math.abs(b.net) - Math.abs(a.net));
}

function partyForTransaction(t) {
  if (t.payee) return t.payee;
  if (t.amount > 0) return ACCOUNTING_ENTITIES[t.entity]?.label || 'Customer';
  return (t.description || '').split(/\s+-\s+|\s{2,}/)[0].slice(0, 48) || 'Vendor';
}

function toCsv(rows) {
  return rows.map(row => row.map(cell => {
    const s = String(cell ?? '');
    return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
  }).join(',')).join('\n');
}

function downloadText(filename, text, type) {
  const blob = new Blob([text], { type: type || 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
  showToast('Downloaded ' + filename);
}

function todayStamp() {
  return new Date().toISOString().slice(0, 10);
}

