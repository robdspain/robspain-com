function editIncName(id, el) { const i = data.income.find(x => x.id === id); if (i) editField(el, i.name, v => { i.name = v || i.name; }); }
function editIncAmount(id, el) { const i = data.income.find(x => x.id === id); if (i) editField(el, i.amount, v => { const n = parseFloat(v.replace(/[$,]/g,'')); if (!isNaN(n)) i.amount = n; }); }
function editIncFreq(id, el) { const i = data.income.find(x => x.id === id); if (i) editField(el, i.frequency, v => { i.frequency = v; }); }
function deleteIncome(id) { data.income = data.income.filter(x => x.id !== id); save(); renderAll(); }
function addIncome() {
  data.income.push({ id: nextId(data.income), name: 'New Source', amount: 0, frequency: 'Monthly' });
  save(); renderAll();
}

// Summary cards
function renderSummary() {
  const cash = data.accounts.filter(a => a.type === 'asset').reduce((s, a) => s + a.balance, 0);
  const loc = data.accounts.filter(a => a.type === 'credit').reduce((s, a) => s + a.balance, 0);
  const debt = data.accounts.filter(a => a.type === 'debt').reduce((s, a) => s + Math.abs(a.balance), 0);
  const totalIncome = data.income.reduce((s, i) => s + i.amount, 0);
  const totalBills = data.bills.reduce((s, b) => s + b.amount, 0);
  const deficit = totalIncome - totalBills;

  document.getElementById('summaryCards').innerHTML =
    '<div class="fin-card"><h3>Cash Available</h3><div class="fin-stat ' + (cash < 500 ? 'red' : 'green') + '">' + fmt(cash) + '</div><div class="fin-sub">Checking + Savings</div></div>' +
    '<div class="fin-card"><h3>LOC Available</h3><div class="fin-stat blue">' + fmt(loc) + '</div><div class="fin-sub">Credit line</div></div>' +
    '<div class="fin-card"><h3>Total Debt</h3><div class="fin-stat red">' + fmt(debt) + '</div><div class="fin-sub">All debt accounts</div></div>' +
    '<div class="fin-card"><h3>Monthly Gap</h3><div class="fin-stat ' + (deficit >= 0 ? 'green' : 'red') + '">' + fmt(deficit) + '</div><div class="fin-sub">Income vs bills</div></div>';

  // Alerts
  const alerts = [];
  if (totalBills > totalIncome) alerts.push('<div class="fin-alert danger"><strong>Structural deficit:</strong> Fixed expenses (' + fmt(totalBills) + '/mo) exceed income (' + fmt(totalIncome) + '/mo).</div>');
  if (cash < 500) alerts.push('<div class="fin-alert warn"><strong>Low cash:</strong> ' + fmt(cash) + ' in checking + savings.</div>');
  const overdue = data.bills.filter(b => b.status === 'overdue');
  if (overdue.length) alerts.push('<div class="fin-alert danger"><strong>Overdue:</strong> ' + overdue.map(b => b.name + ' (' + fmt(b.amount) + ')').join(', ') + '</div>');
  document.getElementById('alerts').innerHTML = alerts.join('');

  // Deficit card
  document.getElementById('deficitCard').innerHTML =
    '<div class="label">Monthly ' + (deficit >= 0 ? 'Surplus' : 'Deficit') + '</div>' +
    '<div class="amount">' + fmt(deficit) + '</div>' +
    '<div class="note">' + (deficit < 0 ? 'This gap must be closed through income increases or expense cuts.' : 'Positive cash flow.') + '</div>';

  // Budget breakdown
  const categories = {};
  data.bills.forEach(b => {
    const cat = b.priority === 1 ? 'P1 Survival' : b.priority === 2 ? 'P2 Insurance & Debt' : b.priority === 3 ? 'P3 Variable' : 'P4 Credit-funded';
    if (!categories[cat]) categories[cat] = 0;
    categories[cat] += b.amount;
  });
  const budgetHtml = Object.entries(categories).map(([cat, amt]) => {
    const pct = Math.round((amt / totalBills) * 100);
    const barColor = cat.startsWith('P1') ? 'red' : cat.startsWith('P2') ? 'yellow' : cat.startsWith('P3') ? 'blue' : 'green';
    return '<div style="margin-bottom:12px;"><div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;"><span>' + cat + '</span><span style="color:#94a3b8">' + fmt(amt) + ' — ' + pct + '%</span></div><div class="fin-bar-bg"><div class="fin-bar ' + barColor + '" style="width:' + pct + '%"></div></div></div>';
  }).join('');
  document.getElementById('budgetBreakdown').innerHTML = budgetHtml +
    '<div style="margin-top:16px;padding-top:12px;border-top:1px solid #334155;display:flex;justify-content:space-between;font-weight:600;"><span>Total Recurring</span><span style="color:#ef4444">' + fmt(totalBills) + '/mo</span></div>';
}

// Envelopes
function renderEnvelopes() {
  const totalIncome = data.income.reduce((s, i) => s + i.amount, 0);
  let remaining = totalIncome;
  const priorities = [1, 2, 3, 4];
  const pLabels = { 1: 'P1 Survival', 2: 'P2 Insurance & Debt Mins', 3: 'P3 Variable / Necessities', 4: 'P4 Credit-Funded' };
  const pColors = { 1: 'p1', 2: 'p2', 3: 'p3', 4: 'p4' };
  let html = '';
  priorities.forEach(p => {
    const bills = data.bills.filter(b => b.priority === p);
    if (!bills.length) return;
    const subtotal = bills.reduce((s, b) => s + b.amount, 0);
    html += '<div class="env-priority ' + pColors[p] + '">' + pLabels[p] + ' — ' + fmt(subtotal) + '</div>';
    bills.forEach(b => {
      const funded = remaining >= b.amount;
      const fillPct = funded ? 100 : (remaining > 0 ? Math.round((remaining / b.amount) * 100) : 0);
      const cls = pColors[p] + (funded ? '' : ' unfunded');
      html += '<div class="envelope ' + cls + '"><div class="env-row"><span class="env-name">' + esc(b.name) + (funded ? '' : ' <span style="color:#ef4444;font-size:11px;">unfunded</span>') + '</span><span class="env-amt">' + fmt(b.amount) + '</span></div><div class="env-bar"><div class="env-fill" style="width:' + fillPct + '%;background:' + (funded ? (p===1?'#ef4444':p===2?'#eab308':p===3?'#3b82f6':'#22c55e') : '#64748b') + '"></div></div></div>';
      remaining -= b.amount;
    });
  });
  html += '<div style="margin-top:16px;padding:12px;border-radius:8px;background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);text-align:center;font-size:14px;">Budget remaining after all envelopes: <strong style="color:' + (remaining >= 0 ? '#22c55e' : '#ef4444') + '">' + fmt(remaining) + '</strong></div>';
  document.getElementById('envelopeContainer').innerHTML = html;
}

// Calendar
function renderCalendar() {
  const now = new Date();
  const sorted = [...data.bills].sort((a, b) => {
    const da = parseDueDay(a.due), db = parseDueDay(b.due);
    return da - db;
  });
  const html = sorted.map(b => {
    const day = parseDueDay(b.due);
    const cls = b.status === 'overdue' ? 'danger' : b.status === 'paid' ? 'done' : b.status === 'autopay' ? 'ok' : day <= now.getDate() ? 'warn' : 'ok';
    const monthStr = day <= now.getDate() && b.status !== 'overdue' && b.status !== 'paid' ? 'Apr' : 'Mar';
    return '<div class="cal-row"><div class="cal-day ' + cls + '"><span class="month">' + monthStr + '</span><span class="date">' + (day || '?') + '</span></div><div class="cal-info"><div class="name">' + esc(b.name) + '</div><div class="detail">' + (STATUS_LABELS[b.status] || b.status) + (b.note ? ' — ' + esc(b.note) : '') + '</div></div><div class="cal-amt">' + fmt(b.amount) + '</div></div>';
  }).join('');
  document.getElementById('calendarList').innerHTML = html || '<p style="color:#64748b;">No bills.</p>';

  // Cash flow projection
  const cash = data.accounts.filter(a => a.type === 'asset').reduce((s, a) => s + a.balance, 0);
  const totalIncome = data.income.reduce((s, i) => s + i.amount, 0);
  let balance = cash;
  const events = [
    { day: 31, label: 'KCUSD paycheck', amount: data.income.find(i => i.name.includes('Kings Canyon') || i.name.includes('KCUSD'))?.amount || 4845, type: 'in' },
    ...sorted.filter(b => b.status !== 'paid').map(b => ({ day: parseDueDay(b.due) || 15, label: b.name, amount: b.amount, type: 'out' }))
  ].sort((a, b) => a.day - b.day);
  let projHtml = '<table class="fin-table"><thead><tr><th>Day</th><th>Event</th><th class="amt">Amount</th><th class="amt">Balance</th></tr></thead><tbody>';
  projHtml += '<tr><td>Now</td><td>Starting cash</td><td class="amt">—</td><td class="amt">' + fmt(balance) + '</td></tr>';
  events.forEach(e => {
    balance += e.type === 'in' ? e.amount : -e.amount;
    const color = balance < 0 ? '#ef4444' : '#e2e8f0';
    projHtml += '<tr><td>' + e.day + '</td><td>' + esc(e.label) + '</td><td class="amt" style="color:' + (e.type === 'in' ? '#22c55e' : '#ef4444') + '">' + (e.type === 'in' ? '+' : '-') + fmt(e.amount) + '</td><td class="amt" style="color:' + color + '">' + fmt(balance) + '</td></tr>';
  });
  projHtml += '</tbody></table>';
  document.getElementById('cashFlowProjection').innerHTML = projHtml;
}

function parseDueDay(due) {
  const m = (due || '').match(/(\d+)/);
  return m ? parseInt(m[1]) : 15;
}

// Net Worth
function renderNetWorth() {
  const chart = document.getElementById('nwChart');
  chart.innerHTML = '';
  const maxAbs = Math.max(...data.netWorth.map(d => Math.abs(d.nw)));
  data.netWorth.forEach(d => {
    const wrap = document.createElement('div');
    wrap.className = 'nw-bar-wrap';
    const bar = document.createElement('div');
    bar.className = 'nw-bar';
    bar.style.height = (Math.abs(d.nw) / maxAbs * 100) + '%';
    bar.style.background = d.nw < -28000 ? '#ef4444' : d.nw < -25000 ? '#eab308' : '#3b82f6';
    bar.title = d.month + ': ' + fmt(d.nw);
    const label = document.createElement('div');
    label.className = 'nw-label';
    label.textContent = d.month;
    wrap.appendChild(bar);
    wrap.appendChild(label);
    chart.appendChild(wrap);
  });
  const latest = data.netWorth[data.netWorth.length - 1];
  document.getElementById('nwSummary').innerHTML = '<div style="font-size:14px;color:#94a3b8;">Current net worth: <strong style="color:#ef4444;font-size:18px;">' + fmt(latest.nw) + '</strong></div>';

  // Debt breakdown
  const debts = data.accounts.filter(a => a.type === 'debt');
  const totalDebt = debts.reduce((s, a) => s + Math.abs(a.balance), 0);
  const colors = ['red', 'yellow', 'blue', 'green', 'purple'];
  document.getElementById('debtBreakdown').innerHTML = debts.map((d, i) => {
    const pct = Math.round(Math.abs(d.balance) / totalDebt * 100);
    return '<div style="margin-bottom:12px;"><div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;"><span>' + esc(d.name) + '</span><span style="color:#94a3b8">' + fmt(Math.abs(d.balance)) + ' (' + pct + '%)</span></div><div class="fin-bar-bg"><div class="fin-bar ' + colors[i % colors.length] + '" style="width:' + pct + '%"></div></div></div>';
  }).join('');

  document.getElementById('debtStrategy').innerHTML =
    '<div style="padding:12px;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:8px;">' +
    '<div style="font-size:13px;font-weight:600;color:#22c55e;margin-bottom:4px;">Recommended: Avalanche + Quick Wins</div>' +
    '<div style="font-size:12px;color:#94a3b8;">Pay off smallest debts first (Discover + LOC) to free up $158/mo, then attack Apple Card.</div></div>';
}

// Payments
function renderPaymentForm() {
  const sel = document.getElementById('payBill');
  const cur = sel.value;
  sel.innerHTML = '<option value="">Select bill...</option>' + data.bills.map(b => '<option value="' + b.id + '">' + esc(b.name) + ' (' + fmt(b.amount) + ')</option>').join('');
  sel.value = cur;
  const from = document.getElementById('payFrom');
  const curFrom = from.value;
  from.innerHTML = '<option value="">Paid from...</option>' + data.accounts.filter(a => a.type !== 'debt').map(a => '<option value="' + a.id + '">' + esc(a.name) + '</option>').join('');
  from.value = curFrom;
  if (!document.getElementById('payDate').value) document.getElementById('payDate').value = new Date().toISOString().split('T')[0];
}
function renderPayments() {
  const list = document.getElementById('paymentHistory');
  if (!data.payments.length) { list.innerHTML = '<p style="color:#64748b;font-size:13px;">No payments logged yet.</p>'; return; }
  list.innerHTML = '<table class="fin-table"><thead><tr><th>Date</th><th>Bill</th><th class="amt">Amount</th><th>From</th><th></th></tr></thead><tbody>' +
    [...data.payments].reverse().map(p => {
      const bill = data.bills.find(b => b.id === p.billId);
      const acc = data.accounts.find(a => a.id === p.fromAccountId);
      return '<tr><td>' + esc(p.date) + '</td><td>' + (bill ? esc(bill.name) : 'Unknown') + '</td><td class="amt">' + fmt(p.amount) + '</td><td style="color:#94a3b8">' + (acc ? esc(acc.name) : '—') + '</td><td><button class="btn-sm danger" onclick="deletePayment(' + p.id + ')">&times;</button></td></tr>';
    }).join('') + '</tbody></table>';
}
function logPayment() {
  const billId = parseInt(document.getElementById('payBill').value);
  const amount = parseFloat(document.getElementById('payAmount').value);
  const date = document.getElementById('payDate').value;
  const fromId = parseInt(document.getElementById('payFrom').value);
  if (!billId || isNaN(amount) || !date) return;
  data.payments.push({ id: nextId(data.payments), billId, amount, date, fromAccountId: fromId || null });
  const bill = data.bills.find(b => b.id === billId);
  if (bill) bill.status = 'paid';
  const acc = data.accounts.find(a => a.id === fromId);
  if (acc) acc.balance -= amount;
  document.getElementById('payBill').value = '';
  document.getElementById('payAmount').value = '';
  save(); renderAll();
}
function deletePayment(id) { data.payments = data.payments.filter(x => x.id !== id); save(); renderAll(); }

// CSV Import
function handleDragOver(e) { e.preventDefault(); e.currentTarget.classList.add('dragover'); }
function handleDragLeave(e) { e.currentTarget.classList.remove('dragover'); }
function handleDrop(e) { e.preventDefault(); e.currentTarget.classList.remove('dragover'); if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); }
function handleFile(file) {
  if (!file || !file.name.endsWith('.csv')) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    const lines = e.target.result.split('\n').filter(l => l.trim());
    if (lines.length < 2) return;
    const header = lines[0].toLowerCase();
    let txns = [];
    if (header.includes('transaction date') && header.includes('merchant')) {
      for (let i = 1; i < lines.length; i++) { const c = parseCSVLine(lines[i]); if (c.length >= 7) txns.push({ date: c[0], desc: c[2] || c[1], amount: parseFloat(c[6]) || 0 }); }
    } else {
      for (let i = 1; i < lines.length; i++) { const c = parseCSVLine(lines[i]); if (c.length < 3) continue; const a = parseFloat((c[c.length-2]||c[c.length-1]||'0').replace(/[$,]/g,'')); if (!isNaN(a)) txns.push({ date: c[0], desc: c[1], amount: a }); }
    }
    if (!txns.length) return;
    const totalOut = txns.filter(t => t.amount < 0).reduce((s,t) => s + Math.abs(t.amount), 0);
    const totalIn = txns.filter(t => t.amount > 0).reduce((s,t) => s + t.amount, 0);
    document.getElementById('importResults').style.display = 'block';
    document.getElementById('importTitle').textContent = file.name;
    document.getElementById('importCount').textContent = txns.length + ' transactions';
    document.getElementById('importSummary').innerHTML = '<span>In: <strong style="color:#22c55e">$' + totalIn.toFixed(2) + '</strong></span><span>Out: <strong style="color:#ef4444">$' + totalOut.toFixed(2) + '</strong></span><span>Net: <strong style="color:' + (totalIn-totalOut>=0?'#22c55e':'#ef4444') + '">$' + (totalIn-totalOut).toFixed(2) + '</strong></span>';
    document.getElementById('txnList').innerHTML = txns.slice(0,100).map(t => '<div class="txn-row"><span class="txn-date">' + (t.date||'').substring(0,10) + '</span><span class="txn-desc">' + esc(t.desc||'Unknown') + '</span><span class="txn-amt ' + (t.amount<0?'debit':'credit') + '">$' + Math.abs(t.amount).toFixed(2) + '</span></div>').join('');
  };
  reader.readAsText(file);
}
function parseCSVLine(line) { const r=[]; let c='',q=false; for(let i=0;i<line.length;i++){const ch=line[i]; if(ch==='"')q=!q; else if(ch===','&&!q){r.push(c.trim());c='';} else c+=ch;} r.push(c.trim()); return r; }

// Export / Import JSON
function exportData() {
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'household-finance-' + new Date().toISOString().split('T')[0] + '.json';
  a.click();
}
function importData(file) {
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const imported = JSON.parse(e.target.result);
      if (imported.bills && imported.accounts && imported.income) {
        data = imported;
        save();
        renderAll();
      }
    } catch(err) { /* ignore bad json */ }
  };
  reader.readAsText(file);
}

function renderAll() {
  renderBills();
  renderAccounts();
  renderIncome();
  renderSummary();
  renderEnvelopes();
  renderCalendar();
  renderNetWorth();
  renderPayments();
}

// Init
load();
save();
renderAll();
</script>
