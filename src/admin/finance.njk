  const queue = STATE.accounting.reviewQueue;
  const income = queue.filter(t => t.amount > 0).reduce((s, t) => s + t.amount, 0);
  const expenses = queue.filter(t => t.amount < 0).reduce((s, t) => s + Math.abs(t.amount), 0);
  const approved = queue.filter(t => t.approved).length;
