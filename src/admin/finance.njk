  <div style="text-align:center;margin-top:24px;font-size:12px;color:#64748b;">
    Data: EECU checking (557 txns, Mar 2025–Mar 2026) + Apple Card statements (Jan–Dec 2025). Managed by Paperclip CTO agent. Inspired by <a href="https://actualbudget.org" style="color:#3b82f6;">Actual Budget</a>.
  </div>
</div>

<div class="toast-msg" id="toast"></div>

<script>
// ═══════════ INTERACTIVE BILLS ═══════════
const DEFAULT_BILLS = [
  { id:'rent', name:'Valley Vista (Rent)', due:'1st', amount:'$2,445', status:'upcoming' },
  { id:'support', name:'Supporting Hands', due:'Monthly', amount:'$1,800', status:'current' },
  { id:'auto', name:'EECU Auto Loan', due:'5th', amount:'$499', status:'autopay' },
  { id:'apple', name:'Apple Card Min', due:'~27th', amount:'$366', status:'paid' },
  { id:'collier', name:'Phillip M. Collier', due:'2-3x/mo', amount:'$300-450', status:'current' },
  { id:'toggle', name:'Toggle Insurance', due:'Monthly', amount:'$202', status:'paid' },
  { id:'pge', name:'PG&E', due:'14th', amount:'$200', status:'upcoming' },
  { id:'att', name:'AT&T Wireless', due:'Monthly', amount:'$129', status:'current' },
  { id:'fresno', name:'City of Fresno', due:'1st', amount:'$121', status:'overdue' },
  { id:'xfinity', name:'Xfinity', due:'1st', amount:'$95', status:'paid' },
  { id:'discover', name:'Discover Min', due:'~18th', amount:'$83', status:'upcoming' },
  { id:'loc', name:'EECU LOC Min', due:'26th', amount:'$75', status:'upcoming' },
  { id:'principal', name:'Principal Insurance', due:'Monthly', amount:'$35', status:'current' },
  { id:'allstate', name:'Allstate Insurance', due:'Monthly', amount:'$25', status:'current' },
];
const STATUS_CYCLE = ['overdue','upcoming','current','autopay','paid'];
const STATUS_LABELS = {overdue:'Overdue',upcoming:'Upcoming',current:'Active',autopay:'Autopay',paid:'Paid'};
const STORAGE_KEY = 'spain-finance-bills';
let changes = {};

function loadBills() {
  try { const s = localStorage.getItem(STORAGE_KEY); if(s){const o=JSON.parse(s);return DEFAULT_BILLS.map(b=>({...b,status:o[b.id]||b.status}));} } catch(e){}
  return DEFAULT_BILLS.map(b=>({...b}));
}
function saveBills(bills) { const o={}; bills.forEach(b=>{o[b.id]=b.status;}); localStorage.setItem(STORAGE_KEY,JSON.stringify(o)); }

function renderBills() {
  const bills = loadBills();
  const tbody = document.getElementById('billsBody');
  if(!tbody) return;
  tbody.innerHTML = bills.map(b =>
    '<tr><td>'+b.name+'</td><td>'+b.due+'</td><td class="amt">'+b.amount+'</td>'+
    '<td><span class="fin-badge '+b.status+'" onclick="cycleBill(\''+b.id+'\')" title="Click to change">'+(STATUS_LABELS[b.status]||b.status)+'</span></td></tr>'
  ).join('');
}

function cycleBill(id) {
  const bills = loadBills(), bill = bills.find(b=>b.id===id);
  if(!bill) return;
  const idx = STATUS_CYCLE.indexOf(bill.status);
  bill.status = STATUS_CYCLE[(idx+1)%STATUS_CYCLE.length];
  saveBills(bills);
  renderBills();
  const orig = DEFAULT_BILLS.find(b=>b.id===id);
  if(bill.status !== orig.status) { changes[id] = {name:bill.name, from:orig.status, to:bill.status}; } else { delete changes[id]; }
  updateSyncBar();
  showToast(bill.name+' → '+(STATUS_LABELS[bill.status]||bill.status));
}

function updateSyncBar() {
  const bar = document.getElementById('syncBar'), n = Object.keys(changes).length;
  if(n>0){bar.classList.add('visible');document.getElementById('syncMsg').textContent=n+' change'+(n>1?'s':'')+' unsent.';}
  else{bar.classList.remove('visible');}
}

function sendUpdate() {
  const entries = Object.values(changes);
  if(!entries.length) return;
  const lines = entries.map(c=>'- **'+c.name+'**: '+c.from+' → '+c.to);
  const msg = '## Bill status update from dashboard\n\n'+lines.join('\n')+'\n\n_Sent from robspain.com/admin/finance/_';
  navigator.clipboard.writeText(msg).then(()=>{
    showToast('Update copied! Paste in Paperclip SPA-2.');
    changes={}; updateSyncBar();
  }).catch(()=>{ prompt('Copy this update:',msg); changes={}; updateSyncBar(); });
}

function showToast(text) {
  const t=document.getElementById('toast'); t.textContent=text; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2000);
}

renderBills();

// Tab switching
function showPanel(name) {
  document.querySelectorAll('.fin-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.fin-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  event.target.classList.add('active');
}

// Net worth chart
(function() {
  const data = [
    { month: 'Apr', nw: -22165 },
    { month: 'May', nw: -22115 },
    { month: 'Jun', nw: -23033 },
    { month: 'Jul', nw: -23201 },
    { month: 'Aug', nw: -23835 },
    { month: 'Sep', nw: -24274 },
    { month: 'Oct', nw: -26278 },
    { month: 'Nov', nw: -26482 },
    { month: 'Dec', nw: -28655 },
    { month: 'Jan', nw: -29007 },
    { month: 'Feb', nw: -30289 },
    { month: 'Mar', nw: -31420 }
  ];
  const maxAbs = Math.max(...data.map(d => Math.abs(d.nw)));
  const chart = document.getElementById('nwChart');
  if (!chart) return;
  data.forEach(d => {
    const wrap = document.createElement('div');
    wrap.className = 'nw-bar-wrap';
    const bar = document.createElement('div');
    bar.className = 'nw-bar';
    const pct = (Math.abs(d.nw) / maxAbs) * 100;
    bar.style.height = pct + '%';
    bar.style.background = d.nw < -28000 ? '#ef4444' : d.nw < -25000 ? '#eab308' : '#3b82f6';
    bar.title = d.month + ': -$' + Math.abs(d.nw).toLocaleString();
    const label = document.createElement('div');
    label.className = 'nw-label';
    label.textContent = d.month;
    wrap.appendChild(bar);
    wrap.appendChild(label);
    chart.appendChild(wrap);
  });
})();

// CSV Import
function handleDragOver(e) { e.preventDefault(); e.currentTarget.classList.add('dragover'); }
function handleDragLeave(e) { e.currentTarget.classList.remove('dragover'); }
function handleDrop(e) {
  e.preventDefault();
  e.currentTarget.classList.remove('dragover');
  const file = e.dataTransfer.files[0];
  if (file) handleFile(file);
}

function handleFile(file) {
  if (!file || !file.name.endsWith('.csv')) { alert('Please drop a CSV file'); return; }
  const reader = new FileReader();
  reader.onload = function(e) {
    const lines = e.target.result.split('\n').filter(l => l.trim());
    if (lines.length < 2) return;
    const header = lines[0].toLowerCase();
    let txns = [];

    if (header.includes('transaction date') && header.includes('merchant')) {
      // Apple Card format
      for (let i = 1; i < lines.length; i++) {
        const cols = parseCSVLine(lines[i]);
        if (cols.length < 7) continue;
        txns.push({ date: cols[0], desc: cols[2] || cols[1], amount: parseFloat(cols[6]) || 0 });
      }
    } else {
      // EECU format - try common patterns
      for (let i = 1; i < lines.length; i++) {
        const cols = parseCSVLine(lines[i]);
        if (cols.length < 3) continue;
        const dateCol = cols[0];
        const descCol = cols.length > 3 ? cols[1] : cols[1];
        const amtCol = parseFloat((cols[cols.length - 2] || cols[cols.length - 1] || '0').replace(/[,$]/g, ''));
        if (isNaN(amtCol)) continue;
        txns.push({ date: dateCol, desc: descCol, amount: amtCol });
      }
    }

    if (txns.length === 0) { alert('Could not parse transactions from this file'); return; }

    const debits = txns.filter(t => t.amount < 0 || (t.amount > 0 && t.desc && !t.desc.match(/payment|deposit|payroll|transfer/i)));
    const credits = txns.filter(t => t.amount > 0 && t.desc && t.desc.match(/payment|deposit|payroll|transfer/i));
    const totalOut = txns.filter(t => t.amount < 0).reduce((s, t) => s + Math.abs(t.amount), 0);
    const totalIn = txns.filter(t => t.amount > 0).reduce((s, t) => s + t.amount, 0);

    document.getElementById('importResults').style.display = 'block';
    document.getElementById('importTitle').textContent = file.name;
    document.getElementById('importCount').textContent = txns.length + ' transactions';
    document.getElementById('importSummary').innerHTML =
      '<span>Total in: <strong style="color:#22c55e">$' + totalIn.toFixed(2) + '</strong></span>' +
      '<span>Total out: <strong style="color:#ef4444">$' + totalOut.toFixed(2) + '</strong></span>' +
      '<span>Net: <strong style="color:' + (totalIn - totalOut >= 0 ? '#22c55e' : '#ef4444') + '">$' + (totalIn - totalOut).toFixed(2) + '</strong></span>';

    const list = document.getElementById('txnList');
    list.innerHTML = txns.slice(0, 100).map(t => {
      const isDebit = t.amount < 0;
      return '<div class="txn-row">' +
        '<span class="txn-date">' + (t.date || '').substring(0, 10) + '</span>' +
        '<span class="txn-desc">' + escapeHtml(t.desc || 'Unknown') + '</span>' +
        '<span class="txn-amt ' + (isDebit ? 'debit' : 'credit') + '">$' + Math.abs(t.amount).toFixed(2) + '</span>' +
        '</div>';
    }).join('');
    if (txns.length > 100) list.innerHTML += '<div style="text-align:center;padding:8px;color:#64748b;font-size:12px;">Showing first 100 of ' + txns.length + '</div>';
  };
  reader.readAsText(file);
}

function parseCSVLine(line) {
  const result = [];
  let current = '';
  let inQuotes = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"') { inQuotes = !inQuotes; }
    else if (ch === ',' && !inQuotes) { result.push(current.trim()); current = ''; }
    else { current += ch; }
  }
  result.push(current.trim());
  return result;
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
</script>
