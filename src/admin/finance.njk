  const bg = readiness.ready ? 'rgba(15,118,110,0.06)' : 'rgba(217,119,6,0.07)';
  const blockers = readiness.blockers.length
    ? readiness.blockers.map(item => `<span style="display:inline-block;margin:3px 6px 0 0;padding:3px 7px;border-radius:999px;background:#fff;border:1px solid #e2e8f0;color:#475569;">${esc(item)}</span>`).join('')
    : '<span style="color:#0f766e;">Ready for CPA package and Frappe export preview.</span>';
  el.innerHTML = `<div style="border:1px solid #e2e8f0;border-left:4px solid ${readyColor};background:${bg};border-radius:8px;padding:10px;">
