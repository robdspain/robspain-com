      reviewQueue: [],
      importedFiles: [],
      importRuns: [],
      frappeRuns: [],
      vendorRules: [],
      frappeSettings: defaultFrappeSettings(),
      cpaNotes: 'Export this package monthly. CPA should confirm entity treatment before business/personal split is finalized.',
    },
    lastUpdated: '2026-04-01T00:00:00Z',
  };
}

function loadState() {
  try {
    const raw = localStorage.getItem(STORE_KEY);
    if (raw) {
      const saved = JSON.parse(raw);
      // Merge with defaults to pick up new fields
      const def = defaultState();
      return {
        bills: saved.bills || def.bills,
        accounts: saved.accounts || def.accounts,
        income: saved.income || def.income,
        payments: saved.payments || def.payments,
        accounting: {
          ...def.accounting,
          ...(saved.accounting || {}),
          reviewQueue: saved.accounting?.reviewQueue || def.accounting.reviewQueue,
          importedFiles: saved.accounting?.importedFiles || def.accounting.importedFiles,
          importRuns: saved.accounting?.importRuns || def.accounting.importRuns,
          frappeRuns: saved.accounting?.frappeRuns || def.accounting.frappeRuns,
          vendorRules: saved.accounting?.vendorRules || def.accounting.vendorRules,
          frappeSettings: {
            ...defaultFrappeSettings(),
            ...(saved.accounting?.frappeSettings || {}),
            categoryAccountMap: {
              ...defaultCategoryAccountMap(saved.accounting?.frappeSettings || {}),
              ...(saved.accounting?.frappeSettings?.categoryAccountMap || {}),
            },
          },
        },
        lastUpdated: saved.lastUpdated || def.lastUpdated,
      };
    }
  } catch(e) {}
  // Migrate from v1 localStorage if present
  try {
    const v1 = localStorage.getItem('spain-finance-bills');
    if (v1) {
      const statuses = JSON.parse(v1);
      const state = defaultState();
      state.bills.forEach(b => { if (statuses[b.id]) b.status = statuses[b.id]; });
      saveState(state);
      return state;
    }
  } catch(e) {}
  return defaultState();
}

function saveState(state) {
  state.lastUpdated = new Date().toISOString();
  localStorage.setItem(STORE_KEY, JSON.stringify(state));
  scheduleAccountingSync();
}

let STATE = loadState();
let ACCOUNTING_SYNC_TIMER = null;
