function ensureAccountingState() {
  if (!STATE.accounting) STATE.accounting = defaultState().accounting;
  if (!Array.isArray(STATE.accounting.reviewQueue)) STATE.accounting.reviewQueue = [];
  if (!Array.isArray(STATE.accounting.importedFiles)) STATE.accounting.importedFiles = [];
  if (!Array.isArray(STATE.accounting.importRuns)) STATE.accounting.importRuns = [];
  if (!Array.isArray(STATE.accounting.frappeRuns)) STATE.accounting.frappeRuns = [];
  if (!Array.isArray(STATE.accounting.vendorRules)) STATE.accounting.vendorRules = [];
  if (!STATE.accounting.activeEntity) STATE.accounting.activeEntity = 'behavior-school';
  if (!STATE.accounting.defaultFrappeAccount) STATE.accounting.defaultFrappeAccount = 'Expenses';
  STATE.accounting.reviewQueue.forEach(row => {
    if (!row.payee) row.payee = normalizePayee(row.description, row.amount);
  });
  STATE.accounting.frappeSettings = {
    ...defaultFrappeSettings(),
    ...(STATE.accounting.frappeSettings || {}),
    categoryAccountMap: {
      ...defaultCategoryAccountMap(STATE.accounting.frappeSettings || {}),
      ...(STATE.accounting.frappeSettings?.categoryAccountMap || {}),
    },
  };
}

