---
layout: base.njk
title: Family Dashboard - Admin
description: Internal family dashboard for bills, payment status, and monthly cash decisions.
permalink: /admin/family/
eleventyExcludeFromCollections: true
---

<section class="finance-app" data-finance-app>
  <div class="finance-shell">
    <header class="finance-header">
      <div>
        <a class="back-link" href="/admin/dashboard/"><i class="fas fa-briefcase"></i> Business Dashboard</a>
        <p class="eyebrow">Family dashboard</p>
        <h1>Family Finance</h1>
        <p class="subhead">Personal tools live here. Track bills, sort what is overdue, and keep paid items separate from this month's cash decisions.</p>
      </div>
      <div class="header-actions">
        <button class="ghost-button" type="button" data-reset>Reset defaults</button>
        <button class="primary-button" type="button" data-export>Export JSON</button>
      </div>
    </header>

    <div class="notice">
      Admin sign-in is required. Edits are saved in this browser until the Convex sync layer is added.
    </div>

    <nav class="family-switcher" aria-label="Admin dashboard switcher">
      <a href="/admin/dashboard/">Business dashboard</a>
      <span>Family dashboard</span>
    </nav>

    <section class="summary-grid" aria-label="Finance summary">
      <div class="summary-card danger">
        <span>Overdue / due now</span>
        <strong data-summary="urgent">$0</strong>
        <small data-summary-detail="urgent">0 items</small>
      </div>
      <div class="summary-card">
        <span>Unpaid this month</span>
        <strong data-summary="unpaid">$0</strong>
        <small data-summary-detail="unpaid">0 items</small>
      </div>
      <div class="summary-card success">
        <span>Paid this month</span>
        <strong data-summary="paid">$0</strong>
        <small data-summary-detail="paid">0 items</small>
      </div>
      <div class="summary-card warning">
        <span>Review queue</span>
        <strong data-summary="review">0</strong>
        <small>Needs verification</small>
      </div>
    </section>

    <section class="toolbar" aria-label="Bill controls">
      <label>
        <span>Show</span>
        <select data-filter>
          <option value="all">All bills</option>
          <option value="overdue">Overdue</option>
          <option value="unpaid">Unpaid</option>
          <option value="paid">Paid</option>
          <option value="autopay">Autopay</option>
          <option value="survival">Survival</option>
          <option value="debt">Debt</option>
        </select>
      </label>
      <label>
        <span>Sort</span>
        <select data-sort>
          <option value="status_due">Status + due date</option>
          <option value="overdue_first">Overdue first</option>
          <option value="unpaid_first">Unpaid first</option>
          <option value="paid_first">Paid first</option>
          <option value="priority">Priority</option>
          <option value="amount_high">Amount high to low</option>
          <option value="amount_low">Amount low to high</option>
          <option value="account">Account</option>
        </select>
      </label>
      <label class="search-box">
        <span>Search</span>
        <input type="search" data-search placeholder="Vendor, note, account">
      </label>
    </section>

    <section class="finance-layout">
      <div class="bill-panel">
        <div class="panel-heading">
          <h2>Bills</h2>
          <span data-count>0 bills</span>
        </div>
        <div class="bill-list" data-bills></div>
      </div>

      <aside class="review-panel">
        <div class="panel-heading">
          <h2>Review Queue</h2>
          <span>Do before relying on autopay</span>
        </div>
        <div class="review-list" data-reviews></div>
      </aside>
    </section>
  </div>
</section>

<style>
  .finance-app {
    min-height: 100vh;
    background: #f6f8fb;
    padding: 7rem 1rem 4rem;
    color: #172033;
  }

  .finance-shell {
    max-width: 1180px;
    margin: 0 auto;
  }

  .finance-header {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .back-link {
    color: #2563eb;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .eyebrow {
    margin: 1rem 0 0.25rem;
    color: #64748b;
    text-transform: uppercase;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0;
  }

  .finance-header h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.05;
    color: #0f172a;
  }

  .subhead {
    max-width: 680px;
    margin: 0.75rem 0 0;
    color: #475569;
    line-height: 1.6;
  }

  .header-actions, .toolbar {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  button, select, input {
    font: inherit;
  }

  .primary-button, .ghost-button, .bill-action {
    border: 0;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-weight: 800;
    cursor: pointer;
  }

  .primary-button {
    background: #0f172a;
    color: white;
  }

  .ghost-button {
    background: white;
    color: #334155;
    border: 1px solid #d8e0ea;
  }

  .notice {
    background: #fff7ed;
    border: 1px solid #fed7aa;
    color: #9a3412;
    padding: 0.85rem 1rem;
    border-radius: 8px;
    font-weight: 700;
    margin: 1rem 0 1.25rem;
  }

  .family-switcher {
    display: inline-flex;
    gap: 0.5rem;
    padding: 0.35rem;
    margin-bottom: 1rem;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
  }

  .family-switcher a, .family-switcher span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 150px;
    padding: 0.65rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 800;
  }

  .family-switcher a {
    color: #475569;
  }

  .family-switcher span {
    background: #0f172a;
    color: white;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .summary-card, .bill-panel, .review-panel {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
  }

  .summary-card {
    padding: 1rem;
  }

  .summary-card span, .summary-card small {
    display: block;
    color: #64748b;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .summary-card strong {
    display: block;
    margin: 0.35rem 0;
    font-size: 1.55rem;
    color: #0f172a;
  }

  .summary-card.danger strong { color: #dc2626; }
  .summary-card.success strong { color: #047857; }
  .summary-card.warning strong { color: #b45309; }

  .toolbar {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1rem;
    align-items: end;
  }

  .toolbar label {
    display: grid;
    gap: 0.35rem;
    color: #475569;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .toolbar select, .toolbar input {
    min-height: 42px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 0 0.75rem;
    background: white;
    color: #0f172a;
  }

  .search-box {
    flex: 1;
    min-width: 240px;
  }

  .finance-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(320px, 0.8fr);
    gap: 1rem;
  }

  .panel-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    border-bottom: 1px solid #e2e8f0;
    align-items: center;
  }

  .panel-heading h2 {
    margin: 0;
    font-size: 1.1rem;
    color: #0f172a;
  }

  .panel-heading span {
    color: #64748b;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .bill-list, .review-list {
    display: grid;
    gap: 0.75rem;
    padding: 1rem;
  }

  .bill-row, .review-row {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 1rem;
    background: #fff;
  }

  .bill-row.overdue { border-color: #fecaca; background: #fff8f8; }
  .bill-row.paid { border-color: #bbf7d0; background: #f7fff9; }

  .bill-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  .bill-name {
    margin: 0;
    font-size: 1rem;
    color: #0f172a;
  }

  .bill-meta {
    margin-top: 0.4rem;
    color: #64748b;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .bill-amount {
    text-align: right;
    white-space: nowrap;
    color: #0f172a;
    font-weight: 900;
    font-size: 1.1rem;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    margin-right: 0.35rem;
    color: #334155;
    background: #e2e8f0;
  }

  .status-pill.paid { color: #065f46; background: #d1fae5; }
  .status-pill.overdue { color: #991b1b; background: #fee2e2; }
  .status-pill.autopay { color: #1d4ed8; background: #dbeafe; }
  .status-pill.survival { color: #9a3412; background: #ffedd5; }

  .bill-notes, .review-row p {
    color: #475569;
    font-size: 0.86rem;
    line-height: 1.55;
    margin: 0.7rem 0 0;
  }

  .bill-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.9rem;
  }

  .bill-action {
    padding: 0.5rem 0.75rem;
    background: #f1f5f9;
    color: #334155;
    font-size: 0.78rem;
  }

  .bill-action.paid-action {
    background: #dcfce7;
    color: #166534;
  }

  .bill-action.unpaid-action {
    background: #fee2e2;
    color: #991b1b;
  }

  .review-row h3 {
    margin: 0;
    font-size: 0.98rem;
    color: #0f172a;
  }

  .review-row .review-meta {
    margin-top: 0.35rem;
    color: #64748b;
    font-size: 0.78rem;
    font-weight: 800;
  }

  @media (max-width: 880px) {
    .finance-header, .finance-layout {
      grid-template-columns: 1fr;
      display: grid;
    }

    .summary-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .finance-app {
      padding-top: 5.5rem;
    }

    .summary-grid {
      grid-template-columns: 1fr;
    }

    .bill-top {
      display: grid;
    }

    .bill-amount {
      text-align: left;
    }
  }
</style>

<script>
(() => {
  const month = '2026-06';
  const today = '2026-06-10';
  const storageKey = 'robspain.familyFinance.v1';
  const defaultBills = [
    { id: 'xfinity', name: 'Xfinity', amount: 190, dueDate: '2026-06-17', status: 'paid', priority: 'survival', category: 'Utilities', account: 'EECU Checking', notes: 'Paid $190 on 2026-06-09. Email showed overdue risk if not paid by 2026-06-16.' },
    { id: 'fast-action', name: 'Fast Action Pest Control', amount: 219, dueDate: '2026-06-09', status: 'unpaid', priority: 'survival', category: 'Home', account: 'EECU Checking', notes: 'Email on 2026-06-06 showed $219 balance, 28 days past due. Pay or call before it gets further behind.' },
    { id: 'att', name: 'AT&T Wireless', amount: 98.22, dueDate: '2026-06-11', status: 'autopay', priority: 'required', category: 'Utilities', account: 'Apple Card autopay', notes: 'Verify Apple Card has at least $98.22 available credit, preferably $125+ buffer, before relying on autopay.' },
    { id: 'pge', name: 'PG&E', amount: 369.12, dueDate: '2026-06-03', status: 'unpaid', priority: 'survival', category: 'Utilities', account: 'EECU Checking', notes: 'Statement showed $619.12 due 2026-06-03. This row assumes $250 AutoPay applied, leaving $369.12 to verify.' },
    { id: 'discover-min', name: 'Discover minimum', amount: 98, dueDate: '2026-06-17', status: 'unpaid', priority: 'debt', category: 'Debt', account: 'EECU Checking', notes: 'Minimum due from statement. Avoid late fee and credit hit.' },
    { id: 'eecu-loc', name: 'EECU line of credit', amount: 75, dueDate: '2026-06-26', status: 'unpaid', priority: 'debt', category: 'Debt', account: 'EECU Checking', notes: 'Minimum payment due this month.' },
    { id: 'apple-card-min', name: 'Apple Card minimum', amount: 366, dueDate: '2026-06-27', status: 'unpaid', priority: 'debt', category: 'Debt', account: 'EECU Checking', notes: 'Needs current Wallet verification before final payment sizing.' },
    { id: 'tipton-legal', name: 'Tipton Legal May invoice', amount: 9547.25, dueDate: '2026-06-02', status: 'hold', priority: 'defer', category: 'Legal', account: 'Settlement funds', notes: 'Hold for settlement processing; do not pay from current operating cash.' }
  ];
  const defaultReviews = [
    { id: 'apple-att-room', title: 'Verify Apple Card room for AT&T autopay', vendor: 'Apple Card / AT&T', amount: 98.22, dueDate: '2026-06-11', priority: 'urgent', notes: 'Confirm available credit is at least $98.22, with $125+ preferred buffer. If short, pay Apple Card or change AT&T payment method.' },
    { id: 'pge-autopay', title: 'Confirm PG&E AutoPay and remaining balance', vendor: 'PG&E', amount: 369.12, dueDate: '2026-06-10', priority: 'urgent', notes: 'Check whether the $250 AutoPay cleared and whether the remaining balance is still $369.12.' },
    { id: 'novo-balance', title: 'Verify Novo balance after $1,000 owner draw', vendor: 'Novo', priority: 'urgent', notes: 'Confirm post-transfer business balance before any more owner draws.' },
    { id: 'google-cloud', title: 'Find Google Cloud billing amount', vendor: 'Google Cloud', priority: 'normal', notes: 'Email showed billing issue/past-due warning but not the amount.' },
    { id: 'apple-statement', title: 'Pull latest Apple Card statement/current activity', vendor: 'Apple Card', priority: 'urgent', notes: 'Needed for balance, limit, minimum, due date, and available credit.' }
  ];

  const money = (value) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(value || 0);
  const parseDate = (value) => new Date(`${value}T12:00:00`);
  const isPaid = (bill) => bill.status === 'paid';
  const isOverdue = (bill) => !isPaid(bill) && bill.status !== 'hold' && parseDate(bill.dueDate) < parseDate(today);

  function loadState() {
    try {
      const saved = JSON.parse(localStorage.getItem(storageKey) || '{}');
      return {
        bills: Array.isArray(saved.bills) ? saved.bills : defaultBills,
        reviews: Array.isArray(saved.reviews) ? saved.reviews : defaultReviews
      };
    } catch {
      return { bills: defaultBills, reviews: defaultReviews };
    }
  }

  let state = loadState();

  function saveState() {
    localStorage.setItem(storageKey, JSON.stringify(state, null, 2));
  }

  function priorityRank(value) {
    return { survival: 0, required: 1, debt: 2, flex: 3, defer: 4 }[value] ?? 9;
  }

  function billMatchesFilter(bill, filter) {
    if (filter === 'all') return true;
    if (filter === 'overdue') return isOverdue(bill);
    if (filter === 'unpaid') return !isPaid(bill) && bill.status !== 'hold';
    if (filter === 'paid') return isPaid(bill);
    if (filter === 'autopay') return bill.status === 'autopay';
    if (filter === 'survival') return bill.priority === 'survival';
    if (filter === 'debt') return bill.priority === 'debt';
    return true;
  }

  function sortBills(bills, sortMode) {
    return [...bills].sort((a, b) => {
      if (sortMode === 'amount_high') return b.amount - a.amount;
      if (sortMode === 'amount_low') return a.amount - b.amount;
      if (sortMode === 'priority') return priorityRank(a.priority) - priorityRank(b.priority) || parseDate(a.dueDate) - parseDate(b.dueDate);
      if (sortMode === 'account') return a.account.localeCompare(b.account) || parseDate(a.dueDate) - parseDate(b.dueDate);
      if (sortMode === 'paid_first') return Number(!isPaid(a)) - Number(!isPaid(b)) || parseDate(a.dueDate) - parseDate(b.dueDate);
      if (sortMode === 'unpaid_first') return Number(isPaid(a)) - Number(isPaid(b)) || parseDate(a.dueDate) - parseDate(b.dueDate);
      if (sortMode === 'overdue_first') return Number(!isOverdue(a)) - Number(!isOverdue(b)) || parseDate(a.dueDate) - parseDate(b.dueDate);
      return Number(isPaid(a)) - Number(isPaid(b)) || Number(!isOverdue(a)) - Number(!isOverdue(b)) || parseDate(a.dueDate) - parseDate(b.dueDate);
    });
  }

  function renderSummary() {
    const urgent = state.bills.filter((bill) => isOverdue(bill) || (!isPaid(bill) && parseDate(bill.dueDate) <= parseDate(today) && bill.status !== 'hold'));
    const unpaid = state.bills.filter((bill) => !isPaid(bill) && bill.status !== 'hold');
    const paid = state.bills.filter(isPaid);
    document.querySelector('[data-summary="urgent"]').textContent = money(urgent.reduce((sum, bill) => sum + bill.amount, 0));
    document.querySelector('[data-summary-detail="urgent"]').textContent = `${urgent.length} items`;
    document.querySelector('[data-summary="unpaid"]').textContent = money(unpaid.reduce((sum, bill) => sum + bill.amount, 0));
    document.querySelector('[data-summary-detail="unpaid"]').textContent = `${unpaid.length} items`;
    document.querySelector('[data-summary="paid"]').textContent = money(paid.reduce((sum, bill) => sum + bill.amount, 0));
    document.querySelector('[data-summary-detail="paid"]').textContent = `${paid.length} items`;
    document.querySelector('[data-summary="review"]').textContent = state.reviews.length;
  }

  function statusLabel(bill) {
    if (isPaid(bill)) return 'Paid';
    if (isOverdue(bill)) return 'Overdue';
    if (bill.status === 'autopay') return 'Autopay';
    if (bill.status === 'hold') return 'Hold';
    return 'Unpaid';
  }

  function renderBills() {
    const filter = document.querySelector('[data-filter]').value;
    const sortMode = document.querySelector('[data-sort]').value;
    const search = document.querySelector('[data-search]').value.trim().toLowerCase();
    const bills = sortBills(state.bills.filter((bill) => {
      const haystack = `${bill.name} ${bill.account} ${bill.category} ${bill.notes}`.toLowerCase();
      return billMatchesFilter(bill, filter) && (!search || haystack.includes(search));
    }), sortMode);

    document.querySelector('[data-count]').textContent = `${bills.length} bills`;
    document.querySelector('[data-bills]').innerHTML = bills.map((bill) => {
      const status = statusLabel(bill);
      const className = `${isPaid(bill) ? 'paid' : ''} ${isOverdue(bill) ? 'overdue' : ''}`.trim();
      const nextStatus = isPaid(bill) ? 'unpaid' : 'paid';
      return `
        <article class="bill-row ${className}">
          <div class="bill-top">
            <div>
              <h3 class="bill-name">${bill.name}</h3>
              <div class="bill-meta">
                <span class="status-pill ${status.toLowerCase()}">${status}</span>
                <span class="status-pill ${bill.priority}">${bill.priority}</span>
                Due ${bill.dueDate} · ${bill.category} · ${bill.account}
              </div>
            </div>
            <div class="bill-amount">${money(bill.amount)}</div>
          </div>
          <p class="bill-notes">${bill.notes}</p>
          <div class="bill-actions">
            <button class="bill-action ${nextStatus === 'paid' ? 'paid-action' : 'unpaid-action'}" type="button" data-mark="${bill.id}" data-status="${nextStatus}">
              Mark ${nextStatus === 'paid' ? 'paid' : 'unpaid'}
            </button>
          </div>
        </article>
      `;
    }).join('') || '<p class="bill-notes">No bills match the current filters.</p>';
  }

  function renderReviews() {
    document.querySelector('[data-reviews]').innerHTML = state.reviews.map((review) => `
      <article class="review-row">
        <h3>${review.title}</h3>
        <div class="review-meta">${review.vendor}${review.amount ? ` · ${money(review.amount)}` : ''}${review.dueDate ? ` · ${review.dueDate}` : ''} · ${review.priority}</div>
        <p>${review.notes}</p>
      </article>
    `).join('');
  }

  function render() {
    renderSummary();
    renderBills();
    renderReviews();
  }

  document.querySelector('[data-filter]').addEventListener('change', render);
  document.querySelector('[data-sort]').addEventListener('change', render);
  document.querySelector('[data-search]').addEventListener('input', render);
  document.querySelector('[data-bills]').addEventListener('click', (event) => {
    const button = event.target.closest('[data-mark]');
    if (!button) return;
    state.bills = state.bills.map((bill) => bill.id === button.dataset.mark ? { ...bill, status: button.dataset.status } : bill);
    saveState();
    render();
  });
  document.querySelector('[data-reset]').addEventListener('click', () => {
    if (!confirm('Reset this browser to the default finance data?')) return;
    state = { bills: defaultBills, reviews: defaultReviews };
    saveState();
    render();
  });
  document.querySelector('[data-export]').addEventListener('click', () => {
    const blob = new Blob([JSON.stringify({ ...state, exportedAt: new Date().toISOString(), month }, null, 2)], { type: 'application/json' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = `family-finance-${month}.json`;
    link.click();
    URL.revokeObjectURL(link.href);
  });

  render();
})();
</script>
