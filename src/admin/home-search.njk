    color: #17221d;
  }
  .hs-share-actions {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .hs-area-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 700;
    background: rgba(139,92,246,0.1);
    color: #7c3aed;
  }
  .hs-new-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #ef4444;
    color: #fff;
    padding: 2px 8px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 800;
    z-index: 1;
  }

  /* Mortgage Calculator Style */
  .hs-calculator-card {
    background: #fffdf8;
    border: 1px solid #d9d1c4;
    border-radius: 22px;
    padding: 20px;
    box-shadow: 0 14px 35px rgba(18, 54, 40, 0.08);
  }
  .hs-calculator-card h3 {
    margin: 0 0 16px;
    font-size: 18px;
    color: #123628;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .hs-calculator-card label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #526158;
    margin-bottom: 4px;
    font-weight: 700;
  }
  .hs-calculator-card input, .hs-calculator-card select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #d9d1c4;
    border-radius: 12px;
    font-size: 14px;
    color: #17221d;
    background: #fffdf8;
    margin-bottom: 12px;
    outline: none;
    transition: all 0.2s;
  }
  .hs-calculator-card input:focus, .hs-calculator-card select:focus {
    border-color: #1f4d3f;
    box-shadow: 0 0 0 3px rgba(31, 77, 63, 0.12);
  }
  .calc-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .calc-results {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #e8e2d5;
  }
  .calc-result-row.total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 15px;
    font-weight: 750;
    color: #123628;
    margin-bottom: 12px;
  }
  .calc-result-row.total strong {
    font-size: 22px;
    color: #1f4d3f;
  }
  .calc-breakdown-bar {
    display: flex;
    height: 10px;
    background: #e8dfd2;
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .calc-breakdown-bar .bar-fill {
    height: 100%;
  }
  .calc-breakdown-bar .bar-pi { background: #1f4d3f; }
  .calc-breakdown-bar .bar-tax { background: #e4b63d; }
  .calc-breakdown-bar .bar-ins { background: #8ba4b8; }
  
  .calc-legend {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13px;
  }
  .calc-legend span {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #43524a;
  }
  .calc-legend .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 8px;
  }
  .calc-legend .dot-pi { background: #1f4d3f; }
  .calc-legend .dot-tax { background: #e4b63d; }
  .calc-legend .dot-ins { background: #8ba4b8; }
  .calc-home-indicator {
    font-size: 11px;
    color: #123628;
    margin-bottom: 12px;
    padding: 8px 12px;
    background: rgba(31, 77, 63, 0.06);
    border: 1px solid rgba(31, 77, 63, 0.12);
    border-radius: 10px;
    display: none;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .hs-grid { grid-template-columns: 1fr; }
    .hs-controls { flex-direction: column; align-items: stretch; }
    .hs-controls select, .hs-controls input, .hs-controls button { width: 100%; }
    .hs-stats { grid-template-columns: 1fr 1fr; }
  }
</style>

<div class="compliance-page">
  <div class="compliance-container">
    <nav class="family-nav">
      <a href="/admin/dashboard/" class="family-nav-brand">
        <i class="fas fa-people-roof" style="color:#1f4d3f;"></i>
        <span>Family Command</span>
      </a>
      <div class="family-nav-links">
        <a href="/admin/family/" class="family-nav-link"><i class="fas fa-wallet"></i> Finance</a>
        <a href="/admin/court-compliance/" class="family-nav-link"><i class="fas fa-clipboard-check"></i> Custody</a>
        <a href="/admin/home-search/" class="family-nav-link active"><i class="fas fa-home"></i> Homes</a>
        <a href="/admin/dashboard/" class="family-nav-link"><i class="fas fa-gauge"></i> Admin</a>
      </div>
    </nav>

    <div class="hs-header">
      <div>
        <h2>Home <span style="font-size:14px;color:#526158;font-weight:400;">Fresno County</span></h2>
        <div class="meta">Daily Fresno County listing refresh &bull; Fresno High, Tower, Old Fig, Sunnyside, rural areas &bull; Mid-century &amp; farmhouse style</div>
      </div>
      <div style="text-align:right;">
        <div class="meta" id="lastSearched">Loading...</div>
        <div class="meta" id="searchCount"></div>
        <div class="hs-source-summary" id="sourceSummary"></div>
      </div>
    </div>

    <!-- Summary Stats -->
    <div class="hs-stats" id="statsRow">
      <div class="hs-stat-card"><div class="label">Listings</div><div class="value" id="statTotal">--</div></div>
      <div class="hs-stat-card"><div class="label">Price Range</div><div class="value green" id="statRange" style="font-size:16px;">--</div></div>
      <div class="hs-stat-card"><div class="label">Avg Sq Ft</div><div class="value" id="statSqft">--</div></div>
      <div class="hs-stat-card"><div class="label">Favorites</div><div class="value" style="color:#e4b63d;" id="statFavs">0</div></div>
      <div class="hs-stat-card"><div class="label">New Today</div><div class="value" style="color:#1f4d3f;" id="statNew">0</div></div>
      <div class="hs-stat-card"><div class="label">Fresno High + Tower</div><div class="value green" id="statPriority">0</div></div>
    </div>

    <div class="hs-layout">
      <!-- Main Listing Column -->
      <div class="hs-listings-column">
        <div class="hs-priority-note">
          <strong>Priority areas:</strong> Fresno High and Tower District are highlighted first. Old Fig, Sunnyside, rural/country, and other Fresno County areas remain in the search. Easton is excluded.
        </div>
        <!-- Controls -->
        <div class="hs-controls">
          <select id="sortBy" onchange="renderListings()">
            <option value="priority-desc">Priority Areas First</option>
            <option value="price-asc">Price: Low to High</option>
            <option value="price-desc">Price: High to Low</option>
            <option value="sqft-desc">Sq Ft: Largest</option>
            <option value="beds-desc">Beds: Most</option>
            <option value="date-desc">Newest First</option>
          </select>
          <select id="filterArea" onchange="renderListings()">
            <option value="all">All Areas</option>
            <option value="fresno-high">Fresno High</option>
            <option value="tower">Tower District</option>
            <option value="old-fig">Old Fig</option>
            <option value="sunnyside">Sunnyside</option>
            <option value="rural">Rural / Country</option>
            <option value="other">Other</option>
          </select>
          <select id="filterView" onchange="renderListings()">
            <option value="all">All Listings</option>
            <option value="favorites">Favorites Only</option>
            <option value="new">New Today</option>
          </select>
          <input type="text" id="searchBox" placeholder="Search address..." oninput="renderListings()" style="flex:1;min-width:120px;">
          <button class="hs-btn hs-btn-primary" id="freshSearchBtn" onclick="runFreshSearch()"><i class="fas fa-rotate"></i> Fresh Search</button>
          <button class="hs-btn hs-btn-green" onclick="openShareModal()">Share Favorites with Cristal</button>
          <span class="hs-refresh-status" id="freshSearchStatus" aria-live="polite"></span>
        </div>

        <!-- Listing Grid -->
        <div id="listingsContainer">
          <div class="hs-loading">Loading listings...</div>
        </div>
      </div>

      <!-- Sidebar Calculator Column -->
      <div class="hs-calculator-column">
        <div class="hs-calculator-card">
          <h3><i class="fas fa-calculator" style="color:#1f4d3f;"></i> Mortgage Calculator</h3>
          <div class="calc-home-indicator" id="calcHomeIndicator"></div>
          
          <div class="calc-form">
            <div class="calc-group">
              <label for="calcPrice">Home Price ($)</label>
              <input type="number" id="calcPrice" value="450000" oninput="calculateMortgage()">
            </div>
            
            <div class="calc-row-2">
              <div class="calc-group">
                <label for="calcDownPercent">Down (%)</label>
                <input type="number" id="calcDownPercent" value="20" min="0" max="100" oninput="updateDownAmount()">
              </div>
              <div class="calc-group">
                <label for="calcDownAmount">Down ($)</label>
                <input type="number" id="calcDownAmount" value="90000" oninput="updateDownPercent()">
              </div>
            </div>

            <div class="calc-row-2">
              <div class="calc-group">
                <label for="calcRate">Rate (%)</label>
                <input type="number" id="calcRate" value="6.5" step="0.05" oninput="calculateMortgage()">
              </div>
              <div class="calc-group">
                <label for="calcTerm">Term</label>
                <select id="calcTerm" onchange="calculateMortgage()">
                  <option value="30">30 Years</option>
                  <option value="20">20 Years</option>
                  <option value="15">15 Years</option>
                </select>
              </div>
            </div>

            <div class="calc-row-2">
              <div class="calc-group">
                <label for="calcTax">Tax (%/yr)</label>
                <input type="number" id="calcTax" value="1.2" step="0.05" oninput="calculateMortgage()">
              </div>
              <div class="calc-group">
                <label for="calcInsurance">Ins ($/yr)</label>
                <input type="number" id="calcInsurance" value="1200" step="50" oninput="calculateMortgage()">
              </div>
            </div>
          </div>

          <div class="calc-results">
            <div class="calc-result-row total">
              <span>Est. Payment</span>
              <strong id="resTotalPayment">$0</strong>
