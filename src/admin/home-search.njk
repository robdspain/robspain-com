    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    z-index: 200;
    align-items: center;
    justify-content: center;
  }
  .hs-share-modal.open {
    display: flex;
  }
  .hs-share-content {
    background: #fffdf8;
    border: 1px solid #d9d1c4;
    border-radius: 22px;
    padding: 24px;
    max-width: 500px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
  }
  .hs-share-content h3 {
    margin: 0 0 12px;
    font-size: 18px;
    color: #123628;
  }
  .hs-share-content textarea {
    width: 100%;
    height: 200px;
    border: 1px solid #d9d1c4;
