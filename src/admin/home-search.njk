const SEED_META = { lastSearched: "2026-05-28T00:00:00Z", searchCount: 1, source: "Redfin - Fresno County fallback" };
const TARGET_AREAS = new Set(['fresno-high', 'tower']);
const AREA_LABELS = {
  'fresno-high': 'Fresno High',
  'tower': 'Tower District',
  'old-fig': 'Old Fig',
  'sunnyside': 'Sunnyside',
  'rural': 'Rural',
  'other': ''
};

async function loadData() {
  try {
    const res = await fetch('/api/home-search');
    const data = await res.json();
    allListings = (data.listings && data.listings.length > 0) ? data.listings : SEED_LISTINGS;
    searchMeta = (data.meta && data.meta.lastSearched) ? data.meta : SEED_META;
    (data.favorites || []).forEach(id => favorites.add(id));
  } catch (e) {
    allListings = SEED_LISTINGS;
    searchMeta = SEED_META;
  }
  updateMeta();
  updateStats();
  renderListings();
  calculateMortgage();
}

async function runFreshSearch() {
  const button = document.getElementById('freshSearchBtn');
  const status = document.getElementById('freshSearchStatus');
  if (button) {
    button.disabled = true;
    button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Searching...';
  }
  if (status) {
    status.className = 'hs-refresh-status';
    status.textContent = 'Pulling fresh Fresno County listings...';
  }

  try {
    const response = await fetch('/admin/api/home-search-refresh', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ manual: true })
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) throw new Error(data.error || `Refresh failed (${response.status})`);
    await loadData();
    if (status) {
      status.className = 'hs-refresh-status ok';
      status.textContent = data.updated
        ? `Fresh search complete: ${data.listings || allListings.length} listings.`
        : (data.message || 'Fresh search complete.');
    }
  } catch (error) {
    if (status) {
      status.className = 'hs-refresh-status error';
      status.textContent = error.message;
    }
  } finally {
    if (button) {
      button.disabled = false;
      button.innerHTML = '<i class="fas fa-rotate"></i> Fresh Search';
    }
  }
}

function updateMeta() {
  const el = document.getElementById('lastSearched');
  if (searchMeta.lastSearched) {
    const d = new Date(searchMeta.lastSearched);
    el.textContent = 'Last searched: ' + d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });
  } else {
    el.textContent = 'No searches yet';
  }
  const countEl = document.getElementById('searchCount');
  if (searchMeta.searchCount) countEl.textContent = searchMeta.searchCount + ' searches total';
  const sourceEl = document.getElementById('sourceSummary');
  if (sourceEl) {
    const counts = searchMeta.sourceCounts || {};
    const countText = Object.entries(counts).map(([source, count]) => `${source}: ${count}`).join(' · ');
    sourceEl.textContent = [searchMeta.source || '', countText].filter(Boolean).join(' · ');
  }
}

function updateStats() {
  document.getElementById('statTotal').textContent = allListings.length;

  if (allListings.length > 0) {
    const prices = allListings.map(l => l.price).filter(p => p > 0).sort((a, b) => a - b);
    if (prices.length > 0) {
      const fmtVal = p => '$' + (p >= 1000000 ? (p / 1000000).toFixed(1) + 'M' : Math.round(p / 100) + 'k');
      document.getElementById('statRange').textContent = fmtVal(prices[0]) + ' - ' + fmtVal(prices[prices.length - 1]);
    }
    const sqfts = allListings.map(l => l.sqft).filter(s => s > 0);
    if (sqfts.length > 0) {
      document.getElementById('statSqft').textContent = Math.round(sqfts.reduce((a, b) => a + b, 0) / sqfts.length).toLocaleString();
    }
  }

  document.getElementById('statFavs').textContent = favorites.size;

  const today = new Date().toDateString();
  const newCount = allListings.filter(l => l.addedAt && new Date(l.addedAt).toDateString() === today).length;
  document.getElementById('statNew').textContent = newCount;
  document.getElementById('statPriority').textContent = allListings.filter(l => isPriorityArea(l)).length;
}

function renderListings() {
  const sortBy = document.getElementById('sortBy').value;
  const filterArea = document.getElementById('filterArea').value;
  const filterView = document.getElementById('filterView').value;
  const search = document.getElementById('searchBox').value.toLowerCase().trim();

  let filtered = [...allListings];

  // Filter by area
  if (filterArea !== 'all') {
    filtered = filtered.filter(l => (l.area || 'other') === filterArea);
  }

  // Filter by view
  if (filterView === 'favorites') {
    filtered = filtered.filter(l => favorites.has(l.id));
  } else if (filterView === 'new') {
    const today = new Date().toDateString();
    filtered = filtered.filter(l => l.addedAt && new Date(l.addedAt).toDateString() === today);
  }

  // Search
  if (search) {
    filtered = filtered.filter(l =>
      (l.address || '').toLowerCase().includes(search) ||
      (l.description || '').toLowerCase().includes(search) ||
      (l.area || '').toLowerCase().includes(search)
    );
  }

  // Sort
  const [field, dir] = sortBy.split('-');
  filtered.sort((a, b) => {
    let va = a[field] || 0, vb = b[field] || 0;
    if (field === 'priority') {
      va = areaPriority(a);
      vb = areaPriority(b);
    }
    if (field === 'date') { va = new Date(a.addedAt || 0).getTime(); vb = new Date(b.addedAt || 0).getTime(); }
    const primary = dir === 'asc' ? va - vb : vb - va;
    if (primary) return primary;
    return new Date(b.addedAt || 0).getTime() - new Date(a.addedAt || 0).getTime();
  });

  const container = document.getElementById('listingsContainer');

  if (filtered.length === 0) {
    container.innerHTML = '<div class="hs-empty"><h3>No listings found</h3><p>Try adjusting your filters or check back after the next search.</p></div>';
    return;
  }

  const today = new Date().toDateString();
  container.innerHTML = '<div class="hs-grid">' + filtered.map(l => {
    const isFav = favorites.has(l.id);
    const isNew = l.addedAt && new Date(l.addedAt).toDateString() === today;
    const isTarget = isPriorityArea(l);
    
    // Escape single quotes in address for javascript call
    const escapedAddr = (l.address || '').replace(/'/g, "\\'");

    return `<div class="hs-card ${isFav ? 'favorited' : ''} ${isTarget ? 'target-area' : ''}">
      ${isNew ? '<span class="hs-new-badge">NEW</span>' : ''}
      ${l.imageUrl
        ? `<img class="hs-card-img" src="${l.imageUrl}" alt="${l.address}" loading="lazy" onerror="this.outerHTML='<div class=hs-card-img-placeholder>No photo</div>'">`
        : '<div class="hs-card-img-placeholder">No photo available</div>'}
      <div class="hs-card-body">
        <div class="hs-card-price">$${(l.price || 0).toLocaleString()}</div>
        <div class="hs-card-address">${l.address || 'Address unavailable'}</div>
        <div class="hs-card-details">
          <span><strong>${l.beds || '?'}</strong> beds</span>
          <span><strong>${l.baths || '?'}</strong> baths</span>
          <span><strong>${l.sqft ? l.sqft.toLocaleString() : '?'}</strong> sq ft</span>
        </div>
        <div class="hs-card-tags">
          ${l.area && l.area !== 'other' ? `<span class="hs-area-badge">${AREA_LABELS[l.area] || l.area}</span>` : ''}
          ${l.sourceLabel || l.source ? `<span class="hs-source-badge">${l.sourceLabel || l.source}</span>` : ''}
          ${isTarget ? '<span class="hs-tag pool">Priority area</span>' : ''}
          ${l.hasPool ? '<span class="hs-tag pool">Pool</span>' : ''}
          ${l.isFixer ? '<span class="hs-tag fixer">Fixer</span>' : ''}
          ${l.area === 'rural' ? '<span class="hs-tag rural">Rural</span>' : ''}
        </div>
        <div class="hs-card-desc">${l.description || ''}</div>
        <div class="hs-card-actions">
          ${l.listingUrl ? `<a class="view-link" href="${l.listingUrl}" target="_blank" rel="noopener">View</a>` : '<span class="view-link" style="opacity:0.5">No link</span>'}
          <button class="calc-btn" onclick="populateCalculator(${l.price}, '${escapedAddr}')"><i class="fas fa-calculator"></i> Calc</button>
          <button class="share-btn" onclick="shareSingle('${l.id}')">Send</button>
          <button class="fav-btn ${isFav ? 'active' : ''}" onclick="toggleFav('${l.id}')">${isFav ? '★' : '☆'}</button>
        </div>
      </div>
    </div>`;
  }).join('') + '</div>';
}

function isPriorityArea(listing) {
  return Boolean(listing?.targetArea) || TARGET_AREAS.has(listing?.area);
}

function areaPriority(listing) {
  if (Number.isFinite(Number(listing?.areaPriority))) return Number(listing.areaPriority);
  if (isPriorityArea(listing)) return 2;
  if (listing?.area === 'old-fig') return 1;
  return 0;
}

function toggleFav(id) {
  if (favorites.has(id)) favorites.delete(id);
  else favorites.add(id);
  updateStats();
  renderListings();
  saveFavorites();
}

async function saveFavorites() {
  const value = [...favorites];
  localStorage.setItem('hs-favorites', JSON.stringify(value));
  try {
    await fetch('/admin/api/family-convex', {
      method: 'PUT',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key: 'hs-favorites', value })
    });
  } catch (error) {
    console.warn('Favorite sync unavailable; kept local copy.', error);
  }
}

function shareSingle(id) {
  const l = allListings.find(x => x.id === id);
  if (!l) return;
  const msg = composeShareMessage([l]);
  document.getElementById('shareText').value = msg;
  document.getElementById('shareModal').classList.add('open');
}

function openShareModal() {
  const favListings = allListings.filter(l => favorites.has(l.id));
  if (favListings.length === 0) {
    showToast('No favorites selected! Star some listings first.');
    return;
  }
  const msg = composeShareMessage(favListings);
  document.getElementById('shareText').value = msg;
  document.getElementById('shareModal').classList.add('open');
}

function closeShareModal() {
  document.getElementById('shareModal').classList.remove('open');
}

function composeShareMessage(listings) {
  let msg = `Hey Cristal! Found ${listings.length} home${listings.length > 1 ? 's' : ''} in Fresno County:\n\n`;
  listings.forEach((l, i) => {
    msg += `${i + 1}. ${l.address || 'Unknown address'}\n`;
    msg += `   $${(l.price || 0).toLocaleString()} | ${l.beds || '?'} bed / ${l.baths || '?'} bath | ${l.sqft ? l.sqft.toLocaleString() + ' sq ft' : 'Sq ft N/A'}\n`;
    if (l.description) msg += `   ${l.description.substring(0, 120)}\n`;
    if (l.listingUrl) msg += `   ${l.listingUrl}\n`;
    msg += '\n';
  });
  msg += 'What do you think? Let me know which ones you want to check out!';
  return msg;
}

function copyShareText() {
  const text = document.getElementById('shareText').value;
  navigator.clipboard.writeText(text).then(() => {
    showToast('Copied to clipboard!');
    closeShareModal();
  }).catch(() => {
    document.getElementById('shareText').select();
    document.execCommand('copy');
    showToast('Copied!');
    closeShareModal();
  });
}

function emailShare() {
  const text = document.getElementById('shareText').value;
  const subject = encodeURIComponent('Homes in Fresno County');
  const body = encodeURIComponent(text);
  window.open(`mailto:?subject=${subject}&body=${body}`, '_blank');
}

function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 2500);
}

/* Mortgage Calculator logic */
function calculateMortgage() {
  const price = parseFloat(document.getElementById('calcPrice').value) || 0;
  const down = parseFloat(document.getElementById('calcDownAmount').value) || 0;
  const rate = parseFloat(document.getElementById('calcRate').value) || 0;
  const termYears = parseFloat(document.getElementById('calcTerm').value) || 30;
  const taxRate = parseFloat(document.getElementById('calcTax').value) || 0;
  const insuranceYr = parseFloat(document.getElementById('calcInsurance').value) || 0;

  const loanAmount = Math.max(0, price - down);
  
  let monthlyPI = 0;
  if (loanAmount > 0) {
    const monthlyRate = (rate / 100) / 12;
    const numberOfPayments = termYears * 12;
    if (monthlyRate === 0) {
      monthlyPI = loanAmount / numberOfPayments;
    } else {
      monthlyPI = loanAmount * (monthlyRate * Math.pow(1 + monthlyRate, numberOfPayments)) / (Math.pow(1 + monthlyRate, numberOfPayments) - 1);
    }
  }

  const monthlyTax = (price * (taxRate / 100)) / 12;
  const monthlyIns = insuranceYr / 12;
  
  const totalPayment = monthlyPI + monthlyTax + monthlyIns;

  document.getElementById('resPi').textContent = '$' + Math.round(monthlyPI).toLocaleString();
  document.getElementById('resTax').textContent = '$' + Math.round(monthlyTax).toLocaleString();
  document.getElementById('resIns').textContent = '$' + Math.round(monthlyIns).toLocaleString();
  document.getElementById('resTotalPayment').textContent = '$' + Math.round(totalPayment).toLocaleString();

  const total = monthlyPI + monthlyTax + monthlyIns;
  if (total > 0) {
    const piPct = (monthlyPI / total) * 100;
    const taxPct = (monthlyTax / total) * 100;
    const insPct = (monthlyIns / total) * 100;
    
    document.getElementById('barPi').style.width = piPct + '%';
    document.getElementById('barTax').style.width = taxPct + '%';
    document.getElementById('barIns').style.width = insPct + '%';
  } else {
    document.getElementById('barPi').style.width = '0%';
    document.getElementById('barTax').style.width = '0%';
    document.getElementById('barIns').style.width = '0%';
  }
}

function updateDownAmount() {
  const price = parseFloat(document.getElementById('calcPrice').value) || 0;
  const pct = parseFloat(document.getElementById('calcDownPercent').value) || 0;
  const amt = Math.round(price * (pct / 100));
  document.getElementById('calcDownAmount').value = amt;
  calculateMortgage();
}

function updateDownPercent() {
  const price = parseFloat(document.getElementById('calcPrice').value) || 0;
  const amt = parseFloat(document.getElementById('calcDownAmount').value) || 0;
  let pct = 0;
  if (price > 0) {
    pct = parseFloat(((amt / price) * 100).toFixed(1));
  }
  document.getElementById('calcDownPercent').value = pct;
  calculateMortgage();
}

function populateCalculator(price, address) {
  document.getElementById('calcPrice').value = price;
  
  const pct = parseFloat(document.getElementById('calcDownPercent').value) || 0;
  const amt = Math.round(price * (pct / 100));
  document.getElementById('calcDownAmount').value = amt;
  
  const indicator = document.getElementById('calcHomeIndicator');
  indicator.style.display = 'block';
  indicator.textContent = 'Listing: ' + address;
  
  calculateMortgage();
  
  if (window.innerWidth < 1024) {
    document.querySelector('.hs-calculator-column').scrollIntoView({ behavior: 'smooth' });
  }
}

// Load favorites from localStorage on init
const savedFavs = localStorage.getItem('hs-favorites');
if (savedFavs) {
  try { JSON.parse(savedFavs).forEach(id => favorites.add(id)); } catch (e) {}
}

async function loadFavoritesFromConvex() {
  try {
    const res = await fetch('/admin/api/family-convex?key=hs-favorites', { credentials: 'same-origin' });
    if (!res.ok) return;
    const data = await res.json();
    if (!data.item || !Array.isArray(data.item.value)) return;
    favorites = new Set(data.item.value);
    localStorage.setItem('hs-favorites', JSON.stringify([...favorites]));
    updateStats();
    renderListings();
  } catch (error) {
    console.warn('Using local favorites.', error);
  }
}

loadData();
loadFavoritesFromConvex();
</script>
