    text-align: center;
    padding: 8px 4px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.15s;
  }
  .hs-card-actions .view-link {
    background: rgba(31, 77, 63, 0.08);
    color: #1f4d3f;
  }
  .hs-card-actions .view-link:hover {
    background: rgba(31, 77, 63, 0.16);
  }
  .hs-card-actions .calc-btn {
    background: rgba(228, 182, 61, 0.12);
    color: #b28510;
  }
  .hs-card-actions .calc-btn:hover {
    background: rgba(228, 182, 61, 0.22);
  }
  .hs-card-actions .share-btn {
    background: rgba(31, 77, 63, 0.08);
    color: #1f4d3f;
  }
  .hs-card-actions .share-btn:hover {
    background: rgba(31, 77, 63, 0.16);
  }
  .hs-card-actions .fav-btn {
    background: rgba(228, 182, 61, 0.08);
    color: #b28510;
    flex: 0 0 36px;
  }
  .hs-card-actions .fav-btn:hover {
    background: rgba(228, 182, 61, 0.18);
  }
  .hs-card-actions .fav-btn.active {
    background: #e4b63d;
    color: #fff;
  }
  .hs-empty {
    text-align: center;
    padding: 60px 20px;
    color: #526158;
  }
  .hs-empty h3 {
    font-size: 18px;
    color: #123628;
    margin-bottom: 8px;
  }
  .hs-loading {
    text-align: center;
    padding: 40px;
    color: #526158;
    font-size: 14px;
  }
  .hs-toast {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #1f4d3f;
    color: #fff;
    padding: 12px 20px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 700;
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 100;
    pointer-events: none;
  }
  .hs-toast.show {
