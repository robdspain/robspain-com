    outline: none;
    border-color: #1f4d3f;
    box-shadow: 0 0 0 3px rgba(31, 77, 63, 0.12);
  }
  .hs-btn {
    padding: 10px 20px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }
  .hs-btn-primary {
    background: #1f4d3f;
    color: #fff;
  }
  .hs-btn-primary:hover {
    background: #123628;
  }
  .hs-btn-green {
    background: #1f4d3f;
    color: #fff;
  }
  .hs-btn-green:hover {
    background: #123628;
  }
  .hs-btn-outline {
    background: #fffdf8;
    color: #526158;
    border: 1px solid #d9d1c4;
  }
  .hs-btn-outline:hover {
    border-color: #526158;
    color: #17221d;
  }
  .hs-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }
  .hs-stat-card {
    background: #fffdf8;
    border: 1px solid #d9d1c4;
    border-radius: 22px;
    padding: 16px;
    text-align: center;
    box-shadow: 0 8px 24px rgba(18, 54, 40, 0.04);
  }
  .hs-stat-card .label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #526158;
    margin-bottom: 4px;
    font-weight: 700;
  }
  .hs-stat-card .value {
    font-size: 24px;
    font-weight: 800;
    color: #123628;
  }
  .hs-stat-card .value.green {
    color: #1f4d3f;
  }
  .hs-priority-note {
    background: linear-gradient(135deg, #fffdf8 0%, #eef7f1 100%);
    border: 1px solid rgba(31, 77, 63, 0.18);
    border-radius: 18px;
    color: #43524a;
    font-size: 13px;
    line-height: 1.55;
    margin: -8px 0 20px;
    padding: 14px 16px;
  }
  .hs-priority-note strong {
    color: #123628;
  }
  .hs-source-summary {
    color: #526158;
    font-size: 12px;
    margin-top: 6px;
  }
  .hs-refresh-status {
    color: #526158;
    display: inline-flex;
    font-size: 12px;
    font-weight: 650;
    min-height: 1.2em;
  }
  .hs-refresh-status.error {
    color: #b91c1c;
  }
  .hs-refresh-status.ok {
    color: #1f4d3f;
  }
  
  /* Layout columns */
  .hs-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .hs-layout {
      grid-template-columns: 1fr 380px;
    }
  }

  .hs-listings-column {
    display: flex;
    flex-direction: column;
  }

  .hs-calculator-column {
    position: sticky;
    top: 24px;
  }

  .hs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }
  .hs-card {
    background: #fffdf8;
    border: 1px solid #d9d1c4;
    border-radius: 22px;
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
    position: relative;
    box-shadow: 0 10px 30px rgba(18, 54, 40, 0.06);
  }
  .hs-card:hover {
    box-shadow: 0 14px 35px rgba(18, 54, 40, 0.12);
    transform: translateY(-2px);
  }
  .hs-card.favorited {
    border-color: #e4b63d;
  }
  .hs-card.target-area {
    border-color: rgba(31, 77, 63, 0.55);
    box-shadow: 0 14px 38px rgba(31, 77, 63, 0.14);
  }
  .hs-card-img {
    width: 100%;
    height: 200px;
    object-fit: contain;
    background: #f1f5f9;
    display: block;
  }
  .hs-card-img-placeholder {
    width: 100%;
    height: 200px;
    background: linear-gradient(135deg, #fffdf8 0%, #e8dfd2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #526158;
    font-size: 14px;
  }
  .hs-card-body {
    padding: 18px;
  }
  .hs-card-price {
    font-size: 22px;
    font-weight: 800;
    color: #123628;
    margin-bottom: 4px;
  }
  .hs-card-address {
    font-size: 14px;
    color: #43524a;
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .hs-card-details {
    display: flex;
    gap: 16px;
    font-size: 13px;
    color: #526158;
    margin-bottom: 10px;
  }
  .hs-card-details span {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .hs-card-desc {
    font-size: 13px;
    color: #526158;
    line-height: 1.5;
    margin-bottom: 12px;
    max-height: 60px;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hs-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 12px;
  }
  .hs-source-badge {
    background: #eff6ff;
    color: #1d4ed8;
    border-radius: 9999px;
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
