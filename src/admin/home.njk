family_pwa: true
---

<style>
  :root {
    --neo-ink: #17221d;
    --neo-muted: #526158;
    --neo-line: #d9d1c4;
    --neo-panel: #fffdf8;
    --neo-panel-strong: #fffdf8;
    --neo-blue: #1f4d3f;
    --neo-gold: #e4b63d;
    --neo-green: #1f4d3f;
    --neo-red: #b91c1c;
    --neo-radius: 22px;
  }

  body { background: #f6f2ea; }
  .nav-premium, .footer { display: none !important; }
  main { min-height: 100vh; }

  .neo-home {
    min-height: 100vh;
    color: var(--neo-ink);
    background: #f6f2ea;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    position: relative;
  }

  .family-nav {
    background: #fffdf8;
    border: 1px solid #d9d1c4;
    padding: 12px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    box-shadow: 0 4px 20px rgba(18, 54, 40, 0.04);
    border-radius: 16px;
  }
  .family-nav-brand {
    font-size: 16px;
    font-weight: 800;
    color: #123628;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .family-nav-links {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .family-nav-link {
    font-size: 13px;
    font-weight: 700;
    color: #526158;
    text-decoration: none;
    padding: 8px 12px;
    border-radius: 8px;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .family-nav-link:hover {
    background: rgba(31, 77, 63, 0.06);
    color: #1f4d3f;
  }
  .family-nav-link.active {
    background: #1f4d3f;
    color: #fffdf8;
  }

  .neo-shell {
    width: min(1120px, calc(100% - 28px));
    margin: 0 auto;
    padding: 2rem 0 max(28px, env(safe-area-inset-bottom));
    position: relative;
    z-index: 1;
  }

  .neo-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 22px;
    padding-bottom: 16px;
    border-bottom: 1px solid #d9d1c4;
  }

  .neo-brand { display: flex; align-items: center; gap: 12px; }
  .neo-orb {
    width: 46px;
    height: 46px;
    border-radius: 18px;
    background: conic-gradient(from 210deg, #1f4d3f, #e4b63d, #526158, #1f4d3f);
    box-shadow: 0 0 34px rgba(31, 77, 63, 0.2);
    position: relative;
  }
  .neo-orb::after { content: ""; position: absolute; inset: 5px; border-radius: 14px; background: #fffdf8; }
  .neo-title h1 { font-size: clamp(1.5rem, 6vw, 3.8rem); line-height: 0.95; margin: 0; letter-spacing: -0.07em; color: #123628; }
  .neo-title p { margin: 4px 0 0; color: #526158; font-size: 0.86rem; }

  .neo-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #123628;
    border: 1px solid rgba(31, 77, 63, 0.28);
    background: rgba(31, 77, 63, 0.08);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 0.78rem;
    font-weight: 800;
    white-space: nowrap;
  }
  .neo-dot { width: 8px; height: 8px; border-radius: 999px; background: #1f4d3f; box-shadow: 0 0 16px #1f4d3f; }

  .neo-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 18px; align-items: stretch; }
  .neo-panel {
    border: 1px solid #d9d1c4;
    background: #fffdf8;
    box-shadow: 0 14px 35px rgba(18, 54, 40, 0.08);
    border-radius: var(--neo-radius);
  }

  .neo-command { padding: clamp(18px, 4vw, 30px); }
  .neo-kicker { color: #e4b63d; font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 900; margin-bottom: 12px; }
  .neo-command h2 { font-size: clamp(2.2rem, 10vw, 5.2rem); line-height: 0.9; letter-spacing: -0.08em; margin: 0 0 18px; max-width: 9ch; color: #123628; }
  .neo-command p { color: #526158; max-width: 55ch; line-height: 1.6; margin: 0 0 20px; }

  .neo-input-wrap { display: grid; gap: 12px; }
  .neo-input {
    width: 100%;
    min-height: 138px;
    border: 1px solid #d9d1c4;
    border-radius: 24px;
    background: #fff;
    color: #17221d;
    resize: vertical;
    padding: 18px;
    font: 700 1.04rem/1.45 Inter, sans-serif;
    outline: none;
  }
  .neo-input:focus { border-color: #1f4d3f; box-shadow: 0 0 0 4px rgba(31, 77, 63, 0.12); }

  .neo-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .neo-btn {
    appearance: none;
    border: 0;
    border-radius: 18px;
    padding: 13px 16px;
    min-height: 48px;
    color: #526158;
    font-weight: 900;
    cursor: pointer;
    background: #fffdf8;
    border: 1px solid #d9d1c4;
    transition: transform .18s ease, border-color .18s ease, background .18s ease;
  }
  .neo-btn:active { transform: scale(0.98); }
  .neo-btn-primary { background: #1f4d3f; color: #fff; border-color: #1f4d3f; box-shadow: 0 8px 24px rgba(31, 77, 63, 0.15); flex: 1; }
  .neo-btn-primary:hover { background: #123628; }
  .neo-btn-gold { background: rgba(228, 182, 61, 0.12); color: #b28510; border-color: rgba(228, 182, 61, 0.32); }
  .neo-btn-gold:hover { background: rgba(228, 182, 61, 0.2); }
  .neo-btn-ghost { color: #526158; border: 1px solid transparent; background: transparent; }
  .neo-btn-ghost:hover { background: rgba(31, 77, 63, 0.06); color: #17221d; }

  .neo-side { display: grid; gap: 18px; }
  .neo-card { padding: 18px; }
  .neo-card h3 { margin: 0 0 12px; font-size: 1rem; letter-spacing: -0.02em; color: #123628; }
  .neo-card p, .neo-small { color: #526158; font-size: .86rem; line-height: 1.55; margin: 0; }

  .neo-token-row { display: flex; gap: 8px; margin-top: 12px; }
  .neo-token-row input {
    flex: 1;
    min-width: 0;
    border: 1px solid #d9d1c4;
    border-radius: 14px;
    background: #fff;
    color: #17221d;
    padding: 11px 12px;
    outline: none;
  }
  .neo-token-row input:focus { border-color: #1f4d3f; }
  .neo-token-row button { white-space: nowrap; }

  .neo-quick-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 10px; }
  .neo-chip {
    border: 1px solid #d9d1c4;
    background: #fffdf8;
    border-radius: 18px;
    color: #17221d;
    min-height: 74px;
    padding: 12px;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s;
  }
  .neo-chip:hover {
    background: rgba(31, 77, 63, 0.04);
    border-color: #1f4d3f;
  }
  .neo-chip strong { display: block; font-size: .95rem; margin-bottom: 4px; color: #123628; }
  .neo-chip span { color: #526158; font-size: .76rem; line-height: 1.25; display: block; }

  .neo-log { min-height: 88px; border-radius: 18px; padding: 14px; background: #fffaf0; border: 1px solid #d9d1c4; color: #17221d; font: 0.86rem/1.45 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; white-space: pre-wrap; }
  .neo-log[data-state="error"] { color: #991b1b; border-color: #fca5a5; background: #fee2e2; }
  .neo-log[data-state="ok"] { color: #065f46; border-color: #a7f3d0; background: #d1fae5; }

  .neo-install { margin-top: 18px; display: flex; align-items: center; gap: 10px; justify-content: space-between; border: 1px dashed rgba(228, 182, 61, 0.4); background: rgba(228, 182, 61, 0.06); padding: 14px; border-radius: 22px; }

  @media (max-width: 820px) {
    .neo-shell { width: min(100% - 20px, 680px); }
    .neo-grid { grid-template-columns: 1fr; }
    .neo-topbar { align-items: flex-start; }
    .neo-status { margin-top: 4px; }
    .neo-command h2 { max-width: 8ch; }
    .neo-btn-primary { flex-basis: 100%; }
  }

  @media (max-width: 480px) {
    .neo-topbar { flex-direction: column; }
    .neo-quick-grid { grid-template-columns: 1fr; }
    .neo-command { border-radius: 24px; }
  }
</style>

<section class="neo-home" aria-label="Neo Home Command Center">
  <div class="neo-shell">
    <nav class="family-nav">
      <a href="/admin/dashboard/" class="family-nav-brand">
        <i class="fas fa-people-roof" style="color:#1f4d3f;"></i>
        <span>Family Command</span>
      </a>
      <div class="family-nav-links">
        <a href="/admin/family/" class="family-nav-link"><i class="fas fa-wallet"></i> Finance</a>
        <a href="/admin/court-compliance/" class="family-nav-link"><i class="fas fa-clipboard-check"></i> Custody</a>
        <a href="/admin/home-search/" class="family-nav-link"><i class="fas fa-home"></i> Home Search</a>
        <a href="/admin/home/" class="family-nav-link active"><i class="fas fa-house-signal"></i> Home Command</a>
        <a href="/admin/dashboard/" class="family-nav-link"><i class="fas fa-gauge"></i> Admin</a>
      </div>
    </nav>

    <header class="neo-topbar">
      <div class="neo-brand">
        <div class="neo-orb" aria-hidden="true"></div>
        <div class="neo-title">
          <h1>Neo Home</h1>
          <p>Private command surface for Rob + Cristal</p>
        </div>
      </div>
      <div class="neo-status" id="bridgeStatus"><span class="neo-dot"></span><span>Command bridge ready</span></div>
    </header>

    <div class="neo-grid">
      <article class="neo-panel neo-command">
        <div class="neo-kicker">Ask the house</div>
        <h2>What do you need?</h2>
        <p>Type a command, use iPhone keyboard dictation, or tap a quick action. Risky commands are queued for confirmation instead of executed blindly.</p>

        <div class="neo-input-wrap">
          <textarea id="commandText" class="neo-input" placeholder="Try: turn on the den lights, open the living room TV remote, or ask Neo what devices are online."></textarea>
          <div class="neo-actions">
            <button class="neo-btn neo-btn-primary" id="sendCommand">Send to Neo</button>
            <button class="neo-btn neo-btn-gold" id="dictationHint">Use keyboard mic</button>
            <button class="neo-btn neo-btn-ghost" id="clearCommand">Clear</button>
          </div>
        </div>

        <div class="neo-install">
          <div>
            <strong>Add to Home Screen</strong>
            <div class="neo-small">In Safari: Share → Add to Home Screen. Then keep using keyboard dictation for reliable voice input.</div>
          </div>
          <span aria-hidden="true">⌂</span>
        </div>
      </article>

      <aside class="neo-side">
        <section class="neo-panel neo-card">
          <h3>Quick commands</h3>
          <div class="neo-quick-grid" id="quickGrid">
            <button class="neo-chip" data-command="Show me the current Home Assistant device status."><strong>Status</strong><span>What is online?</span></button>
            <button class="neo-chip" data-command="Open the living room TV controls."><strong>Living room</strong><span>TV + media controls</span></button>
            <button class="neo-chip" data-command="Open the den controls."><strong>Den</strong><span>Monitor, stereo, Alexa</span></button>
            <button class="neo-chip" data-command="Open parents room controls without playing audio."><strong>Parents room</strong><span>HomePod + Echo Show</span></button>
            <button class="neo-chip" data-command="Start the Yo Gabba Gabba helper for Kian."><strong>Kian mode</strong><span>Kid-safe media helper</span></button>
            <button class="neo-chip" data-command="Ask Neo for a house summary and any issues needing Rob."><strong>Briefing</strong><span>Home summary</span></button>
          </div>
        </section>

        <section class="neo-panel neo-card">
          <h3>Private access key</h3>
          <p>Saved only on this device. The Netlify function rejects commands when a server key is configured and this does not match.</p>
          <div class="neo-token-row">
            <input id="accessKey" type="password" placeholder="Paste home key" autocomplete="off">
            <button class="neo-btn neo-btn-ghost" id="saveKey">Save</button>
          </div>
        </section>

        <section class="neo-panel neo-card">
          <h3>Last result</h3>
          <div class="neo-log" id="resultLog">No command sent yet.</div>
        </section>
      </aside>
    </div>
  </div>
</section>

<script>
(function () {
  const commandText = document.getElementById('commandText');
  const resultLog = document.getElementById('resultLog');
  const accessKey = document.getElementById('accessKey');
  const sendButton = document.getElementById('sendCommand');
  const savedKey = localStorage.getItem('neoHomeAccessKey') || '';
  accessKey.value = savedKey;

  function setLog(message, state) {
    resultLog.textContent = message;
    resultLog.dataset.state = state || '';
  }

  function buildPayload(command, source) {
    return {
      command,
      source: source || 'manual',
      person: localStorage.getItem('neoHomePerson') || 'Rob',
      device: /iPhone|iPad|iPod/i.test(navigator.userAgent) ? 'iOS PWA' : 'Web PWA',
      href: location.href,
      createdAt: new Date().toISOString()
    };
  }

  async function sendCommand(command, source) {
    const clean = (command || '').trim();
    if (!clean) {
      setLog('Type a command first. On iPhone, tap in the box and use the keyboard mic.', 'error');
      commandText.focus();
      return;
    }

    sendButton.disabled = true;
    setLog('Sending command to Neo…');

    try {
      const res = await fetch('/api/neo-home-command', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Neo-Home-Key': localStorage.getItem('neoHomeAccessKey') || ''
        },
        body: JSON.stringify(buildPayload(clean, source))
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        throw new Error(data.error || 'Command failed with HTTP ' + res.status);
      }
      setLog('Queued for Neo.\nID: ' + (data.id || 'pending') + '\nMode: ' + (data.mode || 'queue'), 'ok');
      commandText.value = '';
    } catch (err) {
      setLog('Not sent: ' + err.message + '\n\nIf this is the first run, save the private access key or finish deploying the command bridge.', 'error');
    } finally {
      sendButton.disabled = false;
    }
  }

  sendButton.addEventListener('click', () => sendCommand(commandText.value, 'manual'));
  document.getElementById('clearCommand').addEventListener('click', () => { commandText.value = ''; commandText.focus(); });
  document.getElementById('saveKey').addEventListener('click', () => {
    localStorage.setItem('neoHomeAccessKey', accessKey.value.trim());
    setLog('Access key saved on this device.', 'ok');
  });
  document.getElementById('dictationHint').addEventListener('click', () => {
    commandText.focus();
    setLog('Keyboard dictation is the reliable iPhone path: tap the mic on the iOS keyboard, speak, then Send to Neo.');
  });
  document.getElementById('quickGrid').addEventListener('click', (event) => {
    const chip = event.target.closest('[data-command]');
    if (!chip) return;
    commandText.value = chip.dataset.command;
    sendCommand(chip.dataset.command, 'quick-action');
  });
})();
</script>
