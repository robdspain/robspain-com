<link rel="stylesheet" href="/css/neo-dashboard.css">

<div class="neo-dashboard-page">
  <div class="neo-dashboard-container">
    <div class="neo-header">
      <span class="neo-badge">⚡ Neo Dashboard v2</span>
      <h1>Project Status & Quick Wins</h1>
      <p>
        See all active projects at a glance, knock out quick wins, and plan content.
        Everything syncs to your browser's local storage.
      </p>
    </div>

    <div class="neo-grid">
      <!-- Projects Section -->
      <section class="neo-card neo-projects">
        <h2>🟢 Active Projects</h2>
        <p class="neo-card-subtitle">Click any card to expand and update progress, phase, or status.</p>
        <div id="project-grid" class="project-grid"></div>
        <!-- Blocked section is dynamically inserted here -->
      </section>

      <!-- Quick Wins Section -->
      <section class="neo-card neo-quickwins">
        <div class="quickwin-header">
          <h2>⚡ Quick Wins</h2>
        </div>
        <p class="neo-card-subtitle">5-15 minute tasks. Sorted by time — fastest first.</p>
        
        <div id="quickwin-list" class="quickwin-list"></div>

        <form id="quickwin-form" class="quickwin-form">
          <input id="quickwin-title" type="text" placeholder="Add a quick win..." required>
          <div class="quickwin-form-row">
            <select id="quickwin-estimate">
              <option value="5">5 min</option>
              <option value="10" selected>10 min</option>
              <option value="15">15 min</option>
            </select>
            <select id="quickwin-type">
              <option value="action">⚡ Action</option>
              <option value="approve">✅ Approve</option>
              <option value="review">📄 Review</option>
              <option value="decision">🤔 Decision</option>
            </select>
          </div>
          <button type="submit">+ Add Quick Win</button>
        </form>
      </section>

      <!-- Content Calendar Section (Weekly View) -->
      <section class="neo-card neo-calendar">
        <div class="calendar-header">
          <div>
            <h2>📅 Content Calendar</h2>
            <p class="neo-card-subtitle">Weekly view — click any empty slot to schedule content.</p>
          </div>
          <div class="calendar-controls">
            <button id="calendar-prev" type="button" aria-label="Previous week">◀</button>
            <h3 id="calendar-label"></h3>
            <button id="calendar-next" type="button" aria-label="Next week">▶</button>
          </div>
        </div>

        <div id="calendar-grid" class="calendar-grid"></div>

        <div id="calendar-warning" class="neo-alert"></div>

        <form id="calendar-form" class="calendar-form">
          <input id="content-title" type="text" placeholder="Content title" required>
          <select id="content-channel">
            <option value="linkedin">💼 LinkedIn</option>
            <option value="twitter">🐦 Twitter/X</option>
            <option value="email">📧 Email</option>
          </select>
          <input id="content-date" type="date" required>
          <button type="submit">Schedule</button>
        </form>

        <div id="calendar-upcoming" class="calendar-upcoming"></div>
      </section>
    </div>
  </div>
</div>

<script src="/js/neo-dashboard.js"></script>
