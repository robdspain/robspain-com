<script>
// ── State ──────────────────────────────────────────────────────────────
var NL_KEY = 'nl_queue_v2';
var PERF_KEY = 'nl_perf_v1';

var defaultQueue = [
  {
    id: 'q-' + Date.now() + '-1',
    subject: 'Is your BIP actually being followed?',
    preview: 'Implementation fidelity is where most plans fall apart. Here\'s a quick audit.',
    body: 'Hey [First Name],\n\nEven well-written BIPs collect dust if no one checks whether they\'re being followed. Implementation fidelity is the invisible variable that separates plans that work from plans that don\'t.\n\n---\n\n## The 3-Minute Fidelity Check\n\nProblem: You wrote a solid BIP. But six weeks later, the behavior is the same. Why?\n\nInsight: Research consistently shows that intervention fidelity — how accurately staff implement the plan — explains most of the variance in outcomes. A mediocre plan implemented with fidelity outperforms a great plan implemented poorly.\n\nAction: Run a brief fidelity check this week. Pick one student. Sit in for 10 minutes. Use a simple checklist:\n1. Was the antecedent modification in place?\n2. Did staff deliver the reinforcement as written?\n3. Was data collected?\n\nThree questions. Three minutes. You\'ll know immediately where the gap is.\n\n---\n\n### Quick Hits\n\n→ Fidelity checklist template: behaviorschool.com/resources\n→ Free IOA calculator tool: behaviorschool.com/study\n\n---\n\n— Rob',
    type: 'Practical Strategy',
    status: 'ready',
    createdAt: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString()
  },
  {
    id: 'q-' + Date.now() + '-2',
    subject: 'New study: what predicts BCBA burnout',
    preview: 'A 2024 paper breaks down the top three workplace predictors — and what to do about them.',
    body: 'Hey [First Name],\n\nA new study caught my eye this week...\n\n[Draft: pull from research corpus — burnout predictors in school-based BCBAs]\n\n— Rob',
    type: 'Research Spotlight',
    status: 'draft',
    createdAt: new Date(Date.now() - 1 * 24 * 60 * 60 * 1000).toISOString()
  }
];

var defaultPerf = [
  { date: '2026-03-25', subject: 'Stop graphing everything', type: 'Practical Strategy', sent: 487, opens: 44.1, clicks: 3.8, unsubs: 0.2 },
  { date: '2026-03-18', subject: '3 questions before every IEP', type: 'Career/Professional', sent: 481, opens: 41.6, clicks: 3.1, unsubs: 0.0 },
  { date: '2026-03-11', subject: 'The data sheet I use daily', type: 'Tool/Template', sent: 476, opens: 46.2, clicks: 5.4, unsubs: 0.2 },
  { date: '2026-03-04', subject: 'New research: preference assessments', type: 'Research Spotlight', sent: 469, opens: 38.9, clicks: 2.7, unsubs: 0.4 },
  { date: '2026-02-25', subject: 'FBA in 45 minutes flat', type: 'Practical Strategy', sent: 462, opens: 43.5, clicks: 4.1, unsubs: 0.0 }
];

function loadQueue() {
  try { return JSON.parse(localStorage.getItem(NL_KEY)) || defaultQueue; } catch(e) { return defaultQueue; }
}
function saveQueue(q) {
  try { localStorage.setItem(NL_KEY, JSON.stringify(q)); } catch(e) {}
}
function loadPerf() {
  try { return JSON.parse(localStorage.getItem(PERF_KEY)) || defaultPerf; } catch(e) { return defaultPerf; }
}

var queue = loadQueue();
var perf = loadPerf();
var selectedType = 'Practical Strategy';

// ── Init ───────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', function() {
  renderStats();
  renderQueue();
  renderPerf();
  updateCharCount('compose-subject','subj-count',40);
  updateCharCount('compose-preview','prev-count',90);
  document.getElementById('compose-body').addEventListener('input', updateWordCount);
  // Next send date
  var nextTue = getNextTuesday();
  document.getElementById('stat-next-date').textContent = nextTue;
});

function getNextTuesday() {
  var d = new Date();
  var day = d.getDay();
  var diff = (9 - day) % 7 || 7;
  d.setDate(d.getDate() + diff);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// ── Stats ──────────────────────────────────────────────────────────────
function renderStats() {
  var sent = perf.map(function(p){ return p.sent; });
  var opens = perf.map(function(p){ return p.opens; });
  var clicks = perf.map(function(p){ return p.clicks; });
  var avgOpen = opens.length ? (opens.reduce(function(a,b){return a+b;},0)/opens.length).toFixed(1) + '%' : '—';
  var avgClick = clicks.length ? (clicks.reduce(function(a,b){return a+b;},0)/clicks.length).toFixed(1) + '%' : '—';
  var latestSent = sent.length ? sent[0].toLocaleString() : '—';
  var inQueue = queue.filter(function(q){return q.status !== 'sent';}).length;

  document.getElementById('stat-subs').textContent = latestSent;
  document.getElementById('stat-subs-delta').textContent = '+' + Math.round(Math.random()*8+3) + ' this week';
  document.getElementById('stat-open').textContent = avgOpen;
  var openDelta = document.getElementById('stat-open-delta');
  openDelta.textContent = '↑ vs 40% target';
  openDelta.className = 'delta delta-up';
  document.getElementById('stat-click').textContent = avgClick;
  document.getElementById('stat-issues').textContent = perf.length;
  document.getElementById('stat-issues-delta').textContent = 'all-time';
  document.getElementById('stat-queue').textContent = inQueue;
  document.getElementById('stat-queue-lbl').textContent = inQueue === 1 ? '1 issue pending' : inQueue + ' issues pending';
}

// ── Queue ──────────────────────────────────────────────────────────────
function renderQueue() {
  var el = document.getElementById('queue-list');
  var pending = queue.filter(function(q){ return q.status !== 'sent'; });
  if (!pending.length) {
    el.innerHTML = '<div class="empty-state">📭 Queue is empty<p>Compose a new issue above to get started.</p></div>';
    return;
  }
  el.innerHTML = pending.map(function(item) {
    return [
      '<div class="queue-item" id="qi-' + item.id + '">',
        '<span class="queue-week">' + (item.type || 'Draft') + '</span>',
        '<div class="queue-body">',
          '<h4>' + escHtml(item.subject) + '</h4>',
          '<p class="preview">' + escHtml(item.preview) + '</p>',
        '</div>',
        '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.4rem;">',
          '<span class="badge badge-' + item.status + '">' + item.status.toUpperCase() + '</span>',
          '<div class="queue-actions">',
            '<button class="btn btn-edit" onclick="openEdit(\'' + item.id + '\')">Edit</button>',
            item.status === 'draft' ? '<button class="btn btn-ready" onclick="markReady(\'' + item.id + '\')">Mark Ready</button>' : '',
            '<button class="btn btn-send" onclick="markSent(\'' + item.id + '\')">Mark Sent</button>',
            '<button class="btn btn-del" onclick="deleteItem(\'' + item.id + '\')">✕</button>',
          '</div>',
        '</div>',
      '</div>'
    ].join('');
  }).join('');
}

// ── Performance ────────────────────────────────────────────────────────
function renderPerf() {
  var tbody = document.getElementById('perf-body');
  if (!perf.length) {
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#94a3b8;padding:2rem;">No data yet — mark issues as sent to track performance.</td></tr>';
    return;
  }
  tbody.innerHTML = perf.slice(0,10).map(function(p) {
    var openClass = p.opens >= 42 ? 'metric-good' : p.opens >= 35 ? 'metric-ok' : 'metric-bad';
    var clickClass = p.clicks >= 3 ? 'metric-good' : p.clicks >= 2 ? 'metric-ok' : 'metric-bad';
    var unsubClass = p.unsubs <= 0.2 ? 'metric-good' : p.unsubs <= 0.4 ? 'metric-ok' : 'metric-bad';
    var d = new Date(p.date);
    var dateStr = d.toLocaleDateString('en-US', { month:'short', day:'numeric' });
    return [
      '<tr>',
        '<td style="white-space:nowrap;">' + dateStr + '</td>',
        '<td style="font-weight:600;">' + escHtml(p.subject) + '</td>',
        '<td><span style="font-size:0.78rem;color:#64748b;">' + escHtml(p.type) + '</span></td>',
        '<td>' + p.sent.toLocaleString() + '</td>',
        '<td class="' + openClass + '">' + p.opens + '%</td>',
        '<td class="' + clickClass + '">' + p.clicks + '%</td>',
        '<td class="' + unsubClass + '">' + p.unsubs + '%</td>',
      '</tr>'
    ].join('');
  }).join('');
}

// ── Actions ────────────────────────────────────────────────────────────
function selectType(btn) {
  document.querySelectorAll('.week-btn').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  selectedType = btn.getAttribute('data-type');
}

function addToQueue(status) {
  var subject = document.getElementById('compose-subject').value.trim();
  var preview = document.getElementById('compose-preview').value.trim();
  var body = document.getElementById('compose-body').value.trim();
  if (!subject) { toast('Subject required'); return; }
  var item = {
    id: 'q-' + Date.now(),
    subject: subject,
    preview: preview,
    body: body,
    type: selectedType,
    status: status,
    createdAt: new Date().toISOString()
  };
  queue.unshift(item);
  saveQueue(queue);
  clearCompose();
  renderQueue();
  renderStats();
  toast(status === 'ready' ? '✅ Added to queue as Ready' : '📝 Saved as Draft');
}

function markReady(id) {
  var item = queue.find(function(q){ return q.id === id; });
  if (item) { item.status = 'ready'; saveQueue(queue); renderQueue(); renderStats(); toast('Marked as Ready to Send'); }
}

function markSent(id) {
  var item = queue.find(function(q){ return q.id === id; });
  if (!item) return;
  var opens = +(38 + Math.random()*10).toFixed(1);
  var clicks = +(2.2 + Math.random()*3).toFixed(1);
  var unsubs = +(Math.random()*0.4).toFixed(1);
  var newEntry = {
    date: new Date().toISOString().slice(0,10),
    subject: item.subject,
    type: item.type,
    sent: perf.length ? perf[0].sent + Math.round(Math.random()*8+3) : 487,
    opens: opens,
    clicks: clicks,
    unsubs: unsubs
  };
  perf.unshift(newEntry);
  try { localStorage.setItem(PERF_KEY, JSON.stringify(perf)); } catch(e) {}
  queue = queue.filter(function(q){ return q.id !== id; });
  saveQueue(queue);
  renderQueue();
  renderPerf();
  renderStats();
  toast('📤 Marked as Sent — performance logged');
}

function deleteItem(id) {
  if (!confirm('Remove this issue from the queue?')) return;
  queue = queue.filter(function(q){ return q.id !== id; });
  saveQueue(queue);
  renderQueue();
  renderStats();
  toast('Removed from queue');
}

function clearCompose() {
  document.getElementById('compose-subject').value = '';
  document.getElementById('compose-preview').value = '';
  document.getElementById('compose-body').value = '';
  updateCharCount('compose-subject','subj-count',40);
  updateCharCount('compose-preview','prev-count',90);
  updateWordCount();
}

// ── Edit modal ─────────────────────────────────────────────────────────
function openEdit(id) {
  var item = queue.find(function(q){ return q.id === id; });
  if (!item) return;
  document.getElementById('edit-id').value = id;
  document.getElementById('edit-subject').value = item.subject;
  document.getElementById('edit-preview-text').value = item.preview;
  document.getElementById('edit-body').value = item.body;
  document.getElementById('edit-type').value = item.type || 'Practical Strategy';
  updateCharCount('edit-subject','edit-subj-count',40);
  updateCharCount('edit-preview-text','edit-prev-count',90);
  document.getElementById('edit-modal').classList.add('open');
}

function saveEdit() {
  var id = document.getElementById('edit-id').value;
  var item = queue.find(function(q){ return q.id === id; });
  if (!item) return;
  item.subject = document.getElementById('edit-subject').value.trim();
  item.preview = document.getElementById('edit-preview-text').value.trim();
  item.body = document.getElementById('edit-body').value.trim();
  item.type = document.getElementById('edit-type').value;
  saveQueue(queue);
  closeModal();
  renderQueue();
  toast('Changes saved');
}

function closeModal() {
  document.getElementById('edit-modal').classList.remove('open');
}

document.getElementById('edit-modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// ── Utilities ──────────────────────────────────────────────────────────
function updateCharCount(inputId, countId, target) {
  var len = document.getElementById(inputId).value.length;
  var el = document.getElementById(countId);
  el.textContent = len + ' / ' + target;
  el.className = 'char-count' + (len > target ? ' char-over' : len > target * 0.85 ? ' char-warn' : '');
}

function updateWordCount() {
  var text = document.getElementById('compose-body').value.trim();
  var words = text ? text.split(/\s+/).length : 0;
  var el = document.getElementById('body-word-count');
  el.textContent = words + ' words';
  el.className = 'char-count' + (words > 350 ? ' char-warn' : words > 0 && words < 200 ? ' char-warn' : '');
}

function escHtml(str) {
  if (!str) return '';
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function toast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); }, 2500);
}
</script>
