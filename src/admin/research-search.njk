// Find similar papers
async function findSimilar(sourcePath, btn) {
    if (!btn) return;
    btn.textContent = 'Finding...';
    btn.disabled = true;

    const renderSimilarModal = (items) => {
        if (!items || items.length === 0) {
            showToast('No similar papers found');
            return;
        }
        let modalHtml = '<div class="similar-papers-modal">';
        modalHtml += '<div class="modal-header"><h3>Similar Papers</h3><button onclick="closeModal()">×</button></div>';
        modalHtml += '<div class="modal-content">';

        items.forEach((s) => {
            const srcPath = s.sourcePdf || s.source_pdf || '';
            const isGen = !s.paperTitle || s.paperTitle === 'Behavior Analysis Research' || s.paperTitle === 'Research Paper';
            let title = s.paperTitle || '';
            if (isGen && srcPath) {
                const base = srcPath.replace(/^.*\//, '').replace(/\.pdf$/i, '');
                title = /^\d{2}\.\d{4}/.test(base) ? base.replace(/_/g, '/') : base.replace(/[-_]/g, ' ');
            } else if (!title) title = 'Research Paper';
            const authors = s.authors || '';
            const year = s.year || '';
            const journal = s.journal || s.venue || '';
            const score = s.score ? (s.score * 100).toFixed(0) : '?';
            const paperLink = s.paperUrl || '';
            const apa = buildApaCitation(authors, year, title, journal, paperLink);

            modalHtml += `
                <div class="similar-paper">
                    <div class="similar-header">
                        <span class="similar-score">${score}% match</span>
                        <button class="copy-citation-btn" onclick="copyCitation(this, '${escapeHtml(apa).replace(/'/g, "\\'")}')">Copy APA</button>
                    </div>
                    <h4>${escapeHtml(title)}</h4>
                    <p class="similar-meta">${escapeHtml(authors)} ${year ? `(${year})` : ''} ${journal ? `· ${journal}` : ''}</p>
                    ${paperLink ? `<a href="${paperLink}" target="_blank" class="result-link">View Paper</a>` : ''}
                </div>
            `;
        });

        modalHtml += '</div></div>';
        let modal = document.getElementById('similar-modal');
        if (!modal) {
            modal = document.createElement('div');
            modal.id = 'similar-modal';
            modal.className = 'modal-overlay';
            document.body.appendChild(modal);
        }
        modal.innerHTML = modalHtml;
        modal.style.display = 'flex';
    };
    
    try {
        const result = await convexClient.action("researchCorpus:findSimilar", {
            sourcePdf: sourcePath,
            limit: 5
        });
        renderSimilarModal(result.sources || []);
    } catch (err) {
        // Fallback: similarity from current result set by year/journal
        const target = (lastSources || []).find(s => (s.sourcePdf || s.source_pdf || '') === sourcePath) || (lastSources || [])[0];
        const tYear = Number(target?.year || 0);
        const tJournal = (target?.journal || target?.venue || '').toLowerCase();
        const fallback = (lastSources || [])
            .filter(s => (s.sourcePdf || s.source_pdf || '') !== sourcePath)
            .map(s => {
                let score = 0.4;
                const y = Number(s.year || 0);
                const j = (s.journal || s.venue || '').toLowerCase();
                if (tJournal && j && tJournal === j) score += 0.35;
                if (tYear && y && Math.abs(tYear - y) <= 2) score += 0.2;
                return { ...s, score: Math.min(0.95, score) };
            })
            .sort((a, b) => (b.score || 0) - (a.score || 0))
            .slice(0, 5);
        renderSimilarModal(fallback);
        showToast('Using local similarity fallback');
    }
    
    btn.textContent = 'Find Similar';
    btn.disabled = false;
}

function closeModal() {
    const similar = document.getElementById('similar-modal');
    if (similar) similar.style.display = 'none';
    const bip = document.getElementById('bip-modal');
    if (bip) bip.classList.remove('show');
}

// Toast notification
function showToast(message) {
    let toast = document.querySelector('.toast');
    if (!toast) {
        toast = document.createElement('div');
        toast.className = 'toast';
        document.body.appendChild(toast);
    }
    toast.textContent = message;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
}

// View toggle
function showView(view) {
    const btns = document.querySelectorAll('.view-btn');
    btns.forEach(btn => btn.classList.remove('active'));
    event.target.classList.add('active');

    const networkContainer = document.getElementById('network-container');
    const networkLegend = document.querySelector('.network-legend');
    const sourcesList = document.getElementById('sources-list');
    const sourceControls = document.querySelector('.source-controls');

    if (view === 'network') {
        networkContainer.style.display = 'block';
