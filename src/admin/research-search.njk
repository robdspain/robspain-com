    try {
        console.log("Connecting to Convex:", CONVEX_URL);
        convexClient = new ConvexClient(CONVEX_URL);
        
        // Check if corpus is loaded with timeout
        console.log("Fetching stats...");
        const statsPromise = convexClient.action("researchCorpus:getStats");
        const timeoutPromise = new Promise((_, reject) => 
            setTimeout(() => reject(new Error("Connection timeout - try refreshing")), 15000)
        );
        const stats = await Promise.race([statsPromise, timeoutPromise]);
        console.log("Stats received:", stats);
        
        if (stats.loaded && stats.totalChunks > 0) {
            document.getElementById('corpus-stats').textContent = 
                `${stats.totalChunks.toLocaleString()} chunks • ${stats.uniquePapers.toLocaleString()} papers • Semantic search`;
            statusBar.className = 'status-bar';
            statusBar.innerHTML = 'Connected • Ready to search';
        } else {
            document.getElementById('corpus-stats').textContent = 'Corpus not yet loaded';
            statusBar.className = 'status-bar loading-status';
            statusBar.innerHTML = 'Corpus migration in progress — check back soon';
        }
    } catch (err) {
        console.error("Convex connection error:", err);
        statusBar.className = 'status-bar error-status';
        statusBar.innerHTML = `Connection error: ${err.message || err}`;
    }
}

function setQuery(q) {
    document.getElementById('query').value = q;
    search();
}

async function search() {
    const query = document.getElementById('query').value.trim();
    if (!query) return;

    const loading = document.getElementById('loading');
    const results = document.getElementById('results');
    const error = document.getElementById('error');
    const btn = document.getElementById('search-btn');

    loading.classList.add('active');
    results.classList.remove('active');
    error.classList.remove('active');
    btn.disabled = true;

    try {
        // Streaming via SSE — show answer as it arrives, then render sources
        const response = await fetch('/api/research-stream', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ query, limit: 8 }),
        });

        if (!response.ok) {
            throw new Error(`Stream error: ${response.status} ${response.statusText}`);
        }

        // Inject streaming shell immediately — answer streams in, sources render after
        results.innerHTML = `
            <div class="ai-answer" id="ai-answer-block">
                <div class="ai-answer-header">
                    <span class="ai-badge">AI Overview</span>
                    <span class="streaming-indicator" id="stream-indicator" style="color:#1f4d3f;animation:blink 1s infinite">●</span>
                </div>
                <div id="stream-answer" class="ai-answer-text" style="white-space:pre-wrap;min-height:2em"></div>
                <div class="ai-actions" style="display:none" id="ai-actions">
                    <button class="ai-action-btn" onclick="generateBipLanguage()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
                        Generate BIP Language
                    </button>
                    <button class="ai-action-btn" onclick="showVisually()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
                        Show Me Visually
                    </button>
                </div>
                <div class="followup-inline" style="display:none" id="followup-block">
                    <input type="text" class="followup-input" id="followup-input" placeholder="Ask a follow-up question..." onkeypress="if(event.key==='Enter')askFollowup()">
                    <button class="followup-ask-btn" onclick="askFollowup()">Ask</button>
                </div>
            </div>
            <div id="sources-shell" style="display:none">
                <div class="network-section">
                    <div class="network-header">
                        <h3>Citation Network</h3>
                        <div class="network-toggle">
                            <button class="view-btn active" onclick="showView('network')">Network</button>
                            <button class="view-btn" onclick="showView('list')">List</button>
                        </div>
                    </div>
                    <div id="network-container"></div>
                    <div class="network-legend">
                        <div class="legend-item"><span class="legend-dot high"></span> High relevance</div>
                        <div class="legend-item"><span class="legend-dot medium"></span> Medium</div>
                        <div class="legend-item"><span class="legend-dot low"></span> Lower</div>
                    </div>
                    <div class="network-tooltip" id="network-tooltip"></div>
                </div>
                <div class="sources-header">
                    <h3>Sources <span class="source-count" id="source-count"></span></h3>
                    <button class="toggle-sources" onclick="toggleSources()">Show All</button>
                </div>
                <div class="source-controls">
                    <div class="filter-group">
                        <span class="filter-label">Journal:</span>
                        <select class="filter-select" id="journal-filter" onchange="filterSources()"><option value="">All</option></select>
                    </div>
                    <div class="filter-group">
                        <span class="filter-label">Year:</span>
                        <select class="filter-select" id="year-filter" onchange="filterSources()"><option value="">All</option></select>
                    </div>
                    <button class="sort-btn" id="sort-btn" onclick="toggleSort()">Newest first</button>
                    <div class="bulk-actions">
                        <button class="bulk-btn" onclick="copyAllCitations()">Copy All</button>
                        <button class="bulk-btn" onclick="exportResults()">Export</button>
                    </div>
                </div>
                <div class="sources-list" id="sources-list"></div>
                <p class="result-stats" id="result-stats"></p>
            </div>
        `;
        results.classList.add('active');
        loading.classList.remove('active');
        btn.disabled = false;

        const streamEl = document.getElementById('stream-answer');
        const indicator = document.getElementById('stream-indicator');
        let fullAnswer = '';

        function formatAnswer(text) {
            let f = escapeHtml(text);
            f = f.replace(/\[Source (\d+)\]/g, '<a href="#source-$1" class="source-link">[Source $1]</a>');
            f = f.replace(/\n\n/g, '</p><p class="ai-answer-text">');
            f = f.replace(/\n/g, '<br>');
            return f;
        }

        function buildSourceCard(r, i) {
            const srcPath = r.sourcePdf || r.source_pdf || '';
            const isGeneric = !r.paperTitle || r.paperTitle === 'Behavior Analysis Research' || r.paperTitle === 'Research Paper';
            let title = r.paperTitle || '';
            if (isGeneric && srcPath) {
                const base = srcPath.replace(/^.*\//, '').replace(/\.pdf$/i, '');
                title = /^\d{2}\.\d{4}/.test(base) ? base.replace(/_/g, '/') : base.replace(/[-_]/g, ' ');
            } else if (!title) { title = 'Research Paper'; }
            const authors = r.authors || '';
            const year = r.year || '';
            const journal = r.journal || r.venue || '';
            const score = r.score ? (r.score * 100).toFixed(1) : '?';
            const citParts = [];
            if (authors) citParts.push(authors);
            if (year) citParts.push(`(${year})`);
            if (journal) citParts.push(journal);
            const citation = citParts.join(' · ');
            const paperLink = r.paperUrl || null;
            const apaCitation = buildApaCitation(authors, year, title, journal, paperLink);
            return `
                <div class="result-card source-card" id="source-${i + 1}"
                     data-source="${escapeHtml(srcPath)}"
                     data-year="${year || 0}"
                     data-journal="${escapeHtml(journal)}"
                     data-apa="${escapeHtml(apaCitation)}">
                    <div class="result-header">
                        <span class="result-rank">Source ${i + 1}</span>
                        <div>
                            <button class="copy-citation-btn" onclick="copyCitation(this, '${escapeHtml(apaCitation).replace(/'/g, "\\'")}')">Copy APA</button>
                            <span class="result-score">${score}%</span>
                        </div>
                    </div>
                    <h4 class="source-title">${escapeHtml(title)}</h4>
                    ${citation ? `<p class="source-meta">${escapeHtml(citation)}</p>` : ''}
                    <div class="result-footer">
                        <div class="source-actions">
                            <button class="summarize-btn" onclick="summarizePaper('${escapeHtml(srcPath)}', this)">Summary</button>
                            <button class="summarize-btn" onclick="findSimilar('${escapeHtml(srcPath)}', this)">Find Similar</button>
                            ${paperLink ? `<a href="${paperLink}" target="_blank" class="result-link">View Paper</a>` : ''}
                        </div>
                    </div>
                    <div class="paper-summary" style="display:none;"></div>
                </div>`;
        }

        // Read SSE stream
        const reader = response.body.getReader();
        const dec = new TextDecoder();
        let sseBuffer = '';

        while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            sseBuffer += dec.decode(value, { stream: true });
            const lines = sseBuffer.split('\n');
            sseBuffer = lines.pop();

            for (const line of lines) {
                if (!line.startsWith('data: ')) continue;
                let evt;
                try { evt = JSON.parse(line.slice(6)); } catch (e) { continue; }

                if (evt.type === 'answer') {
                    fullAnswer += evt.text;
                    streamEl.innerHTML = `<p class="ai-answer-text">${formatAnswer(fullAnswer)}</p>`;
                } else if (evt.type === 'sources') {
                    indicator.style.display = 'none';
                    document.getElementById('ai-actions').style.display = 'flex';
                    document.getElementById('followup-block').style.display = 'flex';

                    const sources = evt.sources;
                    lastQuery = query;
                    lastAnswer = fullAnswer;
                    lastSources = sources;

                    document.getElementById('source-count').textContent = `(${sources.length})`;
                    document.getElementById('result-stats').textContent = `Synthesized from ${sources.length} sources`;
                    document.getElementById('sources-list').innerHTML = sources.map((r, i) => buildSourceCard(r, i)).join('');
                    document.getElementById('sources-shell').style.display = 'block';

                    populateFilters(sources);
                    currentSortNewest = true;
                    toggleSort();
                    drawNetwork(sources);
                } else if (evt.type === 'error') {
                    error.textContent = `Error: ${evt.text}`;
                    error.classList.add('active');
                }
            }
        }

    } catch (err) {
        console.error("Search error:", err);
        error.textContent = `Search failed: ${err.message || err}`;
        error.classList.add('active');
        loading.classList.remove('active');
        btn.disabled = false;
    }
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// Build APA 7 citation
function buildApaCitation(authors, year, title, journal, url) {
    let citation = '';
    if (authors) citation += authors;
    if (year) citation += ` (${year}).`;
    if (title) citation += ` ${title}.`;
    if (journal) citation += ` ${journal}.`;
    if (url) citation += ` ${url}`;
    return citation.trim();
}

// Copy single citation
function copyCitation(btn, citation) {
    navigator.clipboard.writeText(citation).then(() => {
        btn.classList.add('copied');
        btn.textContent = 'Copied!';
        setTimeout(() => {
            btn.classList.remove('copied');
            btn.textContent = 'Copy APA';
        }, 2000);
    });
}

// Copy all citations
function copyAllCitations() {
    const cards = document.querySelectorAll('.source-card');
    const citations = Array.from(cards)
        .filter(card => card.style.display !== 'none')
        .map(card => card.dataset.apa)
        .join('\n\n');
    
    navigator.clipboard.writeText(citations).then(() => {
        showToast('All citations copied to clipboard');
    });
}

// Export results
function exportResults() {
    const query = lastQuery;
    const answer = lastAnswer;
    const cards = document.querySelectorAll('.source-card');
    
    let markdown = `# Research Query: ${query}\n\n`;
    markdown += `## AI Overview\n\n${answer}\n\n`;
    markdown += `## Sources\n\n`;
    
    cards.forEach((card, i) => {
        if (card.style.display !== 'none') {
            const title = card.querySelector('.source-title')?.textContent || '';
            const meta = card.querySelector('.source-meta')?.textContent || '';
            const apa = card.dataset.apa;
            markdown += `### ${i + 1}. ${title}\n${meta}\n\n**APA Citation:** ${apa}\n\n---\n\n`;
        }
    });
    
    const blob = new Blob([markdown], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `research-${query.substring(0, 30).replace(/\s+/g, '-')}.md`;
    a.click();
    URL.revokeObjectURL(url);
    showToast('Results exported');
}

// Filter sources
let currentSortNewest = true;
function filterSources() {
    const journalFilter = document.getElementById('journal-filter').value;
    const yearFilter = document.getElementById('year-filter').value;
    const cards = document.querySelectorAll('.source-card');
    
    cards.forEach(card => {
        const journal = card.dataset.journal;
        const year = card.dataset.year;
        const matchJournal = !journalFilter || journal === journalFilter;
        const matchYear = !yearFilter || year === yearFilter;
        card.style.display = (matchJournal && matchYear) ? '' : 'none';
    });
}

// Toggle sort
function toggleSort() {
    currentSortNewest = !currentSortNewest;
    const btn = document.getElementById('sort-btn');
    btn.textContent = currentSortNewest ? 'Newest first' : 'Oldest first';
    
    const list = document.getElementById('sources-list');
    const cards = Array.from(list.querySelectorAll('.source-card'));
    
    cards.sort((a, b) => {
        const yearA = parseInt(a.dataset.year) || 0;
        const yearB = parseInt(b.dataset.year) || 0;
        return currentSortNewest ? yearB - yearA : yearA - yearB;
    });
    
    cards.forEach(card => list.appendChild(card));
}

// Populate filters
function populateFilters(sources) {
    const journals = new Set();
    const years = new Set();
    
    sources.forEach(s => {
        if (s.journal) journals.add(s.journal);
        if (s.year) years.add(s.year);
    });
    
    const journalSelect = document.getElementById('journal-filter');
    const yearSelect = document.getElementById('year-filter');
    
    // Clear existing options except "All"
    journalSelect.innerHTML = '<option value="">All</option>';
    yearSelect.innerHTML = '<option value="">All</option>';
    
    Array.from(journals).sort().forEach(j => {
        journalSelect.innerHTML += `<option value="${escapeHtml(j)}">${escapeHtml(j)}</option>`;
    });
    
    Array.from(years).sort((a, b) => b - a).forEach(y => {
        yearSelect.innerHTML += `<option value="${y}">${y}</option>`;
    });
}

// Generate follow-up questions
async function generateFollowups(query, answer) {
    const chips = document.getElementById('followup-chips');
    
    // Simple heuristic follow-ups based on query
    const followups = [
        `What are common implementation challenges?`,
        `Show me case studies`,
        `What does the research say about maintenance?`,
    ];
    
    chips.innerHTML = followups.map(q => 
        `<button class="followup-chip" onclick="setFollowup('${escapeHtml(q)}')">${escapeHtml(q)}</button>`
    ).join('');
}

function setFollowup(q) {
    document.getElementById('query').value = q;
    search();
}

function askFollowup() {
    const input = document.getElementById('followup-input');
    const q = input.value.trim();
    if (q) {
        document.getElementById('query').value = q;
        input.value = '';
