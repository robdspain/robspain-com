        if (sourcesList) sourcesList.style.display = 'block';
        if (sourceControls) sourceControls.style.display = 'flex';
    }
}

// Draw citation network
function drawNetwork(sources) {
    const container = document.getElementById('network-container');
    const width = container.offsetWidth;
    const height = 400;
    
    // Create SVG
    container.innerHTML = `<svg width="${width}" height="${height}" id="network-svg"></svg>`;
    const svg = document.getElementById('network-svg');
    
    // Extract a readable title from source_pdf path or chunk_id when paperTitle is missing/generic
    function extractFallbackTitle(s) {
        const generic = !s.paperTitle || s.paperTitle === 'Behavior Analysis Research' || s.paperTitle === 'Research Paper';
        if (!generic) return s.paperTitle;
        // Try source_pdf: '/path/to/10.1016_j.jcbs.2024.100804.pdf' -> '10.1016/j.jcbs.2024.100804'
        const src = s.sourcePdf || s.source_pdf || '';
        if (src) {
            const base = src.replace(/^.*\//, '').replace(/\.pdf$/i, '');
            // Looks like a DOI slug — humanize it
            if (/^\d{2}\.\d{4}/.test(base)) {
                return base.replace(/_/g, '/');
            }
            return base.replace(/[-_]/g, ' ');
        }
        return 'Paper ' + (i + 1);
    }

    // Extract authors from chunk text (often appears in first lines as "Author A, Author B (Year)")
    function extractFallbackAuthors(s) {
        if (s.authors && s.authors.trim()) return s.authors;
        const text = s.text || s.snippet || '';
        // Look for author-year pattern at start of chunk
        const match = text.match(/^([A-Z][a-z]+(?:,?\s+[A-Z]\.?)+(?:,\s+[A-Z][a-z]+(?:,?\s+[A-Z]\.?)+)*)\s*[\(\[]\d{4}/);
        if (match) return match[1].trim();
        return '';
    }

    // Create nodes from sources
    const nodes = sources.map((s, i) => ({
        id: i,
        title: extractFallbackTitle(s),
        authors: extractFallbackAuthors(s),
        year: s.year || '',
        journal: s.journal || s.venue || '',
        score: s.score || 0.5,
        x: width/2 + (Math.random() - 0.5) * 200,
        y: height/2 + (Math.random() - 0.5) * 200,
        vx: 0,
        vy: 0
    }));
    
    // Create edges based on shared journals/years (co-citation proxy)
    const edges = [];
    for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
            const shared = (nodes[i].journal === nodes[j].journal && nodes[i].journal) ||
                          (Math.abs((nodes[i].year || 0) - (nodes[j].year || 0)) <= 2);
            if (shared) {
                edges.push({ source: i, target: j });
            }
        }
    }
    
    // Simple force simulation
    function simulate() {
        // Repulsion between nodes
        for (let i = 0; i < nodes.length; i++) {
            for (let j = i + 1; j < nodes.length; j++) {
                const dx = nodes[j].x - nodes[i].x;
                const dy = nodes[j].y - nodes[i].y;
                const dist = Math.sqrt(dx*dx + dy*dy) || 1;
                const force = 2000 / (dist * dist);
                nodes[i].vx -= dx/dist * force;
                nodes[i].vy -= dy/dist * force;
                nodes[j].vx += dx/dist * force;
                nodes[j].vy += dy/dist * force;
            }
        }
        
        // Attraction along edges
        edges.forEach(e => {
            const source = nodes[e.source];
            const target = nodes[e.target];
            const dx = target.x - source.x;
            const dy = target.y - source.y;
            const dist = Math.sqrt(dx*dx + dy*dy) || 1;
            const force = (dist - 100) * 0.01;
            source.vx += dx/dist * force;
            source.vy += dy/dist * force;
            target.vx -= dx/dist * force;
            target.vy -= dy/dist * force;
        });
        
        // Center gravity
        nodes.forEach(n => {
            n.vx += (width/2 - n.x) * 0.001;
            n.vy += (height/2 - n.y) * 0.001;
            n.vx *= 0.9;
            n.vy *= 0.9;
            n.x += n.vx;
            n.y += n.vy;
            // Bounds
            n.x = Math.max(40, Math.min(width - 40, n.x));
            n.y = Math.max(40, Math.min(height - 40, n.y));
        });
    }
    
    // Run simulation
    for (let i = 0; i < 100; i++) simulate();
    
    // Draw edges
    let edgesHtml = '';
    edges.forEach(e => {
        const s = nodes[e.source];
        const t = nodes[e.target];
        edgesHtml += `<line x1="${s.x}" y1="${s.y}" x2="${t.x}" y2="${t.y}" stroke="#e2e8f0" stroke-width="1"/>`;
    });
    
    // Draw nodes
    let nodesHtml = '';
    nodes.forEach((n, i) => {
        const radius = 10 + (n.score || 0.5) * 15;
        let color = '#94a3b8';
        if (n.score > 0.7) color = '#1f4d3f';
        else if (n.score > 0.5) color = '#4ade80';
        
        nodesHtml += `
            <g class="network-node" data-index="${i}" style="cursor:pointer">
                <circle cx="${n.x}" cy="${n.y}" r="${radius}" fill="${color}" stroke="white" stroke-width="2"/>
                <text x="${n.x}" y="${n.y + radius + 14}" text-anchor="middle" font-size="10" fill="#374151">
                    ${n.year || ''}
                </text>
            </g>
        `;
    });
    
    svg.innerHTML = edgesHtml + nodesHtml;
    
    // Add hover interactions
    const tooltip = document.getElementById('network-tooltip');
    function placeTooltip(e) {
        const rect = container.getBoundingClientRect();
        const x = Math.min(rect.width - 320, Math.max(8, e.clientX - rect.left + 12));
        const y = Math.min(rect.height - 140, Math.max(8, e.clientY - rect.top + 12));
        tooltip.style.left = x + 'px';
        tooltip.style.top = y + 'px';
    }

    svg.querySelectorAll('.network-node').forEach(node => {
        node.addEventListener('mouseenter', (e) => {
            const idx = parseInt(node.dataset.index);
            const n = nodes[idx];
            const authors = n.authors && n.authors.trim() ? n.authors : 'Author(s) unavailable';
            const date = n.year ? String(n.year) : 'Date unavailable';
            const journal = n.journal && n.journal.trim() ? n.journal : 'Journal unavailable';
            tooltip.innerHTML = `
                <div style="font-weight:700; margin-bottom:6px;">${escapeHtml(n.title || 'Untitled article')}</div>
                <div style="color:#334155; font-size:12px; line-height:1.4;">Author(s): ${escapeHtml(authors)}</div>
                <div style="color:#334155; font-size:12px; line-height:1.4;">Date: ${escapeHtml(date)}</div>
                <div style="color:#334155; font-size:12px; line-height:1.4;">Journal: ${escapeHtml(journal)}</div>
            `;
            placeTooltip(e);
            tooltip.classList.add('show');
        });
        node.addEventListener('mousemove', (e) => {
            if (tooltip.classList.contains('show')) placeTooltip(e);
        });
        node.addEventListener('mouseleave', () => {
            tooltip.classList.remove('show');
        });
        node.addEventListener('click', (e) => {
            const idx = parseInt(node.dataset.index);
            const n = nodes[idx];
            const authors = n.authors && n.authors.trim() ? n.authors : 'Author(s) unavailable';
            const date = n.year ? String(n.year) : 'Date unavailable';
            const journal = n.journal && n.journal.trim() ? n.journal : 'Journal unavailable';
            tooltip.innerHTML = `
                <div style="font-weight:700; margin-bottom:6px;">${escapeHtml(n.title || 'Untitled article')}</div>
                <div style="color:#334155; font-size:12px; line-height:1.4;">Author(s): ${escapeHtml(authors)}</div>
                <div style="color:#334155; font-size:12px; line-height:1.4;">Date: ${escapeHtml(date)}</div>
                <div style="color:#334155; font-size:12px; line-height:1.4;">Journal: ${escapeHtml(journal)}</div>
            `;
            placeTooltip(e);
            tooltip.classList.add('show');
            // keep previous behavior: jump to source card
            const target = document.getElementById('source-' + (idx + 1));
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    });
}

function toggleSources() {
    const list = document.getElementById('sources-list');
    const btn = document.querySelector('.toggle-sources');
    if (list.classList.contains('expanded')) {
        list.classList.remove('expanded');
        btn.textContent = 'Show All';
    } else {
        list.classList.add('expanded');
        btn.textContent = 'Show Less';
    }
}

async function summarizePaper(sourcePath, btn) {
    if (!btn) return;
    const card = btn.closest('.source-card');
    const summaryDiv = card?.querySelector('.paper-summary');
    if (!summaryDiv) {
        showToast('Summary container not found');
        return;
    }
    
    // Toggle if already loaded
    if (summaryDiv.innerHTML && summaryDiv.style.display !== 'none') {
        summaryDiv.style.display = 'none';
        btn.textContent = 'Get Summary';
        return;
    }
    
    if (summaryDiv.innerHTML) {
        summaryDiv.style.display = 'block';
        btn.textContent = 'Hide Summary';
        return;
    }
    
    btn.textContent = 'Loading...';
    btn.disabled = true;
    
    try {
        const result = await convexClient.action("researchCorpus:summarizePaper", {
            sourcePdf: sourcePath
        });
        
        const meta = result.metadata;
        summaryDiv.innerHTML = `
            <div class="summary-content">
                <p class="summary-citation"><strong>${escapeHtml(meta.title)}</strong></p>
                <p class="summary-meta">${escapeHtml(meta.authors)} (${escapeHtml(meta.year)}). <em>${escapeHtml(meta.journal)}</em></p>
                <p class="summary-text">${escapeHtml(result.summary)}</p>
            </div>
        `;
        summaryDiv.style.display = 'block';
        btn.textContent = 'Hide Summary';
    } catch (err) {
        // Fallback summary from source snippet already on card
        const source = (lastSources || []).find(s => (s.sourcePdf || s.source_pdf || '') === sourcePath) || {};
        const title = source.paperTitle || sourcePath?.split('/').pop()?.replace('.pdf','') || 'Research paper';
        const authors = source.authors || 'Authors unavailable';
        const year = source.year || 'n.d.';
        const journal = source.journal || source.venue || 'Journal unavailable';
        const snippet = (source.text || '').slice(0, 700) || 'No abstract/snippet available in cached results.';
        summaryDiv.innerHTML = `
            <div class="summary-content">
                <p class="summary-citation"><strong>${escapeHtml(title)}</strong></p>
                <p class="summary-meta">${escapeHtml(authors)} (${escapeHtml(String(year))}). <em>${escapeHtml(journal)}</em></p>
                <p class="summary-text">${escapeHtml(snippet)}</p>
            </div>
        `;
        summaryDiv.style.display = 'block';
        btn.textContent = 'Hide Summary';
        showToast('Using local summary fallback');
    }
    
    btn.disabled = false;
}



// Generate BIP Language
async function generateBipLanguage(evt) {
    const btn = (evt?.target && evt.target.closest('.ai-action-btn')) || document.querySelector('.ai-action-btn[onclick*="generateBipLanguage"]');
    if (!lastQuery && !lastAnswer) {
        showToast('Run a search first');
        return;
    }
    if (btn) {
        btn.disabled = true;
        btn.innerHTML = 'Generating...';
    }
    
    try {
        const result = await convexClient.action("researchCorpus:generateBipLanguage", {
            query: lastQuery,
            answer: lastAnswer,
        });
        showModal('BIP Language', result.bipText || result.text || 'No BIP text returned.');
    } catch (err) {
        const fallback = `<p><strong>Behavior to address:</strong> ${escapeHtml(lastQuery || 'Target behavior')}</p>
        <p><strong>Replacement behavior:</strong> Teach a functional communication response that is easy to perform and reinforced quickly.</p>
        <p><strong>Antecedent supports:</strong></p>
        <ul><li>Pre-correct expectations before trigger activities</li><li>Offer clear choices and visual schedule</li><li>Use high-probability request sequence</li></ul>
        <p><strong>Consequence strategy:</strong> Reinforce replacement behavior immediately, minimize reinforcement for problem behavior, and use planned prompting.</p>
        <p><strong>Data plan:</strong> Track frequency, latency, and replacement response rate daily for 2 weeks.</p>`;
        showModal('BIP Language (Fallback)', fallback);
    }
    
    if (btn) {
        btn.disabled = false;
        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg> Generate BIP Language`;
    }
}

