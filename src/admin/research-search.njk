// Show modal
function showModal(title, content) {
    let modal = document.getElementById('bip-modal');
    if (!modal) {
        modal = document.createElement('div');
        modal.id = 'bip-modal';
        modal.className = 'modal-overlay';
        document.body.appendChild(modal);
    }
    
    modal.innerHTML = `
        <div class="modal-content">
            <div class="modal-header">
                <h2>${escapeHtml(title)}</h2>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">${content}</div>
            <div class="modal-actions">
                <button class="ai-action-btn" onclick="copyModalContent()">Copy to Clipboard</button>
                <button class="ai-action-btn" onclick="closeModal()">Close</button>
            </div>
        </div>
    `;
    
    setTimeout(() => modal.classList.add('show'), 10);
}

// Show visual modal
function showVisualModal(result) {
    let modal = document.getElementById('bip-modal');
    if (!modal) {
        modal = document.createElement('div');
        modal.id = 'bip-modal';
        modal.className = 'modal-overlay';
        document.body.appendChild(modal);
    }
    
    modal.innerHTML = `
        <div class="modal-content">
            <div class="modal-header">
                <h2>Visual Explanation</h2>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="visual-section">
                <div class="visual-container" id="visual-chart"></div>
                <div class="visual-summary">${escapeHtml(result.summary)}</div>
            </div>
            <div class="modal-actions">
                <button class="ai-action-btn" onclick="closeModal()">Close</button>
            </div>
        </div>
    `;
    
    setTimeout(() => {
        modal.classList.add('show');
        drawVisualChart(result.chartData);
    }, 10);
}

// Draw visual chart
function drawVisualChart(data) {
    const container = document.getElementById('visual-chart');
    if (!container || !data) return;
    
    const width = container.offsetWidth;
    const height = 250;
    
    if (data.type === 'flowchart') {
        // Draw flowchart
        let html = '<svg width="' + width + '" height="' + height + '">';
        const steps = data.steps || [];
        const stepWidth = (width - 40) / steps.length;
        
        steps.forEach((step, i) => {
            const x = 20 + i * stepWidth;
            const y = height / 2;
            
            // Box
            html += `<rect x="${x}" y="${y - 30}" width="${stepWidth - 20}" height="60" rx="8" fill="#f0f5f3" stroke="#1f4d3f" stroke-width="2"/>`;
            
            // Text
            html += `<text x="${x + (stepWidth - 20) / 2}" y="${y}" text-anchor="middle" font-size="12" fill="#1e293b">${step.label}</text>`;
            
            // Arrow
            if (i < steps.length - 1) {
                html += `<path d="M${x + stepWidth - 20} ${y} L${x + stepWidth - 5} ${y}" stroke="#1f4d3f" stroke-width="2" marker-end="url(#arrowhead)"/>`;
            }
        });
        
        html += '<defs><marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto"><polygon points="0 0, 10 3.5, 0 7" fill="#1f4d3f"/></marker></defs>';
        html += '</svg>';
        container.innerHTML = html;
        
    } else if (data.type === 'comparison') {
        // Draw comparison bars
        let html = '<svg width="' + width + '" height="' + height + '">';
        const items = data.items || [];
        const barHeight = 30;
        const maxVal = Math.max(...items.map(i => i.value));
        
        items.forEach((item, i) => {
            const y = 30 + i * (barHeight + 20);
            const barWidth = (item.value / maxVal) * (width - 150);
            
            html += `<text x="10" y="${y + 20}" font-size="12" fill="#374151">${item.label}</text>`;
            html += `<rect x="120" y="${y}" width="${barWidth}" height="${barHeight}" rx="4" fill="#1f4d3f"/>`;
            html += `<text x="${125 + barWidth}" y="${y + 20}" font-size="12" fill="#64748b">${item.value}%</text>`;
        });
        
        html += '</svg>';
        container.innerHTML = html;
        
    } else {
        // Default: key points
        const points = data.points || ['Point 1', 'Point 2', 'Point 3'];
        let html = '<div style="padding: 1rem;">';
        points.forEach((p, i) => {
            html += `<div style="display: flex; gap: 0.75rem; margin-bottom: 1rem; align-items: flex-start;">
                <span style="background: #1f4d3f; color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0;">${i + 1}</span>
                <span style="color: #374151; line-height: 1.5;">${p}</span>
            </div>`;
        });
        html += '</div>';
        container.innerHTML = html;
    }
}



function copyModalContent() {
    const body = document.querySelector('.modal-body');
    if (body) {
        navigator.clipboard.writeText(body.innerText).then(() => {
            showToast('Copied to clipboard');
        });
    }
}

