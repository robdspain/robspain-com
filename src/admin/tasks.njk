    border-color: var(--blue);
  }

  .card-details {
    display: none;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .task-card.expanded .card-details {
    display: block;
  }

  .card-details h4 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--text-muted);
  }

  .card-details ol {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text);
  }

  .card-details li {
    margin-bottom: 0.4rem;
  }

  .card-details a {
    color: var(--blue);
    text-decoration: none;
  }

  .card-details a:hover {
    text-decoration: underline;
  }

  .card-details code {
    background: var(--bg-dark);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--orange);
  }

