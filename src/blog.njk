---
layout: base.njk
title: Blog - Rob Spain | School BCBA Insights
description: Practical School BCBA articles on behavior systems, burnout prevention, PBIS, educator coaching, and sustainable school-based behavior analysis.
canonical: /blog/
---

<header class="blog-header-premium animate-fade-up">
    <div class="container">
        <div class="blog-header-content">
            <span class="section-badge-premium">Professional Insights</span>
            <h1 class="text-display-md">School BCBA <span class="text-gradient">Blog</span></h1>
            <p class="body-large">Practical articles for school BCBAs, educators, and district leaders building behavior systems that reduce burnout and improve student outcomes.</p>
        </div>
    </div>
</header>

<section class="section-premium" style="padding-top: 0;">
    <div class="container">
        {% set newsletterId = "blog" %}
        {% set newsletterSource = "/blog/" %}
        {% set newsletterTitle = "Get the next School BCBA systems article by email." %}
        {% set newsletterDescription = "Each issue turns one practical blog insight into a short implementation prompt you can use in real school behavior systems." %}
        {% include "newsletter-signup.njk" %}

        <!-- Featured Post: The Crisis Story -->
        {% if collections.posts | length > 0 %}
        {% set latestPost = collections.posts | first %}
        <div class="latest-post-highlight animate-fade-up stagger-1">
            <a href="{{ latestPost.url }}" class="highlight-card card-premium">
                <div class="highlight-image">
                    {% image latestPost.data.image | postImage, latestPost.data.title, "(max-width: 1024px) 100vw, 600px" %}
                </div>
                <div class="highlight-content">
                    <div class="post-meta-premium">
                        <span class="post-date-pill"><i class="far fa-calendar-alt"></i> {{ latestPost.date.toDateString() }}</span>
                        <span class="read-time-pill"><i class="far fa-clock"></i> {{ latestPost.rawInput | readingTime }}</span>
                    </div>
                    <h2 class="text-h1">{{ latestPost.data.title }}</h2>
                    <p class="body-large">{{ latestPost.data.description }}</p>
                    <div class="post-cta-premium">
                        <span>Read Full Insight</span>
                        <i class="fas fa-arrow-right"></i>
                    </div>
                </div>
            </a>
        </div>
        {% endif %}

        <!-- Grid for Remaining Posts -->
        <div class="cards-grid-premium" id="blog-posts" style="margin-top: 4rem;">
            {% for post in collections.posts %}
            {% if loop.index > 1 %}
            <article class="card-premium animate-fade-up">
                <div class="card-image-wrapper">
                    {% image post.data.image | postImage, post.data.title, "(max-width: 768px) 100vw, 400px", [400, 600] %}
                </div>
                <div class="card-content-inner">
                    <div class="post-meta-small">
                        <span>{{ post.date.toDateString() }}</span>
                    </div>
                    <h3 class="card-title-premium">{{ post.data.title }}</h3>
                    <p class="card-description-premium">
                        {{ post.data.description }}
                    </p>
                    <a href="{{ post.url }}" class="card-link-premium">View Full Post <i class="fas fa-arrow-right"></i></a>
                </div>
            </article>
            {% endif %}
            {% else %}
            {% if collections.posts | length == 0 %}
            <div style="grid-column: 1 / -1; text-align: center; padding: 4rem; background: white; border-radius: 24px; border: 2px dashed var(--border-light);">
                <i class="fas fa-feather-alt" style="font-size: 3rem; color: var(--primary-300); margin-bottom: 1.5rem;"></i>
                <h3 class="text-h3">No posts yet.</h3>
                <p class="body-medium">I'm currently drafting new insights. Check back soon!</p>
            </div>
            {% endif %}
            {% endfor %}
        </div>

        <div class="blog-conversion-strip animate-fade-up">
            <div>
                <h2>Need a behavior system that works beyond one student at a time?</h2>
                <p>Start with Rob's School BCBA systems framework, then bring the right training, tools, and implementation plan back to your team.</p>
            </div>
            <div class="blog-conversion-actions">
                <a href="https://behaviorschool.com/transformation-program" target="_blank" rel="noopener" class="btn-primary-premium">
                    <i class="fas fa-rocket"></i> Explore the Program
                </a>
                <a href="/#contact" class="btn-secondary-premium">
                    <i class="fas fa-envelope"></i> Discuss Consulting
                </a>
            </div>
        </div>
    </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "School BCBA Blog Articles",
  "itemListElement": [
    {% for post in collections.posts %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "url": "https://robspain.com{{ post.url }}",
      "name": {{ post.data.title | dump | safe }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<style>
.blog-header-premium {
    padding: 10rem 0 4rem;
    background: radial-gradient(circle at top right, rgba(16, 185, 129, 0.05) 0%, transparent 40%);
}

.blog-header-content {
    max-width: 800px;
}

.blog-header-content h1 {
    margin: 1.5rem 0;
}

.latest-post-highlight {
    margin-bottom: 6rem;
}

.blog-conversion-strip {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 2rem;
    padding: 2rem;
    margin: 4rem 0 0;
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(236, 253, 245, 0.92), rgba(255, 255, 255, 0.96));
    border: 1px solid rgba(16, 185, 129, 0.18);
    box-shadow: 0 18px 45px -28px rgba(6, 78, 59, 0.45);
}

.blog-conversion-strip h2 {
    margin: 0 0 0.55rem;
    font-size: clamp(1.35rem, 2vw, 2rem);
    line-height: 1.15;
    color: var(--gray-900);
}

.blog-conversion-strip p {
    margin: 0;
    color: var(--gray-600);
    max-width: 680px;
}

.blog-conversion-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.85rem;
}

.highlight-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    padding: 3rem !important;
    text-decoration: none;
    color: inherit;
}

.highlight-image {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.1);
    height: 450px;
    padding: 1rem;
    background: linear-gradient(135deg, #ecfdf5, #f8fafc);
}

.highlight-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    border-radius: 14px;
}

.highlight-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.post-meta-premium {
    display: flex;
    gap: 1.5rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--primary-600);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.post-meta-premium i {
    margin-right: 0.5rem;
}

.post-cta-premium {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-weight: 800;
    color: var(--primary-500);
    margin-top: 1rem;
}

.post-cta-premium i {
    transition: transform 0.3s ease;
}

.highlight-card:hover .post-cta-premium i {
    transform: translateX(8px);
}

.card-image-wrapper {
    height: 240px;
    margin: -2rem -2rem 1.5rem -2rem;
    overflow: hidden;
    padding: 0.75rem;
    background: linear-gradient(135deg, #ecfdf5, #f8fafc);
}

.card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    border-radius: 12px;
}

.post-meta-small {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
}

@media (max-width: 1024px) {
    .highlight-card {
        grid-template-columns: 1fr;
        padding: 2rem !important;
        gap: 2rem;
    }
    .highlight-image {
        height: 300px;
    }
}

@media (max-width: 768px) {
    .blog-header-premium {
        padding: 8rem 0 3rem;
        text-align: center;
    }
    .blog-header-content {
        margin: 0 auto;
    }
    .blog-conversion-strip {
        grid-template-columns: 1fr;
        text-align: center;
        padding: 1.5rem;
    }
    .blog-conversion-actions {
        justify-content: center;
    }
    .blog-conversion-actions a {
        width: 100%;
        justify-content: center;
    }
}
</style>
