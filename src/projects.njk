<div class="container-prose">
  <h1>Projects and Behavior School Tools</h1>
  <p class="subtitle">A curated list of School BCBA systems tools, Behavior School resources, and applied behavior support projects I'm currently building or have launched.</p>
</div>

<div class="projects-grid">
  {% for project in projects %}
    <div class="project-card">
      <div class="project-card-header">
        <h2 class="project-title">{{ project.name }}</h2>
        <span class="status-badge status-{{ project.status_slug }}">{{ project.status }}</span>
      </div>
      <p class="project-description">{{ project.description }}</p>
      {% if project.url %}
        <a href="{{ project.url }}" class="project-link" target="_blank" rel="noopener noreferrer">Visit Project &rarr;</a>
      {% else %}
        <span class="project-link-disabled">Internal Tool</span>
      {% endif %}
    </div>
  {% endfor %}
</div>
